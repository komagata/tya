import geometry/* as geo
import transform2d/* as transform2d

move = transform2d.Transform2D(1, 0, 0, 1, 0, 0).translation(10, 20)
scale = transform2d.Transform2D(1, 0, 0, 1, 0, 0).uniform_scale(2)
world = move.compose(scale)

point = world.apply_point(geo.Point(3, 4))
print(point.to_vector().to_array())
