items = [1, 2, 3, 4]

even = item -> item % 2 == 0
add = total, item -> total + item
remember = item ->
  last = item
  nil

doubled = items.map(item -> item * 2)
evens = items.filter(even)
first_even = items.find(even)
has_even = items.any(even)
all_even = items.all(even)
sum = items.reduce(0, add)
each(items, remember)

print doubled[2]
print evens.len()
print first_even
print has_even
print all_even
print sum
