class FileExample
  static write = path, text ->
    write_file(path, text)

  static exists? = path ->
    file_exists(path)

  static read = path ->
    read_file(path)

path = "/tmp/tya_example.txt"
FileExample.write(path, "Hello from Tya")
print(FileExample.exists?(path))
print(FileExample.read(path))
