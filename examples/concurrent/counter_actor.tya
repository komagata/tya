# A long-lived actor that owns its `count` state and answers
# "inc" / "get" / "stop" messages over a channel.
import channel

inbox = channel.Channel.new(64)

run_counter = ic ->
  count = 0
  while true
    msg = channel.Channel.receive(ic)
    if msg == "stop"
      return count
    if msg == "inc"
      count = count + 1
    else
      reply = msg
      channel.Channel.send(reply, count)

counter = spawn run_counter(inbox)

channel.Channel.send(inbox, "inc")
channel.Channel.send(inbox, "inc")
channel.Channel.send(inbox, "inc")

reply_chan = channel.Channel.new(1)
channel.Channel.send(inbox, reply_chan)
print("count = " + to_string(channel.Channel.receive(reply_chan)))

channel.Channel.send(inbox, "stop")
print("final = " + to_string(await counter))
