# Producer / consumer over a buffered channel. The producer pushes
# numbers, signals end-of-stream by closing, and the consumer drains
# until receive returns nil.
import channel

c = channel.Channel(4)

produce = ch ->
  i = 1
  while i <= 5
    ch.send(i)
    i = i + 1
  ch.close()

producer = spawn produce(c)

while true
  v = c.receive()
  if v == nil
    break
  print("got " + v.to_string())

await producer
