parse_user = text ->
  if text == ""
    raise error("empty user")
  { name: text }

read_user = text ->
  user = parse_user(text)
  user["name"]

try
  name = read_user("komagata")
  print(name)
catch err
  print(err["message"])

try
  name = read_user("")
  print(name)
catch err
  print(err["message"])
