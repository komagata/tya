message = "Tya"
alias = message
identity = value ->
  return value
log = message
push log, alias
queue = []
push queue, message
count = 1 + 1
count = count + 1
enabled = true
disabled = false
negated = not enabled
less = 1 < 2
same = 2 == 2
print message
print alias
print count
print enabled
print negated
print less
print same

if true
  print "Indented"

if less
  print "Compared"
  return message

while false
  print "Never"
  continue

while disabled
  print "Also never"
  break
