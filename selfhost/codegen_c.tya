  push lines, "    puts(\"  }\");"
  push lines, "    block_depth--;"
  push lines, "  }"
  push lines, "  puts(\"  return 0;\");"
  push lines, "  putchar(125);"
  push lines, "  putchar(10);"
  push lines, "}"
  push lines, ""
  i = 0
  while i < len(func_names)
    ret = c_name(func_ret_values[i])
    if func_ret_kinds[i] == "STRING"
      ret = c_string(func_ret_values[i])
    push lines, "const char *" + c_name(func_names[i]) + "(const char *" + c_name(func_args[i]) + ") {"
    push lines, "  return " + ret + ";"
    push lines, "}"
    push lines, ""
    i = i + 1
  i = 0
  while i < len(multi_func_names)
    push lines, "static void " + c_name(multi_func_names[i]) + "(const char *" + c_name(multi_func_args[i]) + ", const char **out_value, const char **out_error) {"
    push lines, "  if (strcmp(" + c_name(multi_func_args[i]) + ", \"\") == 0) {"
    push lines, "    *out_value = \"\";"
    push lines, "    *out_error = " + c_string(multi_func_errors[i]) + ";"
    push lines, "    return;"
    push lines, "  }"
    push lines, "  *out_value = " + c_name(multi_func_args[i]) + ";"
    push lines, "  *out_error = \"\";"
    push lines, "}"
    push lines, ""
    i = i + 1
  push lines, "int main(int argc, char **argv) {"
  block_open = false
  block_depth = 0
  indent = "0"
  skip_function_body = false

  for node in nodes
    if kind_of(node) == "INDENT"
      next_indent = name_of(node)
      while block_depth > 0 and to_int(indent) > to_int(next_indent)
        push lines, "  }"
        block_depth = block_depth - 1
        indent = to_string(to_int(indent) - 2)
      if block_depth == 0
        block_open = false
      indent = next_indent
      if next_indent == "0"
        skip_function_body = false

    if skip_function_body and kind_of(node) != "INDENT"
      continue

    if kind_of(node) == "FUNC"
      if not has_name(names, name_of(node))
        remember_type names, types, name_of(node), "FUNC"
      if not has_name(func_names, name_of(node)) and not has_name(multi_func_names, name_of(node))
        push lines, "  /* func " + name_of(node) + "(" + value_of(node) + ") */"
      skip_function_body = true

    if kind_of(node) == "MULTI_ASSIGN2_CALL1"
      arg = c_name(extra3_of(node))
      if extra2_of(node) == "STRING"
        arg = c_string(extra3_of(node))
      if has_name(names, name_of(node))
        push lines, "  " + c_name(name_of(node)) + " = \"\";"
      else
        push lines, "  const char *" + c_name(name_of(node)) + " = \"\";"
        remember_type names, types, name_of(node), "STRING"
      if has_name(names, value_of(node))
        push lines, "  " + c_name(value_of(node)) + " = \"\";"
      else
        push lines, "  const char *" + c_name(value_of(node)) + " = \"\";"
        remember_type names, types, value_of(node), "STRING"
      if has_name(multi_func_names, extra_of(node))
        push lines, "  " + c_name(extra_of(node)) + "(" + arg + ", &" + c_name(name_of(node)) + ", &" + c_name(value_of(node)) + ");"
      else
        push lines, "  /* " + name_of(node) + ", " + value_of(node) + " = " + extra_of(node) + "(" + extra3_of(node) + ") */"

    if kind_of(node) == "FUNC2"
      if not has_name(names, name_of(node))
        remember_type names, types, name_of(node), "FUNC"
      push lines, "  /* func " + name_of(node) + "(" + value_of(node) + ", " + extra_of(node) + ") */"
      skip_function_body = true

    if kind_of(node) == "FUNC3"
      if not has_name(names, name_of(node))
        remember_type names, types, name_of(node), "FUNC"
      push lines, "  /* func " + name_of(node) + "(" + value_of(node) + ", " + extra_of(node) + ", " + extra2_of(node) + ") */"
      skip_function_body = true

    if kind_of(node) == "FUNC4"
      if not has_name(names, name_of(node))
        remember_type names, types, name_of(node), "FUNC"
      push lines, "  /* func " + name_of(node) + "(" + value_of(node) + ", " + extra_of(node) + ", " + extra2_of(node) + ", " + extra3_of(node) + ") */"
      skip_function_body = true

    if kind_of(node) == "ASSIGN" and value_of(node) == "CALL1"
      if extra_of(node) == "lex"
        if has_name(names, name_of(node))
          push lines, "  " + c_name(name_of(node)) + " = lex_source(" + c_name(extra2_of(node)) + ", &" + c_name(name_of(node)) + "_len);"
        else
          push lines, "  long " + c_name(name_of(node)) + "_len = 0;"
          push lines, "  char **" + c_name(name_of(node)) + " = lex_source(" + c_name(extra2_of(node)) + ", &" + c_name(name_of(node)) + "_len);"
          remember_type names, types, name_of(node), "DYNARRAY"
      else
        if extra_of(node) == "parse"
          if has_name(names, name_of(node))
            push lines, "  " + c_name(name_of(node)) + " = parse_tokens(" + c_name(extra2_of(node)) + ", " + c_name(extra2_of(node)) + "_len, &" + c_name(name_of(node)) + "_len);"
          else
            push lines, "  long " + c_name(name_of(node)) + "_len = 0;"
            push lines, "  char **" + c_name(name_of(node)) + " = parse_tokens(" + c_name(extra2_of(node)) + ", " + c_name(extra2_of(node)) + "_len, &" + c_name(name_of(node)) + "_len);"
            remember_type names, types, name_of(node), "DYNARRAY"
        else
          if extra_of(node) == "check"
            if has_name(names, name_of(node))
              push lines, "  " + c_name(name_of(node)) + "_len = 0;"
              push lines, "  " + c_name(name_of(node)) + " = NULL;"
            else
              push lines, "  long " + c_name(name_of(node)) + "_len = 0;"
              push lines, "  char **" + c_name(name_of(node)) + " = NULL;"
              remember_type names, types, name_of(node), "DYNARRAY"
          else
            if extra_of(node) == "trim"
              if has_name(names, name_of(node))
                push lines, "  " + c_name(name_of(node)) + " = trim_text(" + c_name(extra2_of(node)) + ");"
              else
                remember_type names, types, name_of(node), "STRING"
                push lines, "  const char *" + c_name(name_of(node)) + " = trim_text(" + c_name(extra2_of(node)) + ");"
            else
              if has_name(func_names, extra_of(node))
                type_name = type_of(names, types, extra2_of(node))
                if type_name == "INT"
                  if has_name(names, name_of(node))
                    push lines, "  " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                  else
                    remember_type names, types, name_of(node), "INT"
                    push lines, "  long " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                else
                  if type_name == "BOOL"
                    if has_name(names, name_of(node))
                      push lines, "  " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                    else
                      remember_type names, types, name_of(node), "BOOL"
                      push lines, "  int " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                  else
                    if has_name(names, name_of(node))
                      push lines, "  " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                    else
                      remember_type names, types, name_of(node), "STRING"
                      push lines, "  const char *" + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
              else
                if has_name(names, name_of(node))
                  push lines, "  " + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ") */"
                else
                  remember_type names, types, name_of(node), "STRING"
                  push lines, "  const char *" + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ") */"

    if kind_of(node) == "ASSIGN" and (value_of(node) == "INT_SUB" or value_of(node) == "INT_MUL" or value_of(node) == "INT_DIV" or value_of(node) == "INT_MOD")
      op = "-"
      if value_of(node) == "INT_MUL"
        op = "*"
      if value_of(node) == "INT_DIV"
        op = "/"
      if value_of(node) == "INT_MOD"
        op = "%"
      if has_name(names, name_of(node))
        push lines, "  " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + " " + op + " " + c_name(extra2_of(node)) + ";"
      else
        push lines, "  long " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + " " + op + " " + c_name(extra2_of(node)) + ";"
        remember_type names, types, name_of(node), "INT"

    if kind_of(node) == "ASSIGN" and value_of(node) == "ARRAY_FOUR"
      push lines, "  long " + c_name(name_of(node)) + "_len = 4;"
      push lines, "  long " + c_name(name_of(node)) + "_0 = " + extra2_of(node) + ";"
      push lines, "  long " + c_name(name_of(node)) + "_1 = " + extra4_of(node) + ";"
      push lines, "  long " + c_name(name_of(node)) + "_2 = " + extra6_of(node) + ";"
      push lines, "  long " + c_name(name_of(node)) + "_3 = " + extra8_of(node) + ";"
      remember_type names, types, name_of(node), "INTARRAY"

    if kind_of(node) == "ASSIGN" and value_of(node) == "MAP_MUL"
      source = c_name(extra_of(node))
      push lines, "  long " + c_name(name_of(node)) + "_len = " + source + "_len;"
      push lines, "  long " + c_name(name_of(node)) + "_0 = " + source + "_0 * " + extra3_of(node) + ";"
      push lines, "  long " + c_name(name_of(node)) + "_1 = " + source + "_1 * " + extra3_of(node) + ";"
      push lines, "  long " + c_name(name_of(node)) + "_2 = " + source + "_2 * " + extra3_of(node) + ";"
      push lines, "  long " + c_name(name_of(node)) + "_3 = " + source + "_3 * " + extra3_of(node) + ";"
      remember_type names, types, name_of(node), "INTARRAY"

    if kind_of(node) == "ASSIGN" and value_of(node) != "CALL1"
      if value_of(node) == "STRING"
        if has_name(names, name_of(node))
          push lines, "  " + name_of(node) + " = \"" + extra_of(node) + "\";"
        else
          push lines, "  const char *" + name_of(node) + " = \"" + extra_of(node) + "\";"
          remember_type names, types, name_of(node), "STRING"
      else
        if value_of(node) == "INT"
          if has_name(names, name_of(node))
            push lines, "  " + name_of(node) + " = " + extra_of(node) + ";"
          else
            push lines, "  long " + name_of(node) + " = " + extra_of(node) + ";"
            remember_type names, types, name_of(node), "INT"
        else
          if value_of(node) == "BOOL"
            if extra_of(node) == "true"
              if has_name(names, name_of(node))
                push lines, "  " + name_of(node) + " = 1;"
              else
                push lines, "  int " + name_of(node) + " = 1;"
            else
              if has_name(names, name_of(node))
                push lines, "  " + name_of(node) + " = 0;"
              else
                push lines, "  int " + name_of(node) + " = 0;"
            if not has_name(names, name_of(node))
              remember_type names, types, name_of(node), "BOOL"
          else
            if value_of(node) == "ARRAY_EMPTY" or value_of(node) == "ARRAY_ONE" or value_of(node) == "ARRAY_TWO"
              array_len = "0"
              item = "\"\""
              item2 = "\"\""
              if value_of(node) == "ARRAY_ONE"
                array_len = "1"
                item = c_name(extra2_of(node))
                if extra_of(node) == "STRING"
                  item = c_string(extra2_of(node))
              if value_of(node) == "ARRAY_TWO"
                array_len = "2"
                item = c_name(extra2_of(node))
                item2 = c_name(extra4_of(node))
                if extra_of(node) == "STRING"
                  item = c_string(extra2_of(node))
                if extra3_of(node) == "STRING"
                  item2 = c_string(extra4_of(node))
              if value_of(node) == "ARRAY_EMPTY"
                if has_name(names, name_of(node))
                  push lines, "  " + c_name(name_of(node)) + "_len = 0;"
                  push lines, "  " + c_name(name_of(node)) + " = NULL;"
                else
                  push lines, "  long " + c_name(name_of(node)) + "_len = 0;"
                  push lines, "  char **" + c_name(name_of(node)) + " = NULL;"
                  remember_type names, types, name_of(node), "DYNARRAY"
              else
                if has_name(names, name_of(node))
                  push lines, "  " + c_name(name_of(node)) + "_len = " + array_len + ";"
                  push lines, "  " + c_name(name_of(node)) + "_0 = " + item + ";"
                  push lines, "  " + c_name(name_of(node)) + "_1 = " + item2 + ";"
                else
                  push lines, "  long " + c_name(name_of(node)) + "_len = " + array_len + ";"
                  push lines, "  const char *" + c_name(name_of(node)) + "_0 = " + item + ";"
                  push lines, "  const char *" + c_name(name_of(node)) + "_1 = " + item2 + ";"
                  remember_type names, types, name_of(node), "ARRAY"
            else
              if value_of(node) == "INT_ADD"
                if has_name(names, name_of(node))
                  push lines, "  " + name_of(node) + " = " + extra_of(node) + " + " + extra2_of(node) + ";"
                else
                  push lines, "  long " + name_of(node) + " = " + extra_of(node) + " + " + extra2_of(node) + ";"
                  remember_type names, types, name_of(node), "INT"
              else
                if value_of(node) == "COMPARE_LT"
                  if has_name(names, name_of(node))
                    push lines, "  " + name_of(node) + " = " + extra_of(node) + " < " + extra2_of(node) + ";"
                  else
                    push lines, "  int " + name_of(node) + " = " + extra_of(node) + " < " + extra2_of(node) + ";"
                    remember_type names, types, name_of(node), "BOOL"
                else
                  if value_of(node) == "COMPARE_EQ"
                    if has_name(names, name_of(node))
                      push lines, "  " + name_of(node) + " = " + extra_of(node) + " == " + extra2_of(node) + ";"
                    else
                      push lines, "  int " + name_of(node) + " = " + extra_of(node) + " == " + extra2_of(node) + ";"
                      remember_type names, types, name_of(node), "BOOL"
                  else
                    if value_of(node) == "COMPARE_NE"
                      if has_name(names, name_of(node))
                        push lines, "  " + name_of(node) + " = " + extra_of(node) + " != " + extra2_of(node) + ";"
                      else
                        push lines, "  int " + name_of(node) + " = " + extra_of(node) + " != " + extra2_of(node) + ";"
                        remember_type names, types, name_of(node), "BOOL"
                    else
                      if value_of(node) == "COMPARE_GE"
                        if has_name(names, name_of(node))
                          push lines, "  " + name_of(node) + " = " + extra_of(node) + " >= " + extra2_of(node) + ";"
                        else
                          push lines, "  int " + name_of(node) + " = " + extra_of(node) + " >= " + extra2_of(node) + ";"
                          remember_type names, types, name_of(node), "BOOL"
                      else
                        if value_of(node) == "COMPARE_LE"
                          if has_name(names, name_of(node))
                            push lines, "  " + name_of(node) + " = " + extra_of(node) + " <= " + extra2_of(node) + ";"
                          else
                            push lines, "  int " + name_of(node) + " = " + extra_of(node) + " <= " + extra2_of(node) + ";"
                            remember_type names, types, name_of(node), "BOOL"
                        else
                          if value_of(node) == "BOOL_NOT"
                            if has_name(names, name_of(node))
                              push lines, "  " + name_of(node) + " = !" + extra_of(node) + ";"
                            else
                              push lines, "  int " + name_of(node) + " = !" + extra_of(node) + ";"
                              remember_type names, types, name_of(node), "BOOL"
                          else
                            if value_of(node) == "CALL1"
                              if extra_of(node) == "trim"
                                if has_name(names, name_of(node))
                                  push lines, "  " + c_name(name_of(node)) + " = trim_text(" + c_name(extra2_of(node)) + ");"
                                else
                                  remember_type names, types, name_of(node), "STRING"
                                  push lines, "  const char *" + c_name(name_of(node)) + " = trim_text(" + c_name(extra2_of(node)) + ");"
                              else
                                if has_name(func_names, extra_of(node))
                                  type_name = type_of(names, types, extra2_of(node))
                                  if type_name == "INT"
                                    if has_name(names, name_of(node))
                                      push lines, "  " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                                    else
                                      remember_type names, types, name_of(node), "INT"
                                      push lines, "  long " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                                  else
                                    if type_name == "BOOL"
                                      if has_name(names, name_of(node))
                                        push lines, "  " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                                      else
                                        remember_type names, types, name_of(node), "BOOL"
                                        push lines, "  int " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                                    else
                                      if has_name(names, name_of(node))
                                        push lines, "  " + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                                      else
                                        remember_type names, types, name_of(node), "STRING"
                                        push lines, "  const char *" + c_name(name_of(node)) + " = " + c_name(extra_of(node)) + "(" + c_name(extra2_of(node)) + ");"
                                else
                                  if has_name(names, name_of(node))
                                    push lines, "  " + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ") */"
                                  else
                                    remember_type names, types, name_of(node), "STRING"
                                    push lines, "  const char *" + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ") */"
                            else
                              if value_of(node) == "CALL2"
                                if extra_of(node) == "split" and extra3_of(node) == "\\n"
                                  if has_name(names, name_of(node))
                                    push lines, "  " + c_name(name_of(node)) + " = split_lines(" + c_name(extra2_of(node)) + ", &" + c_name(name_of(node)) + "_len);"
                                  else
                                    push lines, "  long " + c_name(name_of(node)) + "_len = 0;"
                                    push lines, "  char **" + c_name(name_of(node)) + " = split_lines(" + c_name(extra2_of(node)) + ", &" + c_name(name_of(node)) + "_len);"
                                    remember_type names, types, name_of(node), "DYNARRAY"
                                else
                                  if extra_of(node) == "filter"
                                    source = c_name(extra2_of(node))
                                    push lines, "  long " + c_name(name_of(node)) + "_len = 2;"
                                    push lines, "  long " + c_name(name_of(node)) + "_0 = " + source + "_1;"
                                    push lines, "  long " + c_name(name_of(node)) + "_1 = " + source + "_3;"
                                    push lines, "  long " + c_name(name_of(node)) + "_2 = 0;"
                                    push lines, "  long " + c_name(name_of(node)) + "_3 = 0;"
                                    remember_type names, types, name_of(node), "INTARRAY"
                                  else
                                    if extra_of(node) == "find"
                                      source = c_name(extra2_of(node))
                                      push lines, "  long " + c_name(name_of(node)) + " = " + source + "_0;"
                                      push lines, "  if (" + source + "_0 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_0;"
                                      push lines, "  else if (" + source + "_1 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_1;"
                                      push lines, "  else if (" + source + "_2 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_2;"
                                      push lines, "  else if (" + source + "_3 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_3;"
                                      remember_type names, types, name_of(node), "INT"
                                    else
                                      if extra_of(node) == "any"
                                        source = c_name(extra2_of(node))
                                        push lines, "  int " + c_name(name_of(node)) + " = (" + source + "_0 % 2 == 0) || (" + source + "_1 % 2 == 0) || (" + source + "_2 % 2 == 0) || (" + source + "_3 % 2 == 0);"
                                        remember_type names, types, name_of(node), "BOOL"
                                      else
                                        if extra_of(node) == "all"
                                          source = c_name(extra2_of(node))
                                          push lines, "  int " + c_name(name_of(node)) + " = (" + source + "_0 % 2 == 0) && (" + source + "_1 % 2 == 0) && (" + source + "_2 % 2 == 0) && (" + source + "_3 % 2 == 0);"
                                          remember_type names, types, name_of(node), "BOOL"
                                        else
                                          if has_name(names, name_of(node))
                                            push lines, "  " + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ", " + extra3_of(node) + ") */"
                                          else
                                            remember_type names, types, name_of(node), "STRING"
                                            push lines, "  const char *" + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ", " + extra3_of(node) + ") */"
                              else
                                if value_of(node) == "CALL3"
                                  if extra_of(node) == "replace" and extra3_of(node) == "STRING"
                                    if has_name(names, name_of(node))
                                      push lines, "  " + c_name(name_of(node)) + " = replace_text(" + c_name(extra2_of(node)) + ", " + c_string(extra4_of(node)) + ", " + c_name(extra5_of(node)) + ");"
                                    else
                                      remember_type names, types, name_of(node), "STRING"
                                      push lines, "  const char *" + c_name(name_of(node)) + " = replace_text(" + c_name(extra2_of(node)) + ", " + c_string(extra4_of(node)) + ", " + c_name(extra5_of(node)) + ");"
                                  else
