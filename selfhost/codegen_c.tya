  push lines, ""
  push lines, "static void node_field(const char *node, int wanted, char *out, size_t out_size) {"
  push lines, "  int field = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; node[i] != 0; i++) {"
  push lines, "    if (node[i] == ':') {"
  push lines, "      field++;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (field == wanted && n + 1 < out_size) {"
  push lines, "      out[n++] = node[i];"
  push lines, "    }"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void node_tail_field(const char *node, int wanted, char *out, size_t out_size) {"
  push lines, "  int field = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; node[i] != 0; i++) {"
  push lines, "    if (node[i] == ':') {"
  push lines, "      field++;"
  push lines, "      if (field == wanted) {"
  push lines, "        i++;"
  push lines, "        while (node[i] != 0 && n + 1 < out_size) out[n++] = node[i++];"
  push lines, "        break;"
  push lines, "      }"
  push lines, "    }"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void print_c_string_literal(const char *text) {"
  push lines, "  putchar(34);"
  push lines, "  for (int i = 0; text[i] != 0; i++) {"
  push lines, "    if (text[i] == 34 || text[i] == 92) putchar(92);"
  push lines, "    if (text[i] == 10) {"
  push lines, "      putchar(92);"
  push lines, "      putchar('n');"
  push lines, "    } else {"
  push lines, "      putchar(text[i]);"
  push lines, "    }"
  push lines, "  }"
  push lines, "  putchar(34);"
  push lines, "}"
  push lines, ""
  push lines, "static void emit_program(char **nodes, long nodes_len) {"
  push lines, "  printf(\"%cinclude <stdio.h>%c\", 35, 10);"
  push lines, "  int needs_string = 0;"
  push lines, "  int needs_trim = 0;"
  push lines, "  int needs_contains = 0;"
  push lines, "  int needs_starts = 0;"
  push lines, "  int needs_ends = 0;"
  push lines, "  int needs_replace = 0;"
  push lines, "  int needs_split = 0;"
  push lines, "  int needs_join = 0;"
  push lines, "  int needs_char_len = 0;"
  push lines, "  for (long i = 0; i < nodes_len; i++) {"
  push lines, "    char kind[64];"
  push lines, "    char a[512];"
  push lines, "    char b[512];"
  push lines, "    char c[512];"
  push lines, "    node_field(nodes[i], 1, kind, sizeof(kind));"
  push lines, "    node_field(nodes[i], 2, a, sizeof(a));"
  push lines, "    node_field(nodes[i], 3, b, sizeof(b));"
  push lines, "    node_field(nodes[i], 4, c, sizeof(c));"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"len\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"byteLen\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"charLen\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_char_len = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"contains\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_contains = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"startsWith\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_starts = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"endsWith\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_ends = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL3\") == 0 && strcmp(a, \"replace\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_replace = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL2\") == 0 && strcmp(c, \"split\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_split = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"join\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_join = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"trim\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_trim = 1;"
  push lines, "    }"
  push lines, "  }"
  push lines, "  if (needs_string) printf(\"%cinclude <string.h>%c\", 35, 10);"
  push lines, "  if (needs_trim || needs_replace || needs_split || needs_join) printf(\"%cinclude <stdlib.h>%c\", 35, 10);"
  push lines, "  puts(\"\");"
  push lines, "  if (needs_char_len) {"
  push lines, "    puts(\"static long char_len_text(const char *text) {\");"
  push lines, "    puts(\"  long len = 0;\");"
  push lines, "    puts(\"  for (long i = 0; text[i] != 0; i++) {\");"
  push lines, "    puts(\"    unsigned char ch = (unsigned char)text[i];\");"
  push lines, "    puts(\"    if ((ch & 192) != 128) len++;\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  return len;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_split || needs_join) {"
  push lines, "    puts(\"static char *slice_text(const char *start, size_t len) {\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, start, len);\");"
  push lines, "    puts(\"  out[len] = 0;\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_split) {"
  push lines, "    puts(\"static char **split_text(const char *text, const char *sep, long *out_len) {\");"
  push lines, "    puts(\"  char **items = NULL;\");"
  push lines, "    puts(\"  long len = 0;\");"
  push lines, "    puts(\"  size_t sep_len = strlen(sep);\");"
  push lines, "    puts(\"  const char *start = text;\");"
  push lines, "    puts(\"  const char *hit = strstr(start, sep);\");"
  push lines, "    puts(\"  while (hit) {\");"
  push lines, "    puts(\"    items = realloc(items, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"    items[len++] = slice_text(start, (size_t)(hit - start));\");"
  push lines, "    puts(\"    start = hit + sep_len;\");"
  push lines, "    puts(\"    hit = strstr(start, sep);\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  items = realloc(items, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"  items[len++] = slice_text(start, strlen(start));\");"
  push lines, "    puts(\"  *out_len = len;\");"
  push lines, "    puts(\"  return items;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_join) {"
  push lines, "    puts(\"static char *join_text(char **items, long len, const char *sep) {\");"
  push lines, "    puts(\"  size_t sep_len = strlen(sep);\");"
  push lines, "    puts(\"  size_t total = 1;\");"
  push lines, "    puts(\"  for (long i = 0; i < len; i++) total += strlen(items[i]) + (i > 0 ? sep_len : 0);\");"
  push lines, "    puts(\"  char *out = malloc(total);\");"
  push lines, "    puts(\"  out[0] = 0;\");"
  push lines, "    puts(\"  for (long i = 0; i < len; i++) {\");"
  push lines, "    puts(\"    if (i > 0) strcat(out, sep);\");"
  push lines, "    puts(\"    strcat(out, items[i]);\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_replace) {"
  push lines, "    puts(\"static char *dup_text(const char *text) {\");"
  push lines, "    puts(\"  size_t len = strlen(text);\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, text, len + 1);\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static char *replace_text(const char *text, const char *old_text, const char *new_text) {\");"
  push lines, "    puts(\"  const char *hit = strstr(text, old_text);\");"
  push lines, "    puts(\"  if (!hit) return dup_text(text);\");"
  push lines, "    puts(\"  size_t prefix = (size_t)(hit - text);\");"
  push lines, "    puts(\"  size_t old_len = strlen(old_text);\");"
  push lines, "    puts(\"  size_t new_len = strlen(new_text);\");"
  push lines, "    puts(\"  size_t suffix_len = strlen(hit + old_len);\");"
  push lines, "    puts(\"  char *out = malloc(prefix + new_len + suffix_len + 1);\");"
  push lines, "    puts(\"  memcpy(out, text, prefix);\");"
  push lines, "    puts(\"  memcpy(out + prefix, new_text, new_len);\");"
  push lines, "    puts(\"  memcpy(out + prefix + new_len, hit + old_len, suffix_len + 1);\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_trim) {"
  push lines, "    puts(\"static char *trim_text(const char *text) {\");"
  push lines, "    puts(\"  const char *start = text;\");"
  push lines, "    puts(\"  while (*start == ' ' || *start == 9 || *start == 10 || *start == 13) start++;\");"
  push lines, "    puts(\"  const char *end = start + strlen(start);\");"
  push lines, "    puts(\"  while (end > start && (end[-1] == ' ' || end[-1] == 9 || end[-1] == 10 || end[-1] == 13)) end--;\");"
  push lines, "    puts(\"  size_t len = (size_t)(end - start);\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, start, len);\");"
  push lines, "    puts(\"  out[len] = 0;\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_contains) {"
  push lines, "    puts(\"static int contains_text(const char *text, const char *needle) {\");"
  push lines, "    puts(\"  return strstr(text, needle) != NULL;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_starts) {"
  push lines, "    puts(\"static int starts_with_text(const char *text, const char *prefix) {\");"
  push lines, "    puts(\"  size_t n = strlen(prefix);\");"
  push lines, "    puts(\"  return strncmp(text, prefix, n) == 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_ends) {"
  push lines, "    puts(\"static int ends_with_text(const char *text, const char *suffix) {\");"
  push lines, "    puts(\"  size_t text_len = strlen(text);\");"
  push lines, "    puts(\"  size_t suffix_len = strlen(suffix);\");"
  push lines, "    puts(\"  if (suffix_len > text_len) return 0;\");"
  push lines, "    puts(\"  return strcmp(text + text_len - suffix_len, suffix) == 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  printf(\"int main(void) %c%c\", 123, 10);"
  push lines, "  char known_names[128][256];"
  push lines, "  char known_types[128][32];"
  push lines, "  int known_len = 0;"
  push lines, "  for (long i = 0; i < nodes_len; i++) {"
  push lines, "    char kind[64];"
  push lines, "    char a[512];"
  push lines, "    char b[512];"
  push lines, "    char c[512];"
  push lines, "    char d[512];"
  push lines, "    char e[512];"
  push lines, "    char f[512];"
  push lines, "    node_field(nodes[i], 1, kind, sizeof(kind));"
  push lines, "    node_field(nodes[i], 2, a, sizeof(a));"
  push lines, "    node_field(nodes[i], 3, b, sizeof(b));"
  push lines, "    node_field(nodes[i], 4, c, sizeof(c));"
  push lines, "    node_field(nodes[i], 5, d, sizeof(d));"
  push lines, "    node_field(nodes[i], 6, e, sizeof(e));"
  push lines, "    node_field(nodes[i], 7, f, sizeof(f));"
  push lines, "    if (strcmp(kind, \"PRINT\") == 0 && strcmp(a, \"STRING\") == 0) {"
  push lines, "      node_tail_field(nodes[i], 3, b, sizeof(b));"
  push lines, "      printf(\"  puts(\");"
  push lines, "      print_c_string_literal(b);"
  push lines, "      puts(\");\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_INDEX\") == 0 && strcmp(a, \"STRING\") == 0) {"
  push lines, "      printf(\"  printf(\\\"%%c\\\\n\\\", \");"
  push lines, "      print_c_string_literal(b);"
  push lines, "      printf(\"[%s]);\\n\", c);"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT\") == 0 && strcmp(a, \"IDENT\") == 0) {"
  push lines, "      const char *type = \"STRING\";"
  push lines, "      for (int j = 0; j < known_len; j++) {"
  push lines, "        if (strcmp(known_names[j], b) == 0) type = known_types[j];"
  push lines, "      }"
  push lines, "      if (strcmp(type, \"INT\") == 0) printf(\"  printf(\\\"%%ld\\\\n\\\", (long)%s);\\n\", b);"
  push lines, "      else if (strcmp(type, \"FLOAT\") == 0) printf(\"  printf(\\\"%%g\\\\n\\\", %s);\\n\", b);"
  push lines, "      else if (strcmp(type, \"BOOL\") == 0) printf(\"  puts(%s ? \\\"true\\\" : \\\"false\\\");\\n\", b);"
  push lines, "      else printf(\"  puts(%s);\\n\", b);"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"len\") == 0) {"
  push lines, "      printf(\"  printf(\\\"%%ld\\\\n\\\", (long)strlen(%s));\\n\", b);"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"byteLen\") == 0) {"
  push lines, "      printf(\"  printf(\\\"%%ld\\\\n\\\", (long)strlen(\");"
  push lines, "      if (strcmp(b, \"STRING\") == 0) print_c_string_literal(c); else printf(\"%s\", b);"
  push lines, "      puts(\"));\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"charLen\") == 0) {"
  push lines, "      printf(\"  printf(\\\"%%ld\\\\n\\\", (long)char_len_text(\");"
  push lines, "      if (strcmp(b, \"STRING\") == 0) print_c_string_literal(c); else printf(\"%s\", b);"
  push lines, "      puts(\"));\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"trim\") == 0) {"
  push lines, "      printf(\"  const char *%s = trim_text(%s);\\n\", a, d);"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"STRING\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"contains\") == 0) {"
  push lines, "      printf(\"  puts(contains_text(%s, \", b);"
  push lines, "      print_c_string_literal(d);"
  push lines, "      puts(\") ? \\\"true\\\" : \\\"false\\\");\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"startsWith\") == 0) {"
  push lines, "      printf(\"  puts(starts_with_text(%s, \", b);"
  push lines, "      print_c_string_literal(d);"
  push lines, "      puts(\") ? \\\"true\\\" : \\\"false\\\");\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"endsWith\") == 0) {"
  push lines, "      printf(\"  puts(ends_with_text(%s, \", b);"
  push lines, "      print_c_string_literal(d);"
  push lines, "      puts(\") ? \\\"true\\\" : \\\"false\\\");\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL3\") == 0 && strcmp(a, \"replace\") == 0) {"
  push lines, "      printf(\"  puts(replace_text(%s, \", b);"
  push lines, "      print_c_string_literal(d);"
  push lines, "      printf(\", \");"
  push lines, "      if (strcmp(e, \"STRING\") == 0) print_c_string_literal(f); else printf(\"%s\", e);"
  push lines, "      puts(\"));\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL2\") == 0 && strcmp(c, \"split\") == 0) {"
  push lines, "      printf(\"  long %s_len = 0;\\n\", a);"
  push lines, "      printf(\"  char **%s = split_text(%s, \", a, d);"
  push lines, "      print_c_string_literal(f);"
  push lines, "      printf(\", &%s_len);\\n\", a);"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"DYNARRAY\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"join\") == 0) {"
  push lines, "      printf(\"  puts(join_text(%s, %s_len, \", b, b);"
  push lines, "      print_c_string_literal(d);"
  push lines, "      puts(\"));\");"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"INT\") == 0) {"
  push lines, "      printf(\"  long %s = %s;\\n\", a, c);"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"INT\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"INT_ADD\") == 0) {"
  push lines, "      printf(\"  long %s = %s + %s;\\n\", a, c, d);"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"INT\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"COMPARE_EQ\") == 0) {"
  push lines, "      printf(\"  int %s = %s == %s;\\n\", a, c, d);"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"BOOL\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"COMPARE_LT\") == 0) {"
