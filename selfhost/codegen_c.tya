  push lines, "      strcpy(known_types[known_len], \"BOOL\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"COMPARE_NE\") == 0) {"
  push lines, "      printf(\"  int %s = %s != %s;\\n\", a, c, d);"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"BOOL\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"BOOL\") == 0) {"
  push lines, "      printf(\"  int %s = %s;\\n\", a, strcmp(c, \"true\") == 0 ? \"1\" : \"0\");"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"BOOL\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"FLOAT\") == 0) {"
  push lines, "      printf(\"  double %s = %s;\\n\", a, c);"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"FLOAT\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"STRING\") == 0) {"
  push lines, "      printf(\"  const char *%s = \", a);"
  push lines, "      print_c_string_literal(c);"
  push lines, "      puts(\";\");"
  push lines, "      strcpy(known_names[known_len], a);"
  push lines, "      strcpy(known_types[known_len], \"STRING\");"
  push lines, "      known_len++;"
  push lines, "    }"
  push lines, "  }"
  push lines, "  puts(\"  return 0;\");"
  push lines, "  putchar(125);"
  push lines, "  putchar(10);"
  push lines, "}"
  push lines, ""
  i = 0
  while i < len(funcNames)
    ret = cName(funcRetValues[i])
    if funcRetKinds[i] == "STRING"
      ret = cString(funcRetValues[i])
    push lines, "const char *" + cName(funcNames[i]) + "(const char *" + cName(funcArgs[i]) + ") {"
    push lines, "  return " + ret + ";"
    push lines, "}"
    push lines, ""
    i = i + 1
  push lines, "int main(int argc, char **argv) {"
  blockOpen = false
  blockDepth = 0
  indent = "0"
  skipFunctionBody = false

  for node in nodes
    if kindOf(node) == "INDENT"
      nextIndent = nameOf(node)
      while blockDepth > 0 and toInt(indent) > toInt(nextIndent)
        push lines, "  }"
        blockDepth = blockDepth - 1
        indent = toString(toInt(indent) - 2)
      if blockDepth == 0
        blockOpen = false
      indent = nextIndent
      if nextIndent == "0"
        skipFunctionBody = false

    if skipFunctionBody and kindOf(node) != "INDENT"
      continue

    if kindOf(node) == "FUNC"
      if not hasName(names, nameOf(node))
        rememberType names, types, nameOf(node), "FUNC"
      if not hasName(funcNames, nameOf(node))
        push lines, "  /* func " + nameOf(node) + "(" + valueOf(node) + ") */"
      skipFunctionBody = true

    if kindOf(node) == "FUNC2"
      if not hasName(names, nameOf(node))
        rememberType names, types, nameOf(node), "FUNC"
      push lines, "  /* func " + nameOf(node) + "(" + valueOf(node) + ", " + extraOf(node) + ") */"
      skipFunctionBody = true

    if kindOf(node) == "FUNC3"
      if not hasName(names, nameOf(node))
        rememberType names, types, nameOf(node), "FUNC"
      push lines, "  /* func " + nameOf(node) + "(" + valueOf(node) + ", " + extraOf(node) + ", " + extra2Of(node) + ") */"
      skipFunctionBody = true

    if kindOf(node) == "FUNC4"
      if not hasName(names, nameOf(node))
        rememberType names, types, nameOf(node), "FUNC"
      push lines, "  /* func " + nameOf(node) + "(" + valueOf(node) + ", " + extraOf(node) + ", " + extra2Of(node) + ", " + extra3Of(node) + ") */"
      skipFunctionBody = true

    if kindOf(node) == "ASSIGN" and valueOf(node) == "CALL1"
