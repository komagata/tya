      if indent != "0"
        prefix = "    "
      push lines, prefix + "/* return " + name_of(node) + "(..., " + extra_of(node) + ") */"

  while block_depth > 0
    push lines, "  }"
    block_depth = block_depth - 1
  push lines, "  return 0;"
  push lines, "}"
  join lines, "\n"

nodes = []
source = read_file args()[0]
lines = split source, "\n"

for line in lines
  if line != ""
    push nodes, line

print emit_c nodes
