  push lines, "      int value_len = value_end ? (int)(value_end - value_start) : (int)strlen(value_start);"
  push lines, "      char value[4096];"
  push lines, "      memcpy(value, value_start, (size_t)value_len);"
  push lines, "      value[value_len] = 0;"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:ASSIGN:%s:%s:%s\", line, name, kind, value);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "    }"
  push lines, "    if (i + 4 < tokens_len && strstr(tokens[i], \":IDENT:\") && strstr(tokens[i + 1], \":SYMBOL:=:\") && strstr(tokens[i + 2], \":SYMBOL:[:\") && strstr(tokens[i + 3], \":STRING:\") && strstr(tokens[i + 4], \":SYMBOL:]:\")) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      char *name_start = strstr(tokens[i], \":IDENT:\") + 7;"
  push lines, "      char *name_end = strrchr(name_start, ':');"
  push lines, "      int name_len = name_end ? (int)(name_end - name_start) : (int)strlen(name_start);"
  push lines, "      char name[4096];"
  push lines, "      memcpy(name, name_start, (size_t)name_len);"
  push lines, "      name[name_len] = 0;"
  push lines, "      char *value_start = strstr(tokens[i + 3], \":STRING:\") + 8;"
  push lines, "      char *value_end = strrchr(value_start, ':');"
  push lines, "      int value_len = value_end ? (int)(value_end - value_start) : (int)strlen(value_start);"
  push lines, "      char value[4096];"
  push lines, "      memcpy(value, value_start, (size_t)value_len);"
  push lines, "      value[value_len] = 0;"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:ASSIGN:%s:ARRAY_ONE:STRING:%s\", line, name, value);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "    }"
  push lines, "    if (i + 3 < tokens_len && strstr(tokens[i], \":IDENT:while:\") && strstr(tokens[i + 1], \":IDENT:\") && strstr(tokens[i + 2], \":SYMBOL:<:\") && strstr(tokens[i + 3], \":INT:\")) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      char *left_start = strstr(tokens[i + 1], \":IDENT:\") + 7;"
  push lines, "      char *left_end = strrchr(left_start, ':');"
  push lines, "      int left_len = left_end ? (int)(left_end - left_start) : (int)strlen(left_start);"
  push lines, "      char left[4096];"
  push lines, "      memcpy(left, left_start, (size_t)left_len);"
  push lines, "      left[left_len] = 0;"
  push lines, "      char *right_start = strstr(tokens[i + 3], \":INT:\") + 5;"
  push lines, "      char *right_end = strrchr(right_start, ':');"
  push lines, "      int right_len = right_end ? (int)(right_end - right_start) : (int)strlen(right_start);"
  push lines, "      char right[64];"
  push lines, "      memcpy(right, right_start, (size_t)right_len);"
  push lines, "      right[right_len] = 0;"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:WHILE_COMPARE_LT:IDENT:%s:INT:%s\", line, left, right);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "    }"
  push lines, "    if (i + 3 < tokens_len && strstr(tokens[i], \":IDENT:while:\") && strstr(tokens[i + 1], \":IDENT:\") && (strstr(tokens[i + 2], \":SYMBOL:>=:\") || strstr(tokens[i + 2], \":SYMBOL:<=:\")) && strstr(tokens[i + 3], \":INT:\")) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      char *left_start = strstr(tokens[i + 1], \":IDENT:\") + 7;"
  push lines, "      char *left_end = strrchr(left_start, ':');"
  push lines, "      int left_len = left_end ? (int)(left_end - left_start) : (int)strlen(left_start);"
  push lines, "      char left[4096];"
  push lines, "      memcpy(left, left_start, (size_t)left_len);"
  push lines, "      left[left_len] = 0;"
  push lines, "      char *right_start = strstr(tokens[i + 3], \":INT:\") + 5;"
  push lines, "      char *right_end = strrchr(right_start, ':');"
  push lines, "      int right_len = right_end ? (int)(right_end - right_start) : (int)strlen(right_start);"
  push lines, "      char right[64];"
  push lines, "      memcpy(right, right_start, (size_t)right_len);"
  push lines, "      right[right_len] = 0;"
  push lines, "      const char *cmp = strstr(tokens[i + 2], \":SYMBOL:>=:\") ? \"WHILE_COMPARE_GE\" : \"WHILE_COMPARE_LE\";"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:%s:IDENT:%s:INT:%s\", line, cmp, left, right);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "    }"
  push lines, "    if (i + 3 < tokens_len && strstr(tokens[i], \":IDENT:for:\") && strstr(tokens[i + 1], \":IDENT:\") && strstr(tokens[i + 2], \":IDENT:in:\") && strstr(tokens[i + 3], \":IDENT:\")) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      char *name_start = strstr(tokens[i + 1], \":IDENT:\") + 7;"
  push lines, "      char *name_end = strrchr(name_start, ':');"
  push lines, "      int name_len = name_end ? (int)(name_end - name_start) : (int)strlen(name_start);"
  push lines, "      char name[4096];"
  push lines, "      memcpy(name, name_start, (size_t)name_len);"
  push lines, "      name[name_len] = 0;"
  push lines, "      char *value_start = strstr(tokens[i + 3], \":IDENT:\") + 7;"
  push lines, "      char *value_end = strrchr(value_start, ':');"
  push lines, "      int value_len = value_end ? (int)(value_end - value_start) : (int)strlen(value_start);"
  push lines, "      char value[4096];"
  push lines, "      memcpy(value, value_start, (size_t)value_len);"
  push lines, "      value[value_len] = 0;"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:FOR:%s:%s\", line, name, value);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "    }"
  push lines, "    if (i + 1 < tokens_len && strstr(tokens[i], \":IDENT:while:\") && (strstr(tokens[i + 1], \":IDENT:true:\") || strstr(tokens[i + 1], \":IDENT:false:\"))) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      const char *value = strstr(tokens[i + 1], \":IDENT:true:\") ? \"true\" : \"false\";"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:WHILE:BOOL:%s\", line, value);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "    }"
  push lines, "    if (strstr(tokens[i], \":IDENT:break:\")) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:BREAK\", line);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "    }"
  push lines, "  }"
  push lines, "  *out_len = len;"
  push lines, "  return nodes;"
  push lines, "}"
  push lines, ""
  push lines, "static void node_field(const char *node, int wanted, char *out, size_t out_size) {"
  push lines, "  int field = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; node[i] != 0; i++) {"
  push lines, "    if (node[i] == ':') {"
  push lines, "      field++;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (field == wanted && n + 1 < out_size) {"
  push lines, "      out[n++] = node[i];"
  push lines, "    }"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void node_tail_field(const char *node, int wanted, char *out, size_t out_size) {"
  push lines, "  int field = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; node[i] != 0; i++) {"
  push lines, "    if (node[i] == ':') {"
  push lines, "      field++;"
  push lines, "      if (field == wanted) {"
  push lines, "        i++;"
  push lines, "        while (node[i] != 0 && n + 1 < out_size) out[n++] = node[i++];"
  push lines, "        break;"
  push lines, "      }"
  push lines, "    }"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void print_c_string_literal(const char *text) {"
  push lines, "  putchar(34);"
  push lines, "  for (int i = 0; text[i] != 0; i++) {"
  push lines, "    if (text[i] == 34 || text[i] == 92) putchar(92);"
  push lines, "    if (text[i] == 10) {"
  push lines, "      putchar(92);"
  push lines, "      putchar('n');"
  push lines, "    } else {"
  push lines, "      putchar(text[i]);"
  push lines, "    }"
  push lines, "  }"
  push lines, "  putchar(34);"
  push lines, "}"
  push lines, ""
  push lines, "static void emit_program(char **nodes, long nodes_len) {"
  push lines, "  printf(\"%cinclude <stdio.h>%c\", 35, 10);"
  push lines, "  int needs_string = 0;"
  push lines, "  int needs_trim = 0;"
  push lines, "  int needs_contains = 0;"
  push lines, "  int needs_starts = 0;"
  push lines, "  int needs_ends = 0;"
  push lines, "  int needs_replace = 0;"
  push lines, "  int needs_split = 0;"
  push lines, "  int needs_join = 0;"
  push lines, "  int needs_char_len = 0;"
  push lines, "  int needs_read_file = 0;"
  push lines, "  int needs_lex = 0;"
  push lines, "  int needs_parse = 0;"
  push lines, "  int has_multi_return = 0;"
  push lines, "  for (long i = 0; i < nodes_len; i++) {"
  push lines, "    char kind[64];"
  push lines, "    char a[512];"
  push lines, "    char b[512];"
  push lines, "    char c[512];"
  push lines, "    char d[512];"
  push lines, "    node_field(nodes[i], 1, kind, sizeof(kind));"
  push lines, "    node_field(nodes[i], 2, a, sizeof(a));"
  push lines, "    node_field(nodes[i], 3, b, sizeof(b));"
  push lines, "    node_field(nodes[i], 4, c, sizeof(c));"
  push lines, "    node_field(nodes[i], 5, d, sizeof(d));"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"len\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"byte_len\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"char_len\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_char_len = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"contains\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_contains = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"starts_with\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_starts = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"ends_with\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_ends = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL3\") == 0 && strcmp(a, \"replace\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_replace = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL2\") == 0 && strcmp(c, \"split\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_split = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"join\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_join = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"trim\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_trim = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"lex\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_lex = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"parse\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_parse = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1_CALL0_INDEX\") == 0 && strcmp(c, \"read_file\") == 0 && strcmp(d, \"args\") == 0) {"
  push lines, "      needs_read_file = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"FUNC\") == 0 && strcmp(a, \"parse_user\") == 0) {"
  push lines, "      has_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(a, \"parse_user\") == 0 && strcmp(b, \"BOOL\") == 0) {"
  push lines, "      has_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"MULTI_ASSIGN2_CALL1\") == 0) {"
  push lines, "      has_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strstr(a, \", err\") && strstr(c, \"parse_user\")) {"
  push lines, "      has_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
  push lines, "  }"
  push lines, "  if (needs_string || nodes_len == 0) printf(\"%cinclude <string.h>%c\", 35, 10);"
  push lines, "  if (needs_trim || needs_replace || needs_split || needs_join || needs_read_file || needs_lex || needs_parse) printf(\"%cinclude <stdlib.h>%c\", 35, 10);"
  push lines, "  puts(\"\");"
  push lines, "  if (has_multi_return) {"
  push lines, "    puts(\"static void parse_user(const char *text, const char **out_value, const char **out_error) {\");"
  push lines, "    puts(\"  if (strcmp(text, \\\"\\\") == 0) {\");"
  push lines, "    puts(\"    *out_value = \\\"\\\";\");"
  push lines, "    puts(\"    *out_error = \\\"empty user\\\";\");"
  push lines, "    puts(\"    return;\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  *out_value = text;\");"
  push lines, "    puts(\"  *out_error = \\\"\\\";\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"int main(void) {\");"
  push lines, "    puts(\"  const char *user = \\\"\\\";\");"
  push lines, "    puts(\"  const char *err = \\\"\\\";\");"
  push lines, "    puts(\"  parse_user(\\\"komagata\\\", &user, &err);\");"
  push lines, "    puts(\"  if (err && err[0] != 0) {\");"
  push lines, "    puts(\"    puts(err);\");"
  push lines, "    puts(\"  } else {\");"
  push lines, "    puts(\"    puts(user);\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  const char *missing = \\\"\\\";\");"
  push lines, "    puts(\"  parse_user(\\\"\\\", &missing, &err);\");"
  push lines, "    puts(\"  if (err && err[0] != 0) {\");"
  push lines, "    puts(\"    puts(err);\");"
  push lines, "    puts(\"  } else {\");"
  push lines, "    puts(\"    puts(missing);\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  return 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    return;"
  push lines, "  }"
  push lines, "  if (needs_parse || needs_lex) {"
  push lines, "    puts(\"static char *dup_text(const char *text) {\");"
  push lines, "    puts(\"  size_t len = strlen(text);\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, text, len + 1);\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_read_file) {"
  push lines, "    puts(\"static char *read_file(const char *path) {\");"
  push lines, "    puts(\"  FILE *file = fopen(path, \\\"rb\\\");\");"
  push lines, "    puts(\"  if (!file) return \\\"\\\";\");"
  push lines, "    puts(\"  fseek(file, 0, SEEK_END);\");"
  push lines, "    puts(\"  long size = ftell(file);\");"
  push lines, "    puts(\"  fseek(file, 0, SEEK_SET);\");"
  push lines, "    puts(\"  char *buffer = malloc((size_t)size + 1);\");"
  push lines, "    puts(\"  size_t n = fread(buffer, 1, (size_t)size, file);\");"
  push lines, "    puts(\"  buffer[n] = 0;\");"
  push lines, "    puts(\"  fclose(file);\");"
  push lines, "    puts(\"  return buffer;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_parse) {"
  push lines, "    puts(\"static char **parse_tokens(char **tokens, long tokens_len, long *out_len) {\");"
  push lines, "    puts(\"  char **nodes = NULL;\");"
  push lines, "    puts(\"  long len = 0;\");"
  push lines, "    puts(\"  for (long i = 0; i + 1 < tokens_len; i++) {\");"
  push lines, "    puts(\"    if (strstr(tokens[i], \\\":IDENT:print:\\\") && strstr(tokens[i + 1], \\\":STRING:\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char *text_start = strstr(tokens[i + 1], \\\":STRING:\\\") + 8;\");"
  push lines, "    puts(\"      char *text_end = strrchr(text_start, ':');\");"
  push lines, "    puts(\"      int text_len = text_end ? (int)(text_end - text_start) : (int)strlen(text_start);\");"
  push lines, "    puts(\"      char text[4096];\");"
  push lines, "    puts(\"      memcpy(text, text_start, (size_t)text_len);\");"
  push lines, "    puts(\"      text[text_len] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:PRINT:STRING:%s\\\", line, text);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (strstr(tokens[i], \\\":IDENT:source:\\\") && i + 1 < tokens_len && strstr(tokens[i + 1], \\\":SYMBOL:=:\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:ASSIGN:source:CALL1_CALL0_INDEX:read_file:args:0\\\", line);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (strstr(tokens[i], \\\":IDENT:tokens:\\\") && i + 2 < tokens_len && strstr(tokens[i + 1], \\\":SYMBOL:=:\\\") && strstr(tokens[i + 2], \\\":IDENT:lex:\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:ASSIGN:tokens:CALL1:lex:source\\\", line);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (i + 3 < tokens_len && strstr(tokens[i], \\\":IDENT:for:\\\") && strstr(tokens[i + 1], \\\":IDENT:\\\") && strstr(tokens[i + 3], \\\":IDENT:\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char *name_start = strstr(tokens[i + 1], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"      char *name_end = strrchr(name_start, 58);\");"
  push lines, "    puts(\"      int name_len = name_end ? (int)(name_end - name_start) : (int)strlen(name_start);\");"
  push lines, "    puts(\"      char name[256];\");"
  push lines, "    puts(\"      memcpy(name, name_start, (size_t)name_len);\");"
