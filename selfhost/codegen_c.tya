kind_of = node ->
  parts = split node, ":"
  parts[1]

name_of = node ->
  parts = split node, ":"
  if len(parts) < 3
    return ""
  parts[2]

value_of = node ->
  parts = split node, ":"
  if len(parts) < 4
    return ""
  parts[3]

extra_of = node ->
  parts = split node, ":"
  if len(parts) < 5
    return ""
  parts[4]

extra2_of = node ->
  parts = split node, ":"
  if len(parts) < 6
    return ""
  parts[5]

extra3_of = node ->
  parts = split node, ":"
  if len(parts) < 7
    return ""
  parts[6]

extra4_of = node ->
  parts = split node, ":"
  if len(parts) < 8
    return ""
  parts[7]

extra5_of = node ->
  parts = split node, ":"
  if len(parts) < 9
    return ""
  parts[8]

extra6_of = node ->
  parts = split node, ":"
  if len(parts) < 10
    return ""
  parts[9]

extra7_of = node ->
  parts = split node, ":"
  if len(parts) < 11
    return ""
  parts[10]

extra8_of = node ->
  parts = split node, ":"
  if len(parts) < 12
    return ""
  parts[11]

remember_type = names, types, name, type_name ->
  push names, name
  push types, type_name

has_name = names, name ->
  for existing in names
    if existing == name
      return true
  false

type_of = names, types, name ->
  i = 0
  while i < len(names)
    if names[i] == name
      return types[i]
    i = i + 1
  "STRING"

c_name = name ->
  if name == "char"
    return "tya_char"
  name

c_string = text ->
  if text == "\\"
    return "\"\\x22\""
  "\"" + text + "\""

emit_c = nodes ->
  lines = []
  names = []
  types = []
  func_names = []
  func_args = []
  func_ret_kinds = []
  func_ret_values = []
  multi_func_names = []
  multi_func_args = []
  multi_func_errors = []
  pending_func_name = ""
  pending_func_arg = ""
  pending_func_error = ""
  for node in nodes
    if kind_of(node) == "FUNC"
      pending_func_name = name_of(node)
      pending_func_arg = value_of(node)
      pending_func_error = ""
    if pending_func_name != "" and kind_of(node) == "RETURN"
      if name_of(node) == "IDENT" and value_of(node) == pending_func_arg
        push func_names, pending_func_name
        push func_args, pending_func_arg
        push func_ret_kinds, name_of(node)
        push func_ret_values, value_of(node)
        pending_func_name = ""
        pending_func_arg = ""
        pending_func_error = ""
    if pending_func_name != "" and kind_of(node) == "RETURN2_CALL1"
      if name_of(node) == "NIL" and extra_of(node) == "error" and extra2_of(node) == "STRING"
        pending_func_error = extra3_of(node)
    if pending_func_name != "" and kind_of(node) == "RETURN2_OBJECT_NIL"
      if value_of(node) == "IDENT" and extra_of(node) == pending_func_arg
        push multi_func_names, pending_func_name
        push multi_func_args, pending_func_arg
        push multi_func_errors, pending_func_error
        pending_func_name = ""
        pending_func_arg = ""
        pending_func_error = ""
    if kind_of(node) == "INDENT" and name_of(node) == "0"
      pending_func_name = ""
      pending_func_arg = ""
      pending_func_error = ""

  push lines, "#include <stdio.h>"
  push lines, "#include <string.h>"
  push lines, "#include <stdlib.h>"
  push lines, ""
  push lines, "static char *read_file(const char *path) {"
  push lines, "  FILE *file = fopen(path, \"rb\");"
  push lines, "  if (!file) return \"\";"
  push lines, "  fseek(file, 0, SEEK_END);"
  push lines, "  long size = ftell(file);"
  push lines, "  fseek(file, 0, SEEK_SET);"
  push lines, "  char *buffer = malloc((size_t)size + 1);"
  push lines, "  size_t n = fread(buffer, 1, (size_t)size, file);"
  push lines, "  buffer[n] = 0;"
  push lines, "  fclose(file);"
  push lines, "  return buffer;"
  push lines, "}"
  push lines, ""
  push lines, "static char *dup_text(const char *text) {"
  push lines, "  size_t len = strlen(text);"
  push lines, "  char *out = malloc(len + 1);"
  push lines, "  memcpy(out, text, len + 1);"
  push lines, "  return out;"
  push lines, "}"
  push lines, ""
  push lines, "static char *replace_text(const char *text, const char *old_text, const char *new_text) {"
  push lines, "  const char *hit = strstr(text, old_text);"
  push lines, "  if (!hit) return dup_text(text);"
  push lines, "  size_t prefix = (size_t)(hit - text);"
  push lines, "  size_t old_len = strlen(old_text);"
  push lines, "  size_t new_len = strlen(new_text);"
  push lines, "  size_t suffix_len = strlen(hit + old_len);"
  push lines, "  char *out = malloc(prefix + new_len + suffix_len + 1);"
  push lines, "  memcpy(out, text, prefix);"
  push lines, "  memcpy(out + prefix, new_text, new_len);"
  push lines, "  memcpy(out + prefix + new_len, hit + old_len, suffix_len + 1);"
  push lines, "  return out;"
  push lines, "}"
  push lines, ""
  push lines, "static char *trim_text(const char *text) {"
  push lines, "  const char *start = text;"
  push lines, "  while (*start == ' ' || *start == 9 || *start == 10 || *start == 13) start++;"
  push lines, "  const char *end = start + strlen(start);"
  push lines, "  while (end > start && (end[-1] == ' ' || end[-1] == 9 || end[-1] == 10 || end[-1] == 13)) end--;"
  push lines, "  size_t len = (size_t)(end - start);"
  push lines, "  char *out = malloc(len + 1);"
  push lines, "  memcpy(out, start, len);"
  push lines, "  out[len] = 0;"
  push lines, "  return out;"
  push lines, "}"
  push lines, ""
  push lines, "static long char_len_text(const char *text) {"
  push lines, "  long len = 0;"
  push lines, "  for (long i = 0; text[i] != 0; i++) {"
  push lines, "    unsigned char ch = (unsigned char)text[i];"
  push lines, "    if ((ch & 192) != 128) len++;"
  push lines, "  }"
  push lines, "  return len;"
  push lines, "}"
  push lines, ""
  push lines, "static int contains_text(const char *text, const char *needle) {"
  push lines, "  return strstr(text, needle) != NULL;"
  push lines, "}"
  push lines, ""
  push lines, "static int starts_with_text(const char *text, const char *prefix) {"
  push lines, "  size_t n = strlen(prefix);"
  push lines, "  return strncmp(text, prefix, n) == 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int ends_with_text(const char *text, const char *suffix) {"
  push lines, "  size_t text_len = strlen(text);"
  push lines, "  size_t suffix_len = strlen(suffix);"
  push lines, "  if (suffix_len > text_len) return 0;"
  push lines, "  return strcmp(text + text_len - suffix_len, suffix) == 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void add_token(char ***tokens, long *len, int line, const char *kind, const char *text, int col) {"
  push lines, "  char buffer[8192];"
  push lines, "  snprintf(buffer, sizeof(buffer), \"%d:%s:%s:%d\", line, kind, text, col);"
  push lines, "  *tokens = realloc(*tokens, sizeof(char *) * (size_t)(*len + 1));"
  push lines, "  (*tokens)[*len] = dup_text(buffer);"
  push lines, "  *len = *len + 1;"
  push lines, "}"
  push lines, ""
  push lines, "static char **lex_source(const char *source, long *out_len) {"
  push lines, "  char **tokens = NULL;"
  push lines, "  long len = 0;"
  push lines, "  int i = 0;"
  push lines, "  int line = 1;"
  push lines, "  int col = 1;"
  push lines, "  int at_line_start = 1;"
  push lines, "  int line_spaces = 0;"
  push lines, "  while (source[i] != 0) {"
  push lines, "    char ch = source[i];"
  push lines, "    if (ch == 10) {"
  push lines, "      line++; col = 1; at_line_start = 1; line_spaces = 0; i++; continue;"
  push lines, "    }"
  push lines, "    if (at_line_start) {"
  push lines, "      if (ch == ' ') {"
  push lines, "        line_spaces++; i++; col++; continue;"
  push lines, "      }"
  push lines, "      char spaces[32];"
  push lines, "      snprintf(spaces, sizeof(spaces), \"%d\", line_spaces);"
  push lines, "      add_token(&tokens, &len, line, \"INDENT\", spaces, 1);"
  push lines, "      at_line_start = 0;"
  push lines, "    }"
  push lines, "    if (ch == ' ' || ch == 9) {"
  push lines, "      i++; col++; continue;"
  push lines, "    }"
  push lines, "    if (source[i] == '-' && source[i + 1] == '>') {"
  push lines, "      add_token(&tokens, &len, line, \"ARROW\", \"->\", col);"
  push lines, "      i += 2; col += 2; continue;"
  push lines, "    }"
  push lines, "    if ((source[i] == '=' || source[i] == '!' || source[i] == '<' || source[i] == '>') && source[i + 1] == '=') {"
  push lines, "      char two[3];"
  push lines, "      two[0] = source[i];"
  push lines, "      two[1] = source[i + 1];"
  push lines, "      two[2] = 0;"
  push lines, "      add_token(&tokens, &len, line, \"SYMBOL\", two, col);"
  push lines, "      i += 2; col += 2; continue;"
  push lines, "    }"
  push lines, "    if (ch >= '0' && ch <= '9') {"
  push lines, "      int start_col = col;"
  push lines, "      char text[4096];"
  push lines, "      int n = 0;"
  push lines, "      while (source[i] >= '0' && source[i] <= '9') {"
  push lines, "        text[n++] = source[i++]; col++;"
  push lines, "      }"
  push lines, "      const char *kind = \"INT\";"
  push lines, "      if (source[i] == '.') {"
  push lines, "        kind = \"FLOAT\";"
  push lines, "        text[n++] = source[i++]; col++;"
  push lines, "        while (source[i] >= '0' && source[i] <= '9') {"
  push lines, "          text[n++] = source[i++]; col++;"
  push lines, "        }"
  push lines, "      }"
  push lines, "      text[n] = 0;"
  push lines, "      add_token(&tokens, &len, line, kind, text, start_col);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch == '_') {"
  push lines, "      int start_col = col;"
  push lines, "      char text[4096];"
  push lines, "      int n = 0;"
  push lines, "      while ((source[i] >= 'A' && source[i] <= 'Z') || (source[i] >= 'a' && source[i] <= 'z') || (source[i] >= '0' && source[i] <= '9') || source[i] == '_') {"
  push lines, "        text[n++] = source[i++]; col++;"
  push lines, "      }"
  push lines, "      text[n] = 0;"
  push lines, "      add_token(&tokens, &len, line, \"IDENT\", text, start_col);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (ch == 34) {"
  push lines, "      int start_col = col;"
  push lines, "      char text[4096];"
  push lines, "      int n = 0;"
  push lines, "      i++; col++;"
  push lines, "      while (source[i] != 0 && source[i] != 34) {"
  push lines, "        if (source[i] == 92 && source[i + 1] != 0) {"
  push lines, "          i++; col++;"
  push lines, "          if (source[i] == 'n') text[n++] = 10;"
  push lines, "          else if (source[i] == 't') text[n++] = 9;"
  push lines, "          else text[n++] = source[i];"
  push lines, "          i++; col++;"
  push lines, "        } else {"
  push lines, "          text[n++] = source[i++]; col++;"
  push lines, "        }"
  push lines, "      }"
  push lines, "      if (source[i] == 34) {"
  push lines, "        i++; col++;"
  push lines, "      }"
  push lines, "      text[n] = 0;"
  push lines, "      add_token(&tokens, &len, line, \"STRING\", text, start_col);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    char sym[2];"
  push lines, "    sym[0] = ch;"
  push lines, "    sym[1] = 0;"
  push lines, "    add_token(&tokens, &len, line, \"SYMBOL\", sym, col);"
  push lines, "    i++; col++;"
  push lines, "  }"
  push lines, "  *out_len = len;"
  push lines, "  return tokens;"
  push lines, "}"
  push lines, ""
  push lines, "static char **split_lines(const char *source, long *out_len) {"
  push lines, "  char **lines = NULL;"
  push lines, "  long len = 0;"
  push lines, "  int start = 0;"
  push lines, "  int i = 0;"
  push lines, "  while (1) {"
  push lines, "    if (source[i] == 10 || source[i] == 0) {"
  push lines, "      int n = i - start;"
  push lines, "      char *line = malloc((size_t)n + 1);"
  push lines, "      memcpy(line, source + start, (size_t)n);"
  push lines, "      line[n] = 0;"
  push lines, "      lines = realloc(lines, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      lines[len++] = line;"
  push lines, "      if (source[i] == 0) break;"
  push lines, "      start = i + 1;"
  push lines, "    }"
  push lines, "    i++;"
  push lines, "  }"
  push lines, "  *out_len = len;"
  push lines, "  return lines;"
  push lines, "}"
  push lines, ""
  push lines, "static void token_part(const char *token, int want, char *out, size_t out_size) {"
  push lines, "  int part = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; token[i] != 0; i++) {"
  push lines, "    if (token[i] == ':') {"
  push lines, "      if (part == want) break;"
  push lines, "      part++;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (part == want && n + 1 < out_size) out[n++] = token[i];"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static char **parse_tokens(char **tokens, long tokens_len, long *out_len) {"
  push lines, "  char **nodes = NULL;"
  push lines, "  long len = 0;"
  push lines, "  int need_block_indent = 0;"
  push lines, "  int in_block = 0;"
  push lines, "  int current_indent = 0;"
  push lines, "  int skip_function_body = 0;"
  push lines, "  for (long i = 0; i + 1 < tokens_len; i++) {"
  push lines, "    if (strstr(tokens[i], \":INDENT:\")) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      char *start = strstr(tokens[i], \":INDENT:\") + 8;"
  push lines, "      char *end = strrchr(start, ':');"
  push lines, "      int n = end ? (int)(end - start) : (int)strlen(start);"
  push lines, "      char spaces[32];"
  push lines, "      memcpy(spaces, start, (size_t)n);"
  push lines, "      spaces[n] = 0;"
  push lines, "      current_indent = atoi(spaces);"
  push lines, "      if (current_indent == 0) skip_function_body = 0;"
  push lines, "      if (need_block_indent || (in_block && strcmp(spaces, \"0\") == 0)) {"
  push lines, "        char node[8192];"
  push lines, "        snprintf(node, sizeof(node), \"%s:INDENT:%s\", line, spaces);"
  push lines, "        nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "        nodes[len++] = dup_text(node);"
  push lines, "        if (strcmp(spaces, \"0\") == 0) in_block = 0; else in_block = 1;"
  push lines, "        need_block_indent = 0;"
  push lines, "      }"
  push lines, "    }"
  push lines, "    if (current_indent == 0 && i + 3 < tokens_len && strstr(tokens[i], \":IDENT:parse_user:\") && strstr(tokens[i + 1], \":SYMBOL:=:\") && strstr(tokens[i + 2], \":IDENT:\") && strstr(tokens[i + 3], \":ARROW:->:\")) {"
  push lines, "      char line[32];"
  push lines, "      char arg[4096];"
  push lines, "      token_part(tokens[i], 0, line, sizeof(line));"
  push lines, "      token_part(tokens[i + 2], 2, arg, sizeof(arg));"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:FUNC:parse_user:%s\", line, arg);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (skip_function_body && current_indent > 0) continue;"
  push lines, "    if (current_indent == 0 && i + 3 < tokens_len && strstr(tokens[i], \":IDENT:\") && strstr(tokens[i + 1], \":SYMBOL:=:\") && strstr(tokens[i + 2], \":IDENT:\") && strstr(tokens[i + 3], \":ARROW:->:\")) {"
  push lines, "      skip_function_body = 1;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (i + 4 < tokens_len && strstr(tokens[i], \":IDENT:if:\") && strstr(tokens[i + 1], \":IDENT:\") && strstr(tokens[i + 2], \":SYMBOL:==:\") && strstr(tokens[i + 3], \":STRING:\")) {"
  push lines, "      char line[32];"
  push lines, "      char left[4096];"
  push lines, "      char right[4096];"
  push lines, "      token_part(tokens[i], 0, line, sizeof(line));"
  push lines, "      token_part(tokens[i + 1], 2, left, sizeof(left));"
  push lines, "      token_part(tokens[i + 3], 2, right, sizeof(right));"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:IF_COMPARE_EQ:IDENT:%s:STRING:%s\", line, left, right);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (i + 1 < tokens_len && strstr(tokens[i], \":IDENT:if:\") && strstr(tokens[i + 1], \":IDENT:\")) {"
  push lines, "      char line[32];"
  push lines, "      char name[4096];"
  push lines, "      token_part(tokens[i], 0, line, sizeof(line));"
  push lines, "      token_part(tokens[i + 1], 2, name, sizeof(name));"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:IF:IDENT:%s\", line, name);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (strstr(tokens[i], \":IDENT:else:\")) {"
  push lines, "      char line[32];"
  push lines, "      token_part(tokens[i], 0, line, sizeof(line));"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:ELSE\", line);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      need_block_indent = 1;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (i + 4 < tokens_len && strstr(tokens[i], \":IDENT:return:\") && strstr(tokens[i + 1], \":IDENT:nil:\") && strstr(tokens[i + 2], \":SYMBOL:,:\") && strstr(tokens[i + 3], \":IDENT:error:\") && strstr(tokens[i + 4], \":STRING:\")) {"
  push lines, "      char line[32];"
  push lines, "      char message[4096];"
  push lines, "      token_part(tokens[i], 0, line, sizeof(line));"
  push lines, "      token_part(tokens[i + 4], 2, message, sizeof(message));"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:RETURN2_CALL1:NIL:nil:error:STRING:%s\", line, message);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (i + 7 < tokens_len && strstr(tokens[i], \":IDENT:return:\") && strstr(tokens[i + 2], \":IDENT:\") && strstr(tokens[i + 4], \":IDENT:\") && strstr(tokens[i + 5], \":SYMBOL:}:\") && strstr(tokens[i + 6], \":SYMBOL:,:\") && strstr(tokens[i + 7], \":IDENT:nil:\")) {"
  push lines, "      char line[32];"
  push lines, "      char key[4096];"
  push lines, "      char value[4096];"
  push lines, "      token_part(tokens[i], 0, line, sizeof(line));"
  push lines, "      token_part(tokens[i + 2], 2, key, sizeof(key));"
  push lines, "      token_part(tokens[i + 4], 2, value, sizeof(value));"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:RETURN2_OBJECT_NIL:%s:IDENT:%s\", line, key, value);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (i + 5 < tokens_len && strstr(tokens[i], \":IDENT:\") && strstr(tokens[i + 1], \":SYMBOL:,:\") && strstr(tokens[i + 2], \":IDENT:\") && strstr(tokens[i + 3], \":SYMBOL:=:\") && strstr(tokens[i + 4], \":IDENT:\") && strstr(tokens[i + 5], \":STRING:\")) {"
  push lines, "      char line[32];"
  push lines, "      char left[4096];"
  push lines, "      char right[4096];"
  push lines, "      char func[4096];"
  push lines, "      char arg[4096];"
  push lines, "      token_part(tokens[i], 0, line, sizeof(line));"
  push lines, "      token_part(tokens[i], 2, left, sizeof(left));"
  push lines, "      token_part(tokens[i + 2], 2, right, sizeof(right));"
  push lines, "      token_part(tokens[i + 4], 2, func, sizeof(func));"
  push lines, "      token_part(tokens[i + 5], 2, arg, sizeof(arg));"
  push lines, "      char node[8192];"
  push lines, "      snprintf(node, sizeof(node), \"%s:MULTI_ASSIGN2_CALL1:%s:%s:%s:STRING:%s\", line, left, right, func, arg);"
  push lines, "      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      nodes[len++] = dup_text(node);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (i + 3 < tokens_len && strstr(tokens[i], \":IDENT:print:\") && strstr(tokens[i + 1], \":IDENT:\") && strstr(tokens[i + 2], \":SYMBOL:.:\") && strstr(tokens[i + 3], \":IDENT:\")) {"
  push lines, "      char line[32];"
  push lines, "      char object[4096];"
