program_node = statements -> { kind: "program", statements: statements }

token_node = kind, text, line, col ->
  { kind: kind, text: text, line: line, col: col }

assign_stmt = name, value, line ->
  { kind: "assign", name: name, value: value, line: line }

import_stmt = name, line -> { kind: "import", name: name, line: line }

module_stmt = name, members, line ->
  { kind: "module", name: name, members: members, classes: [], line: line }

module_member = name, value, line -> { name: name, value: value, line: line }

class_stmt = name, methods, line ->
  { kind: "class", name: name, parent: "", methods: methods, fields: [], vars: [], line: line }

class_method = name, value, line ->
  { name: name, value: value, line: line, class: false }

class_member_method = name, value, line ->
  { name: name, value: value, line: line, class: true }

class_field = name, value, line -> { name: name, value: value, line: line }

multi_assign_stmt = names, value, line ->
  { kind: "multi_assign", names: names, value: value, line: line }

index_assign_stmt = target, index_value, value, line ->
  { kind: "index_assign", target: target, index: index_value, value: value, line: line }

expr_stmt = expr, line -> { kind: "expr_stmt", expr: expr, line: line }

return_stmt = value, line -> { kind: "return", value: value, line: line }

break_stmt = line -> { kind: "break", line: line }

continue_stmt = line -> { kind: "continue", line: line }

if_stmt = cond, then_body, else_body, line ->
  { kind: "if", cond: cond, then: then_body, else: else_body, elseif_cond: nil, elseif_then: [], elseif_conds: [], elseif_bodies: [], line: line }

while_stmt = cond, body, line ->
  { kind: "while", cond: cond, body: body, line: line }

for_stmt = value_name, index_name, loop_kind, iterable ->
  { kind: "for", value_name: value_name, index_name: index_name, loop_kind: loop_kind, iterable: iterable, body: [] }

call_expr = callee, args, line ->
  { kind: "call", callee: callee, args: args, line: line }

func_expr = params, body, line ->
  { kind: "func", params: params, body: body, body_stmts: [], line: line }

ident_expr = name, line -> { kind: "ident", name: name, line: line }

int_expr = value, line -> { kind: "int", value: value, line: line }

float_expr = value, line -> { kind: "float", value: value, line: line }

string_expr = value, line -> { kind: "string", value: value, line: line }

bool_expr = value, line -> { kind: "bool", value: value, line: line }

nil_expr = line -> { kind: "nil", line: line }

array_expr = items, line -> { kind: "array", items: items, line: line }

dict_expr = entries, line -> { kind: "dict", entries: entries, line: line }

dict_entry = key, value -> { key: key, value: value }

index_expr = target, index, line ->
  { kind: "index", target: target, index: index, line: line }

member_expr = target, name, line ->
  { kind: "member", target: target, name: name, line: line }

field_expr = name, line -> { kind: "field", name: name, line: line }

class_var_expr = name, line -> { kind: "class_var", name: name, line: line }

field_assign_stmt = name, value, line ->
  { kind: "field_assign", name: name, value: value, line: line }

class_var_assign_stmt = name, value, line ->
  { kind: "class_var_assign", name: name, value: value, line: line }

member_assign_stmt = target, name, value, line ->
  { kind: "member_assign", target: target, name: name, value: value, line: line }

binary_expr = op, left, right, line ->
  { kind: "binary", op: op, left: left, right: right, line: line }

unary_expr = op, expr, line -> { kind: "unary", op: op, expr: expr, line: line }

try_expr = expr, line -> { kind: "try", expr: expr, line: line }
syntax_errors = []
parse_state = { function_depth: 0, loop_depth: 0 }
checker_modules = []
emitter_state =
  class_ref: ""
  super_class: ""
  method_name: ""
  class_values: {}
has_name = names, name ->
  found = false
  for item in names
    if item == name
      found = true
  found

is_digit = char ->
  result = contains("0123456789", char)
  return result

is_lower = char ->
  result = contains("abcdefghijklmnopqrstuvwxyz", char)
  return result

is_upper = char ->
  result = contains("ABCDEFGHIJKLMNOPQRSTUVWXYZ", char)
  return result

is_alpha = char ->
  lower = is_lower(char)
  if lower
    return true
  upper = is_upper(char)
  if upper
    return true
  return char == "_"

is_alpha_num = char ->
  alpha = is_alpha(char)
  if alpha
    return true
  digit = is_digit(char)
  return digit

escape_char = char ->
  if char == "n"
    return "\n"
  if char == "t"
    return "\t"
  char

lex = source ->
  tokens = []
  errors = []
  indents = [0]
  i = 0
  line = 1
  col = 1
  at_line_start = true
  while i < len(source)
    char = source[i]
    if at_line_start and char == "\n"
      line = line + 1
      col = 1
      i = i + 1
      continue
    if char == "\n"
      push(tokens, token_node("NEWLINE", "\n", line, col))
      line = line + 1
      col = 1
      at_line_start = true
      i = i + 1
      continue
    if at_line_start
      spaces = 0
      while i < len(source) and source[i] == " "
        spaces = spaces + 1
        i = i + 1
        col = col + 1
      if i < len(source) and source[i] == "\t"
        push(errors, to_string(line) + ": tabs are forbidden")
        while i < len(source) and source[i] != "\n"
          i = i + 1
          col = col + 1
        continue
      if i < len(source) and source[i] == "#"
        while i < len(source) and source[i] != "\n"
          i = i + 1
          col = col + 1
        continue
      if i < len(source) and source[i] == "\n"
        continue
      if spaces % 2 != 0
        push(
          errors,
          to_string(line) + ": indentation must use exactly 2 spaces",
        )
        while i < len(source) and source[i] != "\n"
          i = i + 1
          col = col + 1
        continue
      current_indent = indents[len(indents) - 1]
      if spaces > current_indent
        if spaces != current_indent + 2
          push(
            errors,
            to_string(line) + ": indentation may only increase by 2 spaces",
          )
        push(indents, spaces)
        push(tokens, token_node("INDENT", "", line, 1))
      else
        while spaces < indents[len(indents) - 1]
          pop(indents)
          push(tokens, token_node("DEDENT", "", line, 1))
        if spaces != indents[len(indents) - 1]
          push(errors, to_string(line) + ": inconsistent indentation")
      at_line_start = false
      if i >= len(source)
        continue
      char = source[i]
    if char == "\t"
      push(errors, to_string(line) + ": tabs are forbidden")
      while i < len(source) and source[i] != "\n"
        i = i + 1
        col = col + 1
      continue
    if char == " "
      i = i + 1
      col = col + 1
      continue
    if char == "#"
      while i < len(source) and source[i] != "\n"
        i = i + 1
        col = col + 1
      continue
    if is_alpha(char)
      start_col = col
      text = ""
      while i < len(source) and is_alpha_num(source[i])
        text = text + source[i]
        i = i + 1
        col = col + 1
      push(tokens, token_node("IDENT", text, line, start_col))
      continue
    if is_digit(char)
      start_col = col
      text = ""
      while i < len(source) and is_digit(source[i])
        text = text + source[i]
        i = i + 1
        col = col + 1
      kind = "INT"
      if i + 1 < len(source) and source[i] == "." and is_digit(source[i + 1])
        kind = "FLOAT"
        text = text + "."
        i = i + 1
        col = col + 1
        while i < len(source) and is_digit(source[i])
          text = text + source[i]
          i = i + 1
          col = col + 1
      push(tokens, token_node(kind, text, line, start_col))
      continue
    if char == "\""
      start_col = col
      i = i + 1
      col = col + 1
      text = ""
      while i < len(source) and source[i] != "\""
        if source[i] == "\\" and i + 1 < len(source)
          esc = source[i + 1]
          if esc == "n" or esc == "t" or esc == "\"" or esc == "\\"
            text = text + escape_char(esc)
          else
            push(
              errors,
              to_string(line) + ":" + to_string(col) + ": unknown escape \\" + esc,
            )
          i = i + 2
          col = col + 2
        else
          if source[i] == "\n"
            push(
              errors,
              to_string(line) + ":" + to_string(start_col) + ": unterminated string",
            )
            break
          text = text + source[i]
          i = i + 1
          col = col + 1
      if i >= len(source)
        push(
          errors,
          to_string(line) + ":" + to_string(start_col) + ": unterminated string",
        )
        push(tokens, token_node("STRING", text, line, start_col))
        continue
      i = i + 1
      col = col + 1
      push(tokens, token_node("STRING", text, line, start_col))
      continue
    if i + 1 < len(source)
      two = char + source[i + 1]
      if two == "==" or two == "!=" or two == "<=" or two == ">=" or two == "->"
        push(tokens, token_node("SYMBOL", two, line, col))
        i = i + 2
        col = col + 2
        continue
    if contains("=<>:,.@+-*/%()[]{{}}", char)
      push(tokens, token_node("SYMBOL", char, line, col))
      i = i + 1
      col = col + 1
      continue
    push(
      errors,
      to_string(line) + ":" + to_string(col) + ": unexpected character " + char,
    )
    i = i + 1
    col = col + 1
  while len(indents) > 1
    pop(indents)
    push(tokens, token_node("DEDENT", "", line, col))
  push(tokens, token_node("EOF", "", line, col))
  return suppress_bracket_newlines(tokens), errors

token_text = token -> token["text"]

token_kind = token -> token["kind"]

# CANONICAL §5: drop NEWLINE / INDENT / DEDENT inside `(` `[`
# brackets and around binary-operator continuation lines so wrap
# forms emitted by the canonical formatter parse as a single
# logical line.
suppress_bracket_newlines = tokens ->
  out = []
  depth = 0
  pending_dedent = 0
  i = 0
  n = len(tokens)
  while i < n
    t = tokens[i]
    kind = token_kind(t)
    text = token_text(t)
    if kind == "SYMBOL" and (text == "(" or text == "[")
      depth = depth + 1
    if kind == "SYMBOL" and (text == ")" or text == "]")
      if depth > 0
        depth = depth - 1
    if depth > 0 and (kind == "NEWLINE" or kind == "INDENT" or kind == "DEDENT")
      i = i + 1
      continue
    if kind == "NEWLINE" and i + 2 < n
      if (
        token_kind(tokens[i + 1]) == "INDENT" and is_continuation_op(tokens[i + 2])
      )
        pending_dedent = pending_dedent + 1
        i = i + 2
        continue
    if kind == "NEWLINE" and i + 1 < n and is_continuation_op(tokens[i + 1])
      i = i + 1
      continue
    if kind == "INDENT" and i + 1 < n and is_continuation_op(tokens[i + 1])
      pending_dedent = pending_dedent + 1
      i = i + 1
      continue
    if kind == "DEDENT" and pending_dedent > 0
      pending_dedent = pending_dedent - 1
      i = i + 1
      continue
    push(out, t)
    i = i + 1
  return out

is_continuation_op = t ->
  kind = token_kind(t)
  text = token_text(t)
  if kind == "IDENT"
    return text == "and" or text == "or"
  if kind != "SYMBOL"
    return false
  if text == "+" or text == "-" or text == "*" or text == "/" or text == "%"
    return true
  if (
    text == "==" or text == "!=" or text == "<" or text == "<=" or text == ">" or text == ">="
  )
    return true
  return false

token_line = token -> token["line"]

token_label = token ->
  if token["kind"] == "SYMBOL"
    return token["text"]
  token["kind"]

print_tokens = tokens ->
  for token in tokens
    print token_label(token)

expr_label = expr ->
  if expr["kind"] == "ident"
    return "ident " + expr["name"]
  if expr["kind"] == "int"
    return "int"
  if expr["kind"] == "float"
    return "float"
  if expr["kind"] == "string"
    return "string"
  if expr["kind"] == "bool"
    return "bool"
  if expr["kind"] == "nil"
    return "nil"
  if expr["kind"] == "array"
    return "array " + to_string(len(expr["items"]))
  if expr["kind"] == "dict"
    return "dict " + to_string(len(expr["entries"]))
  if expr["kind"] == "index"
    return "index"
  if expr["kind"] == "member"
    return "member " + expr["name"]
  if expr["kind"] == "call"
    return "call " + expr_label(expr["callee"]) + " " + to_string(len(expr["args"]))
  if expr["kind"] == "func"
    if len(expr["body_stmts"]) > 0
      return "func " + to_string(len(expr["params"])) + " block " + to_string(len(expr["body_stmts"]))
    return "func " + to_string(len(expr["params"])) + " expr " + expr_label(expr["body"])
  if expr["kind"] == "binary"
    return "binary " + expr["op"]
  if expr["kind"] == "unary"
    return "unary " + expr["op"]
  if expr["kind"] == "try"
    return "try " + expr_label(expr["expr"])
  expr["kind"]

stmt_label = stmt ->
  prefix = to_string(stmt["line"]) + ": "
  if stmt["kind"] == "assign"
    return prefix + "assign " + stmt["name"] + " = " + expr_label(stmt["value"])
  if stmt["kind"] == "multi_assign"
    return prefix + "multi_assign " + to_string(len(stmt["names"]))
  if stmt["kind"] == "expr_stmt"
    return prefix + "expr_stmt " + expr_label(stmt["expr"])
  if stmt["kind"] == "if"
    return prefix + "if elseif " + to_string(len(stmt["elseif_conds"])) + " else " + to_string(len(stmt["else"]))
  if stmt["kind"] == "module"
    return prefix + "module " + stmt["name"] + " " + to_string(len(stmt["members"]))
  prefix + stmt["kind"]

print_ast = program ->
  for stmt in program["statements"]
    print stmt_label(stmt)

is_v01_excluded_word = word ->
  word == "interface" or word == "object" or word == "set"

is_v01_reserved_name = word ->
  word == "self" or word == "true" or word == "false" or word == "nil" or word == "if" or word == "elseif" or word == "else" or word == "while" or word == "for" or word == "in" or word == "of" or word == "break" or word == "continue" or word == "return" or word == "import" or word == "module" or word == "and" or word == "or" or word == "not" or word == "try"

record_name_error = tok ->
  if token_kind(tok) == "IDENT" and is_v01_reserved_name(token_text(tok))
    push(
      syntax_errors,
      to_string(token_line(tok)) + ": " + token_text(tok) + " cannot be used as a name",
    )

parse_errors = tokens ->
  errors = []
  i = 0
  depth = 0
  while token_kind(tokens[i]) != "EOF"
    if token_kind(tokens[i]) == "INDENT"
      depth = depth + 1
    if token_kind(tokens[i]) == "DEDENT"
      depth = depth - 1
    if token_kind(tokens[i]) == "NEWLINE"
      i = i + 1
      continue
    if (
      token_kind(tokens[i]) == "IDENT" and token_text(tokens[i]) == "import" and token_text(tokens[i + 2]) == "as"
    )
      push(
        errors,
        to_string(token_line(tokens[i + 2])) + ": import aliases are not in Tya v0.1",
      )
    if (
      token_kind(tokens[i]) == "IDENT" and token_text(tokens[i]) == "import" and depth > 0
    )
      push(
        errors,
        to_string(token_line(tokens[i])) + ": import must be top-level",
      )
    if (
      token_kind(tokens[i]) == "IDENT" and token_text(tokens[i]) == "module" and depth > 0
    )
      push(
        errors,
        to_string(token_line(tokens[i])) + ": module must be top-level",
      )
    if (
      token_kind(tokens[i]) == "IDENT" and is_v01_excluded_word(token_text(tokens[i]))
    )
      push(
        errors,
        to_string(token_line(tokens[i])) + ": " + token_text(tokens[i]) + " is not in Tya v0.1",
      )
    i = i + 1
  errors

parse_scalar = tokens, index ->
  tok = tokens[index]
  if token_kind(tok) == "IDENT"
    if token_text(tok) == "true"
      return bool_expr(true, token_line(tok)), index + 1
    if token_text(tok) == "false"
      return bool_expr(false, token_line(tok)), index + 1
    if token_text(tok) == "nil"
      return nil_expr(token_line(tok)), index + 1
    return ident_expr(token_text(tok), token_line(tok)), index + 1
  if token_kind(tok) == "INT"
    return int_expr(to_int(token_text(tok)), token_line(tok)), index + 1
  if token_kind(tok) == "FLOAT"
    return float_expr(to_float(token_text(tok)), token_line(tok)), index + 1
  if token_kind(tok) == "STRING"
    return string_expr(token_text(tok), token_line(tok)), index + 1
  return nil_expr(token_line(tok)), index + 1

parse_nested = tokens, index ->
  left, next = parse_or(tokens, index)
  while is_postfix_start(token_text(tokens[next]))
    if token_text(tokens[next]) == "["
      index_value, after_index = parse_or(tokens, next + 1)
      left = index_expr(left, index_value, token_line(tokens[next]))
      next = after_index
      if token_text(tokens[next]) == "]"
        next = next + 1
    elseif token_text(tokens[next]) == "."
      left = member_expr(
        left,
        token_text(tokens[next + 1]),
        token_line(tokens[next]),
      )
      next = next + 2
    else
      args = []
      call_line = token_line(tokens[next])
      next = next + 1
      while (
        token_text(tokens[next]) != ")" and token_kind(tokens[next]) != "EOF"
      )
        arg, after_arg = parse_call_arg(tokens, next)
        push(args, arg)
        next = after_arg
        if token_text(tokens[next]) == ","
          next = next + 1
      left = call_expr(left, args, call_line)
      if token_text(tokens[next]) == ")"
        next = next + 1
  return left, next

is_binary_op = op ->
  op == "and" or op == "or" or op == "+" or op == "-" or op == "*" or op == "/" or op == "%" or op == "==" or op == "!=" or op == "<" or op == "<=" or op == ">" or op == ">="

is_postfix_start = text ->
  if text == "["
    return true
  if text == "("
    return true
  if text == "."
    return true
  false

is_mul_op = text ->
  if text == "*"
    return true
  if text == "/"
    return true
  if text == "%"
    return true
  false

is_compare_op = text ->
  if text == "=="
    return true
  if text == "!="
    return true
  if text == "<"
    return true
  if text == "<="
    return true
  if text == ">"
    return true
  if text == ">="
    return true
  false

is_empty_param_arrow = tokens, index ->
  if token_kind(tokens[index]) != "SYMBOL" or token_text(tokens[index]) != "("
    return false
  if (
    token_kind(tokens[index + 1]) != "SYMBOL" or token_text(tokens[index + 1]) != ")"
  )
    return false
  token_kind(tokens[index + 2]) == "SYMBOL" and token_text(tokens[index + 2]) == "->"

parse_primary = tokens, index ->
  tok = tokens[index]
  if token_kind(tok) == "SYMBOL" and token_text(tok) == "("
    left, next = parse_or(tokens, index + 1)
    if token_text(tokens[next]) == ")"
      next = next + 1
    return left, next
  if token_kind(tok) == "SYMBOL" and token_text(tok) == "@"
    if token_text(tokens[index + 1]) == "@"
      return class_var_expr(token_text(tokens[index + 2]), token_line(tok)), index + 3
    return field_expr(token_text(tokens[index + 1]), token_line(tok)), index + 2
  if token_kind(tok) == "IDENT"
    if token_text(tok) == "true"
      return bool_expr(true, token_line(tok)), index + 1
    if token_text(tok) == "false"
      return bool_expr(false, token_line(tok)), index + 1
    if token_text(tok) == "nil"
      return nil_expr(token_line(tok)), index + 1
    return ident_expr(token_text(tok), token_line(tok)), index + 1
  if token_kind(tok) == "INT"
    return int_expr(to_int(token_text(tok)), token_line(tok)), index + 1
  if token_kind(tok) == "FLOAT"
    return float_expr(to_float(token_text(tok)), token_line(tok)), index + 1
  if token_kind(tok) == "STRING"
    return string_expr(token_text(tok), token_line(tok)), index + 1
  if token_kind(tok) == "SYMBOL" and token_text(tok) == "["
    items = []
    next = index + 1
    while token_text(tokens[next]) != "]" and token_kind(tokens[next]) != "EOF"
      item, after = parse_expr(tokens, next)
      push(items, item)
      next = after
      if token_text(tokens[next]) == ","
        next = next + 1
    return array_expr(items, token_line(tok)), next + 1
  if token_kind(tok) == "SYMBOL" and token_text(tok) == "{{"
    entries = []
    next = index + 1
    while token_text(tokens[next]) != "}}" and token_kind(tokens[next]) != "EOF"
      key = token_text(tokens[next])
      if token_text(tokens[next + 1]) != ":"
        push(
          syntax_errors,
          to_string(token_line(tokens[next])) + ": set literals are not in Tya v0.1",
        )
        while (
          token_text(tokens[next]) != "}}" and token_kind(tokens[next]) != "EOF"
        )
          next = next + 1
        return dict_expr(entries, token_line(tok)), next + 1
      next = next + 2
      value, after_value = parse_expr(tokens, next)
      push(entries, dict_entry(key, value))
      next = after_value
      if token_text(tokens[next]) == ","
        next = next + 1
    return dict_expr(entries, token_line(tok)), next + 1
  return nil_expr(token_line(tok)), index + 1

parse_postfix = tokens, index ->
  left, next = parse_primary(tokens, index)
  while is_postfix_start(token_text(tokens[next]))
    if token_text(tokens[next]) == "["
      index_value, after_index = parse_nested(tokens, next + 1)
      left = index_expr(left, index_value, token_line(tokens[next]))
      next = after_index
      if token_text(tokens[next]) == "]"
        next = next + 1
    elseif token_text(tokens[next]) == "."
      left = member_expr(
        left,
        token_text(tokens[next + 1]),
        token_line(tokens[next]),
      )
      next = next + 2
    else
      args = []
      call_line = token_line(tokens[next])
      next = next + 1
      while (
        token_text(tokens[next]) != ")" and token_kind(tokens[next]) != "EOF"
      )
        arg, after_arg = parse_call_arg(tokens, next)
        push(args, arg)
        next = after_arg
        if token_text(tokens[next]) == ","
          next = next + 1
      left = call_expr(left, args, call_line)
      if token_text(tokens[next]) == ")"
        next = next + 1
  return left, next

parse_unary = tokens, index ->
  if token_kind(tokens[index]) == "IDENT" and token_text(tokens[index]) == "try"
    if parse_state["function_depth"] == 0
      push(
        syntax_errors,
        to_string(token_line(tokens[index])) + ": try must be inside a function",
      )
    expr, next = parse_postfix(tokens, index + 1)
    return try_expr(expr, token_line(tokens[index])), next
  if token_kind(tokens[index]) == "IDENT" and token_text(tokens[index]) == "not"
    expr, next = parse_postfix(tokens, index + 1)
    return unary_expr(token_text(tokens[index]), expr, token_line(tokens[index])), next
  if token_kind(tokens[index]) == "SYMBOL" and token_text(tokens[index]) == "-"
    expr, next = parse_postfix(tokens, index + 1)
    return unary_expr(token_text(tokens[index]), expr, token_line(tokens[index])), next
  return parse_postfix(tokens, index)

parse_mul = tokens, index ->
  left, next = parse_unary(tokens, index)
  while is_mul_op(token_text(tokens[next]))
    op = tokens[next]
    right, after = parse_unary(tokens, next + 1)
    left = binary_expr(token_text(op), left, right, token_line(op))
    next = after
  return left, next

parse_add = tokens, index ->
  left, next = parse_mul(tokens, index)
  while token_text(tokens[next]) == "+" or token_text(tokens[next]) == "-"
    op = tokens[next]
    right, after = parse_mul(tokens, next + 1)
    left = binary_expr(token_text(op), left, right, token_line(op))
    next = after
  return left, next

parse_compare = tokens, index ->
  left, next = parse_add(tokens, index)
  while is_compare_op(token_text(tokens[next]))
    op = tokens[next]
    right, after = parse_add(tokens, next + 1)
    left = binary_expr(token_text(op), left, right, token_line(op))
    next = after
  return left, next

parse_and = tokens, index ->
  left, next = parse_compare(tokens, index)
  while token_text(tokens[next]) == "and"
    op = tokens[next]
    right, after = parse_compare(tokens, next + 1)
    left = binary_expr(token_text(op), left, right, token_line(op))
    next = after
  return left, next

parse_or = tokens, index ->
  left, next = parse_and(tokens, index)
  while token_text(tokens[next]) == "or"
    op = tokens[next]
    right, after = parse_and(tokens, next + 1)
    left = binary_expr(token_text(op), left, right, token_line(op))
    next = after
  return left, next

parse_expr = tokens, index ->
  if is_empty_param_arrow(tokens, index)
    parse_state["function_depth"] = parse_state["function_depth"] + 1
    body, after_body = parse_or(tokens, index + 3)
    parse_state["function_depth"] = parse_state["function_depth"] - 1
    return func_expr([], body, token_line(tokens[index])), after_body
  if token_text(tokens[index]) == "->"
    parse_state["function_depth"] = parse_state["function_depth"] + 1
    body, after_body = parse_or(tokens, index + 1)
    parse_state["function_depth"] = parse_state["function_depth"] - 1
    return func_expr([], body, token_line(tokens[index])), after_body
  if (
    token_kind(tokens[index]) == "IDENT" and token_text(tokens[index + 1]) == "->"
  )
    record_name_error(tokens[index])
    parse_state["function_depth"] = parse_state["function_depth"] + 1
    body, after_body = parse_or(tokens, index + 2)
    parse_state["function_depth"] = parse_state["function_depth"] - 1
    return func_expr([token_text(tokens[index])], body, token_line(tokens[index])), after_body
  if (
    token_kind(tokens[index]) == "IDENT" and token_text(tokens[index + 1]) == "," and token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "->"
  )
    record_name_error(tokens[index])
    record_name_error(tokens[index + 2])
    parse_state["function_depth"] = parse_state["function_depth"] + 1
    body, after_body = parse_or(tokens, index + 4)
    parse_state["function_depth"] = parse_state["function_depth"] - 1
    return func_expr([token_text(tokens[index]), token_text(tokens[index + 2])], body, token_line(tokens[index])), after_body
  if (
    token_kind(tokens[index]) == "IDENT" and token_text(tokens[index + 1]) == "," and token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "," and token_kind(tokens[index + 4]) == "IDENT" and token_text(tokens[index + 5]) == "->"
  )
    record_name_error(tokens[index])
    record_name_error(tokens[index + 2])
    record_name_error(tokens[index + 4])
    parse_state["function_depth"] = parse_state["function_depth"] + 1
    body, after_body = parse_or(tokens, index + 6)
    parse_state["function_depth"] = parse_state["function_depth"] - 1
    return func_expr([token_text(tokens[index]), token_text(tokens[index + 2]), token_text(tokens[index + 4])], body, token_line(tokens[index])), after_body
  if (
    token_kind(tokens[index]) == "IDENT" and token_text(tokens[index + 1]) == "," and token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "," and token_kind(tokens[index + 4]) == "IDENT" and token_text(tokens[index + 5]) == "," and token_kind(tokens[index + 6]) == "IDENT" and token_text(tokens[index + 7]) == "->"
  )
    record_name_error(tokens[index])
    record_name_error(tokens[index + 2])
    record_name_error(tokens[index + 4])
    record_name_error(tokens[index + 6])
    parse_state["function_depth"] = parse_state["function_depth"] + 1
    body, after_body = parse_or(tokens, index + 8)
    parse_state["function_depth"] = parse_state["function_depth"] - 1
    return func_expr([token_text(tokens[index]), token_text(tokens[index + 2]), token_text(tokens[index + 4]), token_text(tokens[index + 6])], body, token_line(tokens[index])), after_body
  return parse_or(tokens, index)

parse_call_arg = tokens, index ->
  if is_empty_param_arrow(tokens, index)
    return parse_expr(tokens, index)
  if token_text(tokens[index]) == "->"
    return parse_expr(tokens, index)
  if (
    token_kind(tokens[index]) == "IDENT" and token_text(tokens[index + 1]) == "->"
  )
    return parse_expr(tokens, index)
  return parse_or(tokens, index)

record_trailing_statement_error = tokens, start, index ->
  if (
    token_line(tokens[index]) == token_line(tokens[start]) and token_kind(tokens[index]) != "NEWLINE" and token_kind(tokens[index]) != "DEDENT" and token_kind(tokens[index]) != "EOF"
  )
    push(
      syntax_errors,
      to_string(token_line(tokens[index])) + ": function calls require parentheses in Tya v0.1",
    )
    while (
      token_kind(tokens[index]) != "NEWLINE" and token_kind(tokens[index]) != "DEDENT" and token_kind(tokens[index]) != "EOF"
    )
      index = index + 1
  index

record_block_header_error = tokens, index ->
  if (
    token_kind(tokens[index]) != "NEWLINE" and token_kind(tokens[index]) != "INDENT" and token_kind(tokens[index]) != "EOF"
  )
    push(
      syntax_errors,
      to_string(token_line(tokens[index])) + ": unexpected token before block",
    )
    while (
      token_kind(tokens[index]) != "NEWLINE" and token_kind(tokens[index]) != "EOF"
    )
      index = index + 1
  index

class_body_start = tokens, index ->
  next = index + 2
  parent = ""
  if token_text(tokens[next]) == "extends"
    parent = token_text(tokens[next + 1])
    next = next + 2
  return parent, next

parse_simple_statement = tokens, index ->
  current = tokens[index]
  if (
    token_kind(current) == "IDENT" and token_text(tokens[index + 1]) == "." and token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "="
  )
    value, next = parse_expr(tokens, index + 4)
    return member_assign_stmt(ident_expr(token_text(current), token_line(current)), token_text(tokens[index + 2]), value, token_line(current)), next
  if token_text(current) == "@"
    if token_text(tokens[index + 1]) == "@"
      if token_text(tokens[index + 3]) == "="
        value, next = parse_expr(tokens, index + 4)
        return class_var_assign_stmt(token_text(tokens[index + 2]), value, token_line(current)), next
    if token_text(tokens[index + 2]) == "="
      value, next = parse_expr(tokens, index + 3)
      return field_assign_stmt(token_text(tokens[index + 1]), value, token_line(current)), next
  if (
    token_kind(current) == "IDENT" and token_text(tokens[index + 1]) == "=" and is_v01_reserved_name(token_text(current))
  )
    record_name_error(current)
    expr, next = parse_expr(tokens, index + 2)
    return assign_stmt(token_text(current), expr, token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(current) == "return"
    if parse_state["function_depth"] == 0
      push(
        syntax_errors,
        to_string(token_line(current)) + ": return must be inside a function",
      )
    if (
      token_kind(tokens[index + 1]) == "NEWLINE" or token_kind(tokens[index + 1]) == "DEDENT" or token_kind(tokens[index + 1]) == "EOF"
    )
      return return_stmt(nil_expr(token_line(current)), token_line(current)), index + 1
    expr, next = parse_expr(tokens, index + 1)
    if token_text(tokens[next]) == ","
      right, after_right = parse_expr(tokens, next + 1)
      expr = array_expr([expr, right], token_line(current))
      next = after_right
    return return_stmt(expr, token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(current) == "break"
    if parse_state["loop_depth"] == 0
      push(
        syntax_errors,
        to_string(token_line(current)) + ": break must be inside a loop",
      )
    return break_stmt(token_line(current)), index + 1
  if token_kind(current) == "IDENT" and token_text(current) == "continue"
    if parse_state["loop_depth"] == 0
      push(
        syntax_errors,
        to_string(token_line(current)) + ": continue must be inside a loop",
      )
    return continue_stmt(token_line(current)), index + 1
  if token_kind(current) == "IDENT" and token_text(current) == "print"
    expr, next = parse_expr(tokens, index + 1)
    return expr_stmt(call_expr(ident_expr("print", token_line(current)), [expr], token_line(current)), token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(current) == "assert"
    expr, next = parse_expr(tokens, index + 1)
    return expr_stmt(call_expr(ident_expr("assert", token_line(current)), [expr], token_line(current)), token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(current) == "assert_equal"
    expected, after_expected = parse_expr(tokens, index + 1)
    next = after_expected
    if token_text(tokens[next]) == ","
      actual, after_actual = parse_expr(tokens, next + 1)
      return expr_stmt(call_expr(ident_expr("assert_equal", token_line(current)), [expected, actual], token_line(current)), token_line(current)), after_actual
    push(
      syntax_errors,
      to_string(token_line(current)) + ": assert_equal expects two expressions",
    )
    return expr_stmt(call_expr(ident_expr("assert_equal", token_line(current)), [expected], token_line(current)), token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(tokens[index + 1]) == "["
    target = ident_expr(token_text(current), token_line(current))
    index_value, after_index = parse_expr(tokens, index + 2)
    next = after_index
    if token_text(tokens[next]) == "]"
      next = next + 1
    while token_text(tokens[next]) == "["
      target = index_expr(target, index_value, token_line(tokens[next]))
      index_value, after_index = parse_expr(tokens, next + 1)
      next = after_index
      if token_text(tokens[next]) == "]"
        next = next + 1
    if token_text(tokens[next]) == ","
      push(
        syntax_errors,
        to_string(token_line(tokens[next])) + ": multiple assignment targets must be identifiers",
      )
      while (
        token_text(tokens[next]) != "=" and token_kind(tokens[next]) != "NEWLINE" and token_kind(tokens[next]) != "EOF"
      )
        next = next + 1
      if token_text(tokens[next]) == "="
        value, after_value = parse_expr(tokens, next + 1)
        return expr_stmt(value, token_line(current)), after_value
    if token_text(tokens[next]) == "="
      value, after_value = parse_expr(tokens, next + 1)
      return index_assign_stmt(target, index_value, value, token_line(current)), after_value
  if (
    token_kind(current) == "IDENT" and token_text(tokens[index + 1]) == "," and token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "="
  )
    record_name_error(current)
    record_name_error(tokens[index + 2])
    value, next = parse_expr(tokens, index + 4)
    return multi_assign_stmt([token_text(current), token_text(tokens[index + 2])], value, token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(tokens[index + 1]) == "="
    record_name_error(current)
    if (
      token_kind(tokens[index + 2]) == "NEWLINE" and token_kind(tokens[index + 3]) == "INDENT"
    )
      dict, after_dict = parse_dict_block_body(
        tokens,
        index + 4,
        token_line(current),
      )
      return assign_stmt(token_text(current), dict, token_line(current)), after_dict
    expr, next = parse_expr(tokens, index + 2)
    return assign_stmt(token_text(current), expr, token_line(current)), next
  expr, next = parse_expr(tokens, index)
  return expr_stmt(expr, token_line(current)), next

parse_dict_block_body = tokens, index, line ->
  entries = []
  while (
    token_kind(tokens[index]) != "DEDENT" and token_kind(tokens[index]) != "EOF"
  )
    if token_kind(tokens[index]) == "NEWLINE"
      index = index + 1
      continue
    if token_kind(tokens[index]) != "IDENT"
      push(
        syntax_errors,
        to_string(token_line(tokens[index])) + ": dict block entry must start with a key",
      )
      while (
        token_kind(tokens[index]) != "NEWLINE" and token_kind(tokens[index]) != "DEDENT" and token_kind(tokens[index]) != "EOF"
      )
        index = index + 1
      continue
    key = token_text(tokens[index])
    if token_text(tokens[index + 1]) != ":"
      push(
        syntax_errors,
        to_string(token_line(tokens[index])) + ": dict block entry expects ':' after key",
      )
      while (
        token_kind(tokens[index]) != "NEWLINE" and token_kind(tokens[index]) != "DEDENT" and token_kind(tokens[index]) != "EOF"
      )
        index = index + 1
      continue
    value, after_value = parse_expr(tokens, index + 2)
    push(entries, dict_entry(key, value))
    index = after_value
  if token_kind(tokens[index]) == "DEDENT"
    index = index + 1
  return dict_expr(entries, line), index

parse_simple_block = tokens, index ->
  statements = []
  next = index
  if token_kind(tokens[next]) == "NEWLINE"
    next = next + 1
  if token_kind(tokens[next]) == "INDENT"
    next = next + 1
  while (
    token_kind(tokens[next]) != "DEDENT" and token_kind(tokens[next]) != "EOF"
  )
    if token_kind(tokens[next]) == "NEWLINE"
      next = next + 1
      continue
    current = tokens[next]
    if token_kind(current) == "IDENT" and token_text(current) == "class"
      parent, body_start = class_body_start(tokens, next)
      body, after_class = parse_simple_block(tokens, body_start)
      methods = []
      fields = []
      vars = []
      for stmt in body
        if stmt["kind"] == "assign" and stmt["value"]["kind"] == "func"
          push(methods, class_method(stmt["name"], stmt["value"], stmt["line"]))
        elseif stmt["kind"] == "assign"
          push(fields, class_field(stmt["name"], stmt["value"], stmt["line"]))
        else
          if stmt["kind"] == "class_var_assign"
            if stmt["value"]["kind"] == "func"
              push(
                methods,
                class_member_method(stmt["name"], stmt["value"], stmt["line"]),
              )
            else
              push(vars, class_field(stmt["name"], stmt["value"], stmt["line"]))
          else
            push(
              syntax_errors,
              to_string(stmt["line"]) + ": class body may only contain member definitions",
            )
      cls = class_stmt(
        token_text(tokens[next + 1]),
        methods,
        token_line(current),
      )
      cls["parent"] = parent
      cls["fields"] = fields
      cls["vars"] = vars
      push(statements, cls)
      next = after_class
      continue
    if (
      token_text(current) == "@" and token_text(tokens[next + 1]) == "@" and token_text(tokens[next + 3]) == "=" and token_kind(tokens[next + 4]) == "IDENT" and token_text(tokens[next + 5]) == "->" and token_kind(tokens[next + 6]) == "NEWLINE"
    )
      record_name_error(tokens[next + 4])
      body, after_block_func = parse_function_body_block(tokens, next + 6)
      fn = func_expr(
        [token_text(tokens[next + 4])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      push(
        statements,
        class_var_assign_stmt(token_text(tokens[next + 2]), fn, token_line(current)),
      )
      next = after_block_func
      continue
    if (
      token_text(current) == "@" and token_text(tokens[next + 1]) == "@" and token_text(tokens[next + 3]) == "=" and token_text(tokens[next + 4]) == "->" and token_kind(tokens[next + 5]) == "NEWLINE"
    )
      body, after_block_func = parse_function_body_block(tokens, next + 5)
      fn = func_expr([], nil_expr(token_line(current)), token_line(current))
      fn["body_stmts"] = body
      push(
        statements,
        class_var_assign_stmt(token_text(tokens[next + 2]), fn, token_line(current)),
      )
      next = after_block_func
      continue
    if (
      token_kind(current) == "IDENT" and token_text(tokens[next + 1]) == "=" and token_text(tokens[next + 2]) == "->" and token_kind(tokens[next + 3]) == "NEWLINE"
    )
      record_name_error(current)
      body, after_block_func = parse_function_body_block(tokens, next + 3)
      fn = func_expr([], nil_expr(token_line(current)), token_line(current))
      fn["body_stmts"] = body
      push(
        statements,
        assign_stmt(token_text(current), fn, token_line(current)),
      )
      next = after_block_func
      continue
    if (
      token_kind(current) == "IDENT" and token_text(tokens[next + 1]) == "=" and token_kind(tokens[next + 2]) == "IDENT" and token_text(tokens[next + 3]) == "->" and token_kind(tokens[next + 4]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[next + 2])
      body, after_block_func = parse_function_body_block(tokens, next + 4)
      fn = func_expr(
        [token_text(tokens[next + 2])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      push(
        statements,
        assign_stmt(token_text(current), fn, token_line(current)),
      )
      next = after_block_func
      continue
    if (
      token_kind(current) == "IDENT" and token_text(tokens[next + 1]) == "=" and token_kind(tokens[next + 2]) == "IDENT" and token_text(tokens[next + 3]) == "," and token_kind(tokens[next + 4]) == "IDENT" and token_text(tokens[next + 5]) == "->" and token_kind(tokens[next + 6]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[next + 2])
      record_name_error(tokens[next + 4])
      body, after_block_func = parse_function_body_block(tokens, next + 6)
      fn = func_expr(
        [token_text(tokens[next + 2]), token_text(tokens[next + 4])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      push(
        statements,
        assign_stmt(token_text(current), fn, token_line(current)),
      )
      next = after_block_func
      continue
    if (
      token_kind(current) == "IDENT" and token_text(tokens[next + 1]) == "=" and token_kind(tokens[next + 2]) == "IDENT" and token_text(tokens[next + 3]) == "," and token_kind(tokens[next + 4]) == "IDENT" and token_text(tokens[next + 5]) == "," and token_kind(tokens[next + 6]) == "IDENT" and token_text(tokens[next + 7]) == "->" and token_kind(tokens[next + 8]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[next + 2])
      record_name_error(tokens[next + 4])
      record_name_error(tokens[next + 6])
      body, after_block_func = parse_function_body_block(tokens, next + 8)
      fn = func_expr(
        [token_text(tokens[next + 2]), token_text(tokens[next + 4]), token_text(tokens[next + 6])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      push(
        statements,
        assign_stmt(token_text(current), fn, token_line(current)),
      )
      next = after_block_func
      continue
    if (
      token_kind(current) == "IDENT" and token_text(tokens[next + 1]) == "=" and token_kind(tokens[next + 2]) == "IDENT" and token_text(tokens[next + 3]) == "," and token_kind(tokens[next + 4]) == "IDENT" and token_text(tokens[next + 5]) == "," and token_kind(tokens[next + 6]) == "IDENT" and token_text(tokens[next + 7]) == "," and token_kind(tokens[next + 8]) == "IDENT" and token_text(tokens[next + 9]) == "->" and token_kind(tokens[next + 10]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[next + 2])
      record_name_error(tokens[next + 4])
      record_name_error(tokens[next + 6])
      record_name_error(tokens[next + 8])
      body, after_block_func = parse_function_body_block(tokens, next + 10)
      fn = func_expr(
        [token_text(tokens[next + 2]), token_text(tokens[next + 4]), token_text(tokens[next + 6]), token_text(tokens[next + 8])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      push(
        statements,
        assign_stmt(token_text(current), fn, token_line(current)),
      )
      next = after_block_func
      continue
    if token_kind(current) == "IDENT" and token_text(current) == "if"
      cond, after_cond = parse_expr(tokens, next + 1)
      after_cond = record_block_header_error(tokens, after_cond)
      then_body, after_then = parse_simple_block(tokens, after_cond)
      else_body = []
      after_stmt = after_then
      stmt = if_stmt(cond, then_body, [], token_line(current))
      while (
        token_kind(tokens[after_stmt]) == "IDENT" and token_text(tokens[after_stmt]) == "elseif"
      )
        else_cond, after_else_cond = parse_expr(tokens, after_stmt + 1)
        after_else_cond = record_block_header_error(tokens, after_else_cond)
        else_then, after_else_then = parse_simple_block(tokens, after_else_cond)
        if stmt["elseif_cond"] == nil
          stmt["elseif_cond"] = else_cond
          stmt["elseif_then"] = else_then
        push(stmt["elseif_conds"], else_cond)
        push(stmt["elseif_bodies"], else_then)
        after_stmt = after_else_then
      if (
        token_kind(tokens[after_stmt]) == "IDENT" and token_text(tokens[after_stmt]) == "else"
      )
        else_body, after_stmt = parse_simple_block(tokens, after_stmt + 1)
        stmt["else"] = else_body
      push(statements, stmt)
      next = after_stmt
      continue
    if token_kind(current) == "IDENT" and token_text(current) == "while"
      cond, after_cond = parse_expr(tokens, next + 1)
      after_cond = record_block_header_error(tokens, after_cond)
      body, after_stmt = parse_loop_body_block(tokens, after_cond)
      push(statements, while_stmt(cond, body, token_line(current)))
      next = after_stmt
      continue
    if token_kind(current) == "IDENT" and token_text(current) == "for"
      value_name = token_text(tokens[next + 1])
      record_name_error(tokens[next + 1])
      index_name = ""
      loop_kind = token_text(tokens[next + 2])
      iterable_start = next + 3
      if token_text(tokens[next + 2]) == ","
        index_name = token_text(tokens[next + 3])
        record_name_error(tokens[next + 3])
        loop_kind = token_text(tokens[next + 4])
        iterable_start = next + 5
      iterable, after_iterable = parse_expr(tokens, iterable_start)
      after_iterable = record_block_header_error(tokens, after_iterable)
      body, after_stmt = parse_loop_body_block(tokens, after_iterable)
      stmt = for_stmt(value_name, index_name, loop_kind, iterable)
      stmt["body"] = body
      push(statements, stmt)
      next = after_stmt
      continue
    stmt, after = parse_simple_statement(tokens, next)
    push(statements, stmt)
    next = record_trailing_statement_error(tokens, next, after)
    if token_kind(tokens[next]) == "NEWLINE"
      next = next + 1
  if token_kind(tokens[next]) == "DEDENT"
    next = next + 1
  return statements, next

parse_function_body_block = tokens, index ->
  saved_loop_depth = parse_state["loop_depth"]
  parse_state["function_depth"] = parse_state["function_depth"] + 1
  parse_state["loop_depth"] = 0
  body, next = parse_simple_block(tokens, index)
  parse_state["loop_depth"] = saved_loop_depth
  parse_state["function_depth"] = parse_state["function_depth"] - 1
  return body, next

parse_loop_body_block = tokens, index ->
  parse_state["loop_depth"] = parse_state["loop_depth"] + 1
  body, next = parse_simple_block(tokens, index)
  parse_state["loop_depth"] = parse_state["loop_depth"] - 1
  return body, next

parse_statement = tokens, index ->
  current = tokens[index]
  if token_kind(current) == "IDENT" and token_text(current) == "import"
    record_name_error(tokens[index + 1])
    return import_stmt(token_text(tokens[index + 1]), token_line(current)), index + 2
  if token_kind(current) == "IDENT" and token_text(current) == "class"
    parent, body_start = class_body_start(tokens, index)
    body, next = parse_simple_block(tokens, body_start)
    methods = []
    fields = []
    vars = []
    for stmt in body
      if stmt["kind"] == "assign" and stmt["value"]["kind"] == "func"
        push(methods, class_method(stmt["name"], stmt["value"], stmt["line"]))
      elseif stmt["kind"] == "assign"
        push(fields, class_field(stmt["name"], stmt["value"], stmt["line"]))
      else
        if stmt["kind"] == "class_var_assign"
          if stmt["value"]["kind"] == "func"
            push(
              methods,
              class_member_method(stmt["name"], stmt["value"], stmt["line"]),
            )
          else
            push(vars, class_field(stmt["name"], stmt["value"], stmt["line"]))
        else
          push(
            syntax_errors,
            to_string(stmt["line"]) + ": class body may only contain member definitions",
          )
    cls = class_stmt(
      token_text(tokens[index + 1]),
      methods,
      token_line(current),
    )
    cls["parent"] = parent
    cls["fields"] = fields
    cls["vars"] = vars
    return cls, next
  if token_kind(current) == "IDENT" and token_text(current) == "module"
    record_name_error(tokens[index + 1])
    body, next = parse_simple_block(tokens, index + 2)
    members = []
    classes = []
    for stmt in body
      if stmt["kind"] == "assign"
        push(members, module_member(stmt["name"], stmt["value"], stmt["line"]))
      if stmt["kind"] == "class"
        push(classes, stmt)
    mod = module_stmt(
      token_text(tokens[index + 1]),
      members,
      token_line(current),
    )
    mod["classes"] = classes
    return mod, next
  if token_kind(current) == "IDENT" and token_text(tokens[index + 1]) == "="
    if (
      token_text(tokens[index + 2]) == "->" and token_kind(tokens[index + 3]) == "NEWLINE"
    )
      record_name_error(current)
      body, next = parse_function_body_block(tokens, index + 3)
      fn = func_expr([], nil_expr(token_line(current)), token_line(current))
      fn["body_stmts"] = body
      return assign_stmt(token_text(current), fn, token_line(current)), next
    if (
      token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "->" and token_kind(tokens[index + 4]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[index + 2])
      body, next = parse_function_body_block(tokens, index + 4)
      fn = func_expr(
        [token_text(tokens[index + 2])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      return assign_stmt(token_text(current), fn, token_line(current)), next
    if (
      token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "," and token_kind(tokens[index + 4]) == "IDENT" and token_text(tokens[index + 5]) == "->" and token_kind(tokens[index + 6]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[index + 2])
      record_name_error(tokens[index + 4])
      body, next = parse_function_body_block(tokens, index + 6)
      fn = func_expr(
        [token_text(tokens[index + 2]), token_text(tokens[index + 4])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      return assign_stmt(token_text(current), fn, token_line(current)), next
    if (
      token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "," and token_kind(tokens[index + 4]) == "IDENT" and token_text(tokens[index + 5]) == "," and token_kind(tokens[index + 6]) == "IDENT" and token_text(tokens[index + 7]) == "->" and token_kind(tokens[index + 8]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[index + 2])
      record_name_error(tokens[index + 4])
      record_name_error(tokens[index + 6])
      body, next = parse_function_body_block(tokens, index + 8)
      fn = func_expr(
        [token_text(tokens[index + 2]), token_text(tokens[index + 4]), token_text(tokens[index + 6])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      return assign_stmt(token_text(current), fn, token_line(current)), next
    if (
      token_kind(tokens[index + 2]) == "IDENT" and token_text(tokens[index + 3]) == "," and token_kind(tokens[index + 4]) == "IDENT" and token_text(tokens[index + 5]) == "," and token_kind(tokens[index + 6]) == "IDENT" and token_text(tokens[index + 7]) == "," and token_kind(tokens[index + 8]) == "IDENT" and token_text(tokens[index + 9]) == "->" and token_kind(tokens[index + 10]) == "NEWLINE"
    )
      record_name_error(current)
      record_name_error(tokens[index + 2])
      record_name_error(tokens[index + 4])
      record_name_error(tokens[index + 6])
      record_name_error(tokens[index + 8])
      body, next = parse_function_body_block(tokens, index + 10)
      fn = func_expr(
        [token_text(tokens[index + 2]), token_text(tokens[index + 4]), token_text(tokens[index + 6]), token_text(tokens[index + 8])],
        nil_expr(token_line(current)),
        token_line(current),
      )
      fn["body_stmts"] = body
      return assign_stmt(token_text(current), fn, token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(current) == "if"
    cond, after_cond = parse_expr(tokens, index + 1)
    after_cond = record_block_header_error(tokens, after_cond)
    then_body, after_then = parse_simple_block(tokens, after_cond)
    else_body = []
    next = after_then
    stmt = if_stmt(cond, then_body, [], token_line(current))
    while (
      token_kind(tokens[next]) == "IDENT" and token_text(tokens[next]) == "elseif"
    )
      else_cond, after_else_cond = parse_expr(tokens, next + 1)
      after_else_cond = record_block_header_error(tokens, after_else_cond)
      else_then, after_else_then = parse_simple_block(tokens, after_else_cond)
      if stmt["elseif_cond"] == nil
        stmt["elseif_cond"] = else_cond
        stmt["elseif_then"] = else_then
      push(stmt["elseif_conds"], else_cond)
      push(stmt["elseif_bodies"], else_then)
      next = after_else_then
    if (
      token_kind(tokens[next]) == "IDENT" and token_text(tokens[next]) == "else"
    )
      else_body, next = parse_simple_block(tokens, next + 1)
      stmt["else"] = else_body
    return stmt, next
  if token_kind(current) == "IDENT" and token_text(current) == "while"
    cond, after_cond = parse_expr(tokens, index + 1)
    after_cond = record_block_header_error(tokens, after_cond)
    body, next = parse_loop_body_block(tokens, after_cond)
    return while_stmt(cond, body, token_line(current)), next
  if token_kind(current) == "IDENT" and token_text(current) == "for"
    value_name = token_text(tokens[index + 1])
    record_name_error(tokens[index + 1])
    index_name = ""
    loop_kind = token_text(tokens[index + 2])
    iterable_start = index + 3
    if token_text(tokens[index + 2]) == ","
      index_name = token_text(tokens[index + 3])
      record_name_error(tokens[index + 3])
      loop_kind = token_text(tokens[index + 4])
      iterable_start = index + 5
    iterable, after_iterable = parse_expr(tokens, iterable_start)
    after_iterable = record_block_header_error(tokens, after_iterable)
    body, next = parse_loop_body_block(tokens, after_iterable)
    stmt = for_stmt(value_name, index_name, loop_kind, iterable)
    stmt["body"] = body
    return stmt, next
  return parse_simple_statement(tokens, index)

parse = tokens ->
  statements = []
  index = 0
  while token_kind(tokens[index]) != "EOF"
    if token_kind(tokens[index]) == "NEWLINE"
      index = index + 1
      continue
    stmt, next = parse_statement(tokens, index)
    push(statements, stmt)
    index = record_trailing_statement_error(tokens, index, next)
    if token_kind(tokens[index]) == "NEWLINE"
      index = index + 1
  program_node(statements)

remember = names, name ->
  if not has_name(names, name)
    push(names, name)

clone_names = names ->
  out = []
  for name in names
    push(out, name)
  out

clone_dict = dict ->
  out = {}
  for key, value of dict
    out[key] = value
  out

is_snake_name = name ->
  if len(name) == 0
    return false
  first = name[0]
  if not (is_lower(first) or first == "_")
    return false
  i = 0
  while i < len(name)
    char = name[i]
    if not (is_lower(char) or is_digit(char) or char == "_")
      return false
    i = i + 1
  true

is_screaming_name = name ->
  if len(name) == 0
    return false
  first = name[0]
  if not (is_upper(first) or first == "_")
    return false
  i = 0
  has_upper = false
  while i < len(name)
    char = name[i]
    if is_upper(char)
      has_upper = true
    if not (is_upper(char) or is_digit(char) or char == "_")
      return false
    i = i + 1
  has_upper

is_binding_name = name ->
  is_snake_name(name) or is_screaming_name(name)

is_pure_builtin_name = name ->
  if name == "len"
    return true
  if name == "has"
    return true
  if name == "keys"
    return true
  if name == "values"
    return true
  if name == "to_string"
    return true
  if name == "to_int"
    return true
  if name == "to_float"
    return true
  if name == "to_number"
    return true
  if name == "read_file"
    return true
  if name == "file_exists"
    return true
  if name == "args"
    return true
  if name == "env"
    return true
  if name == "error"
    return true
  if name == "pop"
    return true
  if name == "split"
    return true
  if name == "join"
    return true
  if name == "trim"
    return true
  if name == "replace"
    return true
  if name == "contains"
    return true
  if name == "starts_with"
    return true
  if name == "ends_with"
    return true
  if name == "map"
    return true
  if name == "filter"
    return true
  if name == "find"
    return true
  if name == "any"
    return true
  if name == "all"
    return true
  if name == "reduce"
    return true
  if name == "equal"
    return true
  if name == "read_line"
    return true
  false

check_name = errors, line, kind, name ->
  if kind == "variable"
    if not is_binding_name(name)
      push(errors, to_string(line) + ": invalid " + kind + " name: " + name)
    return nil
  if not is_snake_name(name) or name[0] == "_"
    push(errors, to_string(line) + ": invalid " + kind + " name: " + name)

expr_kind = kinds, expr ->
  if expr["kind"] == "ident"
    if has(kinds, expr["name"])
      return kinds[expr["name"]]
  if expr["kind"] == "array"
    return "array"
  if expr["kind"] == "dict"
    return "dict"
  if expr["kind"] == "func"
    return "func"
  "unknown"

checker_context = errors, names, kinds, constants ->
  { errors: errors, names: names, kinds: kinds, constants: constants }

clone_checker_context = ctx ->
  checker_context(
    ctx["errors"],
    clone_names(ctx["names"]),
    clone_dict(ctx["kinds"]),
    clone_dict(ctx["constants"]),
  )

predeclare_function_bindings = ctx, statements ->
  for stmt in statements
    if stmt["kind"] == "assign"
      if stmt["value"]["kind"] == "func"
        remember(ctx["names"], stmt["name"])
        ctx["kinds"][stmt["name"]] = "func"

check_expr = ctx, expr ->
  errors = ctx["errors"]
  names = ctx["names"]
  kinds = ctx["kinds"]
  constants = ctx["constants"]
  work = [expr]
  while len(work) > 0
    current = pop(work)
    if current["kind"] == "ident"
      if current["name"] == "super"
        names = names
      elseif current["name"] == "self"
        if not has(ctx, "in_class_method")
          push(
            errors,
            to_string(current["line"]) + ": self is only valid inside a class method",
          )
      else
        if not has_name(names, current["name"])
          push(
            errors,
            to_string(current["line"]) + ": undefined variable: " + current["name"],
          )
    if current["kind"] == "binary"
      push(work, current["left"])
      push(work, current["right"])
    if current["kind"] == "unary"
      push(work, current["expr"])
    if current["kind"] == "try"
      push(work, current["expr"])
    if current["kind"] == "array"
      for item in current["items"]
        push(work, item)
    if current["kind"] == "dict"
      seen_keys = []
      for entry in current["entries"]
        if not is_snake_name(entry["key"])
          push(
            errors,
            to_string(current["line"]) + ": invalid dictionary key: " + entry["key"],
          )
        if has_name(seen_keys, entry["key"])
          push(
            errors,
            to_string(current["line"]) + ": duplicate dictionary key: " + entry["key"],
          )
        remember(seen_keys, entry["key"])
        push(work, entry["value"])
    if current["kind"] == "index"
      push(work, current["target"])
      push(work, current["index"])
    if current["kind"] == "member"
      push(work, current["target"])
      target_kind = expr_kind(kinds, current["target"])
      if target_kind == "dict"
        push(
          errors,
          to_string(current["line"]) + ": cannot use . access on dictionary; use index access",
        )
      elseif target_kind == "array"
        push(
          errors,
          to_string(current["line"]) + ": cannot use . access on array",
        )
    if current["kind"] == "field"
      if not has(ctx, "in_method")
        push(
          errors,
          to_string(current["line"]) + ": @" + current["name"] + " is only valid inside an instance method",
        )
    if current["kind"] == "class_var"
      if not has(ctx, "in_class")
        push(
          errors,
          to_string(current["line"]) + ": @@" + current["name"] + " is only valid inside a class",
        )
    if current["kind"] == "call"
      push(work, current["callee"])
      for arg in current["args"]
        push(work, arg)
    if current["kind"] == "func"
      fn_names = clone_names(names)
      fn_kinds = clone_dict(kinds)
      fn_constants = clone_dict(constants)
      fn_ctx = checker_context(errors, fn_names, fn_kinds, fn_constants)
      if has(ctx, "in_method")
        fn_ctx["in_method"] = true
      if has(ctx, "in_class")
        fn_ctx["in_class"] = true
      if has(ctx, "in_class_method")
        fn_ctx["in_class_method"] = true
      param_names = []
      for param in current["params"]
        if has_name(param_names, param)
          push(
            errors,
            to_string(current["line"]) + ": duplicate function parameter: " + param,
          )
        remember(param_names, param)
        check_name(errors, current["line"], "variable", param)
        remember(fn_names, param)
        fn_kinds[param] = "unknown"
      if len(current["body_stmts"]) > 0
        predeclare_function_bindings(fn_ctx, current["body_stmts"])
        for child in current["body_stmts"]
          check_stmt(fn_ctx, child)
      else
        check_expr(fn_ctx, current["body"])

check_simple_stmt = ctx, stmt ->
  errors = ctx["errors"]
  names = ctx["names"]
  kinds = ctx["kinds"]
  constants = ctx["constants"]
  if stmt["kind"] == "import"
    check_name(errors, stmt["line"], "module", stmt["name"])
    remember(names, stmt["name"])
    remember(checker_modules, stmt["name"])
    kinds[stmt["name"]] = "module"
  if stmt["kind"] == "module"
    check_name(errors, stmt["line"], "module", stmt["name"])
    remember(names, stmt["name"])
    remember(checker_modules, stmt["name"])
    kinds[stmt["name"]] = "module"
    member_names = []
    for member in stmt["members"]
      check_name(errors, member["line"], "module member", member["name"])
      if has_name(member_names, member["name"])
        push(
          errors,
          to_string(member["line"]) + ": duplicate module member: " + member["name"],
        )
      remember(member_names, member["name"])
      check_expr(ctx, member["value"])
    for class_value in stmt["classes"]
      if has_name(member_names, class_value["name"])
        push(
          errors,
          to_string(class_value["line"]) + ": duplicate module member: " + class_value["name"],
        )
      remember(member_names, class_value["name"])
      for method in class_value["methods"]
        method_ctx = checker_context(errors, names, kinds, constants)
        method_ctx["in_class"] = true
        if not method["class"]
          method_ctx["in_method"] = true
        else
          method_ctx["in_class_method"] = true
        check_expr(method_ctx, method["value"])
  if stmt["kind"] == "class"
    remember(names, stmt["name"])
    kinds[stmt["name"]] = "class"
    for method in stmt["methods"]
      method_ctx = checker_context(errors, names, kinds, constants)
      method_ctx["in_class"] = true
      if not method["class"]
        method_ctx["in_method"] = true
      else
        method_ctx["in_class_method"] = true
      check_expr(method_ctx, method["value"])
  if stmt["kind"] == "assign"
    check_name(errors, stmt["line"], "variable", stmt["name"])
    check_expr(ctx, stmt["value"])
    if has(constants, stmt["name"]) and constants[stmt["name"]]
      push(
        errors,
        to_string(stmt["line"]) + ": cannot reassign constant: " + stmt["name"],
      )
    remember(names, stmt["name"])
    kinds[stmt["name"]] = expr_kind(kinds, stmt["value"])
    if is_screaming_name(stmt["name"])
      constants[stmt["name"]] = true
  if stmt["kind"] == "multi_assign"
    check_expr(ctx, stmt["value"])
    for name in stmt["names"]
      check_name(errors, stmt["line"], "variable", name)
      if has(constants, name) and constants[name]
        push(
          errors,
          to_string(stmt["line"]) + ": cannot reassign constant: " + name,
        )
      remember(names, name)
      kinds[name] = "unknown"
      if is_screaming_name(name)
        constants[name] = true
  if stmt["kind"] == "index_assign"
    check_expr(ctx, stmt["target"])
    check_expr(ctx, stmt["index"])
    check_expr(ctx, stmt["value"])
  if stmt["kind"] == "member_assign"
    check_expr(ctx, stmt["target"])
    check_expr(ctx, stmt["value"])
  if stmt["kind"] == "field_assign"
    if not has(ctx, "in_method")
      push(
        errors,
        to_string(stmt["line"]) + ": @" + stmt["name"] + " is only valid inside an instance method",
      )
    check_expr(ctx, stmt["value"])
  if stmt["kind"] == "class_var_assign"
    if not has(ctx, "in_class")
      push(
        errors,
        to_string(stmt["line"]) + ": @@" + stmt["name"] + " is only valid inside a class",
      )
    check_expr(ctx, stmt["value"])
  if stmt["kind"] == "return"
    check_expr(ctx, stmt["value"])
  if stmt["kind"] == "expr_stmt"
    check_expr(ctx, stmt["expr"])

check_stmt = ctx, stmt ->
  errors = ctx["errors"]
  names = ctx["names"]
  kinds = ctx["kinds"]
  constants = ctx["constants"]
  check_simple_stmt(ctx, stmt)
  if stmt["kind"] == "if"
    check_expr(ctx, stmt["cond"])
    then_ctx = clone_checker_context(ctx)
    predeclare_function_bindings(then_ctx, stmt["then"])
    for child in stmt["then"]
      check_stmt(then_ctx, child)
    elseif_index = 0
    while elseif_index < len(stmt["elseif_conds"])
      check_expr(ctx, stmt["elseif_conds"][elseif_index])
      elseif_ctx = clone_checker_context(ctx)
      predeclare_function_bindings(
        elseif_ctx,
        stmt["elseif_bodies"][elseif_index],
      )
      for child in stmt["elseif_bodies"][elseif_index]
        check_stmt(elseif_ctx, child)
      elseif_index = elseif_index + 1
    else_ctx = clone_checker_context(ctx)
    predeclare_function_bindings(else_ctx, stmt["else"])
    for child in stmt["else"]
      check_stmt(else_ctx, child)
  if stmt["kind"] == "while"
    check_expr(ctx, stmt["cond"])
    body_ctx = clone_checker_context(ctx)
    predeclare_function_bindings(body_ctx, stmt["body"])
    for child in stmt["body"]
      check_stmt(body_ctx, child)
  if stmt["kind"] == "for"
    check_expr(ctx, stmt["iterable"])
    body_ctx = clone_checker_context(ctx)
    check_name(errors, stmt["line"], "variable", stmt["value_name"])
    remember(body_ctx["names"], stmt["value_name"])
    body_ctx["kinds"][stmt["value_name"]] = "unknown"
    if stmt["index_name"] != ""
      check_name(errors, stmt["line"], "variable", stmt["index_name"])
      remember(body_ctx["names"], stmt["index_name"])
      body_ctx["kinds"][stmt["index_name"]] = "unknown"
    predeclare_function_bindings(body_ctx, stmt["body"])
    for child in stmt["body"]
      check_stmt(body_ctx, child)

check = program ->
  names = []
  kinds = {}
  constants = {}
  errors = []
  remember(names, "print")
  remember(names, "len")
  remember(names, "push")
  remember(names, "pop")
  remember(names, "delete")
  remember(names, "has")
  remember(names, "keys")
  remember(names, "values")
  remember(names, "to_string")
  remember(names, "to_int")
  remember(names, "to_float")
  remember(names, "to_number")
  remember(names, "read_file")
  remember(names, "write_file")
  remember(names, "file_exists")
  remember(names, "args")
  remember(names, "env")
  remember(names, "error")
  remember(names, "panic")
  remember(names, "exit")
  remember(names, "split")
  remember(names, "join")
  remember(names, "trim")
  remember(names, "replace")
  remember(names, "contains")
  remember(names, "starts_with")
  remember(names, "ends_with")
  remember(names, "map")
  remember(names, "filter")
  remember(names, "find")
  remember(names, "any")
  remember(names, "all")
  remember(names, "reduce")
  remember(names, "equal")
  remember(names, "read_line")
  remember(names, "assert")
  remember(names, "assert_equal")
  ctx = checker_context(errors, names, kinds, constants)
  predeclare_function_bindings(ctx, program["statements"])
  for stmt in program["statements"]
    check_stmt(ctx, stmt)
  errors

c_string = text ->
  out = "\""
  i = 0
  while i < len(text)
    char = text[i]
    if char == "\""
      out = out + "\\\""
    elseif char == "\\"
      out = out + "\\\\"
    else
      if char == "\n"
        out = out + "\\n"
      else
        out = out + char
    i = i + 1
  out + "\""

c_name = name -> "tya_user_" + name

c_func_name = name -> "tya_fn_" + name
emitter_functions = []
emitter_classes = []
emitter_anon_functions = []
emitter_source_path = ""
register_anon_expr = expr ->
  if expr["kind"] == "func"
    if not has(expr, "anon_name")
      name = "__anon" + to_string(len(emitter_anon_functions))
      expr["anon_name"] = name
      push(emitter_anon_functions, expr)
  if expr["kind"] == "binary"
    register_anon_expr(expr["left"])
    register_anon_expr(expr["right"])
  if expr["kind"] == "unary" or expr["kind"] == "try"
    register_anon_expr(expr["expr"])
  if expr["kind"] == "array"
    for item in expr["items"]
      register_anon_expr(item)
  if expr["kind"] == "dict"
    for entry in expr["entries"]
      register_anon_expr(entry["value"])
  if expr["kind"] == "index"
    register_anon_expr(expr["target"])
    register_anon_expr(expr["index"])
  if expr["kind"] == "member"
    register_anon_expr(expr["target"])
  if expr["kind"] == "field"
    return nil
  if expr["kind"] == "call"
    register_anon_expr(expr["callee"])
    for arg in expr["args"]
      register_anon_expr(arg)

register_anon_stmt = stmt ->
  if stmt["kind"] == "assign"
    if stmt["value"]["kind"] != "func"
      register_anon_expr(stmt["value"])
  if stmt["kind"] == "multi_assign"
    register_anon_expr(stmt["value"])
  if stmt["kind"] == "index_assign"
    register_anon_expr(stmt["target"])
    register_anon_expr(stmt["index"])
    register_anon_expr(stmt["value"])
  if stmt["kind"] == "member_assign"
    register_anon_expr(stmt["target"])
    register_anon_expr(stmt["value"])
  if stmt["kind"] == "field_assign"
    register_anon_expr(stmt["value"])
  if stmt["kind"] == "return"
    register_anon_expr(stmt["value"])
  if stmt["kind"] == "expr_stmt"
    register_anon_expr(stmt["expr"])
  if stmt["kind"] == "module"
    for member in stmt["members"]
      if member["value"]["kind"] != "func"
        register_anon_expr(member["value"])
    for class_value in stmt["classes"]
      for method in class_value["methods"]
        register_anon_expr(method["value"])
  if stmt["kind"] == "class"
    for method in stmt["methods"]
      register_anon_expr(method["value"])
  if stmt["kind"] == "if"
    register_anon_expr(stmt["cond"])
    for child in stmt["then"]
      register_anon_stmt(child)
    for child in stmt["else"]
      register_anon_stmt(child)
    elseif_index = 0
    while elseif_index < len(stmt["elseif_conds"])
      register_anon_expr(stmt["elseif_conds"][elseif_index])
      for child in stmt["elseif_bodies"][elseif_index]
        register_anon_stmt(child)
      elseif_index = elseif_index + 1
  if stmt["kind"] == "while"
    register_anon_expr(stmt["cond"])
    for child in stmt["body"]
      register_anon_stmt(child)
  if stmt["kind"] == "for"
    register_anon_expr(stmt["iterable"])
    for child in stmt["body"]
      register_anon_stmt(child)

emit_direct_call = name, args ->
  parts = []
  for arg in args
    push(parts, emit_nested(arg))
  while len(parts) < 4
    push(parts, "tya_nil()")
  c_func_name(name) + "(tya_nil(), " + parts[0] + ", " + parts[1] + ", " + parts[2] + ", " + parts[3] + ")"

emit_string_value = text ->
  parts = []
  literal = ""
  i = 0
  while i < len(text)
    char = text[i]
    if char == "{{"
      if i + 1 < len(text) and text[i + 1] == "{{"
        literal = literal + "{{"
        i = i + 2
      else
        name = ""
        j = i + 1
        while j < len(text) and text[j] != "}}"
          name = name + text[j]
          j = j + 1
        if j < len(text) and text[j] == "}}" and name != ""
          if literal != ""
            push(parts, "tya_string(" + c_string(literal) + ")")
            literal = ""
          if len(name) > 1 and name[0] == "@" and name[1] == "@"
            field_name = ""
            field_index = 2
            while field_index < len(name)
              field_name = field_name + name[field_index]
              field_index = field_index + 1
            push(
              parts,
              "tya_to_string(tya_member(" + emitter_state["class_ref"] + ", " + c_string(field_name) + "))",
            )
          elseif name == "super()"
            push(
              parts,
              "tya_to_string(" + c_func_name(emitter_state["super_class"] + "_" + emitter_state["method_name"]) + "(__this, tya_nil(), tya_nil(), tya_nil(), tya_nil()))",
            )
          else
            if len(name) > 0 and name[0] == "@"
              field_name = ""
              field_index = 1
              while field_index < len(name)
                field_name = field_name + name[field_index]
                field_index = field_index + 1
              push(
                parts,
                "tya_to_string(tya_member(__this, " + c_string("@" + field_name) + "))",
              )
            else
              push(parts, "tya_to_string(" + c_name(name) + ")")
          i = j + 1
        else
          literal = literal + char
          i = i + 1
    elseif char == "}}" and i + 1 < len(text) and text[i + 1] == "}}"
      literal = literal + "}}"
      i = i + 2
    else
      literal = literal + char
      i = i + 1
  if literal != ""
    push(parts, "tya_string(" + c_string(literal) + ")")
  if len(parts) == 0
    return "tya_string(\"\")"
  expr = parts[0]
  index = 1
  while index < len(parts)
    expr = "tya_add(" + expr + ", " + parts[index] + ")"
    index = index + 1
  expr

emit_atom = expr ->
  if expr["kind"] == "ident"
    if expr["name"] == "self"
      return "__this"
    if has_name(emitter_classes, expr["name"])
      return c_name(expr["name"])
    if has_name(emitter_functions, expr["name"])
      return "tya_function(" + c_func_name(expr["name"]) + ")"
    return c_name(expr["name"])
  if expr["kind"] == "int"
    return "tya_number(" + to_string(expr["value"]) + ")"
  if expr["kind"] == "float"
    return "tya_number(" + to_string(expr["value"]) + ")"
  if expr["kind"] == "string"
    return emit_string_value(expr["value"])
  if expr["kind"] == "bool"
    if expr["value"]
      return "tya_bool(true)"
    return "tya_bool(false)"
  if expr["kind"] == "nil"
    return "tya_nil()"
  if expr["kind"] == "func"
    return "tya_function(" + c_func_name(expr["anon_name"]) + ")"
  if expr["kind"] == "field"
    return "tya_member(__this, " + c_string("@" + expr["name"]) + ")"
  if expr["kind"] == "class_var"
    return "tya_member(" + emitter_state["class_ref"] + ", " + c_string(expr["name"]) + ")"
  if expr["kind"] == "member"
    return "tya_member(" + emit_atom(expr["target"]) + ", " + c_string(expr["name"]) + ")"
  "tya_nil()"

emit_nested = expr ->
  if expr["kind"] == "binary" or expr["kind"] == "unary"
    return emit_inner_expr(expr)
  if expr["kind"] == "member"
    return "tya_member(" + emit_nested(expr["target"]) + ", " + c_string(expr["name"]) + ")"
  if expr["kind"] == "field"
    return "tya_member(__this, " + c_string("@" + expr["name"]) + ")"
  if expr["kind"] == "class_var"
    return "tya_member(" + emitter_state["class_ref"] + ", " + c_string(expr["name"]) + ")"
  if expr["kind"] == "call"
    if expr["callee"]["kind"] == "ident"
      name = expr["callee"]["name"]
      if name == "super"
        parent_name = emitter_state["super_class"]
        method_name = emitter_state["method_name"]
        parts = []
        for arg in expr["args"]
          push(parts, emit_expr(arg))
        while len(parts) < 4
          push(parts, "tya_nil()")
        return c_func_name(parent_name + "_" + method_name) + "(__this, " + parts[0] + ", " + parts[1] + ", " + parts[2] + ", " + parts[3] + ")"
      if has_name(emitter_functions, name)
        return emit_direct_call(name, expr["args"])
      if name == "len"
        return "tya_len(" + emit_nested(expr["args"][0]) + ")"
      if name == "keys"
        return "tya_keys(" + emit_nested(expr["args"][0]) + ")"
      if name == "values"
        return "tya_values(" + emit_nested(expr["args"][0]) + ")"
      if name == "error"
        return "tya_error(" + emit_nested(expr["args"][0]) + ")"
      if name == "trim"
        return "tya_trim(" + emit_nested(expr["args"][0]) + ")"
      if name == "split"
        return "tya_split(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "join"
        return "tya_join(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "map"
        return "tya_map(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "filter"
        return "tya_filter(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "find"
        return "tya_find(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "any"
        return "tya_any(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "all"
        return "tya_all(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "reduce"
        return "tya_reduce(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ", " + emit_nested(expr["args"][2]) + ")"
      if name == "equal"
        return "tya_deep_equal(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "read_line"
        return "tya_read_line()"
      if is_pure_builtin_name(name)
        return emit_scalar(expr)
    if len(expr["args"]) == 0
      return "tya_call1(" + emit_nested(expr["callee"]) + ", tya_nil())"
    if len(expr["args"]) == 2
      return "tya_call2(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
    if len(expr["args"]) == 3
      return "tya_call3(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ", " + emit_nested(expr["args"][2]) + ")"
    if len(expr["args"]) == 4
      return "tya_call4(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ", " + emit_nested(expr["args"][2]) + ", " + emit_nested(expr["args"][3]) + ")"
    return "tya_call1(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ")"
  return emit_scalar(expr)

emit_scalar = expr ->
  if expr["kind"] == "ident"
    if expr["name"] == "self"
      return "__this"
    if has_name(emitter_classes, expr["name"])
      return c_name(expr["name"])
    if has_name(emitter_functions, expr["name"])
      return "tya_function(" + c_func_name(expr["name"]) + ")"
    return c_name(expr["name"])
  if expr["kind"] == "int"
    return "tya_number(" + to_string(expr["value"]) + ")"
  if expr["kind"] == "float"
    return "tya_number(" + to_string(expr["value"]) + ")"
  if expr["kind"] == "string"
    return emit_string_value(expr["value"])
  if expr["kind"] == "bool"
    if expr["value"]
      return "tya_bool(true)"
    return "tya_bool(false)"
  if expr["kind"] == "nil"
    return "tya_nil()"
  if expr["kind"] == "func"
    return "tya_function(" + c_func_name(expr["anon_name"]) + ")"
  if expr["kind"] == "field"
    return "tya_member(__this, " + c_string("@" + expr["name"]) + ")"
  if expr["kind"] == "class_var"
    return "tya_member(" + emitter_state["class_ref"] + ", " + c_string(expr["name"]) + ")"
  if expr["kind"] == "array"
    parts = []
    for item in expr["items"]
      push(parts, emit_nested(item))
    if len(parts) == 0
      return "tya_array(0, 0)"
    return "tya_array((TyaValue[]){{" + join(parts, ", ") + "}}, " + to_string(len(parts)) + ")"
  if expr["kind"] == "dict"
    parts = []
    for entry in expr["entries"]
      push(
        parts,
        "{{" + c_string(entry["key"]) + ", " + emit_nested(entry["value"]) + "}}",
      )
    if len(parts) == 0
      return "tya_dict(0, 0)"
    return "tya_dict((TyaDictEntry[]){{" + join(parts, ", ") + "}}, " + to_string(len(parts)) + ")"
  if expr["kind"] == "index"
    return "tya_index(" + emit_nested(expr["target"]) + ", " + emit_nested(expr["index"]) + ")"
  if expr["kind"] == "member"
    return "tya_member(" + emit_nested(expr["target"]) + ", " + c_string(expr["name"]) + ")"
  if expr["kind"] == "call"
    if expr["callee"]["kind"] == "ident"
      name = expr["callee"]["name"]
      if name == "super"
        parent_name = emitter_state["super_class"]
        method_name = emitter_state["method_name"]
        parts = []
        for arg in expr["args"]
          push(parts, emit_expr(arg))
        while len(parts) < 4
          push(parts, "tya_nil()")
        return c_func_name(parent_name + "_" + method_name) + "(__this, " + parts[0] + ", " + parts[1] + ", " + parts[2] + ", " + parts[3] + ")"
      if has_name(emitter_functions, name)
        return emit_direct_call(name, expr["args"])
      if name == "len"
        return "tya_len(" + emit_nested(expr["args"][0]) + ")"
      if name == "has"
        return "tya_has(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "keys"
        return "tya_keys(" + emit_nested(expr["args"][0]) + ")"
      if name == "values"
        return "tya_values(" + emit_nested(expr["args"][0]) + ")"
      if name == "to_string"
        return "tya_to_string(" + emit_nested(expr["args"][0]) + ")"
      if name == "to_int"
        return "tya_to_int(" + emit_nested(expr["args"][0]) + ")"
      if name == "to_float"
        return "tya_to_float(" + emit_nested(expr["args"][0]) + ")"
      if name == "to_number"
        return "tya_to_number(" + emit_nested(expr["args"][0]) + ")"
      if name == "read_file"
        return "tya_read_file(" + emit_nested(expr["args"][0]) + ")"
      if name == "file_exists"
        return "tya_file_exists(" + emit_nested(expr["args"][0]) + ")"
      if name == "args"
        return "tya_args(argc, argv)"
      if name == "env"
        return "tya_env(" + emit_nested(expr["args"][0]) + ")"
      if name == "error"
        return "tya_error(" + emit_nested(expr["args"][0]) + ")"
      if name == "pop"
        return "tya_pop(" + emit_nested(expr["args"][0]) + ")"
      if name == "split"
        return "tya_split(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "join"
        return "tya_join(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "trim"
        return "tya_trim(" + emit_nested(expr["args"][0]) + ")"
      if name == "replace"
        return "tya_replace(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ", " + emit_nested(expr["args"][2]) + ")"
      if name == "contains"
        return "tya_contains(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "starts_with"
        return "tya_starts_with(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "ends_with"
        return "tya_ends_with(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "map"
        return "tya_map(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "filter"
        return "tya_filter(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "find"
        return "tya_find(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "any"
        return "tya_any(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "all"
        return "tya_all(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "reduce"
        return "tya_reduce(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ", " + emit_nested(expr["args"][2]) + ")"
      if name == "equal"
        return "tya_deep_equal(" + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
      if name == "read_line"
        return "tya_read_line()"
    if len(expr["args"]) == 0
      return "tya_call1(" + emit_nested(expr["callee"]) + ", tya_nil())"
    if len(expr["args"]) == 2
      return "tya_call2(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ")"
    if len(expr["args"]) == 3
      return "tya_call3(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ", " + emit_nested(expr["args"][2]) + ")"
    if len(expr["args"]) == 4
      return "tya_call4(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ", " + emit_nested(expr["args"][1]) + ", " + emit_nested(expr["args"][2]) + ", " + emit_nested(expr["args"][3]) + ")"
    return "tya_call1(" + emit_nested(expr["callee"]) + ", " + emit_nested(expr["args"][0]) + ")"
  "tya_nil()"

emit_inner_expr = expr ->
  if expr["kind"] == "unary"
    if expr["op"] == "not"
      return "tya_bool(!tya_truthy(" + emit_inner_expr(expr["expr"]) + "))"
    if expr["op"] == "-"
      return "tya_number(-" + emit_inner_expr(expr["expr"]) + ".number)"
  if expr["kind"] != "binary"
    return emit_scalar(expr)
  if expr["kind"] == "binary"
    if expr["op"] == "+"
      return "tya_add(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + ")"
    if expr["op"] == "-"
      return "tya_number(" + emit_inner_expr(expr["left"]) + ".number - " + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "*"
      return "tya_number(" + emit_inner_expr(expr["left"]) + ".number * " + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "/"
      return "tya_number(" + emit_inner_expr(expr["left"]) + ".number / " + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "%"
      return "tya_number((int)" + emit_inner_expr(expr["left"]) + ".number % (int)" + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "and"
      return "tya_and(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + ")"
    if expr["op"] == "or"
      return "tya_or(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + ")"
    if expr["op"] == "=="
      return "tya_bool(tya_equal(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + "))"
    if expr["op"] == "!="
      return "tya_bool(!tya_equal(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + "))"
    if (
      expr["op"] == "<" or expr["op"] == "<=" or expr["op"] == ">" or expr["op"] == ">="
    )
      return "tya_bool(" + emit_inner_expr(expr["left"]) + ".number " + expr["op"] + " " + emit_inner_expr(expr["right"]) + ".number)"
  "tya_nil()"

emit_expr = expr ->
  if expr["kind"] == "try"
    return emit_expr(expr["expr"])
  if expr["kind"] == "unary"
    if expr["op"] == "not"
      return "tya_bool(!tya_truthy(" + emit_inner_expr(expr["expr"]) + "))"
    if expr["op"] == "-"
      return "tya_number(-" + emit_inner_expr(expr["expr"]) + ".number)"
  if expr["kind"] != "binary"
    return emit_scalar(expr)
  if expr["kind"] == "binary"
    if expr["op"] == "+"
      return "tya_add(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + ")"
    if expr["op"] == "-"
      return "tya_number(" + emit_inner_expr(expr["left"]) + ".number - " + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "*"
      return "tya_number(" + emit_inner_expr(expr["left"]) + ".number * " + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "/"
      return "tya_number(" + emit_inner_expr(expr["left"]) + ".number / " + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "%"
      return "tya_number((int)" + emit_inner_expr(expr["left"]) + ".number % (int)" + emit_inner_expr(expr["right"]) + ".number)"
    if expr["op"] == "and"
      return "tya_and(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + ")"
    if expr["op"] == "or"
      return "tya_or(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + ")"
    if expr["op"] == "=="
      return "tya_bool(tya_equal(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + "))"
    if expr["op"] == "!="
      return "tya_bool(!tya_equal(" + emit_inner_expr(expr["left"]) + ", " + emit_inner_expr(expr["right"]) + "))"
    if (
      expr["op"] == "<" or expr["op"] == "<=" or expr["op"] == ">" or expr["op"] == ">="
    )
      return "tya_bool(" + emit_inner_expr(expr["left"]) + ".number " + expr["op"] + " " + emit_inner_expr(expr["right"]) + ".number)"
  "tya_nil()"

emit_simple_stmt = lines, names, stmt ->
  if stmt["kind"] == "return"
    push(lines, "  return " + emit_expr(stmt["value"]) + ";")
  if stmt["kind"] == "break"
    push(lines, "  break;")
  if stmt["kind"] == "continue"
    push(lines, "  continue;")
  if stmt["kind"] == "index_assign"
    push(
      lines,
      "  tya_set_index(" + emit_expr(stmt["target"]) + ", " + emit_expr(stmt["index"]) + ", " + emit_expr(stmt["value"]) + ");",
    )
  if stmt["kind"] == "member_assign"
    push(
      lines,
      "  tya_set_member(" + emit_expr(stmt["target"]) + ", " + c_string(stmt["name"]) + ", " + emit_expr(stmt["value"]) + ");",
    )
  if stmt["kind"] == "field_assign"
    tmp_name = "__field" + to_string(len(lines))
    push(
      lines,
      "  TyaValue " + tmp_name + " = " + emit_expr(stmt["value"]) + ";",
    )
    push(
      lines,
      "  tya_set_member(__this, " + c_string("@" + stmt["name"]) + ", " + tmp_name + ");",
    )
    push(
      lines,
      "  tya_set_member(__this, " + c_string(stmt["name"]) + ", " + tmp_name + ");",
    )
  if stmt["kind"] == "class_var_assign"
    push(
      lines,
      "  tya_set_member(" + emitter_state["class_ref"] + ", " + c_string(stmt["name"]) + ", " + emit_expr(stmt["value"]) + ");",
    )
  if stmt["kind"] == "multi_assign"
    tuple_name = "__tuple" + to_string(len(lines))
    push(
      lines,
      "  TyaValue " + tuple_name + " = " + emit_expr(stmt["value"]) + ";",
    )
    name_index = 0
    for name in stmt["names"]
      item = "tya_index("
        + tuple_name
        + ", tya_number("
        + to_string(name_index)
        + "))"
      if has_name(names, name)
        push(lines, "  " + c_name(name) + " = " + item + ";")
      else
        push(names, name)
        push(lines, "  TyaValue " + c_name(name) + " = " + item + ";")
      name_index = name_index + 1
  if stmt["kind"] == "assign"
    if stmt["value"]["kind"] == "try"
      tuple_name = "__try" + to_string(len(lines))
      err_name = "__tryErr" + to_string(len(lines))
      push(
        lines,
        "  TyaValue " + tuple_name + " = " + emit_expr(stmt["value"]["expr"]) + ";",
      )
      push(
        lines,
        "  TyaValue " + err_name + " = tya_index(" + tuple_name + ", tya_number(1));",
      )
      push(lines, "  if (tya_truthy(" + err_name + ")) {{")
      push(
        lines,
        "    return tya_array((TyaValue[]){{tya_nil(), " + err_name + "}}, 2);",
      )
      push(lines, "  }}")
      item = "tya_index(" + tuple_name + ", tya_number(0))"
      if has_name(names, stmt["name"])
        push(lines, "  " + c_name(stmt["name"]) + " = " + item + ";")
      else
        push(names, stmt["name"])
        push(lines, "  TyaValue " + c_name(stmt["name"]) + " = " + item + ";")
    else
      value = emit_expr(stmt["value"])
      if stmt["value"]["kind"] == "func"
        value = "tya_function(" + c_func_name(stmt["name"]) + ")"
      if has_name(names, stmt["name"])
        push(lines, "  " + c_name(stmt["name"]) + " = " + value + ";")
      else
        push(names, stmt["name"])
        push(lines, "  TyaValue " + c_name(stmt["name"]) + " = " + value + ";")
  if stmt["kind"] == "expr_stmt"
    expr = stmt["expr"]
    if (
      expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "print"
    )
      push(lines, "  tya_print(" + emit_expr(expr["args"][0]) + ");")
    elseif (
      expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "push"
    )
      push(
        lines,
        "  tya_push(" + emit_expr(expr["args"][0]) + ", " + emit_expr(expr["args"][1]) + ");",
      )
    else
      if (
        expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "delete"
      )
        push(
          lines,
          "  tya_delete(" + emit_expr(expr["args"][0]) + ", " + emit_expr(expr["args"][1]) + ");",
        )
      elseif (
        expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "write_file"
      )
        push(
          lines,
          "  tya_write_file(" + emit_expr(expr["args"][0]) + ", " + emit_expr(expr["args"][1]) + ");",
        )
      else
        if (
          expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "panic"
        )
          push(lines, "  tya_panic(" + emit_expr(expr["args"][0]) + ");")
        elseif (
          expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "exit"
        )
          push(lines, "  tya_exit(" + emit_expr(expr["args"][0]) + ");")
        else
          if (
            expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "assert"
          )
            push(
              lines,
              "  tya_assert(" + emit_expr(expr["args"][0]) + ", " + c_string(emitter_source_path) + ", " + to_string(stmt["line"]) + ");",
            )
          elseif (
            expr["kind"] == "call" and expr["callee"]["kind"] == "ident" and expr["callee"]["name"] == "assert_equal"
          )
            push(
              lines,
              "  tya_assert_equal(" + emit_expr(expr["args"][0]) + ", " + emit_expr(expr["args"][1]) + ", " + c_string(emitter_source_path) + ", " + to_string(stmt["line"]) + ");",
            )
          else
            push(lines, "  (void)" + emit_expr(expr) + ";")

emit_stmt = lines, names, stmt ->
  emit_simple_stmt(lines, names, stmt)
  if stmt["kind"] == "import"
    push(lines, "  /* import resolved by compiler */")
  if stmt["kind"] == "module"
    entries = []
    for member in stmt["members"]
      if member["value"]["kind"] != "func"
        push(
          entries,
          "{{" + c_string(member["name"]) + ", " + emit_expr(member["value"]) + "}}",
        )
    prefix = "TyaValue " + c_name(stmt["name"]) + " = "
    if has_name(names, stmt["name"])
      prefix = c_name(stmt["name"]) + " = "
    else
      push(names, stmt["name"])
    if len(entries) == 0
      push(lines, "  " + prefix + "tya_dict(0, 0);")
    else
      push(
        lines,
        "  " + prefix + "tya_dict((TyaDictEntry[]){{" + join(entries, ", ") + "}}, " + to_string(len(entries)) + ");",
      )
    for member in stmt["members"]
      if member["value"]["kind"] == "func"
        push(
          lines,
          "  tya_set_member(" + c_name(stmt["name"]) + ", " + c_string(member["name"]) + ", tya_function(" + c_func_name(stmt["name"] + "_" + member["name"]) + "));",
        )
    for class_value in stmt["classes"]
      class_parent = "tya_nil()"
      if class_value["parent"] != ""
        class_parent = c_name(stmt["name"] + "_" + class_value["parent"])
      push(
        lines,
        "  " + c_name(stmt["name"] + "_" + class_value["name"]) + " = tya_class(" + c_func_name(stmt["name"] + "_" + class_value["name"]) + ", " + c_string(class_value["name"]) + ", " + class_parent + ");",
      )
      push(
        lines,
        "  tya_set_member(" + c_name(stmt["name"]) + ", " + c_string(class_value["name"]) + ", " + c_name(stmt["name"] + "_" + class_value["name"]) + ");",
      )
  if stmt["kind"] == "class"
    class_parent = "tya_nil()"
    if stmt["parent"] != ""
      class_parent = c_name(stmt["parent"])
    if has_name(names, stmt["name"])
      push(
        lines,
        "  " + c_name(stmt["name"]) + " = tya_class(" + c_func_name(stmt["name"]) + ", " + c_string(stmt["name"]) + ", " + class_parent + ");",
      )
    else
      push(names, stmt["name"])
      push(
        lines,
        "  " + c_name(stmt["name"]) + " = tya_class(" + c_func_name(stmt["name"]) + ", " + c_string(stmt["name"]) + ", " + class_parent + ");",
      )
    saved_class_ref = emitter_state["class_ref"]
    emitter_state["class_ref"] = c_name(stmt["name"])
    for variable in stmt["vars"]
      push(
        lines,
        "  tya_set_member(" + c_name(stmt["name"]) + ", " + c_string(variable["name"]) + ", " + emit_expr(variable["value"]) + ");",
      )
    for method in stmt["methods"]
      if method["class"]
        push(
          lines,
          "  tya_set_member(" + c_name(stmt["name"]) + ", " + c_string(method["name"]) + ", tya_bind_method(" + c_name(stmt["name"]) + ", " + c_func_name(stmt["name"] + "_" + method["name"]) + "));",
        )
    emitter_state["class_ref"] = saved_class_ref
  if stmt["kind"] == "if"
    push(lines, "  if (tya_truthy(" + emit_expr(stmt["cond"]) + ")) {{")
    for child in stmt["then"]
      emit_stmt(lines, names, child)
    elseif_index = 0
    while elseif_index < len(stmt["elseif_conds"])
      push(
        lines,
        "  }} else if (tya_truthy(" + emit_expr(stmt["elseif_conds"][elseif_index]) + ")) {{",
      )
      for child in stmt["elseif_bodies"][elseif_index]
        emit_stmt(lines, names, child)
      elseif_index = elseif_index + 1
    if len(stmt["else"]) > 0
      push(lines, "  }} else {{")
      for child in stmt["else"]
        emit_stmt(lines, names, child)
    push(lines, "  }}")
  if stmt["kind"] == "while"
    push(lines, "  while (tya_truthy(" + emit_expr(stmt["cond"]) + ")) {{")
    for child in stmt["body"]
      emit_stmt(lines, names, child)
    push(lines, "  }}")
  if stmt["kind"] == "for"
    iter_name = "__iter" + to_string(len(lines))
    index_name = "__i" + to_string(len(lines))
    push(
      lines,
      "  TyaValue " + iter_name + " = " + emit_expr(stmt["iterable"]) + ";",
    )
    push(
      lines,
      "  for (int " + index_name + " = 0; " + index_name + " < (int)tya_len(" + iter_name + ").number; " + index_name + "++) {{",
    )
    item_expr = "tya_index(" + iter_name + ", tya_number(" + index_name + "))"
    if stmt["loop_kind"] == "of"
      item_expr = "tya_dict_key_at("
        + iter_name
        + ", tya_number("
        + index_name
        + "))"
    push(
      lines,
      "  TyaValue " + c_name(stmt["value_name"]) + " = " + item_expr + ";",
    )
    if stmt["index_name"] != ""
      index_value_expr = "tya_number(" + index_name + ")"
      if stmt["loop_kind"] == "of"
        index_value_expr = "tya_dict_value_at("
          + iter_name
          + ", tya_number("
          + index_name
          + "))"
      push(
        lines,
        "  TyaValue " + c_name(stmt["index_name"]) + " = " + index_value_expr + ";",
      )
    for child in stmt["body"]
      emit_stmt(lines, names, child)
    push(lines, "  }}")

collect_assigned_names = statements ->
  names = []
  work = []
  for stmt in statements
    push(work, stmt)
  while len(work) > 0
    stmt = pop(work)
    if stmt["kind"] == "assign"
      remember(names, stmt["name"])
    if stmt["kind"] == "multi_assign"
      for name in stmt["names"]
        remember(names, name)
    if stmt["kind"] == "if"
      for child in stmt["then"]
        push(work, child)
      for child in stmt["else"]
        push(work, child)
      elseif_index = 0
      while elseif_index < len(stmt["elseif_bodies"])
        for child in stmt["elseif_bodies"][elseif_index]
          push(work, child)
        elseif_index = elseif_index + 1
    if stmt["kind"] == "while"
      for child in stmt["body"]
        push(work, child)
    if stmt["kind"] == "for"
      remember(names, stmt["value_name"])
      if stmt["index_name"] != ""
        remember(names, stmt["index_name"])
      for child in stmt["body"]
        push(work, child)
  names

emit_function_definition = lines, c_fn_name, fn, use_this ->
  push(
    lines,
    "TyaValue " + c_fn_name + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3) {{",
  )
  if not use_this
    push(lines, "  (void)__this;")
  push(lines, "  (void)__arg2;")
  push(lines, "  (void)__arg3;")
  if len(fn["params"]) < 2
    push(lines, "  (void)__arg1;")
  arg_index = 0
  for param in fn["params"]
    push(
      lines,
      "  TyaValue " + c_name(param) + " = __arg" + to_string(arg_index) + ";",
    )
    arg_index = arg_index + 1
  if len(fn["body_stmts"]) > 0
    fn_names = []
    for param in fn["params"]
      push(fn_names, param)
    for local in collect_assigned_names(fn["body_stmts"])
      if not has_name(fn_names, local)
        push(fn_names, local)
        push(lines, "  TyaValue " + c_name(local) + " = tya_nil();")
    child_index = 0
    while child_index < len(fn["body_stmts"])
      child = fn["body_stmts"][child_index]
      if (
        child_index == len(fn["body_stmts"]) - 1 and child["kind"] == "expr_stmt"
      )
        push(lines, "  return " + emit_expr(child["expr"]) + ";")
      else
        emit_stmt(lines, fn_names, child)
      child_index = child_index + 1
    push(lines, "  return tya_nil();")
    if len(fn["body_stmts"]) == 0
      push(lines, "  return tya_nil();")
  else
    push(lines, "  return " + emit_expr(fn["body"]) + ";")
  push(lines, "}}")
  push(lines, "")
  return nil

emit_class_definition = lines, class_name, class_value ->
  saved_class_ref = emitter_state["class_ref"]
  for method in class_value["methods"]
    saved_super = emitter_state["super_class"]
    saved_method = emitter_state["method_name"]
    saved_method_class_ref = emitter_state["class_ref"]
    emitter_state["super_class"] = class_value["parent"]
    emitter_state["method_name"] = method["name"]
    if method["class"]
      emitter_state["class_ref"] = "__this"
    else
      emitter_state["class_ref"] = "tya_member(__this, "
        + c_string("class")
        + ")"
    emit_function_definition(
      lines,
      c_func_name(class_name + "_" + method["name"]),
      method["value"],
      true,
    )
    emitter_state["super_class"] = saved_super
    emitter_state["method_name"] = saved_method
    emitter_state["class_ref"] = saved_method_class_ref
  emitter_state["class_ref"] = saved_class_ref
  push(
    lines,
    "TyaValue " + c_func_name(class_name) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3) {{",
  )
  push(lines, "  (void)__this;")
  push(lines, "  TyaValue __obj = tya_object();")
  push(
    lines,
    "  tya_set_member(__obj, " + c_string("class") + ", " + c_name(class_name) + ");",
  )
  push(
    lines,
    "  tya_set_member(__obj, " + c_string("class_name") + ", tya_string(" + c_string(class_value["name"]) + "));",
  )
  saved_class_ref = emitter_state["class_ref"]
  emitter_state["class_ref"] = c_name(class_name)
  if (
    class_value["parent"] != "" and has(emitter_state["class_values"], class_value["parent"])
  )
    parent_class = emitter_state["class_values"][class_value["parent"]]
    for field in parent_class["fields"]
      field_tmp = "__field" + to_string(len(lines))
      push(
        lines,
        "  TyaValue " + field_tmp + " = " + emit_expr(field["value"]) + ";",
      )
      push(
        lines,
        "  tya_set_member(__obj, " + c_string("@" + field["name"]) + ", " + field_tmp + ");",
      )
      push(
        lines,
        "  tya_set_member(__obj, " + c_string(field["name"]) + ", " + field_tmp + ");",
      )
  for field in class_value["fields"]
    field_tmp = "__field" + to_string(len(lines))
    push(
      lines,
      "  TyaValue " + field_tmp + " = " + emit_expr(field["value"]) + ";",
    )
    push(
      lines,
      "  tya_set_member(__obj, " + c_string("@" + field["name"]) + ", " + field_tmp + ");",
    )
    push(
      lines,
      "  tya_set_member(__obj, " + c_string(field["name"]) + ", " + field_tmp + ");",
    )
  has_init = false
  for method in class_value["methods"]
    if method["name"] == "init" and not method["class"]
      has_init = true
  if has_init
    push(
      lines,
      "  (void)" + c_func_name(class_name + "_init") + "(__obj, __arg0, __arg1, __arg2, __arg3);",
    )
  elseif (
    class_value["parent"] != "" and has(emitter_state["class_values"], class_value["parent"])
  )
    parent_class = emitter_state["class_values"][class_value["parent"]]
    parent_has_init = false
    for method in parent_class["methods"]
      if method["name"] == "init" and not method["class"]
        parent_has_init = true
    if parent_has_init
      push(
        lines,
        "  (void)" + c_func_name(class_value["parent"] + "_init") + "(__obj, __arg0, __arg1, __arg2, __arg3);",
      )
    else
      push(lines, "  (void)__arg0;")
      push(lines, "  (void)__arg1;")
      push(lines, "  (void)__arg2;")
      push(lines, "  (void)__arg3;")
  else
    push(lines, "  (void)__arg0;")
    push(lines, "  (void)__arg1;")
    push(lines, "  (void)__arg2;")
    push(lines, "  (void)__arg3;")
  if (
    class_value["parent"] != "" and has(emitter_state["class_values"], class_value["parent"])
  )
    parent_class = emitter_state["class_values"][class_value["parent"]]
    for method in parent_class["methods"]
      if not method["class"] and method["name"] != "init"
        overridden = false
        for own_method in class_value["methods"]
          if not own_method["class"] and own_method["name"] == method["name"]
            overridden = true
        if not overridden
          push(
            lines,
            "  tya_set_member(__obj, " + c_string(method["name"]) + ", tya_bind_method(__obj, " + c_func_name(class_value["parent"] + "_" + method["name"]) + "));",
          )
  for method in class_value["methods"]
    if not method["class"] and method["name"] != "init"
      push(
        lines,
        "  tya_set_member(__obj, " + c_string(method["name"]) + ", tya_bind_method(__obj, " + c_func_name(class_name + "_" + method["name"]) + "));",
      )
  emitter_state["class_ref"] = saved_class_ref
  push(lines, "  return __obj;")
  push(lines, "}}")
  push(lines, "")
  return nil

emit_c = program ->
  while len(emitter_functions) > 0
    pop(emitter_functions)
  while len(emitter_classes) > 0
    pop(emitter_classes)
  emitter_state["class_values"] = {}
  while len(emitter_anon_functions) > 0
    pop(emitter_anon_functions)
  for stmt in program["statements"]
    if stmt["kind"] == "assign" and stmt["value"]["kind"] == "func"
      remember(emitter_functions, stmt["name"])
    if stmt["kind"] == "module"
      for member in stmt["members"]
        if member["value"]["kind"] == "func"
          remember(emitter_functions, stmt["name"] + "_" + member["name"])
      for class_value in stmt["classes"]
        remember(emitter_functions, stmt["name"] + "_" + class_value["name"])
        remember(emitter_classes, stmt["name"] + "_" + class_value["name"])
        emitter_state["class_values"][stmt["name"] + "_" + class_value["name"]] = class_value
        for method in class_value["methods"]
          remember(
            emitter_functions,
            stmt["name"] + "_" + class_value["name"] + "_" + method["name"],
          )
    if stmt["kind"] == "class"
      remember(emitter_functions, stmt["name"])
      remember(emitter_classes, stmt["name"])
      emitter_state["class_values"][stmt["name"]] = stmt
      for method in stmt["methods"]
        remember(emitter_functions, stmt["name"] + "_" + method["name"])
  for stmt in program["statements"]
    register_anon_stmt(stmt)
  lines = []
  push(lines, "#include \"tya_runtime.h\"")
  push(lines, "")
  global_names = collect_assigned_names(program["statements"])
  for stmt in program["statements"]
    if stmt["kind"] == "module"
      remember(global_names, stmt["name"])
      for class_value in stmt["classes"]
        remember(global_names, stmt["name"] + "_" + class_value["name"])
    if stmt["kind"] == "class"
      remember(global_names, stmt["name"])
  for name in global_names
    if name != ""
      push(lines, "TyaValue " + c_name(name) + ";")
  if len(global_names) > 0
    push(lines, "")
  for stmt in program["statements"]
    if stmt["kind"] == "assign" and stmt["value"]["kind"] == "func"
      push(
        lines,
        "TyaValue " + c_func_name(stmt["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3);",
      )
    if stmt["kind"] == "module"
      for member in stmt["members"]
        if member["value"]["kind"] == "func"
          push(
            lines,
            "TyaValue " + c_func_name(stmt["name"] + "_" + member["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3);",
          )
      for class_value in stmt["classes"]
        push(
          lines,
          "TyaValue " + c_func_name(stmt["name"] + "_" + class_value["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3);",
        )
        for method in class_value["methods"]
          push(
            lines,
            "TyaValue " + c_func_name(stmt["name"] + "_" + class_value["name"] + "_" + method["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3);",
          )
    if stmt["kind"] == "class"
      push(
        lines,
        "TyaValue " + c_func_name(stmt["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3);",
      )
      for method in stmt["methods"]
        push(
          lines,
          "TyaValue " + c_func_name(stmt["name"] + "_" + method["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3);",
        )
  for fn in emitter_anon_functions
    push(
      lines,
      "TyaValue " + c_func_name(fn["anon_name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3);",
    )
  push(lines, "")
  for stmt in program["statements"]
    if stmt["kind"] == "assign" and stmt["value"]["kind"] == "func"
      fn = stmt["value"]
      push(
        lines,
        "TyaValue " + c_func_name(stmt["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3) {{",
      )
      push(lines, "  (void)__this;")
      push(lines, "  (void)__arg2;")
      push(lines, "  (void)__arg3;")
      if len(fn["params"]) < 2
        push(lines, "  (void)__arg1;")
      arg_index = 0
      for param in fn["params"]
        push(
          lines,
          "  TyaValue " + c_name(param) + " = __arg" + to_string(arg_index) + ";",
        )
        arg_index = arg_index + 1
      if len(fn["body_stmts"]) > 0
        fn_names = []
        for param in fn["params"]
          push(fn_names, param)
        for local in collect_assigned_names(fn["body_stmts"])
          if not has_name(fn_names, local)
            push(fn_names, local)
            push(lines, "  TyaValue " + c_name(local) + " = tya_nil();")
        child_index = 0
        while child_index < len(fn["body_stmts"])
          child = fn["body_stmts"][child_index]
          if (
            child_index == len(fn["body_stmts"]) - 1 and child["kind"] == "expr_stmt"
          )
            push(lines, "  return " + emit_expr(child["expr"]) + ";")
          else
            emit_stmt(lines, fn_names, child)
          child_index = child_index + 1
        if len(fn["body_stmts"]) == 0
          push(lines, "  return tya_nil();")
      else
        push(lines, "  return " + emit_expr(fn["body"]) + ";")
      push(lines, "}}")
      push(lines, "")
    if stmt["kind"] == "module"
      for member in stmt["members"]
        if member["value"]["kind"] == "func"
          fn = member["value"]
          push(
            lines,
            "TyaValue " + c_func_name(stmt["name"] + "_" + member["name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3) {{",
          )
          push(lines, "  (void)__this;")
          push(lines, "  (void)__arg2;")
          push(lines, "  (void)__arg3;")
          if len(fn["params"]) < 2
            push(lines, "  (void)__arg1;")
          arg_index = 0
          for param in fn["params"]
            push(
              lines,
              "  TyaValue " + c_name(param) + " = __arg" + to_string(arg_index) + ";",
            )
            arg_index = arg_index + 1
          if len(fn["body_stmts"]) > 0
            fn_names = []
            for param in fn["params"]
              push(fn_names, param)
            for local in collect_assigned_names(fn["body_stmts"])
              if not has_name(fn_names, local)
                push(fn_names, local)
                push(lines, "  TyaValue " + c_name(local) + " = tya_nil();")
            child_index = 0
            while child_index < len(fn["body_stmts"])
              child = fn["body_stmts"][child_index]
              if (
                child_index == len(fn["body_stmts"]) - 1 and child["kind"] == "expr_stmt"
              )
                push(lines, "  return " + emit_expr(child["expr"]) + ";")
              else
                emit_stmt(lines, fn_names, child)
              child_index = child_index + 1
            if len(fn["body_stmts"]) == 0
              push(lines, "  return tya_nil();")
          else
            push(lines, "  return " + emit_expr(fn["body"]) + ";")
          push(lines, "}}")
          push(lines, "")
      for class_value in stmt["classes"]
        emit_class_definition(
          lines,
          stmt["name"] + "_" + class_value["name"],
          class_value,
        )
    if stmt["kind"] == "class"
      emit_class_definition(lines, stmt["name"], stmt)
  for fn in emitter_anon_functions
    push(
      lines,
      "TyaValue " + c_func_name(fn["anon_name"]) + "(TyaValue __this, TyaValue __arg0, TyaValue __arg1, TyaValue __arg2, TyaValue __arg3) {{",
    )
    push(lines, "  (void)__this;")
    push(lines, "  (void)__arg2;")
    push(lines, "  (void)__arg3;")
    if len(fn["params"]) < 2
      push(lines, "  (void)__arg1;")
    arg_index = 0
    for param in fn["params"]
      push(
        lines,
        "  TyaValue " + c_name(param) + " = __arg" + to_string(arg_index) + ";",
      )
      arg_index = arg_index + 1
    push(lines, "  return " + emit_expr(fn["body"]) + ";")
    push(lines, "}}")
    push(lines, "")
  push(lines, "int main(int argc, char **argv) {{")
  push(lines, "  (void)argc;")
  push(lines, "  (void)argv;")
  names = clone_names(global_names)
  for stmt in program["statements"]
    emit_stmt(lines, names, stmt)
  push(lines, "  return 0;")
  push(lines, "}}")
  join(lines, "\n") + "\n"

dir_name = path ->
  slash = -1
  i = 0
  while i < len(path)
    if path[i] == "/"
      slash = i
    i = i + 1
  if slash < 0
    return ""
  out = ""
  i = 0
  while i < slash
    out = out + path[i]
    i = i + 1
  out

join_path = dir, name ->
  if dir == ""
    return name
  dir + "/" + name

find_module_path = dir, name ->
  file_name = name + ".tya"
  same_dir = join_path(dir, file_name)
  if file_exists(same_dir)
    return same_dir
  path_list = env("TYA_PATH")
  if path_list != ""
    for entry in split(path_list, ":")
      if entry != ""
        candidate = join_path(entry, file_name)
        if file_exists(candidate)
          return candidate
  stdlib_dir = env("TYA_STDLIB_DIR")
  if stdlib_dir != ""
    candidate = join_path(stdlib_dir, file_name)
    if file_exists(candidate)
      return candidate
  candidate = join_path("stdlib", file_name)
  if file_exists(candidate)
    return candidate
  file_name

load_imports = program, path ->
  dir = dir_name(path)
  extra = []
  for stmt in program["statements"]
    if stmt["kind"] == "import"
      module_path = find_module_path(dir, stmt["name"])
      module_source = read_file(module_path)
      module_tokens, module_errors = lex(module_source)
      for message in module_errors
        print message
        exit(1)
      module_parse_errors = parse_errors(module_tokens)
      for message in module_parse_errors
        print message
        exit(1)
      syntax_errors = []
      parse_state["function_depth"] = 0
      module_program = parse(module_tokens)
      if len(syntax_errors) > 0
        for message in syntax_errors
          print message
          exit(1)
      module_count = 0
      for module_stmt_value in module_program["statements"]
        if module_stmt_value["kind"] == "module"
          module_count = module_count + 1
          if module_stmt_value["name"] != stmt["name"]
            print stmt["name"] + ".tya must define module " + stmt["name"]
            exit(1)
          push(extra, module_stmt_value)
        elseif module_stmt_value["kind"] != "import"
          print stmt["name"] + ".tya may only contain imports and one module declaration"
          exit(1)
      if module_count != 1
        print stmt["name"] + ".tya must define exactly one module"
        exit(1)
  combined = []
  for stmt in extra
    push(combined, stmt)
  for stmt in program["statements"]
    push(combined, stmt)
  program["statements"] = combined
  program
if len(args()) > 1 and args()[0] == "--tokens"
  token_source = read_file(args()[1])
  token_values, token_errors = lex(token_source)
  if len(token_errors) > 0
    for message in token_errors
      print message
    exit(1)
  token_parse_errors = parse_errors(token_values)
  if len(token_parse_errors) > 0
    for message in token_parse_errors
      print message
    exit(1)
  print_tokens(token_values)
  exit(0)
if len(args()) > 1 and args()[0] == "--ast"
  ast_source = read_file(args()[1])
  ast_tokens, ast_errors = lex(ast_source)
  if len(ast_errors) > 0
    for message in ast_errors
      print message
    exit(1)
  ast_parse_errors = parse_errors(ast_tokens)
  if len(ast_parse_errors) > 0
    for message in ast_parse_errors
      print message
    exit(1)
  syntax_errors = []
  parse_state["function_depth"] = 0
  parse_state["loop_depth"] = 0
  ast_program = parse(ast_tokens)
  if len(syntax_errors) > 0
    for message in syntax_errors
      print message
    exit(1)
  print_ast(ast_program)
  exit(0)
path = args()[0]
source = read_file(path)
tokens, lex_errors = lex(source)
if len(lex_errors) > 0
  for message in lex_errors
    print message
  exit(1)
parse_diagnostics = parse_errors(tokens)
if len(parse_diagnostics) > 0
  for message in parse_diagnostics
    print message
  exit(1)
syntax_errors = []
parse_state["function_depth"] = 0
parse_state["loop_depth"] = 0
program = parse(tokens)
if len(syntax_errors) > 0
  for message in syntax_errors
    print message
  exit(1)
program = load_imports(program, path)
errors = check(program)
if len(errors) > 0
  for message in errors
    print message
  exit(1)
emitter_source_path = path
print emit_c(program)
