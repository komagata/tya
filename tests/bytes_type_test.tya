import unittest/*
import bytes

class BytesTypeTest extends TestCase

  test_literal_and_len: ->
    b = b"hello"
    self.assert_equal(5, b.len(), "len 5")
    self.assert_equal(104, b[0], "h byte")
    self.assert_equal(111, b[4], "o byte")
  test_hex_escapes: ->
    b = b"\x00\x01\xff"
    self.assert_equal(3, b.len(), "hex escapes")
    self.assert_equal(0, b[0], "0x00")
    self.assert_equal(255, b[2], "0xff")
  test_kind: ->
    self.assert_equal([120], bytes_array(b"x"), "bytes array")
  test_concat: ->
    b = b"foo" + b"bar"
    self.assert_equal(6, b.len(), "concat len")
    self.assert_equal(102, b[0], "f")
  test_equality: ->
    self.assert(b"abc" == b"abc", "equal")
    self.assert_equal(false, b"abc" == b"abd", "not equal")
  test_bytes_of: ->
    b = bytes_of("Tya")
    self.assert_equal(3, b.len(), "len 3")
    self.assert_equal(84, b[0], "T")
  test_bytes_text: ->
    self.assert_equal("Tya", bytes_text(b"Tya"), "round trip")
  test_bytes_array: ->
    self.assert_equal([97, 98, 99], bytes_array(b"abc"), "to array")
  test_bytes_from_array: ->
    b = bytes([72, 101, 108, 108, 111])
    self.assert_equal("Hello", bytes_text(b), "from array")
  test_bytes_slice: ->
    b = bytes_slice(b"hello world", 0, 5)
    self.assert_equal("hello", bytes_text(b), "slice 0..5")
    b = bytes_slice(b"hello world", 6, 11)
    self.assert_equal("world", bytes_text(b), "slice 6..11")
  test_bytes_class_wraps_native_bytes: ->
    b = bytes.Bytes(b"Tya")
    self.assert_equal("Bytes", b.class.name, "wrapper class")
    self.assert_equal([84, 121, 97], b.to_array(), "array")
    self.assert_equal("Tya", b.to_string(), "text")
    self.assert_equal(3, b.len(), "len")
    self.assert_equal(84, b.at(0), "at")
  test_bytes_class_builds_from_array_and_text: ->
    from_array = bytes.Bytes.from_array([65, 66, 67])
    from_string = bytes.Bytes.from_string("ABC")
    self.assert_equal("Bytes", from_array.class.name, "array wrapper")
    self.assert_equal("ABC", from_array.to_string(), "array text")
    self.assert_equal([65, 66, 67], from_string.to_array(), "string array")
  test_bytes_class_concat_and_slice_return_wrappers: ->
    b = bytes.Bytes.from_string("hello").concat(bytes.Bytes.from_string(" world")).slice(0, 5)
    self.assert_equal("Bytes", b.class.name, "wrapper")
    self.assert_equal("hello", b.to_string(), "slice")
