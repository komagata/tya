import unittest
import matrix

module stdlib_matrix_test
  test_new_and_at = ->
    m = matrix.new([[1, 2], [3, 4]])
    unittest.assert_equal(2, m["rows"], "rows")
    unittest.assert_equal(2, m["cols"], "cols")
    unittest.assert_equal(1, matrix.at(m, 0, 0), "at 0,0")
    unittest.assert_equal(4, matrix.at(m, 1, 1), "at 1,1")
  test_zero = ->
    m = matrix.zero(2, 3)
    unittest.assert_equal([[0, 0, 0], [0, 0, 0]], m["data"], "zero 2x3")
  test_identity = ->
    m = matrix.identity(3)
    unittest.assert_equal([[1, 0, 0], [0, 1, 0], [0, 0, 1]], m["data"], "I3")
  test_add = ->
    a = matrix.new([[1, 2], [3, 4]])
    b = matrix.identity(2)
    sum = matrix.add(a, b)
    unittest.assert_equal([[2, 2], [3, 5]], sum["data"], "add")
  test_mul = ->
    a = matrix.new([[1, 2], [3, 4]])
    p = matrix.mul(a, a)
    unittest.assert_equal([[7, 10], [15, 22]], p["data"], "a*a")
  test_transpose = ->
    a = matrix.new([[1, 2, 3]])
    t = matrix.transpose(a)
    unittest.assert_equal([[1], [2], [3]], t["data"], "transpose")
  test_det_2x2 = ->
    a = matrix.new([[1, 2], [3, 4]])
    unittest.assert_equal(-2, matrix.det(a), "det 2x2")
  test_det_3x3 = ->
    a = matrix.new([[6, 1, 1], [4, -2, 5], [2, 8, 7]])
    unittest.assert_equal(-306, matrix.det(a), "det 3x3")
  test_scale = ->
    a = matrix.new([[1, 2], [3, 4]])
    s = matrix.scale(a, 2)
    unittest.assert_equal([[2, 4], [6, 8]], s["data"], "scale 2")
