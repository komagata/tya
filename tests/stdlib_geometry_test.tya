import unittest/* as unittest
import geometry/*

class StdlibGeometryTest extends TestCase

  test_vector2: ->
    v = geometry.Vector2(3, 4)
    self.assert_equal(geometry.Vector2, v.class, "class")
    self.assert_equal([4, 5], v.add(geometry.Vector2(0, 0).one()).to_array(), "add")
    self.assert_equal([2, 3], v.sub(geometry.Vector2(0, 0).one()).to_array(), "sub")
    self.assert_equal([6, 8], v.scale(2).to_array(), "scale")
    self.assert_equal(25, v.length_squared(), "length squared")
    self.assert_equal(5, v.length(), "length")
    self.assert_equal(25, v.distance_squared(geometry.Vector2(0, 0).zero()), "distance squared")
    self.assert_equal(5, v.distance(geometry.Vector2(0, 0).zero()), "distance")
    self.assert_equal(11, v.dot(geometry.Vector2(1, 2)), "dot")
    self.assert_equal([0, 0], geometry.Vector2(0, 0).zero().normalize().to_array(), "normalize zero")
    self.assert_equal([1.5, 2], geometry.Vector2(0, 0).lerp(geometry.Vector2(0, 0).zero(), v, 0.5).to_array(), "lerp")
    self.assert_equal([2, 3], geometry.Vector2(0, 0).clamp(v, geometry.Vector2(0, 0), geometry.Vector2(2, 3)).to_array(), "clamp")
    self.assert(v.equal?(geometry.Vector2(0, 0).from_array([3, 4])), "equal")
    self.assert(v.nearly_equal?(geometry.Vector2(3.1, 3.9), 0.11), "nearly")

  test_vector3: ->
    v = geometry.Vector3(1, 2, 3)
    self.assert_equal(geometry.Vector3, v.class, "class")
    self.assert_equal([2, 3, 4], v.add(geometry.Vector3(0, 0, 0).one()).to_array(), "add")
    self.assert_equal([2, 4, 6], v.scale(2).to_array(), "scale")
    self.assert_equal(14, v.length_squared(), "length squared")
    self.assert_equal(32, v.dot(geometry.Vector3(4, 5, 6)), "dot")
    self.assert_equal([-3, 6, -3], v.cross(geometry.Vector3(4, 5, 6)).to_array(), "cross")
    self.assert_equal([0, 0, 0], geometry.Vector3(0, 0, 0).zero().normalize().to_array(), "normalize zero")
    self.assert_equal([2.5, 3.5, 4.5], geometry.Vector3(0, 0, 0).lerp(v, geometry.Vector3(4, 5, 6), 0.5).to_array(), "lerp")
    self.assert(v.equal?(geometry.Vector3(0, 0, 0).from_array([1, 2, 3])), "equal")
    self.assert(v.nearly_equal?(geometry.Vector3(1.1, 2.1, 2.9), 0.11), "nearly")

  test_point_and_size: ->
    p = geometry.Point(1, 2)
    v = p.to_vector()
    self.assert_equal(geometry.Point, p.class, "point class")
    self.assert_equal([1, 2], geometry.Vector2(0, 0).to_array(v), "to vector")
    self.assert(p.equal?(geometry.Point(0, 0).from_vector(v)), "from vector")
    self.assert_equal(geometry.Point(4, 6).x, p.translate(geometry.Vector2(3, 4)).x, "translate x")
    self.assert_equal(5, geometry.Point(0, 0).distance(geometry.Point(3, 4)), "distance")
    size = geometry.Size(16, 9)
    self.assert_equal(144, size.area(), "area")
    self.assert_equal(16 / 9, size.aspect_ratio(), "aspect")
    self.assert_raises(-> geometry.Size(-1, 2), "negative size")
    self.assert_raises(-> geometry.Size(1, 0).aspect_ratio(), "zero height")

  test_rect: ->
    r = geometry.Rect(0, 0, 10, 5)
    self.assert_equal(geometry.Rect, r.class, "class")
    self.assert_equal(10, r.right(), "right")
    self.assert_equal(5, r.bottom(), "bottom")
    self.assert(r.contains_point?(geometry.Point(9, 4)), "contains point")
    self.assert(not r.contains_point?(geometry.Point(10, 4)), "right edge exclusive")
    self.assert(r.contains_rect?(geometry.Rect(1, 1, 2, 2)), "contains rect")
    self.assert(r.intersects?(geometry.Rect(5, 2, 10, 10)), "intersects")
    self.assert_equal([5, 2], [r.intersection(geometry.Rect(5, 2, 10, 10)).x, r.intersection(geometry.Rect(5, 2, 10, 10)).y], "intersection origin")
    self.assert_equal(15, r.union(geometry.Rect(5, 2, 10, 10)).right(), "union")
    self.assert_equal(-2, r.expand(2).x, "expand")
    self.assert_equal(3, r.translate(geometry.Vector2(3, 4)).x, "translate")
    self.assert_equal(14, r.inflate(2, 3).width, "inflate")
    self.assert_equal([10, 0], r.clamp_point(geometry.Point(20, -5)).to_vector().to_array(), "clamp point")
    self.assert(geometry.Rect(0, 0, 0, 1).empty?(), "empty")
    self.assert_raises(-> geometry.Rect(0, 0, -1, 1), "negative rect")

  test_circle: ->
    c = geometry.Circle(0, 0, 5)
    self.assert_equal(geometry.Circle, c.class, "class")
    self.assert(c.contains_point?(geometry.Point(3, 4)), "contains point")
    self.assert(c.intersects_circle?(geometry.Circle(8, 0, 3)), "intersects circle")
    self.assert(c.intersects_rect?(geometry.Rect(4, 0, 10, 10)), "intersects rect")
    self.assert_equal([-5, -5, 10, 10], [c.bounding_rect().x, c.bounding_rect().y, c.bounding_rect().width, c.bounding_rect().height], "bounds")
    self.assert(c.translate(geometry.Vector2(1, 2)).equal?(geometry.Circle(1, 2, 5)), "translate")
    self.assert_raises(-> geometry.Circle(0, 0, -1), "negative radius")

  test_errors: ->
    self.assert_raises(-> geometry.Vector2("x", 0), "non-number")
    self.assert_raises(-> geometry.Vector2(0, 0).one().div(0), "divide zero")
    self.assert_raises(-> geometry.Vector3(0, 0, 0).one().div(0), "divide zero")
