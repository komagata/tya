import unittest
import geometry as geo

class StdlibGeometryTest extends TestCase

  test_vector2 = ->
    v = geo.Vector2.new(3, 4)
    self.assert_equal(geo.Vector2, v.class, "class")
    self.assert_equal([4, 5], geo.Vector2.to_array(geo.Vector2.add(v, geo.Vector2.one())), "add")
    self.assert_equal([2, 3], geo.Vector2.to_array(geo.Vector2.sub(v, geo.Vector2.one())), "sub")
    self.assert_equal([6, 8], geo.Vector2.to_array(geo.Vector2.scale(v, 2)), "scale")
    self.assert_equal(25, geo.Vector2.length_squared(v), "length squared")
    self.assert_equal(5, geo.Vector2.length(v), "length")
    self.assert_equal(25, geo.Vector2.distance_squared(v, geo.Vector2.zero()), "distance squared")
    self.assert_equal(5, geo.Vector2.distance(v, geo.Vector2.zero()), "distance")
    self.assert_equal(11, geo.Vector2.dot(v, geo.Vector2.new(1, 2)), "dot")
    self.assert_equal([0, 0], geo.Vector2.to_array(geo.Vector2.normalize(geo.Vector2.zero())), "normalize zero")
    self.assert_equal([1.5, 2], geo.Vector2.to_array(geo.Vector2.lerp(geo.Vector2.zero(), v, 0.5)), "lerp")
    self.assert_equal([2, 3], geo.Vector2.to_array(geo.Vector2.clamp(v, geo.Vector2.new(0, 0), geo.Vector2.new(2, 3))), "clamp")
    self.assert(geo.Vector2.equal?(v, geo.Vector2.from_array([3, 4])), "equal")
    self.assert(geo.Vector2.nearly_equal?(v, geo.Vector2.new(3.1, 3.9), 0.11), "nearly")

  test_vector3 = ->
    v = geo.Vector3.new(1, 2, 3)
    self.assert_equal(geo.Vector3, v.class, "class")
    self.assert_equal([2, 3, 4], geo.Vector3.to_array(geo.Vector3.add(v, geo.Vector3.one())), "add")
    self.assert_equal([2, 4, 6], geo.Vector3.to_array(geo.Vector3.scale(v, 2)), "scale")
    self.assert_equal(14, geo.Vector3.length_squared(v), "length squared")
    self.assert_equal(32, geo.Vector3.dot(v, geo.Vector3.new(4, 5, 6)), "dot")
    self.assert_equal([-3, 6, -3], geo.Vector3.to_array(geo.Vector3.cross(v, geo.Vector3.new(4, 5, 6))), "cross")
    self.assert_equal([0, 0, 0], geo.Vector3.to_array(geo.Vector3.normalize(geo.Vector3.zero())), "normalize zero")
    self.assert_equal([2.5, 3.5, 4.5], geo.Vector3.to_array(geo.Vector3.lerp(v, geo.Vector3.new(4, 5, 6), 0.5)), "lerp")
    self.assert(geo.Vector3.equal?(v, geo.Vector3.from_array([1, 2, 3])), "equal")
    self.assert(geo.Vector3.nearly_equal?(v, geo.Vector3.new(1.1, 2.1, 2.9), 0.11), "nearly")

  test_point_and_size = ->
    p = geo.Point.new(1, 2)
    v = geo.Point.to_vector(p)
    self.assert_equal(geo.Point, p.class, "point class")
    self.assert_equal([1, 2], geo.Vector2.to_array(v), "to vector")
    self.assert(geo.Point.equal?(geo.Point.from_vector(v), p), "from vector")
    self.assert_equal(geo.Point.new(4, 6).x, geo.Point.translate(p, geo.Vector2.new(3, 4)).x, "translate x")
    self.assert_equal(5, geo.Point.distance(geo.Point.new(0, 0), geo.Point.new(3, 4)), "distance")
    size = geo.Size.new(16, 9)
    self.assert_equal(144, geo.Size.area(size), "area")
    self.assert_equal(16 / 9, geo.Size.aspect_ratio(size), "aspect")
    self.assert_raises(-> geo.Size.new(-1, 2), "negative size")
    self.assert_raises(-> geo.Size.aspect_ratio(geo.Size.new(1, 0)), "zero height")

  test_rect = ->
    r = geo.Rect.new(0, 0, 10, 5)
    self.assert_equal(geo.Rect, r.class, "class")
    self.assert_equal(10, geo.Rect.right(r), "right")
    self.assert_equal(5, geo.Rect.bottom(r), "bottom")
    self.assert(geo.Rect.contains_point?(r, geo.Point.new(9, 4)), "contains point")
    self.assert(not geo.Rect.contains_point?(r, geo.Point.new(10, 4)), "right edge exclusive")
    self.assert(geo.Rect.contains_rect?(r, geo.Rect.new(1, 1, 2, 2)), "contains rect")
    self.assert(geo.Rect.intersects?(r, geo.Rect.new(5, 2, 10, 10)), "intersects")
    self.assert_equal([5, 2], [geo.Rect.intersection(r, geo.Rect.new(5, 2, 10, 10)).x, geo.Rect.intersection(r, geo.Rect.new(5, 2, 10, 10)).y], "intersection origin")
    self.assert_equal(15, geo.Rect.right(geo.Rect.union(r, geo.Rect.new(5, 2, 10, 10))), "union")
    self.assert_equal(-2, geo.Rect.expand(r, 2).x, "expand")
    self.assert_equal(3, geo.Rect.translate(r, geo.Vector2.new(3, 4)).x, "translate")
    self.assert_equal(14, geo.Rect.inflate(r, 2, 3).width, "inflate")
    self.assert_equal([10, 0], geo.Vector2.to_array(geo.Point.to_vector(geo.Rect.clamp_point(r, geo.Point.new(20, -5)))), "clamp point")
    self.assert(geo.Rect.empty?(geo.Rect.new(0, 0, 0, 1)), "empty")
    self.assert_raises(-> geo.Rect.new(0, 0, -1, 1), "negative rect")

  test_circle = ->
    c = geo.Circle.new(0, 0, 5)
    self.assert_equal(geo.Circle, c.class, "class")
    self.assert(geo.Circle.contains_point?(c, geo.Point.new(3, 4)), "contains point")
    self.assert(geo.Circle.intersects_circle?(c, geo.Circle.new(8, 0, 3)), "intersects circle")
    self.assert(geo.Circle.intersects_rect?(c, geo.Rect.new(4, 0, 10, 10)), "intersects rect")
    self.assert_equal([-5, -5, 10, 10], [geo.Circle.bounding_rect(c).x, geo.Circle.bounding_rect(c).y, geo.Circle.bounding_rect(c).width, geo.Circle.bounding_rect(c).height], "bounds")
    self.assert(geo.Circle.equal?(geo.Circle.translate(c, geo.Vector2.new(1, 2)), geo.Circle.new(1, 2, 5)), "translate")
    self.assert_raises(-> geo.Circle.new(0, 0, -1), "negative radius")

  test_errors = ->
    self.assert_raises(-> geo.Vector2.new("x", 0), "non-number")
    self.assert_raises(-> geo.Vector2.div(geo.Vector2.one(), 0), "divide zero")
    self.assert_raises(-> geo.Vector3.div(geo.Vector3.one(), 0), "divide zero")
