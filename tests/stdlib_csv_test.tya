import unittest
import csv

module stdlib_csv_test
  test_parse_no_header = ->
    rows = csv.parse("a,b\n1,2\n", nil)
    unittest.assert_equal([["a", "b"], ["1", "2"]], rows, "raw rows")
  test_parse_with_header = ->
    rows = csv.parse("name,age\ntya,1\n", { header: true })
    unittest.assert_equal([{ name: "tya", age: "1" }], rows, "with header")
  test_parse_quoted_field = ->
    rows = csv.parse("a,b\n\"hello, world\",x\n", nil)
    unittest.assert_equal([["a", "b"], ["hello, world", "x"]], rows, "quoted")
  test_dump_arrays = ->
    out = csv.dump([["a", "b"], ["1", "2"]], nil)
    unittest.assert_equal("a,b\n1,2\n", out, "dump arrays")
  test_dump_quotes_special = ->
    out = csv.dump([["a, b", "c"]], nil)
    unittest.assert_equal("\"a, b\",c\n", out, "quotes comma")
  test_dump_dicts_with_header = ->
    out = csv.dump([{ x: "1", y: "2" }], { header: true })
    unittest.assert_equal("x,y\n1,2\n", out, "dicts with header")
