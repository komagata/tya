import unittest
import random as random

class StdlibRandomTest extends TestCase

  test_seed_reproducible = ->
    random.Random.seed(42)
    a = random.Random.int(1, 1000)
    random.Random.seed(42)
    b = random.Random.int(1, 1000)
    self.assert_equal(a, b, "seeded reproducibility")
  test_int_range = ->
    random.Random.seed(1)
    i = 0
    while i < 50
      v = random.Random.int(0, 9)
      self.assert(v >= 0, "lower")
      self.assert(v <= 9, "upper")
      i = i + 1
  test_float_range = ->
    f = random.Random.float()
    self.assert(f >= 0, "f >= 0")
    self.assert(f < 1, "f < 1")
  test_choice_picks_member = ->
    items = ["a", "b", "c"]
    c = random.Random.choice(items)
    self.assert(c == "a" or c == "b" or c == "c", "valid choice")
