import unittest/*
import dir/* as dir
import file/* as file

class StdlibDirTest extends TestCase

  test_mkdir_list_rmdir: ->
    root = "/tmp/tya_v23_dir_a"
    try
      dir.Dir(root).rmdir()
    catch _
      nil
    dir.Dir(root).mkdir()
    file.File("{root}/b.txt").write("")
    file.File("{root}/a.txt").write("")
    self.assert_equal(["a.txt", "b.txt"], dir.Dir(root).list(), "sorted list")
    file.File("{root}/a.txt").remove()
    file.File("{root}/b.txt").remove()
    dir.Dir(root).rmdir()
    self.assert_equal(false, file.File(root).exists?(), "rmdir removed")

  test_mkdir_existing_raises: ->
    root = "/tmp/tya_v23_dir_b"
    try
      dir.Dir(root).rmdir()
    catch _
      nil
    dir.Dir(root).mkdir()
    raised = false
    try
      dir.Dir(root).mkdir()
    catch _
      raised = true
    self.assert(raised, "duplicate mkdir raises")
    dir.Dir(root).rmdir()
