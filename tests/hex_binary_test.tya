import unittest/*

class HexBinaryTest extends TestCase

  test_hex_lower: ->
    self.assert_equal(255, 0xff, "0xff")
    self.assert_equal(51966, 0xcafe, "0xcafe")
  test_hex_upper: ->
    self.assert_equal(255, 0xFF, "0xFF")
    self.assert_equal(15, 0x0F, "0x0F")
  test_hex_mixed_case: ->
    self.assert_equal(43981, 0xaBcD, "mixed case")
  test_binary: ->
    self.assert_equal(10, 0b1010, "0b1010")
    self.assert_equal(255, 0b11111111, "0b11111111")
    self.assert_equal(0, 0b0, "0b0")
  test_binary_upper_prefix: ->
    self.assert_equal(5, 0B101, "0B101")
  test_underscore_decimal: ->
    self.assert_equal(1000000, 1_000_000, "1_000_000")
  test_underscore_hex: ->
    self.assert_equal(16772829, 0xff_ee_dd, "0xff_ee_dd")
  test_underscore_binary: ->
    self.assert_equal(255, 0b1111_1111, "0b1111_1111")
  test_underscore_float: ->
    self.assert_equal(1000.5, 1_000.5, "1_000.5")
  test_negative_hex: ->
    self.assert_equal(-255, -0xff, "-0xff")
  test_equivalence: ->
    self.assert(255 == 0xff, "decimal == hex")
    self.assert(255 == 0b1111_1111, "decimal == binary")
  test_kind: ->
    self.assert_equal(Number, 0xff.class, "hex is number")
    self.assert_equal(Number, 0b10.class, "binary is number")
  test_bit_ops_with_hex: ->
    self.assert_equal(0xf0, 0xff & 0xf0, "and")
    self.assert_equal(0xff, 0x0f | 0xf0, "or")
    self.assert_equal(16, 1 << 4, "shift")
