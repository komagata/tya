import unittest
import hex

module stdlib_hex_test
  test_encode_string = ->
    unittest.assert_equal("547961", hex.encode("Tya"), "encode string")
    unittest.assert_equal("", hex.encode(""), "empty")
  test_encode_bytes = ->
    unittest.assert_equal("547961", hex.encode(b"Tya"), "encode bytes")
    unittest.assert_equal("0001ff", hex.encode(b"\x00\x01\xff"), "binary")
  test_decode_returns_bytes = ->
    decoded = hex.decode("547961")
    unittest.assert_equal("bytes", kind(decoded), "decode returns bytes")
    unittest.assert_equal("Tya", bytes_text(decoded), "decoded value")
  test_decode_uppercase = ->
    unittest.assert_equal("Tya", bytes_text(hex.decode("547961")), "lowercase")
  test_round_trip = ->
    text = "hello world"
    unittest.assert_equal(text, bytes_text(hex.decode(hex.encode(text))), "round trip")
