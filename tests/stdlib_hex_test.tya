import unittest
import hex as hex

class StdlibHexTest extends TestCase

  test_encode_string = ->
    self.assert_equal("547961", hex.Hex.encode("Tya"), "encode string")
    self.assert_equal("", hex.Hex.encode(""), "empty")
  test_encode_bytes = ->
    self.assert_equal("547961", hex.Hex.encode(b"Tya"), "encode bytes")
    self.assert_equal("0001ff", hex.Hex.encode(b"\x00\x01\xff"), "binary")
  test_decode_returns_bytes = ->
    decoded = hex.Hex.decode("547961")
    self.assert_equal([84, 121, 97], bytes_array(decoded), "decode returns bytes")
    self.assert_equal("Tya", bytes_text(decoded), "decoded value")
  test_decode_uppercase = ->
    self.assert_equal("Tya", bytes_text(hex.Hex.decode("547961")), "lowercase")
  test_round_trip = ->
    text = "hello world"
    self.assert_equal(text, bytes_text(hex.Hex.decode(hex.Hex.encode(text))), "round trip")
