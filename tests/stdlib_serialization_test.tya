import unittest
import serialization as serialization

class SavePlayer
  initialize = name, score ->
    self.name = name
    self.score = score

class HookedPlayer
  initialize = name ->
    self.name = name

  to_serialized = ->
    return { name: self.name.upper() }

  static from_serialized = data ->
    return HookedPlayer(data["name"].lower())

class StdlibSerializationTest extends TestCase

  test_data_and_json_primitives = ->
    data = { name: "tya", nums: [1, 2], ok: true, none: nil }
    out = serialization.Serializer.to_data(data)
    self.assert_equal(data, out, "to_data")
    parsed = serialization.Serializer.from_json(serialization.Serializer.to_json(data), nil)
    self.assert_equal(data, parsed, "json")

  test_class_fields = ->
    player = SavePlayer("Ada", 7)
    data = serialization.Serializer.to_data(player)
    self.assert_equal({ name: "Ada", score: 7 }, data, "class data")
    restored = serialization.Serializer.from_data(data, SavePlayer)
    self.assert_equal(SavePlayer, restored.class, "class")
    self.assert_equal("Ada", restored.name, "name")
    self.assert_equal(7, restored.score, "score")

  test_hooks = ->
    player = HookedPlayer("ada")
    data = serialization.Serializer.to_data(player)
    self.assert_equal({ name: "ADA" }, data, "hook data")
    restored = serialization.Serializer.from_data({ name: "ADA" }, HookedPlayer)
    self.assert_equal(HookedPlayer, restored.class, "hook class")
    self.assert_equal("ada", restored.name, "hook name")

  test_options = ->
    player = SavePlayer("Ada", 7)
    data = serialization.Serializer.to_data(player, { include_class: true, class_key: "_type", fields: ["name"] })
    self.assert_equal({ _type: "SavePlayer", name: "Ada" }, data, "options")
    restored = serialization.Serializer.from_data({ name: "Ada" }, SavePlayer, { defaults: { score: 10 } })
    self.assert_equal(10, restored.score, "default")
    self.assert_raises(-> serialization.Serializer.from_data({ extra: 1 }, SavePlayer, { strict_fields: true }), "unknown field")
    self.assert_raises(-> serialization.Serializer.to_data(SavePlayer("Ada", 7), { unknown: true }), "unknown option")

  test_bytes = ->
    value = bytes_of("tya")
    self.assert_raises(-> serialization.Serializer.to_data(bytes_of("tya")), "bytes require")
    self.assert_equal([116, 121, 97], serialization.Serializer.to_data(value, { bytes: "array" }), "bytes array")
    self.assert_equal("dHlh", serialization.Serializer.to_data(value, { bytes: "base64" }), "bytes base64")

  test_cycles_and_unsupported = ->
    self.assert_raises(-> StdlibSerializationTest.cyclic_to_data(), "cycle detected")
    self.assert_raises(-> serialization.Serializer.to_data(-> 1), "unsupported function")

  test_toml = ->
    text = serialization.Serializer.to_toml({ name: "tya", port: 8080 })
    restored = serialization.Serializer.from_toml(text, nil)
    self.assert_equal("tya", restored["name"], "toml name")
    self.assert_equal(8080, restored["port"], "toml port")

  static cyclic_to_data = ->
    values = []
    values.push(values)
    return serialization.Serializer.to_data(values)
