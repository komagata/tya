import unittest/* as *
import serializer

class SavePlayer
  name: nil
  score: nil

  initialize: player_name, player_score ->
    self.name = player_name
    self.score = player_score

class HookedPlayer
  name: nil

  static from_serialized: data ->
    return HookedPlayer(data["name"].lower())

  initialize: player_name ->
    self.name = player_name

  to_serialized: ->
    return { name: self.name.upper() }

class SerializablePlayer implements Serializable
  name: nil
  score: nil

  initialize: player_name, player_score ->
    self.name = player_name
    self.score = player_score

  to_data: ->
    return { name: self.name, score: self.score, kind: "serializable" }

class DualHookPlayer implements Serializable
  to_data: ->
    return { hook: "to_data" }

  to_serialized: ->
    return { hook: "to_serialized" }

class ObjectData implements Serializable
  to_data: ->
    return SavePlayer("Ada", 7)

class StdlibSerializationTest extends TestCase
  static cyclic_to_data: ->
    values = []
    values.push(values)
    return serializer.Serializer(nil).serialize(values)

  test_bytes: ->
    value = bytes_of("tya")
    self.assert_raises(
      () -> serializer.Serializer(nil).serialize(bytes_of("tya")),
      "bytes require"
    )
    self.assert_equal(
      [116, 121, 97],
      serializer.Serializer(nil).serialize(value, { bytes: "array" }),
      "bytes array"
    )
    self.assert_equal(
      "dHlh",
      serializer.Serializer(nil).serialize(value, { bytes: "base64" }),
      "bytes base64"
    )

  test_class_fields: ->
    player = SavePlayer("Ada", 7)
    data = serializer.Serializer(nil).serialize(player)
    self.assert_equal({ name: "Ada", score: 7 }, data, "class data")
    restored = serializer.Serializer(nil).deserialize(data, SavePlayer)
    self.assert_equal(SavePlayer, restored.class, "class")
    self.assert_equal("Ada", restored.name, "name")
    self.assert_equal(7, restored.score, "score")

  test_cycles_and_unsupported: ->
    cycle = ->
      values = []
      values.push(values)
      serializer.Serializer(nil).serialize(values)
    self.assert_raises(cycle, "cycle detected")
    self.assert_raises(
      () -> serializer.Serializer(nil).serialize(() -> 1),
      "unsupported function"
    )

  test_data_and_json_primitives: ->
    data = { name: "tya", nums: [1, 2], ok: true, none: nil }
    out = serializer.Serializer(nil).serialize(data)
    self.assert_equal(data, out, "to_data")
    parsed = serializer.Serializer(nil).from_json(
      serializer.Serializer(nil).to_json(data),
      nil
    )
    self.assert_equal(data, parsed, "json")

  test_hooks: ->
    player = HookedPlayer("ada")
    data = serializer.Serializer(nil).serialize(player)
    self.assert_equal({ name: "ADA" }, data, "hook data")
    restored = serializer.Serializer(nil).deserialize(
      { name: "ADA" },
      HookedPlayer
    )
    self.assert_equal(HookedPlayer, restored.class, "hook class")
    self.assert_equal("ada", restored.name, "hook name")

  test_options: ->
    player = SavePlayer("Ada", 7)
    data = serializer.Serializer(nil).serialize(
      player,
      { include_class: true, class_key: "_type", fields: ["name"] }
    )
    self.assert_equal({ _type: "SavePlayer", name: "Ada" }, data, "options")
    restored = serializer.Serializer(nil).deserialize(
      { name: "Ada" },
      SavePlayer,
      { defaults: { score: 10 } }
    )
    self.assert_equal(10, restored.score, "default")
    self.assert_raises(
      () -> serializer.Serializer(nil).deserialize({ extra: 1 }, SavePlayer, { strict_fields: true }),
      "unknown field"
    )
    self.assert_raises(
      () -> serializer.Serializer(nil).serialize(SavePlayer("Ada", 7), { unknown: true }),
      "unknown option"
    )

  test_serializable_interface: ->
    player = SerializablePlayer("Ada", 7)
    data = serializer.Serializer(nil).serialize(player)
    self.assert_equal(
      { name: "Ada", score: 7, kind: "serializable" },
      data,
      "serializable data"
    )
    self.assert_equal(
      { hook: "to_data" },
      serializer.Serializer(nil).serialize(DualHookPlayer()),
      "to_data precedence"
    )
    self.assert_raises(
      () -> serializer.Serializer(nil).serialize(ObjectData()),
      "to_data returned unsupported object"
    )

  test_toml: ->
    text = serializer.Serializer(nil).to_toml({ name: "tya", port: 8080 })
    restored = serializer.Serializer(nil).from_toml(text, nil)
    self.assert_equal("tya", restored["name"], "toml name")
    self.assert_equal(8080, restored["port"], "toml port")
