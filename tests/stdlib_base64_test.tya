import unittest
import base64

module stdlib_base64_test
  test_encode_basic = ->
    unittest.assert_equal("aGVsbG8=", base64.encode("hello"), "encode hello")
  test_encode_two = ->
    unittest.assert_equal("aGk=", base64.encode("hi"), "encode 2 bytes")
  test_encode_one = ->
    unittest.assert_equal("aA==", base64.encode("h"), "encode 1 byte")
  test_encode_empty = ->
    unittest.assert_equal("", base64.encode(""), "empty")
  test_decode_basic = ->
    unittest.assert_equal("hello", base64.decode("aGVsbG8="), "decode hello")
  test_decode_no_padding = ->
    unittest.assert_equal("hi", base64.decode("aGk"), "no padding")
  test_decode_with_whitespace = ->
    unittest.assert_equal("hello world", base64.decode("aGVsbG8gd29ybGQ="), "longer")
  test_round_trip = ->
    text = "The quick brown fox"
    unittest.assert_equal(text, base64.decode(base64.encode(text)), "round trip")
