import option_parser
import unittest/* as *

class StdlibOptionParserTest extends TestCase
  test_arguments_and_double_dash: ->
    result = option_parser.OptionParser.parse(["src", "--", "--literal", "-x"])
    assert_equal(["src", "--literal", "-x"], result.arguments, "arguments")
    assert_equal([], result.options, "options")

  test_instance_parse_bang_resets_previous_state: ->
    parser = option_parser.OptionParser.parse(["-a", "one"])
    parser.parse!(["--name=tya", "two"])
    assert_equal(["--name=tya", "two"], parser.args, "args")
    assert_equal(1, parser.options.len(), "option count")
    assert_equal("long", parser.options[0].kind, "kind")
    assert_equal("name", parser.options[0].name, "name")
    assert_equal("tya", parser.options[0].value, "value")
    assert_equal(["two"], parser.arguments, "arguments")

  test_long_options: ->
    result = option_parser.OptionParser.parse(["--verbose", "--output=dist"])
    assert_equal(["--verbose", "--output=dist"], result.args, "args")
    assert_equal(2, result.options.len(), "option count")
    assert_equal("long", result.options[0].kind, "verbose kind")
    assert_equal("verbose", result.options[0].name, "verbose name")
    assert_equal(true, result.options[0].value, "verbose value")
    assert_equal("--verbose", result.options[0].raw, "verbose raw")
    assert_equal("long", result.options[1].kind, "output kind")
    assert_equal("output", result.options[1].name, "output name")
    assert_equal("dist", result.options[1].value, "output value")
    assert_equal("--output=dist", result.options[1].raw, "output raw")

  test_short_cluster: ->
    result = option_parser.OptionParser.parse(["-abc"])
    assert_equal(3, result.options.len(), "option count")
    assert_equal("short", result.options[0].kind, "a kind")
    assert_equal("a", result.options[0].name, "a name")
    assert_equal(true, result.options[0].value, "a value")
    assert_equal("-a", result.options[0].raw, "a raw")
    assert_equal("b", result.options[1].name, "b name")
    assert_equal("-b", result.options[1].raw, "b raw")
    assert_equal("c", result.options[2].name, "c name")
    assert_equal("-c", result.options[2].raw, "c raw")

  test_single_dash_is_argument: ->
    result = option_parser.OptionParser.parse(["-", "-v"])
    assert_equal(["-"], result.arguments, "arguments")
    assert_equal(1, result.options.len(), "option count")
    assert_equal("v", result.options[0].name, "name")
