import unittest
import cli as cli

class StdlibCliTest extends TestCase

  spec = ->
    options = {}
    options["verbose"] = { type: "bool", alias: "v", help: "verbose output" }
    options["output"] = { type: "string", alias: "o", required: true }
    options["count"] = { type: "int", default: 1 }
    options["ratio"] = { type: "float" }
    options["tag"] = { type: "array", alias: "t" }
    options["color"] = { type: "bool", default: true }
    out =
      options: options
      positionals: ["input"]
      stop_at_double_dash: true
    return out

  test_long_and_equals = ->
    result = cli.Cli(["--verbose", "--output=dist", "--count", "3", "src"]).parse(self.spec())
    self.assert_equal(true, result["options"]["verbose"], "verbose")
    self.assert_equal("dist", result["options"]["output"], "output")
    self.assert_equal(3, result["options"]["count"], "count")
    self.assert_equal(["src"], result["positionals"], "positionals")
    self.assert_equal([], result["errors"], "errors")

  test_short_grouped_bool_and_value = ->
    result = cli.Cli(["-v", "-t", "one", "-ttwo", "-o", "out"]).parse(self.spec())
    self.assert_equal(true, result["options"]["verbose"], "verbose")
    self.assert_equal("out", result["options"]["output"], "output")
    self.assert_equal(["one", "two"], result["options"]["tag"], "tag")

  test_no_flag_and_double_dash = ->
    result = cli.Cli(["--no-color", "-o", "out", "--", "--literal", "x"]).parse(self.spec())
    self.assert_equal(false, result["options"]["color"], "color")
    self.assert_equal(["--literal", "x"], result["rest"], "rest")

  test_required_and_unknown_errors = ->
    result = cli.Cli(["--missing"]).parse(self.spec())
    self.assert_equal(2, result["errors"].len(), "error count")
    self.assert_equal("unknown_option", result["errors"][0]["kind"], "unknown")
    self.assert_equal("required", result["errors"][1]["kind"], "required")

  test_allow_unknown = ->
    spec = self.spec()
    spec["allow_unknown"] = true
    result = cli.Cli(["--other", "-o", "out"]).parse(spec)
    self.assert_equal(["--other"], result["rest"], "rest")
    self.assert_equal([], result["errors"], "errors")

  test_usage = ->
    text = cli.Cli("tool").usage(self.spec())
    self.assert(text.contains("Usage: tool [options] <input>"), "usage line")
    self.assert(text.contains("-o, --output <string> (required)"), "required")
    self.assert(text.contains("--count <int> (default: 1)"), "default")
