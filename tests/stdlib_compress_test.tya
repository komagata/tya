import unittest
import compress as compress
import file as file

class StdlibCompressTest extends TestCase

  test_gzip_round_trip_string = ->
    data = compress.Compress("hello gzip").gzip_compress()
    self.assert(data.len() > 0, "gzip returns bytes")
    self.assert_equal("hello gzip", bytes_text(compress.Compress(data).gzip_decompress()), "gzip round trip")

  test_gzip_round_trip_bytes = ->
    data = compress.Compress(b"\x00\x01data").gzip_compress()
    self.assert_equal([0, 1, 100, 97, 116, 97], bytes_array(compress.Compress(data).gzip_decompress()), "bytes round trip")

  test_zlib_round_trip = ->
    data = compress.Compress("hello zlib").zlib_compress()
    self.assert_equal("hello zlib", bytes_text(compress.Compress(data).zlib_decompress()), "zlib round trip")

  test_invalid_input_raises = ->
    self.assert_raises(() -> compress.Compress(b"not gzip").gzip_decompress())
    self.assert_raises(() -> compress.Compress(b"not zlib").zlib_decompress())

  test_file_helpers = ->
    src = "compress_src.txt"
    gz = "compress_src.txt.gz"
    dst = "compress_dst.txt"
    file.File(src).write("file contents")
    compress.Compress(src).gzip_compress_file(gz)
    compress.Compress(gz).gzip_decompress_file(dst)
    self.assert_equal("file contents", file.File(dst).read(), "file round trip")
    file.File(src).remove()
    file.File(gz).remove()
    file.File(dst).remove()
