import unittest
import collections as collections

class StdlibCollectionsTest extends TestCase

  test_stack: ->
    stack = collections.Stack(nil)
    self.assert_equal(collections.Stack, stack.class, "class")
    self.assert(stack.empty?(), "empty")
    stack.push("first").push(nil).push("last")
    self.assert_equal(3, stack.len(), "len")
    self.assert_equal(["first", nil, "last"], stack.to_array(), "array")
    self.assert_equal("last", stack.peek(), "peek")
    self.assert_equal("last", stack.pop(), "pop last")
    self.assert_equal(nil, stack.pop(), "pop nil")
    self.assert_equal("first", stack.pop(), "pop first")
    self.assert_raises(-> collections.Stack(nil).pop(), "empty stack")
    from = collections.Stack([1, 2, 3])
    self.assert_equal(3, from.pop(), "from array")
    self.assert(from.clear().empty?(), "clear")

  test_queue: ->
    queue = collections.Queue(nil)
    self.assert_equal(collections.Queue, queue.class, "class")
    queue.push("a").push("b").push(nil)
    self.assert_equal(["a", "b", nil], queue.to_array(), "array")
    self.assert_equal("a", queue.peek(), "peek")
    self.assert_equal("a", queue.pop(), "pop a")
    self.assert_equal("b", queue.pop(), "pop b")
    self.assert_equal(nil, queue.pop(), "pop nil")
    self.assert(queue.empty?(), "empty")
    self.assert_raises(-> collections.Queue(nil).peek(), "empty queue")
    from = collections.Queue([1, 2, 3])
    self.assert_equal(1, from.pop(), "from array")
    self.assert_equal([2, 3], from.to_array(), "remaining")
    self.assert_equal(0, from.clear().len(), "clear")

  test_deque: ->
    deque = collections.Deque(nil)
    self.assert_equal(collections.Deque, deque.class, "class")
    deque.push_back("b").push_front("a").push_back("c")
    self.assert_equal(["a", "b", "c"], deque.to_array(), "array")
    self.assert_equal("a", deque.peek_front(), "peek front")
    self.assert_equal("c", deque.peek_back(), "peek back")
    self.assert_equal("a", deque.pop_front(), "pop front")
    self.assert_equal("c", deque.pop_back(), "pop back")
    self.assert_equal("b", deque.pop_front(), "last")
    self.assert_raises(-> collections.Deque(nil).pop_back(), "empty deque")
    from = collections.Deque([1, 2])
    self.assert_equal(1, from.pop_front(), "from front")
    self.assert_equal(2, from.pop_back(), "from back")
    self.assert(from.clear().empty?(), "clear")

  test_set: ->
    seen = collections.Set(["a", "b", "a", nil])
    self.assert_equal(collections.Set, seen.class, "class")
    self.assert_equal(3, seen.len(), "unique")
    self.assert(seen.has?("a"), "has")
    self.assert(seen.has?(nil), "has nil")
    self.assert_equal(["a", "b", nil], seen.to_array(), "order")
    self.assert(seen.delete("b"), "delete")
    self.assert(not seen.delete("b"), "delete absent")
    self.assert_equal(["a", nil], seen.to_array(), "after delete")
    seen.add("c").add("a")
    self.assert_equal(["a", nil, "c"], seen.to_array(), "after add")

    left = collections.Set([1, 2, 3])
    right = collections.Set([3, 4])
    self.assert_equal([1, 2, 3, 4], left.union(right).to_array(), "union")
    self.assert_equal([3], left.intersection(right).to_array(), "intersection")
    self.assert_equal([1, 2], left.difference(right).to_array(), "difference")
    self.assert(collections.Set([1, 3]).subset?(left), "subset")
    self.assert(not right.subset?(left), "not subset")
    self.assert(seen.clear().empty?(), "clear")

  test_priority_queue: ->
    pq = collections.PriorityQueue(nil)
    self.assert_equal(collections.PriorityQueue, pq.class, "class")
    self.assert(pq.empty?(), "empty")
    pq.push("medium", 5).push("first-low", 1).push("second-low", 1).push("high", 10)
    self.assert_equal(4, pq.len(), "len")
    self.assert_equal("first-low", pq.peek(), "peek")
    self.assert_equal(1, pq.peek_priority(), "peek priority")
    self.assert_equal([[1, "first-low"], [1, "second-low"], [5, "medium"], [10, "high"]], pq.to_array(), "order")
    self.assert_equal(4, pq.len(), "to array does not mutate")
    self.assert_equal("first-low", pq.pop(), "stable first")
    self.assert_equal("second-low", pq.pop(), "stable second")
    self.assert_equal("medium", pq.pop(), "medium")
    self.assert_equal("high", pq.pop(), "high")
    self.assert_raises(-> collections.PriorityQueue(nil).pop(), "empty priority queue")
    self.assert_raises(-> collections.PriorityQueue(nil).push("bad", "low"), "priority must be a number")

    from = collections.PriorityQueue([[2, "b"], [1, "a"], [1, "c"]])
    self.assert_equal(["a", "c", "b"], [from.pop(), from.pop(), from.pop()], "from array")
    self.assert(from.clear().empty?(), "clear")
