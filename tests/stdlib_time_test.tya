import unittest/*
import time

class StdlibTimeTest extends TestCase

  test_now_returns_positive: ->
    self.assert(time.Time().now().unix() > 1700000000, "epoch is recent")
  test_format_iso: ->
    self.assert_equal("1970-01-01T00:00:00Z", time.Time(0).format("iso"), "epoch iso")
  test_format_date: ->
    self.assert_equal("1970-01-01", time.Time(0).format("date"), "epoch date")
  test_parse_iso: ->
    self.assert_equal(0, time.Time("1970-01-01T00:00:00Z").parse().unix(), "parse epoch")
  test_parse_date: ->
    self.assert_equal(0, time.Time("1970-01-01").parse("date").unix(), "parse date")
  test_since_zero: ->
    n = time.Time().now()
    elapsed = time.Time(n).since()
    self.assert(elapsed.seconds() >= 0, "since non-negative")
