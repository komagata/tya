import unittest
import time as time

class StdlibTimeTest extends TestCase

  test_now_returns_positive = ->
    self.assert(time.Time.now().unix() > 1700000000, "epoch is recent")
  test_format_iso = ->
    self.assert_equal("1970-01-01T00:00:00Z", time.Time.format(0, "iso"), "epoch iso")
  test_format_date = ->
    self.assert_equal("1970-01-01", time.Time.format(0, "date"), "epoch date")
  test_parse_iso = ->
    self.assert_equal(0, time.Time.parse("1970-01-01T00:00:00Z").unix(), "parse epoch")
  test_parse_date = ->
    self.assert_equal(0, time.Time.parse("1970-01-01", "date").unix(), "parse date")
  test_since_zero = ->
    n = time.Time.now()
    elapsed = time.Time.since(n)
    self.assert(elapsed.seconds() >= 0, "since non-negative")
