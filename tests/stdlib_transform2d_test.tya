import unittest/* as unittest
import geometry/*
import matrix
import transform2_d as transform2d

class StdlibTransform2DTest extends TestCase

  test_constructors_and_fields: ->
    t = Transform2D(1, 2, 3, 4, 5, 6)
    self.assert_equal(Transform2D, t.class, "class")
    self.assert_equal([1, 2, 3, 4, 5, 6], t.to_array(), "array")
    self.assert(t.equal?(Transform2D(1, 0, 0, 1, 0, 0).from_array([1, 2, 3, 4, 5, 6])), "equal")

  test_basic_transforms: ->
    identity = Transform2D(1, 0, 0, 1, 0, 0).identity()
    translation = Transform2D(1, 0, 0, 1, 0, 0).translation(10, 20)
    scale = Transform2D(1, 0, 0, 1, 0, 0).scale(2, 3)
    uniform = Transform2D(1, 0, 0, 1, 0, 0).uniform_scale(4)
    self.assert_equal([1, 0, 0, 1, 0, 0], identity.to_array(), "identity")
    self.assert_equal([1, 0, 0, 1, 10, 20], translation.to_array(), "translation")
    self.assert_equal([2, 0, 0, 3, 0, 0], scale.to_array(), "scale")
    self.assert_equal([4, 0, 0, 4, 0, 0], uniform.to_array(), "uniform")
    self.assert(Transform2D(1, 0, 0, 1, 0, 0).rotation(3.141592653589793 / 2).nearly_equal?(Transform2D(0, 1, -1, 0, 0, 0), 0.0000001), "rotation")

  test_compose_order_and_apply: ->
    translation = Transform2D(1, 0, 0, 1, 0, 0).translation(10, 0)
    scale = Transform2D(1, 0, 0, 1, 0, 0).scale(2, 2)
    world = translation.compose(scale)
    moved = world.apply_point(geometry.Point(3, 4))
    vector = world.apply_vector2(geometry.Vector2(3, 4))
    self.assert_equal([16, 8], moved.to_vector().to_array(), "point applies b then a")
    self.assert_equal([6, 8], vector.to_array(), "vector ignores translation")

  test_rotation_around_and_skew: ->
    center = geometry.Point(10, 10)
    around = Transform2D(1, 0, 0, 1, 0, 0).rotation_around(3.141592653589793 / 2, center)
    moved = around.apply_point(geometry.Point(11, 10))
    self.assert(Transform2D(1, 0, 0, 1, 0, 0).skew(0, 0).nearly_equal?(Transform2D(1, 0, 0, 1, 0, 0).identity(), 0.0000001), "zero skew")
    self.assert_equal([10, 11], [moved.x.round(), moved.y.round()], "rotate around")

  test_rect_size_and_matrix: ->
    t = Transform2D(1, 0, 0, 1, 0, 0).translation(5, 6).compose(Transform2D(1, 0, 0, 1, 0, 0).scale(2, 3))
    rect = t.apply_rect(geometry.Rect(0, 0, 10, 4))
    size = t.apply_size(geometry.Size(10, 4))
    m = t.to_matrix()
    roundtrip = Transform2D(1, 0, 0, 1, 0, 0).from_matrix(m)
    self.assert_equal([5, 6, 20, 12], [rect.x, rect.y, rect.width, rect.height], "rect")
    self.assert_equal([20, 12], [size.width, size.height], "size")
    self.assert_equal(matrix.Matrix, m.class, "matrix")
    self.assert(t.equal?(roundtrip), "matrix roundtrip")

  test_inverse: ->
    t = Transform2D(1, 0, 0, 1, 0, 0).translation(10, 20).compose(Transform2D(1, 0, 0, 1, 0, 0).scale(2, 4))
    inv = t.inverse()
    p = geometry.Point(7, 8)
    restored = inv.apply_point(t.apply_point(p))
    self.assert(t.invertible?(), "invertible")
    self.assert_equal([7, 8], [restored.x, restored.y], "inverse")
    self.assert_raises(-> Transform2D(1, 0, 0, 1, 0, 0).scale(0, 1).inverse(), "non-invertible")

  test_errors: ->
    self.assert_raises(-> Transform2D("x", 0, 0, 1, 0, 0), "non-number")
    self.assert_raises(-> Transform2D(1, 0, 0, 1, 0, 0).from_array([1, 2]), "array")
    self.assert_raises(-> Transform2D(1, 0, 0, 1, 0, 0).from_matrix(matrix.Matrix().identity(2)), "matrix")
