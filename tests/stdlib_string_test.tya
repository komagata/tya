import unittest/*

class StdlibStringTest extends TestCase

  test_blank_for_whitespace: ->
    self.assert(" ".blank?(), "blank for spaces")
  test_present_for_content: ->
    self.assert("tya".present?(), "present for content")
  test_blank_returns_false_for_content: ->
    self.assert_equal(false, "tya".blank?(), "blank false")
  test_present_returns_true_for_content: ->
    self.assert_equal(true, "tya".present?(), "present true")
