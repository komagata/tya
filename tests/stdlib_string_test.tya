import unittest
import string

module stdlib_string_test
  test_blank_for_whitespace = ->
    unittest.Unittest.assert(string.String.blank(" "), "blank for spaces")
  test_present_for_content = ->
    unittest.Unittest.assert(string.String.present("tya"), "present for content")
  test_blank_returns_false_for_content = ->
    unittest.Unittest.assert_equal(false, string.String.blank("tya"), "blank false")
  test_present_returns_true_for_content = ->
    unittest.Unittest.assert_equal(true, string.String.present("tya"), "present true")
