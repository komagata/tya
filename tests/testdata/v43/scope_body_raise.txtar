# v0.43 STEP 2: a synchronous raise from a scope body still calls
# tya_scope_raise so siblings are cancelled and joined before control
# unwinds.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout 'caught: body raise'
stdout 'fast: true'
stdout 'after'

-- sample.tya --
import task as task
import time as time

cooperative_worker = () ->
  me = task.Task.current()
  i = 0
  while not me.cancelled?()
    i = i + 1
    if i % 1000 == 0
      time.Time.sleep(0.001)
  return i

start = time.Time.now()
try
  scope
    t = spawn cooperative_worker()
    raise error("body raise")
  print("unreachable")
catch e
  elapsed = time.Time.now() - start
  print("caught: " + e["message"])
  print("fast: " + (elapsed < 1.0).to_s())
print("after")
