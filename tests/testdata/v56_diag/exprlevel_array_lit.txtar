# v0.56 expression-level recovery in array literal elements.
# Each broken element records a parser diagnostic and recovery
# skips to the next comma so the rest of the array is still parsed.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
cd $WORK

! exec $WORK/tya check bad.tya
stderr -count=3 'expected instance field name'

-- bad.tya --
xs = [@, @, @]
