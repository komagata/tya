# v0.56 expression-level recovery in dict literal property values.
# Each broken prop value records a parser diagnostic and recovery
# skips to the next comma so the rest of the dict is still parsed.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
cd $WORK

! exec $WORK/tya check bad.tya
stderr -count=3 'expected instance field name'

-- bad.tya --
d = {a: @, b: @, c: @}
