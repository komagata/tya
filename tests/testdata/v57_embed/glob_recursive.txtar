# v0.57 embed "static/**" as assets recursively reads files under
# static/, returning a dict<string, bytes> keyed by paths relative
# to the source file's directory.
cd $REPO
exec go run ./cmd/tya run $WORK/main.tya
stdout 'static/css/main.css'
stdout 'static/index.html'
stdout 'static/css/main\.[0-9a-f]{16}\.css'
stdout 'text/html; charset=utf-8'

exec go run ./cmd/tya embed --list --format=json $WORK/main.tya
stdout '"binding": "packed"'
stdout '"source_path": "static/index.html"'

-- static/index.html --
<h1>hi</h1>
-- static/css/main.css --
body{}
-- main.tya --
embed "static/**" as assets
for entry in assets
  print(entry["key"])

embed "static/**" as packed with { gzip: true, hash: true, minify: true }
for entry in packed
  if entry["key"] == "static/css/main.css"
    print(entry["value"]["hashed_path"])
  if entry["key"] == "static/index.html"
    print(entry["value"]["content_type"])
