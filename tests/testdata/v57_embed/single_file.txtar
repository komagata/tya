# v0.57 embed "path" as name reads the file at codegen time and
# binds the bytes to the given name. bytes.Bytes.to_string recovers the
# original text.
cd $REPO
exec go run ./cmd/tya run $WORK/main.tya
stdout 'hello tya embed'
stdout 'data.txt'
stdout 'text/plain; charset=utf-8'
stdout 'hash len: 64'

-- data.txt --
hello tya embed
-- main.tya --
import bytes

embed "data.txt" as payload
print(bytes.Bytes(payload).to_string())

embed "data.txt" as meta with { hash: true, gzip: true }
print(meta["path"])
print(meta["content_type"])
print("hash len: " + meta["hash"].len().to_s())
