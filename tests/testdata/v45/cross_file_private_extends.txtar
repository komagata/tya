# v0.45 M5: a sibling class file inside the same package cannot
# extend a class that is private to another file (extends variant).
cd $REPO

! exec go run ./cmd/tya run $WORK/main.tya
stderr 'TYA-E0406'
stderr 'private class'

-- main.tya --
import pkg/*

print(Util.run())

-- pkg/util.tya --
class Util
  static run: ->
    s = Sub()
    s.tag()

class Sub extends Base
  initialize: ->
    super()

-- pkg/helper.tya --
class Helper
  t: nil

  static noop: ->
    "noop"

class Base
  t: nil

  initialize: ->
    self.t = "b"

  tag: ->
    self.t
