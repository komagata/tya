# v0.45 M5: a private class cannot be reached from outside the
# package (the entry script tries to call Internal which is a
# private sibling of pkg.Util).
cd $REPO

! exec go run ./cmd/tya run $WORK/main.tya
stderr 'TYA-E0406'
stderr 'private class'

-- main.tya --
import pkg/*

print(Internal.do_work())

-- pkg/util.tya --
class Util
  static run: ->
    "ok"

-- pkg/helper.tya --
class Helper
  static noop: ->
    "noop"

class Internal
  static do_work: ->
    "leak"
