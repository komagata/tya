# v0.14-era destructuring assignment is excluded from the v1 syntax surface.
cd $REPO

! exec go run ./cmd/tya run $WORK/destructuring.tya
stderr 'destructuring assignment is not part of Tya v1.0.0'

! exec go run ./cmd/tya run $WORK/bad_array_len.tya
stderr 'destructuring assignment is not part of Tya v1.0.0'

! exec go run ./cmd/tya run $WORK/bad_dict_missing.tya
stderr 'destructuring assignment is not part of Tya v1.0.0'

! exec go run ./cmd/tya check $WORK/bad_dict_key.tya
stderr 'destructuring assignment is not part of Tya v1.0.0'

! exec go run ./cmd/tya check $WORK/bad_mixed.tya
stderr 'destructuring assignment is not part of Tya v1.0.0'

exec go run ./cmd/tya version
stdout '0.72.15\n'
! stderr .

-- destructuring.tya --
user = {name: "ada", age: 31, email: "ada@example.test"}
{"name": name, "age": age} = user
print(name)
print(age)

[first, _, third] = ["x", "ignored", "left"]
print(first)
print(third)

[outer, {"name": nested_name}] = [["nested"], user]
[nested] = outer
print(nested)
print(nested_name)

name = "changed"
print(name)

run = ->
  [local, value] = ["local", 7]
  print(value)
  print(local)

run()

-- bad_array_len.tya --
[name, age] = ["ada"]

-- bad_dict_missing.tya --
{"name": name, "email": email} = {name: "ada"}

-- bad_dict_key.tya --
{name: value} = {name: "ada"}

-- bad_mixed.tya --
[name, age], other = [["ada", 31], "x"]
