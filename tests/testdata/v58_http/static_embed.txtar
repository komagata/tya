# v0.58+ HTTP static serving can serve embedded metadata assets.
[!exec:curl] skip 'curl not on PATH'
[!exec:sh] skip 'sh not on PATH'
cd $REPO

exec go run ./cmd/tya build $WORK/main.tya -o $WORK/server
exec sh -c '$WORK/server & pid=$!; sleep 1; curl -s -D "$WORK/headers" -m 5 --retry 5 --retry-connrefused http://localhost:18084/assets/static/app.css; curl -s -o /dev/null -D "$WORK/gzip_headers" -H "Accept-Encoding: gzip" -m 5 --retry 5 --retry-connrefused http://localhost:18084/assets/static/app.css; ret=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; exit $ret'
stdout 'body \{ color: red; \}'
exec cat $WORK/headers
stdout 'Content-Type: text/css'
stdout 'ETag: [0-9a-f]{64}'
exec cat $WORK/gzip_headers
stdout 'Content-Encoding: gzip'

-- static/app.css --
body {
  color: red;
}

-- main.tya --
import net/http as http

embed "static/**" as assets with { hash: true, minify: true, gzip: true }

app = http.Server()
app.static("/assets", assets)
app.run(18084)
