# net/http v2: Client helpers and cooperative server concurrency.
[!exec:sh] skip 'sh not on PATH'
[!exec:curl] skip 'curl not on PATH'
cd $REPO

exec go run ./cmd/tya build $WORK/client_server.tya -o $WORK/client_server
exec go run ./cmd/tya build $WORK/client.tya -o $WORK/client
exec sh -c '$WORK/client_server & pid=$!; sleep 0.2; $WORK/client; client=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; server=$?; test $client -eq 0 && test $server -eq 0'
stdout '201'
stdout 'hello client'
stdout 'chunked body'

exec go run ./cmd/tya build $WORK/concurrent_server.tya -o $WORK/concurrent_server
exec sh -c '$WORK/concurrent_server & pid=$!; (i=0; while [ $i -lt 20 ]; do curl -s -m 2 http://localhost:18092/slow >/tmp/tya-slow-$$ && exit 0; sleep 0.25; i=$((i + 1)); done; exit 1) & slow=$!; sleep 0.1; fast=""; fast_status=1; i=0; while [ $i -lt 20 ]; do fast=$(curl -s -m 0.4 http://localhost:18092/fast); fast_status=$?; [ "$fast_status" -eq 0 ] && break; sleep 0.25; i=$((i + 1)); done; wait $slow; slow_status=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; test "$fast" = fast && exit $((fast_status + slow_status))'

-- client_server.tya --
import net/socket/* as socket

class HttpText
  static cr: ->
    chr(13)

crlf = HttpText.cr() + "\n"
server = socket.Server(nil).listen("127.0.0.1", 18091, {})
conn = server.accept()
line = conn.read_line()
while line != nil and line != crlf and line != "\n"
  line = conn.read_line()
conn.read(7)
conn.write("HTTP/1.1 201 Created" + crlf)
conn.write("Content-Length: 12" + crlf)
conn.write(crlf)
conn.write("hello client")
conn.close()

conn = server.accept()
line = conn.read_line()
while line != nil and line != crlf and line != "\n"
  line = conn.read_line()
conn.write("HTTP/1.1 200 OK" + crlf)
conn.write("Transfer-Encoding: chunked" + crlf)
conn.write(crlf)
conn.write("c" + crlf)
conn.write("chunked body" + crlf)
conn.write("0" + crlf)
conn.write(crlf)
conn.close()
server.close()

-- client.tya --
import net/http/* as http

posted = http.Client("http://127.0.0.1:18091/submit").post("payload")
print(posted["status"])
print(posted["body"])

chunked = http.Client("http://127.0.0.1:18091/chunked").get()
print(chunked["body"])

-- concurrent_server.tya --
import net/http/* as http
import time

app = http.Server()
slow = _req ->
  time.Time().sleep(1)
  return { status: 200, body: "slow" }
app.get("/slow", slow)
app.get("/fast", _req -> { status: 200, body: "fast" })
app.run(18092)
