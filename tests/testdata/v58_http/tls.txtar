# net/http supports HTTPS client requests and TLS server responses.
[!exec:openssl] skip 'openssl not on PATH'
[!exec:sh] skip 'sh not on PATH'
cd $REPO

exec openssl req -x509 -nodes -newkey rsa:2048 -days 1 -subj /CN=127.0.0.1 -addext subjectAltName=IP:127.0.0.1 -keyout $WORK/key.pem -out $WORK/cert.pem
exec go run ./cmd/tya build $WORK/server.tya -o $WORK/server
exec go run ./cmd/tya build $WORK/client.tya -o $WORK/client
exec sh -c '(cd $WORK && ./server) & pid=$!; sleep 1; (cd $WORK && ./client); ret=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; exit $ret'
stdout 'verify_failed'
stdout 'trusted:secure'
stdout 'insecure:secure'

-- server.tya --
import net/http as http

app = http.Server()
app.get("/", _req -> { status: 200, body: "secure" })
app.run_tls(18098, "cert.pem", "key.pem", { host: "127.0.0.1" })

-- client.tya --
import net/http as http

url = "https://127.0.0.1:18098/"
try
  http.Client(url).get()
  print("unexpected")
catch err
  print("verify_failed")

trusted = http.Client(url).request("GET", { ca_file: "cert.pem" })
print("trusted:" + trusted["body"])

insecure = http.Client(url).request("GET", { insecure_skip_verify: true })
print("insecure:" + insecure["body"])
