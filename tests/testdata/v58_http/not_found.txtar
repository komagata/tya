# v0.58 unmatched routes return 404 without invoking any handler.
[!exec:curl] skip 'curl not on PATH'
[!exec:sh] skip 'sh not on PATH'
cd $REPO

exec go run ./cmd/tya build $WORK/main.tya -o $WORK/server
exec sh -c '$WORK/server & pid=$!; sleep 1; curl -s -m 5 -o /dev/null -w "%{http_code}\n" --retry 5 --retry-connrefused http://localhost:18083/missing; ret=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; exit $ret'
stdout '^404$'

-- main.tya --
import net/http/* as http

app = http.Server()
app.get("/", _req -> { status: 200, body: "root" })
app.run(18083)
