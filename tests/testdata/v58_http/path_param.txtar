# v0.58 path params (`/users/:id`) are extracted at dispatch time
# and exposed via `req["params"][name]`.
[!exec:curl] skip 'curl not on PATH'
[!exec:sh] skip 'sh not on PATH'
cd $REPO

exec go run ./cmd/tya build $WORK/main.tya -o $WORK/server
exec sh -c '$WORK/server & pid=$!; sleep 1; curl -s -m 5 --retry 5 --retry-connrefused http://localhost:18081/users/42; ret=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; exit $ret'
stdout 'id=42'

-- main.tya --
import net/http/* as http

handle = req -> { status: 200, body: "id=" + req["params"]["id"] }

app = http.Server()
app.get("/users/:id", handle)
app.run(18081)
