# v0.58 net/http Server: a minimal GET / handler responds with the
# handler's string body.
#
# Test strategy: build the compiled binary up-front via `tya build`
# so we can supervise it directly (no intermediate `tya run`
# wrapper that orphans its child). The shell wrapper launches the
# server, curls it, then kills via the recorded PID.
[!exec:curl] skip 'curl not on PATH'
[!exec:sh] skip 'sh not on PATH'
cd $REPO

exec go run ./cmd/tya build $WORK/main.tya -o $WORK/server
exec sh -c '$WORK/server & pid=$!; sleep 1; curl -s -m 5 --retry 5 --retry-connrefused http://localhost:18080/; ret=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; exit $ret'
stdout 'Hello v58'

-- main.tya --
import net/http

app = http.Server()
app.get("/", _req -> { status: 200, body: "Hello v58" })
app.run(18080)
