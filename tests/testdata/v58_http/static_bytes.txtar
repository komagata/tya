# v0.58+ HTTP static serving can serve v0.57 byte-dictionary embeds.
[!exec:curl] skip 'curl not on PATH'
[!exec:sh] skip 'sh not on PATH'
cd $REPO

exec go run ./cmd/tya build $WORK/main.tya -o $WORK/server
exec sh -c '$WORK/server & pid=$!; sleep 1; curl -s -D "$WORK/headers" -m 5 --retry 5 --retry-connrefused http://localhost:18085/assets/static/app.css; ret=$?; kill $pid 2>/dev/null; wait $pid 2>/dev/null; exit $ret'
stdout 'body \{ color: blue; \}'
exec cat $WORK/headers
stdout 'Content-Type: text/css'

-- static/app.css --
body { color: blue; }

-- main.tya --
import net/http as http

embed "static/**" as assets

app = http.Server()
app.serve_static("/assets", assets)
app.run(18085)
