# v0.32 markdown.to_html: minimal CommonMark subset.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout '<h1>Hello</h1>'
stdout '<p>Some <strong>bold</strong> and <em>em</em> and <code>code</code>'
stdout '<ul>'
stdout '<li>one</li>'
stdout '<ol>'
stdout '<li>first</li>'
stdout '<blockquote>'
stdout '<a href="https://example.com">link</a>'
stdout '<hr/>'
stdout '<pre><code>line &lt;html&gt;'

exec go run ./cmd/tya version
stdout '0.40.0\n'

-- sample.tya --
import markdown

src = """
# Hello

Some **bold** and *em* and `code` and a [link](https://example.com).

- one
- two

1. first
2. second

> a quote line

```
line <html>
```

---
"""
print markdown.to_html(src)
