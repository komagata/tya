# v0.32 markdown.Markdown.to_html: minimal CommonMark subset.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout '<h1>Hello</h1>'
stdout '<p>Some <strong>bold</strong> and <em>em</em> and <code>code</code>'
stdout '<ul>'
stdout '<li>one</li>'
stdout '<ol>'
stdout '<li>first</li>'
stdout '<blockquote>'
stdout '<a href="https://example.com">link</a>'
stdout '<hr/>'
stdout '<pre><code>line &lt;html&gt;'

exec go run ./cmd/tya version
stdout '0.67.3\n'

exec go run ./cmd/tya run $WORK/extended.tya
stdout '<h1>Setext</h1>'
stdout '<th>Name</th><th>Done</th>'
stdout '<td>Build</td><td><del>no</del></td>'
stdout '<input type="checkbox" disabled checked/> shipped'
stdout '<pre><code class="language-tya">print'
stdout '<a href="https://example.com/ref">reference</a>'
stdout '<img src="logo.png" alt="logo"/>'
stdout '<ul>'
stdout '<li>parent'
stdout '<li>child</li>'
stdout '<p>&lt;div&gt;escaped&lt;/div&gt;</p>'
stdout '<div>escaped</div>'

-- sample.tya --
import markdown as markdown

src = """
# Hello

Some **bold** and *em* and `code` and a [link](https://example.com).

- one
- two

1. first
2. second

> a quote line

```
line <html>
```

---
"""
print(markdown.Markdown.to_html(src))

-- extended.tya --
import markdown as markdown

src = """
Setext
======

| Name | Done |
| ---- | ---- |
| Build | ~~no~~ |

- [x] shipped
- [ ] pending

```tya
print("hi")
```

[reference][ref] and ![logo](logo.png)

- parent
  - child

<div>escaped</div>

[ref]: https://example.com/ref
"""

ast = markdown.Markdown.parse(src)
html_ast = markdown.Markdown.to_html_ast(ast)
print(markdown.Markdown.render(html_ast))
print(markdown.Markdown.render(html_ast, { raw_html: true }))
