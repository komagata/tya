# v0.42 STEP 6: Channel.receive_timeout returns nil if no value
# arrives within the deadline, otherwise the dequeued value.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout 'timed out'
stdout 'got 42'

exec go run ./cmd/tya run $WORK/zero_poll.tya
stdout 'zero nil'

-- sample.tya --
import channel

c = channel.Channel(1)
v = c.receive_timeout(0.1)
if v == nil
  print("timed out")
else
  print(v)

c2 = channel.Channel(1)
c2.send(42)
v2 = c2.receive_timeout(0.1)
print("got " + v2.to_s())

-- zero_poll.tya --
import channel

c = channel.Channel(1)
v = c.receive_timeout(0)
if v == nil
  print("zero nil")
