# v0.42 STEP 5: channel stdlib basic send / receive.
cd $REPO

exec go run ./cmd/tya run $WORK/echo.tya
stdout 'hi'

exec go run ./cmd/tya run $WORK/concurrent.tya
stdout 'received: 42'

exec go run ./cmd/tya run $WORK/counter_actor.tya
stdout 'count after three increments: 3'
stdout 'final: 3'

exec go run ./cmd/tya run $WORK/close_drains.tya
stdout 'first: 1'
stdout 'second: 2'
stdout 'after close, drained: 0'

! exec go run ./cmd/tya run $WORK/send_closed.tya
stderr 'channel.send: channel is closed'

-- echo.tya --
import channel/* as channel

c = channel.Channel(1)
c.send("hi")
print(c.receive())

-- concurrent.tya --
import channel/* as channel

c = channel.Channel(1)
worker = ic -> ic.send(42)
spawn worker(c)
print("received: " + (c.receive()).to_s())

-- counter_actor.tya --
import channel/* as channel

inbox = channel.Channel(100)

worker = ic ->
  count = 0
  while true
    msg = ic.receive()
    if msg == "stop"
      return count
    if msg == "inc"
      count = count + 1
    else
      reply = msg
      reply.send(count)

t = spawn worker(inbox)

inbox.send("inc")
inbox.send("inc")
inbox.send("inc")

reply_chan = channel.Channel(1)
inbox.send(reply_chan)
print("count after three increments: " + (reply_chan.receive()).to_s())

inbox.send("stop")
print("final: " + (await t).to_s())

-- close_drains.tya --
import channel/* as channel

c = channel.Channel(2)
c.send(1)
c.send(2)
c.close()
print("first: " + (c.receive()).to_s())
print("second: " + (c.receive()).to_s())
nilv = c.receive()
if nilv == nil
  print("after close, drained: 0")
else
  print("after close, drained: 1")

-- send_closed.tya --
import channel/* as channel

c = channel.Channel(1)
c.close()
c.send("bad")
