# v0.42 STEP 5: channel stdlib basic send / receive.
cd $REPO

exec go run ./cmd/tya run $WORK/echo.tya
stdout 'hi'

exec go run ./cmd/tya run $WORK/concurrent.tya
stdout 'received: 42'

exec go run ./cmd/tya run $WORK/counter_actor.tya
stdout 'count after three increments: 3'
stdout 'final: 3'

exec go run ./cmd/tya run $WORK/close_drains.tya
stdout 'first: 1'
stdout 'second: 2'
stdout 'after close, drained: 0'

-- echo.tya --
import channel

c = channel.Channel.new(1)
channel.Channel.send(c, "hi")
print(channel.Channel.receive(c))

-- concurrent.tya --
import channel

c = channel.Channel.new(1)
worker = ic -> channel.Channel.send(ic, 42)
spawn worker(c)
print("received: " + to_string(channel.Channel.receive(c)))

-- counter_actor.tya --
import channel

inbox = channel.Channel.new(100)

worker = ic ->
  count = 0
  while true
    msg = channel.Channel.receive(ic)
    if msg == "stop"
      return count
    if msg == "inc"
      count = count + 1
    else
      reply = msg
      channel.Channel.send(reply, count)

t = spawn worker(inbox)

channel.Channel.send(inbox, "inc")
channel.Channel.send(inbox, "inc")
channel.Channel.send(inbox, "inc")

reply_chan = channel.Channel.new(1)
channel.Channel.send(inbox, reply_chan)
print("count after three increments: " + to_string(channel.Channel.receive(reply_chan)))

channel.Channel.send(inbox, "stop")
print("final: " + to_string(await t))

-- close_drains.tya --
import channel

c = channel.Channel.new(2)
channel.Channel.send(c, 1)
channel.Channel.send(c, 2)
channel.Channel.close(c)
print("first: " + to_string(channel.Channel.receive(c)))
print("second: " + to_string(channel.Channel.receive(c)))
nilv = channel.Channel.receive(c)
if nilv == nil
  print("after close, drained: 0")
else
  print("after close, drained: 1")
