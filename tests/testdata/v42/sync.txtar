# v0.42 STEP 7: sync stdlib (mutex, atomic_integer, wait_group).
cd $REPO

exec go run ./cmd/tya run $WORK/mutex.tya
stdout 'count: 200'

exec go run ./cmd/tya run $WORK/with_lock_raise.tya
stdout 'unlocked'
stdout 'same: boom'

exec go run ./cmd/tya run $WORK/atomic.tya
stdout 'atomic: 15'
stdout 'cas success: true'
stdout 'cas value: 99'
stdout 'cas alias: true'

exec go run ./cmd/tya run $WORK/waitgroup.tya
stdout 'wait_group ok'

-- mutex.tya --
import sync/*

state = {}
state["count"] = 0
m = sync.Mutex()

inc100 = mref, sref ->
  i = 0
  while i < 100
    mref.lock()
    sref["count"] = sref["count"] + 1
    mref.unlock()
    i = i + 1

t1 = spawn inc100(m, state)
t2 = spawn inc100(m, state)
await t1
await t2
print("count: " + state["count"].to_string())

-- atomic.tya --
import sync/*

a = sync.AtomicInteger(0)
a.add(10)
a.add(5)
print("atomic: " + (a.load()).to_string())

ok = a.compare_and_swap(15, 99)
print("cas success: " + ok.to_string())
print("cas value: " + (a.load()).to_string())

ok2 = a.cas(99, 100)
print("cas alias: " + ok2.to_string())

-- with_lock_raise.tya --
import sync/*

m = sync.Mutex()
boom = ->
  raise error("boom")

try
  m.with_lock(boom)
catch e
  m.lock()
  print("unlocked")
  m.unlock()
  print("same: " + e["message"])

-- waitgroup.tya --
import sync/*
import channel

wg = sync.WaitGroup()
wg.add(3)

ch = channel.Channel(3)
worker = wgr, chr ->
  chr.send("ok")
  wgr.done()

spawn worker(wg, ch)
spawn worker(wg, ch)
spawn worker(wg, ch)
wg.wait()
print("wait_group ok")
