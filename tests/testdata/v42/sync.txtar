# v0.42 STEP 7: sync stdlib (mutex, atomic_integer, wait_group).
cd $REPO

exec go run ./cmd/tya run $WORK/mutex.tya
stdout 'count: 200'

exec go run ./cmd/tya run $WORK/atomic.tya
stdout 'atomic: 15'
stdout 'cas success: true'
stdout 'cas value: 99'

exec go run ./cmd/tya run $WORK/waitgroup.tya
stdout 'wait_group ok'

-- mutex.tya --
import sync

state = {}
state["count"] = 0
m = sync.Sync.mutex()

inc100 = mref, sref ->
  i = 0
  while i < 100
    sync.Sync.lock(mref)
    sref["count"] = sref["count"] + 1
    sync.Sync.unlock(mref)
    i = i + 1

t1 = spawn inc100(m, state)
t2 = spawn inc100(m, state)
await t1
await t2
print("count: " + to_string(state["count"]))

-- atomic.tya --
import sync

a = sync.Sync.atomic_integer(0)
sync.Sync.atomic_add(a, 10)
sync.Sync.atomic_add(a, 5)
print("atomic: " + to_string(sync.Sync.atomic_load(a)))

ok = sync.Sync.atomic_cas(a, 15, 99)
print("cas success: " + to_string(ok))
print("cas value: " + to_string(sync.Sync.atomic_load(a)))

-- waitgroup.tya --
import sync
import channel

wg = sync.Sync.wait_group()
sync.Sync.wait_group_add(wg, 3)

ch = channel.Channel.new(3)
worker = wgr, chr ->
  channel.Channel.send(chr, "ok")
  sync.Sync.wait_group_done(wgr)

spawn worker(wg, ch)
spawn worker(wg, ch)
spawn worker(wg, ch)
sync.Sync.wait_group_wait(wg)
print("wait_group ok")
