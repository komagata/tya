# v0.8 class-level inheritance, class-method self/super, and introspection.
cd $REPO

exec go run ./cmd/tya run $WORK/class_level.tya
stdout '0\n0\n0\n10\nadmin\nuser\nadmin\nuser admin\nAdmin\nAdmin\nAdmin\nUser\nUser\nnil\nUser\n'
! stderr .

exec go run ./cmd/tya run $WORK/main.tya
stdout 'Ada\neditor\neditor\naccount\nEditor\nEditor\nAccount\nAccount\n'
! stderr .

! exec go run ./cmd/tya run $WORK/self_outside.tya
stderr 'self is only valid inside a class method or instance method'

! exec go run ./cmd/tya run $WORK/super_no_parent_class_method.tya
stderr 'super has no parent class method make'

! exec go run ./cmd/tya run $WORK/bad_class_method_override_arity.tya
stderr 'overriding class method role expects 0 parameters'

! exec go run ./cmd/tya run $WORK/assign_object_class.tya
stderr 'cannot assign to read-only introspection member class'

! exec go run ./cmd/tya run $WORK/assign_object_class_name.tya
stderr 'cannot assign to read-only introspection member class_name'

! exec go run ./cmd/tya run $WORK/assign_class_name.tya
stderr 'cannot assign to read-only introspection member name'

! exec go run ./cmd/tya run $WORK/assign_class_parent.tya
stderr 'cannot assign to read-only introspection member parent'

! exec go run ./cmd/tya run $WORK/missing_class_member.tya
stderr 'missing class variable or method: missing'
! stdout .

exec go run ./cmd/tya version
stdout '0.67.6\n'
! stderr .

-- class_level.tya --
class User
  static count = 0
  static label = "user"

  initialize = name ->
    self.name = name
    Self.count = Self.count + 1

  label = ->
    Self.label

  static build = name ->
    Self(name)

  static label_name = ->
    Self.label

  static role = ->
    "user"

class Admin extends User
  static label = "admin"

  static role = ->
    "{super()} admin"

print(User.count)
print(Admin.count)
Admin.count = 10
print(User.count)
print(Admin.count)
print(Admin.label_name())
print(User.label_name())
admin = Admin.build("komagata")
print(admin.label())
print(Admin.role())
print(admin.class)
print(admin.class_name)
print(Admin.name)
print(Admin.parent)
print(User.name)
print(User.parent)
print(admin.class.parent)

-- account.tya --
class Account
  static kind = "account"

  initialize = name ->
    self.name = name

  kind = ->
    Self.kind

  static build = name ->
    Self(name)

  static kind_name = ->
    Self.kind

class Editor extends Account
  static kind = "editor"

-- main.tya --
import account

editor = account.Editor.build("Ada")
print(editor.name)
print(editor.kind())
print(account.Editor.kind_name())
print(account.Editor.parent.kind_name())
print(editor.class)
print(editor.class_name)
print(account.Editor.parent)
print(account.Account.name)

-- self_outside.tya --
print(self)

-- super_no_parent_class_method.tya --
class User
  static build = ->
    "user"

class Admin extends User
  static make = ->
    super()

print(Admin.make())

-- bad_class_method_override_arity.tya --
class User
  static role = ->
    "user"

class Admin extends User
  static role = name ->
    name

-- assign_object_class.tya --
class User
  name = ""

user = User()
user.class = "bad"

-- assign_object_class_name.tya --
class User
  name = ""

user = User()
user.class_name = "bad"

-- assign_class_name.tya --
class User
  name = ""

User.name = "bad"

-- assign_class_parent.tya --
class User
  name = ""

User.parent = "bad"

-- missing_class_member.tya --
class User
  name = ""

print(User.missing)
