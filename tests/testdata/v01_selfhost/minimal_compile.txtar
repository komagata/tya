# Tya-written v0.1 compiler starts from AST dictionaries and matches the Go oracle for a small slice.
cd $REPO
env TYA_LEGACY_MODULES=1

exec go run ./cmd/tya run $WORK/main.tya
stdout 'Hello, Tya\nInterpolated Tya\nHello from Tya\nready\nelseif ready\nsecond elseif ready\n0\n1\n2\n2\n9\n2\n9\n6\n0\n2\n1\n9\n2\n6\n8\n3\n3\nTya\ncompiler\ntrue\n2\nfalse\nname\nTya\nleft\nright\n6\n5\n7\n9\n4\n8\n10\nconstant\nblock constant\n6\n4\n5\n0\ninner\ntuple\nok\n12\n4\n2\n14\ntrue\ntrue\ntrue\ntrue\n-4\n7\nhello-Tya\nhello:Tya\nhello,compiler\ntrue\ntrue\ntrue\n42\n2.5\n12.5\nnested-expr\ntrue\nfile text\nfile expr\n5\nfalse\nbad\n'

exec sh -c '$SELFHOST_V01_STAGE1_BIN "$WORK/main.tya" > "$WORK/main.c"'
! stderr .

exec grep 'tya_user_name' $WORK/main.c
stdout 'tya_user_name'

exec cc $WORK/main.c runtime/tya_runtime.c -I runtime -o $WORK/main -lpthread -lm -lz
! stderr .

exec $WORK/main
stdout 'Hello, Tya\nInterpolated Tya\nHello from Tya\nready\nelseif ready\nsecond elseif ready\n0\n1\n2\n2\n9\n2\n9\n6\n0\n2\n1\n9\n2\n6\n8\n3\n3\nTya\ncompiler\ntrue\n2\nfalse\nname\nTya\nleft\nright\n6\n5\n7\n9\n4\n8\n10\nconstant\nblock constant\n6\n4\n5\n0\ninner\ntuple\nok\n12\n4\n2\n14\ntrue\ntrue\ntrue\ntrue\n-4\n7\nhello-Tya\nhello:Tya\nhello,compiler\ntrue\ntrue\ntrue\n42\n2.5\n12.5\nnested-expr\ntrue\nfile text\nfile expr\n5\nfalse\nbad\n'
! stderr .

exec go run ./cmd/tya run $WORK/branch_scope.tya
stdout 'yes\ntop\n'
! stderr .

exec sh -c '$SELFHOST_V01_STAGE1_BIN "$WORK/branch_scope.tya" > "$WORK/branch_scope.c"'
! stderr .

exec cc $WORK/branch_scope.c runtime/tya_runtime.c -I runtime -o $WORK/branch_scope -lpthread -lm -lz
! stderr .

exec $WORK/branch_scope
stdout 'yes\ntop\n'
! stderr .

! exec $SELFHOST_V01_STAGE1_BIN $WORK/undefined.tya
stdout 'undefined variable: missing'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/tab.tya
stdout '2: tabs are forbidden'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_indent.tya
stdout '2: indentation may only increase by 2 spaces'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_char.tya
stdout 'unexpected character'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_escape.tya
stdout '1:11: unknown escape \\q'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/unterminated.tya
stdout '1:7: unterminated string'

exec $SELFHOST_V01_STAGE1_BIN --tokens $WORK/lexer_tokens.tya
stdout 'IDENT\n=\nINT\n.\nNEWLINE\nIDENT\n\(\nSTRING\n\)\nNEWLINE\nEOF\n'

exec $SELFHOST_V01_STAGE1_BIN --ast $WORK/parser_ast.tya
stdout '1: import\n3: assign add = func 2 expr binary [+]\n4: assign zero = func 0 expr int\n5: assign mapped = call member map 1\n6: assign zero_paren = func 0 expr int\n7: expr_stmt call ident print 1\n8: if elseif 0 else 0\n'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/import_alias.tya
stdout '1: import aliases are not in Tya v0.1'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/nested_import.tya
stdout '2: import must be top-level'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/nested_module.tya
stdout '2: module must be top-level'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/no_paren_call.tya
stdout '1: function calls require parentheses in Tya v0.1'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_elseif_header.tya
stdout '3: unexpected token before block'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_if_header.tya
stdout '1: unexpected token before block'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_while_header.tya
stdout '1: unexpected token before block'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_for_header.tya
stdout '1: unexpected token before block'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/top_level_try.tya
stdout '1: try must be inside a function'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/class.tya
stdout 'class body may only contain member definitions'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/self.tya
stdout '1: self is only valid inside a class method'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/set_literal.tya
stdout '1: set literals are not in Tya v0.1'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/function_missing.tya
stdout '2: undefined variable: missing'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/param_scope.tya
stdout '2: undefined variable: value'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/bad_name.tya
stdout '1: invalid variable name: BadName'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/constant_reassign.tya
stdout '2: cannot reassign constant: MAX_RETRY'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/invalid_dict_key.tya
stdout '1: invalid dictionary key: Name'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/duplicate_dict_key.tya
stdout '1: duplicate dictionary key: name'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/reserved_name.tya
stdout '1: true cannot be used as a name'

exec $SELFHOST_V01_STAGE1_BIN $WORK/member_access.tya
stdout 'tya_member'

exec $SELFHOST_V01_STAGE1_BIN $WORK/array_member.tya
stdout 'tya_member'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/member_assignment.tya
stdout 'undefined variable: user'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/multiple_index_assign.tya
stdout '1: multiple assignment targets must be identifiers'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/duplicate_member.tya
stdout '3: duplicate module member: hello'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/module_mismatch/main.tya
stdout 'greeting.tya must define module greeting'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/module_multiple/main.tya
stdout 'greeting.tya must define exactly one module'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/module_extra/main.tya
stdout 'greeting.tya may only contain imports and one module declaration'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/top_level_return.tya
stdout '1: return must be inside a function'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/top_level_break.tya
stdout '1: break must be inside a loop'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/top_level_continue.tya
stdout '1: continue must be inside a loop'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/function_break.tya
stdout '3: break must be inside a loop'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/duplicate_param.tya
stdout '1: duplicate function parameter: value'

! exec $SELFHOST_V01_STAGE1_BIN $WORK/nested_missing.tya
stdout '4: undefined variable: missing'

-- main.tya --
import greeting

name = "Tya"
print("Hello, " + name)
print("Interpolated {name}")
print(greeting.hello(name))
if true
  print("ready")
else
  print("not ready")
if false
  print("not ready")
elseif true
  print("elseif ready")
else
  print("still not ready")
if false
  print("not ready")
elseif false
  print("first elseif not ready")
elseif true
  print("second elseif ready")
else
  print("still not ready")
count = 0
while count < 2
  print(count)
  count = count + 1
while true
  print(2)
  break
while count < 3
  count = count + 1
  continue
  print("never")
items = [2, 4, 6]
print(items[0])
items[1] = 9
print(items[1])
for item in items
  print(item)
for item, index in items
  print(index)
  print(item)
items.push(8)
print(items.pop())
print(items.len())
print(items.len())
user = { name: "Tya", role: "compiler" }
print(user["name"])
user["name"] = "compiler"
print(user["name"])
user["name"] = "Tya"
print(user.has("name"))
print(user.keys().len())
user.delete("role")
print(user.has("role"))
user_entries = [{ key: "name", value: "Tya" }]
for entry in user_entries
  print(entry["key"])
  print(entry["value"])
left, right = ["left", "right"]
print(left)
print(right)
double = value -> value + value
print(double(3))
add = left -> left + 2
print(add(3))
sum = left, right -> left + right
print(sum(3, 4))
print(sum(2 + 3, 4))
pick4 = _a, _b, _c, d -> d
print(pick4(1, 2, 3, 4))
block_double = value ->
  return value + value
print(block_double(4))
implicit_double = value ->
  value + value
print(implicit_double(5))
constant = -> "constant"
print(constant())
block_constant = ->
  return "block constant"
print(block_constant())
block_sum3 = a, b, c ->
  return a + b + c
print(block_sum3(1, 2, 3))
block_pick4 = _a, _b, _c, d ->
  return d
print(block_pick4(1, 2, 3, 4))
nested = value ->
  if value > 2
    while value < 5
      value = value + 1
    return value
  else
    return 0
print(nested(3))
print(nested(1))
loop = 0
while loop < 3
  if loop == 1
    print("inner")
  loop = loop + 1
pair = value ->
  return value, "ok"
tuple_value, tuple_status = pair("tuple")
print(tuple_value)
print(tuple_status)
ok_pair = value ->
  return value, nil
print(3 * 4)
print(8 / 2)
print(8 % 3)
print(2 + 3 * 4)
print(true and true)
print(false or true)
print(false and false or true)
print(not false)
print(-4)
print (3 + 4)
text = " hello,Tya ".trim()
parts = text.split(",")
print(parts.join("-"))
print(text.split(",").join(":"))
print(text.replace("Tya", "compiler"))
print(text.contains("hello"))
print(text.starts_with("hello"))
print(text.ends_with("Tya"))
print("42".to_i())
print("2.5".to_f())
print("12.5".to_number())
print(["nested", "expr"].join("-").to_s())
path = "/tmp/tya_selfhost_v01.txt"
write_file(path, "file text")
print(file_exists(path))
print(read_file(path))
path_expr = "/tmp/" + "tya_selfhost_v01_expr.txt"
write_file(path_expr, ["file", "expr"].join(" "))
print(read_file(path_expr))
side_items = []
side_items.push(2 + 3)
print(side_items[0])
side_dict = { dynamic: 1 }
side_key = ["dyn", "amic"].join("")
side_dict.delete(side_key)
print(side_dict.has("dynamic"))
err = error("bad")
print(err["message"])

-- undefined.tya --
print(missing)

-- branch_scope.tya --
choose = flag ->
  value = ""
  if flag
    value = "yes"
  else
    value = "no"
  return value
print(choose(true))
top_value = ""
if true
  top_value = "top"
print(top_value)

-- tab.tya --
print("ok")
	print("tab")

-- bad_indent.tya --
if true
    print("bad")

-- bad_char.tya --
x $ 1

-- bad_escape.tya --
print("bad\q")

-- unterminated.tya --
print("bad)

-- lexer_tokens.tya --
value = 1.
print("a\n\"b\"")

-- parser_ast.tya --
import greeting

add = left, right -> left + right
zero = -> 0
mapped = items.map(item -> item * 2)
zero_paren = () -> 0
print(add(2 + 3, zero()))
if true
  print(greeting.hello("parser"))

-- import_alias.tya --
import greeting as g

-- nested_import.tya --
if true
  import greeting

-- nested_module.tya --
if true
  module greeting
    hello = name -> name

-- no_paren_call.tya --
len keys user

-- bad_elseif_header.tya --
if false
  print("no")
elseif ready true
  print("bad")

-- bad_if_header.tya --
if ready true
  print("bad")

-- bad_while_header.tya --
while ready true
  print("bad")

-- bad_for_header.tya --
for item in items extra
  print(item)

-- top_level_try.tya --
value = try parse_user("x")

-- class.tya --
class User
  1

-- self.tya --
print(self)

-- set_literal.tya --
roles = { admin, writer }

-- function_missing.tya --
fn = _value ->
  print(missing)
print(fn("x"))

-- param_scope.tya --
fn = value -> value
print(value)

-- bad_name.tya --
BadName = 1

-- constant_reassign.tya --
MAX_RETRY = 3
MAX_RETRY = 5

-- invalid_dict_key.tya --
user = { Name: "a" }

-- duplicate_dict_key.tya --
user = { name: "a", name: "b" }

-- reserved_name.tya --
true = 1

-- member_access.tya --
user = { name: "Tya" }
print(user.name)

-- array_member.tya --
items = [1]
print(items.len())

-- member_assignment.tya --
user.name = "Tya"

-- multiple_index_assign.tya --
items[0], right = pair()

-- duplicate_member.tya --
module greeting
  hello = name -> name
  hello = name -> name

-- module_mismatch/main.tya --
import greeting
print(greeting.hello("Tya"))

-- module_mismatch/greeting.tya --
module message
  hello = name -> name

-- module_multiple/main.tya --
import greeting
print(greeting.hello("Tya"))

-- module_multiple/greeting.tya --
module greeting
  hello = name -> name
module greeting
  bye = name -> name

-- module_extra/main.tya --
import greeting
print(greeting.hello("Tya"))

-- module_extra/greeting.tya --
module greeting
  hello = name -> name
_helper = "bad"

-- top_level_return.tya --
return 1

-- top_level_break.tya --
break

-- top_level_continue.tya --
continue

-- function_break.tya --
while true
  stop = ->
    break

-- duplicate_param.tya --
fn = value, value -> value

-- nested_missing.tya --
fn = items ->
  for item in items
    if item
      print(missing)
print(fn([]))

-- greeting.tya --
module greeting
  hello = name -> "Hello from {name}"
