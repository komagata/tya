# Tya-written compiler supports the current v0.7 inheritance surface while preserving self-host.
cd $REPO
env TYA_LEGACY_MODULES=1

exec cp $SELFHOST_V01_STAGE1_C $WORK/stage1.c
exec cp $SELFHOST_V01_STAGE1_BIN $WORK/stage1

exec sh -c '"$WORK/stage1" "$WORK/current_v07.tya" > "$WORK/current_v07.c"'
! stderr .

exec cc $WORK/current_v07.c runtime/tya_runtime.c -I runtime -o $WORK/current_v07 -lpthread -lm -lz
! stderr .

exec $WORK/current_v07
stdout 'komagata\nadmin\nHello, komagata \(admin\)\nTya\n'
! stderr .

-- current_v07.tya --
class User
  name = ""
  role = "user"

  init = name ->
    @name = name

  greeting = ->
    "Hello, {@name}"

  rename = name ->
    @name = name

class Admin extends User
  role = "admin"

  init = name ->
    super(name)

  greeting = ->
    "{super()} (admin)"

admin = Admin("komagata")
print(admin.name)
print(admin.role)
print(admin.greeting())
admin.rename("Tya")
print(admin.name)
