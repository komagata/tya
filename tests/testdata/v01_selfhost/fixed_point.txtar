# The Tya-written v0.1 compiler must be able to compile itself to a stable C emitter output.
cd $REPO

exec sh -c 'go run ./cmd/tya run selfhost/v01/compiler.tya selfhost/v01/compiler.tya > "$WORK/stage1.c"'
! stderr .

exec sh -c 'cc "$WORK/stage1.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage1" 2>/dev/null'

exec sh -c '"$WORK/stage1" selfhost/v01/compiler.tya > "$WORK/stage2.c"'
! stderr .

exec sh -c 'cc "$WORK/stage2.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage2" 2>/dev/null'

exec sh -c '"$WORK/stage2" selfhost/v01/compiler.tya > "$WORK/stage3.c"'
! stderr .

exec sh -c 'cc "$WORK/stage3.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage3" 2>/dev/null'

exec cmp $WORK/stage2.c $WORK/stage3.c

exec sh -c '"$WORK/stage2" "$WORK/app.tya" > "$WORK/app.c"'
! stderr .

exec sh -c 'cc "$WORK/app.c" runtime/tya_runtime.c -I runtime -o "$WORK/app" 2>/dev/null'

exec $WORK/app first second
stdout 'Hello, stage2\n3\nx:y\nsecond\n'
! stderr .

-- app.tya --
name = "stage2"
print("Hello, {name}")

items = [1, 2, 3]
print(len(items))

labels = { x: "X", y: "Y" }
joined = ""
for key, value of labels
  if joined == ""
    joined = key
  else
    joined = joined + ":" + key
print(joined)

argv = args()
print(argv[1])
