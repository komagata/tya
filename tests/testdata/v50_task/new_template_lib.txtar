# v0.50 `tya new --template lib` scaffolds a package-form library
# (src/<name>/<name>.tya) instead of the default script-form app.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
cd $WORK

exec $WORK/tya new --template lib mylib --no-git
stdout 'Created mylib'
stdout 'tya task test'
! stderr .

exists mylib/src/mylib/mylib.tya
exists mylib/tests/mylib_test.tya
! exists mylib/src/main.tya
! grep 'tya run src/main.tya' mylib/tya.toml

# Lib template should have a class declaration, not a script.
grep 'class Mylib' mylib/src/mylib/mylib.tya

cd mylib
env PATH=$WORK:$PATH
env TYA_LIB_DIR=$REPO/lib
env TYA_RUNTIME_DIR=$REPO/runtime
exec $WORK/tya task test
stdout '1 tests, 1 passed, 0 failed'
! stderr .
