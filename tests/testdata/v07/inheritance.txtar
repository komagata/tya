# v0.7 single inheritance and super.
cd $REPO

exec go run ./cmd/tya run $WORK/inheritance.tya
stdout 'komagata\nadmin\nHello, komagata \(admin\)\nTya\nHello, Tya \(admin\)\n0\n1\n'
! stderr .

exec go run ./cmd/tya run $WORK/main.tya
stdout 'module\nHello, module \(admin\)\n'
! stderr .

exec go run ./cmd/tya run $WORK/accounts_main.tya
stdout 'komagata\nadmin\nHello, komagata \(admin\)\n'
! stderr .

! exec go run ./cmd/tya run $WORK/unknown_parent.tya
stderr 'unknown parent class Missing'

! exec go run ./cmd/tya run $WORK/multiple_inheritance.tya
stderr 'multiple inheritance is not in Tya v0.7'

! exec go run ./cmd/tya run $WORK/cycle.tya
stderr 'inheritance cycle involving User'

! exec go run ./cmd/tya run $WORK/super_outside.tya
stderr 'super must be called inside init, an instance method, or a class method'

! exec go run ./cmd/tya run $WORK/super_in_class_method.tya
stderr 'super has no parent class method build'

! exec go run ./cmd/tya run $WORK/no_parent_method.tya
stderr 'super has no parent method greeting'

! exec go run ./cmd/tya run $WORK/missing_super.tya
stderr 'subclass init must call super'

! exec go run ./cmd/tya run $WORK/bad_override_arity.tya
stderr 'overriding method rename expects 1 parameters'

exec go run ./cmd/tya run $WORK/class_member_inheritance.tya
stdout '0\n'
! stderr .

exec go run ./cmd/tya version
stdout '0.72.11\n'
! stderr .

-- inheritance.tya --
class User
  name: ""
  role: "user"
  static count: 0

  initialize: user_name ->
    self.name = user_name
    Self.count = Self.count + 1

  greeting: ->
    "Hello, {self.name}"

  rename: user_name ->
    self.name = user_name

class Admin extends User
  role: "admin"

  initialize: admin_name ->
    super(admin_name)

  greeting: ->
    "{super()} ({self.role})"

admin = Admin("komagata")
print(admin.name)
print(admin.role)
print(admin.greeting())
admin.rename("Tya")
print(admin.name)
print(admin.greeting())
print(User.count)
print(Admin.count)

-- user.tya --
class User
  name: ""

  initialize: user_name ->
    self.name = user_name

  greeting: ->
    "Hello, {self.name}"

-- main.tya --
import user

class Admin extends user.User
  greeting: ->
    "{super()} (admin)"

admin = Admin("module")
print(admin.name)
print(admin.greeting())

-- accounts.tya --
class User
  name: ""

  initialize: user_name ->
    self.name = user_name

  greeting: ->
    "Hello, {self.name}"

class Admin extends User
  role: "admin"

  greeting: ->
    "{super()} ({self.role})"

-- accounts_main.tya --
import accounts

admin = accounts.Admin("komagata")
print(admin.name)
print(admin.role)
print(admin.greeting())

-- unknown_parent.tya --
class Admin extends Missing
  name: ""

-- multiple_inheritance.tya --
class Bad extends User, Account
  name: ""

-- cycle.tya --
class User extends Admin
  name: ""
class Admin extends User
  name: ""

-- super_outside.tya --
print(super())

-- super_in_class_method.tya --
class User
  greeting: ->
    "Hello"

class Admin extends User
  static build: ->
    super()

-- no_parent_method.tya --
class User
  name: ""

class Admin extends User
  greeting: ->
    super()

-- missing_super.tya --
class User
  name: ""

  initialize: user_name ->
    self.name = user_name

class Admin extends User
  initialize: admin_name ->
    self.name = admin_name

-- bad_override_arity.tya --
class User
  name: ""

  rename: user_name ->
    self.name = user_name

class Admin extends User
  rename: first_name, last_name ->
    self.name = first_name + " " + last_name

-- class_member_inheritance.tya --
class User
  static count: 0

class Admin extends User
  name: ""

print(Admin.count)
