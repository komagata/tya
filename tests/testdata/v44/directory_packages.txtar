# v0.44 directory-as-package import.
# A directory containing snake_case class/interface files is an importable package.
# Unaliased `import net/http/*` exposes public package classes through `net.http`.
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'http://example.com\n200\n'
! stderr .

! exec go run ./cmd/tya run $WORK/bad_pkg_main.tya
stderr 'package bad_pkg contains script file'

! exec go run ./cmd/tya run $WORK/hello.tya
stderr 'hello.tya is a class file'

# v0.44 same-directory sibling auto-visibility: an entry script sees
# every PascalCase class file in its directory without an import.
exec go run ./cmd/tya run $WORK/two_files/main.tya
stdout 'Hello, komagata\n'
! stderr .

-- main.tya --
import net/http/*

request = net.http.Request("http://example.com")
response = net.http.Response()
print(request.url())
print(response.status())

-- net/http/request.tya --
class Request
  url: nil

  initialize: value ->
    self.url = value

  url: ->
    self.url

-- net/http/response.tya --
class Response
  status: nil

  initialize: ->
    self.status = 200

  status: ->
    self.status

-- bad_pkg_main.tya --
import bad_pkg/*

x = Helper()
print(x)

-- bad_pkg/helper.tya --
class Helper
  x: nil

  initialize: ->
    self.x = 1

-- bad_pkg/oops.tya --
print("this is a script file inside a package; should be rejected")

-- hello.tya --
class Hello
  x: nil

  initialize: ->
    self.x = 1

-- two_files/main.tya --
g = Greeter("komagata")
print(g.greet())

-- two_files/greeter.tya --
class Greeter
  name: nil

  initialize: value ->
    self.name = value

  greet: ->
    "Hello, {self.name}"
