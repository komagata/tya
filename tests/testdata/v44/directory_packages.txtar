# v0.44 directory-as-package import.
# A directory containing PascalCase class files is an importable package.
# `import net/http` resolves to the directory and the binding is `http`.
# Cross-package access uses `<binding>.<ClassName>`.
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'http://example.com\n200\n'
! stderr .

! exec go run ./cmd/tya run $WORK/bad_pkg_main.tya
stderr 'package bad_pkg contains script file'

! exec go run ./cmd/tya run $WORK/Hello.tya
stderr 'Hello.tya is a class file'

# v0.44 same-directory sibling auto-visibility: an entry script sees
# every PascalCase class file in its directory without an import.
exec go run ./cmd/tya run $WORK/two_files/main.tya
stdout 'Hello, komagata\n'
! stderr .

-- main.tya --
import net/http

request = http.Request("http://example.com")
response = http.Response()
print(request.url())
print(response.status())

-- net/http/Request.tya --
class Request
  initialize = url ->
    self.url = url

  url = ->
    self.url

-- net/http/Response.tya --
class Response
  initialize = ->
    self.status = 200

  status = ->
    self.status

-- bad_pkg_main.tya --
import bad_pkg

x = bad_pkg.Helper()
print(x)

-- bad_pkg/Helper.tya --
class Helper
  initialize = ->
    self.x = 1

-- bad_pkg/oops.tya --
print("this is a script file inside a package; should be rejected")

-- Hello.tya --
class Hello
  initialize = ->
    self.x = 1

-- two_files/main.tya --
g = Greeter("komagata")
print(g.greet())

-- two_files/Greeter.tya --
class Greeter
  initialize = name ->
    self.name = name

  greet = ->
    "Hello, {self.name}"
