# v0.44 edge cases for directory-as-package import.
# Pin behavior we explicitly want stable:
# - Three-level package nesting (foo/bar/baz) works; `import x/y/z`
#   exposes Tag as a bare class.
# - A package containing only one class file also exposes its public
#   class bare.
# - Within-package class-to-class bare reference works under
#   nesting too.
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'deep\nsolo\nGET /\n'
! stderr .

# Importing a directory that mixes a class file and a script file
# at its leaf is rejected.
! exec go run ./cmd/tya run $WORK/bad/bad_main.tya
stderr 'package mixed_pkg contains script file'

-- main.tya --
import x/y/z
import solo
import api/v2

print(Tag.label())
print(Solo.greet())
client = Client()
print(client.summary())

-- x/y/z/Tag.tya --
class Tag
  static label: ->
    "deep"

-- solo/Solo.tya --
class Solo
  static greet: ->
    "solo"

-- api/v2/Client.tya --
class Client
  initialize: ->
    self.method = "GET"

  summary: ->
    req = Request(self.method)
    "{req.method()} {req.url()}"

-- api/v2/Request.tya --
class Request
  initialize: method ->
    self.method = method

  method: ->
    self.method

  url: ->
    "/"

-- bad/bad_main.tya --
import mixed_pkg

print(Helper())

-- bad/mixed_pkg/Helper.tya --
class Helper
  static show: ->
    "ok"

-- bad/mixed_pkg/oops.tya --
print("script file is not allowed inside a package")
