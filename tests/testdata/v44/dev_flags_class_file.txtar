# v0.44 read-only developer flags (--tokens, --emit-c) accept
# class files in addition to script files. The flags route through
# isolated parse + check + (for --emit-c) class-file codegen,
# producing partial output (no main()) without invoking entry-only
# import resolution.
cd $REPO

# --tokens on a class file: lexer output for the file content.
exec go run ./cmd/tya --tokens $WORK/foo.tya
stdout 'IDENT.*class'
stdout 'IDENT.*Foo'
! stderr .

# --emit-c on a class file: emits the class constructor function
# and a main() that initializes the class global, sufficient to
# compile and link as a standalone C program (the resulting binary
# would just initialize Foo and exit).
exec go run ./cmd/tya --emit-c $WORK/foo.tya
stdout 'TyaValue Foo;'
stdout 'tya_fn_Foo_'
stdout 'int main\('
! stderr .

# --emit-c on a snake_case script that declares a differently named class
# follows normal script-file handling.
exec go run ./cmd/tya --emit-c $WORK/bad_name.tya
stdout 'tya_fn_WrongName_'

# --check-unused on a clean class file: passes silently.
exec go run ./cmd/tya --check-unused $WORK/foo.tya
! stderr .

# --check-unused on a class file with an unused method argument
# reports the unused-argument diagnostic from the strict pass.
! exec go run ./cmd/tya --check-unused $WORK/unused.tya
stderr 'never used'

-- foo.tya --
class Foo
  initialize: ->
    self.x = 1

-- bad_name.tya --
class WrongName
  initialize: ->
    self.x = 1

-- unused.tya --
class Unused
  initialize: ->
    self.x = 1

  helper: unused_arg ->
    self.x
