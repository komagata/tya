# v0.44 a class file in a package may `implements` an interface
# defined in another file of the same package, using the bare
# interface name. Interface-only snake_case files are accepted when
# the interface name matches the filename.
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'json-encoded\n'
! stderr .

-- main.tya --
import codec/*

print(codec.JsonEncoder().encode())

-- codec/encodable.tya --
interface Encodable
  encode: ->

-- codec/json_encoder.tya --
class JsonEncoder implements Encodable
  initialize: ->
    nil

  encode: ->
    "json-encoded"
