# v0.44 single-class package where the class name and directory
# name differ: the access form is the bare public class name.
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'helper used\n'
! stderr .

-- main.tya --
import tools

print(Helper.use())

-- tools/Helper.tya --
class Helper
  static use = ->
    "helper used"
