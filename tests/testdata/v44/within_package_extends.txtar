# v0.44 a class file inside a package may extend another sibling
# class in the same package using the bare name. The within-package
# fallback (commit f6d276b) covers `extends`/`implements` references
# the same way it covers method-body call sites.
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'animal:dog\n'
! stderr .

-- main.tya --
import zoo/*

d = zoo.Dog()
print(d.describe())

-- zoo/animal.tya --
class Animal
  category: nil

  initialize: ->
    self.category = "animal"

  category: ->
    self.category

-- zoo/dog.tya --
class Dog extends Animal
  kind: nil

  initialize: ->
    super()
    self.kind = "dog"

  describe: ->
    "{self.category}:{self.kind}"
