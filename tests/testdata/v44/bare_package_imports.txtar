# Unaliased package imports expose public class names through their
# import-path namespace. Aliased package imports expose public class
# names bare and do not create an alias namespace.
cd $REPO

exec go run ./cmd/tya run $WORK/bare.tya
stdout 'bare\n'
! stderr .

exec go run ./cmd/tya run $WORK/bare_path_name_local.tya
stdout 'local http\nbare\n'
! stderr .

exec go run ./cmd/tya run $WORK/aliased.tya
stdout 'aliased\n'
! stderr .

! exec go run ./cmd/tya run $WORK/bare_namespace.tya
stderr 'undefined variable http'

! exec go run ./cmd/tya run $WORK/aliased_bare.tya
stderr 'undefined variable http'

! exec go run ./cmd/tya run $WORK/conflict_imports.tya
stderr 'import name conflict: Request'

exec go run ./cmd/tya run $WORK/local_bare_name.tya
stdout 'local\nbare\n'
! stderr .

! exec go run ./cmd/tya run $WORK/conflict_namespace.tya
stderr 'import name conflict: net'

-- bare.tya --
import net/http/*

request = net.http.Request("bare")
print(request.label())

-- bare_path_name_local.tya --
import net/http/*

http = "local http"
request = net.http.Request("bare")
print(http)
print(request.label())

-- aliased.tya --
import net/http/* as http

request = Request("aliased")
print(request.label())

-- bare_namespace.tya --
import net/http/*

request = http.Request("hidden")
print(request.label())

-- aliased_bare.tya --
import net/http/* as http

request = http.Request("hidden")
print(request.label())

-- conflict_imports.tya --
import api/* as api
import web/* as web

print("unreachable")

-- local_bare_name.tya --
import net/http/*

class Server
  static label: ->
    "local"

print(Server.label())
request = net.http.Request("bare")
print(request.label())

-- conflict_namespace.tya --
import net/http/*

net = "local"
print(net)

-- net/http/request.tya --
class Request
  text: nil

  initialize: label ->
    self.text = label

  label: ->
    self.text

-- api/request.tya --
class Request
  text: nil

  initialize: label ->
    self.text = label

  label: ->
    self.text

-- web/request.tya --
class Request
  text: nil

  initialize: label ->
    self.text = label

  label: ->
    self.text
