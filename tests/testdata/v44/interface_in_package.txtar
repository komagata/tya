# v0.44 package may contain interfaces alongside class files. The
# interface declaration coexists with class declarations in a class
# file (per CheckClassFileStructure: top-level allowed declarations
# are import / class / interface).
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'GET /\n'
! stderr .

-- main.tya --
import api/web

req = Request("GET", "/")
print(req.summary())

-- api/web/Request.tya --
interface Summarizable
  summary = ->

class Request implements Summarizable
  initialize = method, url ->
    self.method = method
    self.url = url

  summary = ->
    "{self.method} {self.url}"
