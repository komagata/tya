# v0.44 nested package directories and within-package class-to-class
# references. Packages may nest to arbitrary depth via directory
# nesting; unaliased imports expose package classes bare. Within a
# package, sibling classes call each other by their unqualified
# PascalCase name (Client.fetch builds Request and Response without
# the v1. prefix).
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'GET / -> 200\n'
! stderr .

-- main.tya --
import api/v1

client = Client()
print(client.fetch("/"))

-- api/v1/client.tya --
class Client
  initialize: ->
    self.hits = 0

  fetch: url ->
    request = Request("GET", url)
    response = Response(200)
    "{request.summary()} -> {response.status()}"

-- api/v1/request.tya --
class Request
  initialize: method, url ->
    self.method = method
    self.url = url

  summary: ->
    "{self.method} {self.url}"

-- api/v1/response.tya --
class Response
  initialize: status ->
    self.status = status

  status: ->
    self.status
