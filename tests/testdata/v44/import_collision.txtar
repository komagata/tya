# Directory-package imports expose public names through the import
# path namespace, so same terminal directory names can coexist when
# their qualified names differ. Aliased package imports still expose
# public names bare, so duplicate public names conflict.
cd $REPO

exec go run ./cmd/tya run $WORK/main.tya
stdout 'a\nb\n'
! stderr .

! exec go run ./cmd/tya run $WORK/aliased.tya
stderr 'import name conflict'

-- main.tya --
import a/net/*
import b/net/*

print(a.net.Request().label)
print(b.net.Request().label)

-- aliased.tya --
import a/net/* as a_net
import b/net/* as b_net

print("unreachable")

-- a/net/request.tya --
class Request
  label: nil

  initialize: ->
    self.label = "a"

-- b/net/request.tya --
class Request
  label: nil

  initialize: ->
    self.label = "b"
