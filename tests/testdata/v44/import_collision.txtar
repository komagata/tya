# v0.44 directory-package name collision: two imports whose
# directories share a terminal segment would synthesize the same
# module name. The runner detects this at synthesis time and fails
# with a clear message naming both directories. The check fires
# before the visibleImports binding check, so it covers both
# unaliased and aliased same-segment imports.
cd $REPO

! exec go run ./cmd/tya run $WORK/main.tya
stderr 'package name conflict.*module net'

! exec go run ./cmd/tya run $WORK/aliased.tya
stderr 'package name conflict.*module net'

-- main.tya --
import a/net/*
import b/net/*

print("unreachable")

-- aliased.tya --
import a/net/* as a_net
import b/net/* as b_net

print("unreachable")

-- a/net/request.tya --
class Request
  initialize: ->
    self.label = "a"

-- b/net/request.tya --
class Request
  initialize: ->
    self.label = "b"
