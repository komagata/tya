# v0.44 `tya format` accepts both script files and class files. The
# formatter is the same `formatter.Unparse` foundation from v0.37
# plus subsequent refinements; v0.44's class-file shape doesn't
# introduce new constructs, so format passes through canonical
# class syntax unchanged.
#
# Implementation note: format uses runner.ValidateAnyTyaFileName
# (read-only-friendly), distinct from runner.ValidateFileName
# (entry-only, rejects PascalCase) used by `tya run`.
cd $REPO

exec go run ./cmd/tya format $WORK/greeter.tya
stdout 'class Greeter'
stdout 'initialize: name ->'
stdout 'greet: ->'
! stderr .

exec go run ./cmd/tya format $WORK/main.tya
stdout 'import lib/*'
stdout 'lib.Lib.greet'
! stderr .

-- greeter.tya --
class Greeter
  initialize: name ->
    self.name = name

  greet: ->
    "Hello, {self.name}"

-- main.tya --
import lib/*

print(lib.Lib.greet())

-- lib/lib.tya --
class Lib
  static greet: ->
    "hi"
