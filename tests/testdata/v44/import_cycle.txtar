# v0.44 import cycle detection works through directory packages.
# The runner's loadState.loading set tracks in-progress loads by
# absolute path; a cycle through packages is detected the same way
# as a cycle through legacy module files.
cd $REPO

! exec go run ./cmd/tya run $WORK/main.tya
stderr 'import cycle'

-- main.tya --
import a/*

print(a.A.go())

-- a/a.tya --
import b/*

class A
  static go: ->
    "via " + b.B.go()

-- b/b.tya --
import a/*

class B
  static go: ->
    "via " + a.A.go()
