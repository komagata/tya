# v0.44 `tya check` validates a v0.44 entry without running it.
# Same resolution + class-file validation as `tya run`. In addition,
# `tya check` accepts class files directly (read-only validation):
# the structure rules from CheckClassFile fire and report any
# violations.
cd $REPO

# Happy path: script entry with a clean directory package.
exec go run ./cmd/tya check $WORK/good_entry/main.tya
! stderr .

# Class file checked successfully — reads the file as a v0.44
# library member without entry semantics.
exec go run ./cmd/tya check $WORK/standalone_good/Good.tya
! stderr .

# Class file checked directly sees sibling public interfaces.
exec go run ./cmd/tya check $WORK/codec/JsonEncoder.tya
! stderr .

# Class file with a name mismatch fails the structure check.
! exec go run ./cmd/tya check $WORK/standalone_bad/Hello.tya
stderr 'must define class or interface Hello'

# Check failure on an unresolved import.
! exec go run ./cmd/tya check $WORK/missing/main.tya
stderr 'module not found: never_exists'

-- good_entry/main.tya --
import lib

print(Lib.greet())

-- good_entry/lib/Lib.tya --
class Lib
  static greet: ->
    "hi"

-- standalone_good/Good.tya --
class Good
  initialize: ->
    self.x = 1

-- standalone_bad/Hello.tya --
class WrongName
  static noop: ->
    nil

-- codec/Encodable.tya --
interface Encodable
  encode: ->

-- codec/JsonEncoder.tya --
class JsonEncoder implements Encodable
  encode: ->
    "json"

-- missing/main.tya --
import never_exists

print(never_exists.Never.X())
