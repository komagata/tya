# run a broad v0.1 language-surface program through generated C
cd $REPO
exec go run ./cmd/tya run $WORK/main.tya first second
stdout 'large\nHello, Tya\n2\ntrue\nTya-lang\n3\nx:y\nfalse\nmissing\ntrue\ntrue\nfirst\n'
! stderr .

-- main.tya --
import greeting

score = 85
if score >= 90
  print("top")
elseif score >= 80
  print("large")
else
  print("small")

user = { name: "Tya", active: true }
print(greeting.hello(user["name"]))
print(user.len())
print(user.has("active"))
user.delete("active")
user["kind"] = "lang"
print(user["name"] + "-" + user["kind"])

items = [1, 2, 3]
print(items.len())

labels = { x: "X", y: "Y" }
joined = ""
for key, value of labels
  if joined == ""
    joined = key
  else
    joined = joined + ":" + key
print(joined)

err = error("missing")
print(err["message"] == "other")
print(err["message"])

text = " hello,tya ".trim()
parts = text.split(",")
print(parts.join("-").contains("hello"))
print(text.replace("tya", "Tya").starts_with("hello"))

arguments = args()
print(arguments[0])

-- greeting.tya --
hello = name -> "Hello, {name}"
