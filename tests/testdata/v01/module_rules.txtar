# `module` declarations are retired; imported script files synthesize a
# namespace from public top-level bindings.
cd $REPO

exec go run ./cmd/tya --emit-c $WORK/mismatch/main.tya
stdout 'tya_set_index.*tya_string\("text"\).*text'

exec go run ./cmd/tya --emit-c $WORK/two_modules/main.tya
stdout 'tya_set_index.*tya_string\("extra"\).*extra'

exec go run ./cmd/tya --emit-c $WORK/alias/main.tya

-- mismatch/main.tya --
import greeting
print(greeting.text)

-- mismatch/greeting.tya --
text = "hello"

-- two_modules/main.tya --
import greeting
print(greeting.text)

-- two_modules/greeting.tya --
text = "hello"
extra = "bad"

-- alias/main.tya --
import greeting as message
print(message.text)

-- alias/greeting.tya --
text = "hello"
