# v02 latest fixed-point proof.
#
# Stage 1 compiles selfhost/v02/compiler.tya, stage 2 recompiles the same
# source, and stage 3 must match stage 2 byte-for-byte. The same stage 1
# compiler also emits every other selfhost/v02/*.tya source that exists today.
# Latest lexical-closure, iterable, and protocol-interface fixtures live in
# sibling v02_selfhost scripts; this fixture is the fixed-point anchor.
cd $REPO
env TYA_LEGACY_MODULES=1

exec sh -c 'go run ./cmd/tya run selfhost/v02/compiler.tya selfhost/v02/compiler.tya > "$WORK/stage1.c"'
! stderr .

exec sh -c 'cc "$WORK/stage1.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage1" -lpthread -lm -lz 2>/dev/null'

exec sh -c '"$WORK/stage1" selfhost/v02/compiler.tya > "$WORK/stage2.c"'
! stderr .

exec sh -c 'cc "$WORK/stage2.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage2" -lpthread -lm -lz 2>/dev/null'

exec sh -c '"$WORK/stage2" selfhost/v02/compiler.tya > "$WORK/stage3.c"'
! stderr .

exec sh -c 'cc "$WORK/stage3.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage3" -lpthread -lm -lz 2>/dev/null'

exec cmp $WORK/stage2.c $WORK/stage3.c

exec sh -c '"$WORK/stage1" selfhost/v02/ast.tya > "$WORK/ast.c"'
! stderr .

exec sh -c 'cc "$WORK/ast.c" runtime/tya_runtime.c -I runtime -o "$WORK/ast" -lpthread -lm -lz 2>/dev/null'

exec sh -c '"$WORK/stage2" "$WORK/app.tya" > "$WORK/app.c"'
! stderr .

exec sh -c 'cc "$WORK/app.c" runtime/tya_runtime.c -I runtime -o "$WORK/app" -lpthread -lm -lz 2>/dev/null'

exec $WORK/app first second
stdout 'Hello, stage2\n3\nx:y\nsecond\n'
! stderr .

-- app.tya --
name = "stage2"
print("Hello, {name}")

items = [1, 2, 3]
print(items.len())

labels = [{ key: "x" }, { key: "y" }]
joined = ""
for entry in labels
  if joined == ""
    joined = entry["key"]
  else
    joined = joined + ":" + entry["key"]
print(joined)

argv = args()
print(argv[1])
