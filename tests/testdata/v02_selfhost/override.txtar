# v0.45 M8.2d: v02 parser accepts `override` before a method name.
# Codegen ignores the modifier (override correctness is the Go
# reference checker's job). Verifies the generated C still calls the
# subclass's method body, not the parent's.
cd $REPO
env TYA_LEGACY_MODULES=1

exec cp $SELFHOST_V02_STAGE1_C $WORK/stage1.c
exec cp $SELFHOST_V02_STAGE1_BIN $WORK/stage1

exec sh -c '"$WORK/stage1" "$WORK/override.tya" > "$WORK/override.c"'
! stderr .

exec cc $WORK/override.c runtime/tya_runtime.c -I runtime -o $WORK/override -lpthread -lm -lz
! stderr .

exec $WORK/override
stdout 'dog says woof\n'
! stderr .

-- override.tya --
class Animal
  init: name ->
    @name = name

  speak: ->
    "{@name} says ???"

class Dog extends Animal
  init: ->
    super("dog")

  override speak: ->
    "{@name} says woof"

d = Dog()
print(d.speak())
