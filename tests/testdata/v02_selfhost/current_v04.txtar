# Tya-written compiler supports the current v0.4 surface while preserving self-host.
cd $REPO
env TYA_LEGACY_MODULES=1

exec sh -c 'go run ./cmd/tya run selfhost/v02/compiler.tya "$WORK/current_v04.tya" > "$WORK/current_v04.c"'
! stderr .

exec cc $WORK/current_v04.c runtime/tya_runtime.c -I runtime -o $WORK/current_v04 -lpthread -lm -lz
! stderr .

exec $WORK/current_v04
stdout 'ok\n'
! stderr .

exec sh -c 'go run ./cmd/tya run selfhost/v02/compiler.tya selfhost/v02/compiler.tya > "$WORK/stage1.c"'
! stderr .

exec sh -c 'cc "$WORK/stage1.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage1" -lpthread -lm -lz 2>/dev/null'

exec sh -c '"$WORK/stage1" selfhost/v02/compiler.tya > "$WORK/stage2.c"'
! stderr .

exec sh -c 'cc "$WORK/stage2.c" runtime/tya_runtime.c -I runtime -o "$WORK/stage2" -lpthread -lm -lz 2>/dev/null'

exec sh -c '"$WORK/stage2" "$WORK/current_v04.tya" > "$WORK/current_v04_stage2.c"'
! stderr .

exec cc $WORK/current_v04_stage2.c runtime/tya_runtime.c -I runtime -o $WORK/current_v04_stage2 -lpthread -lm -lz
! stderr .

exec $WORK/current_v04_stage2
stdout 'ok\n'
! stderr .

exec sh -c 'go run ./cmd/tya run selfhost/v02/compiler.tya "$WORK/fail_assert.tya" > "$WORK/fail_assert.c"'
! stderr .

exec cc $WORK/fail_assert.c runtime/tya_runtime.c -I runtime -o $WORK/fail_assert -lpthread -lm -lz
! stderr .

! exec $WORK/fail_assert
stderr 'fail_assert.tya:1:1: assertion failed'
! stdout .

exec sh -c 'go run ./cmd/tya run selfhost/v02/compiler.tya "$WORK/fail_equal.tya" > "$WORK/fail_equal.c"'
! stderr .

exec cc $WORK/fail_equal.c runtime/tya_runtime.c -I runtime -o $WORK/fail_equal -lpthread -lm -lz
! stderr .

! exec $WORK/fail_equal
stderr 'fail_equal.tya:1:1: assert_equal failed'
stderr 'expected:'
stderr 'name: tya'
stderr 'actual:'
stderr 'name: Tya'
! stdout .

exec sh -c 'go run ./cmd/tya run selfhost/v02/compiler.tya "$WORK/v04_string.tya" > "$WORK/v04_string.c"'
! stderr .

exec cc $WORK/v04_string.c runtime/tya_runtime.c -I runtime -o $WORK/v04_string -lpthread -lm -lz
! stderr .

exec $WORK/v04_string
! stdout .
! stderr .

exec sh -c 'go run ./cmd/tya run selfhost/v02/compiler.tya "$WORK/v04_array.tya" > "$WORK/v04_array.c"'
! stderr .

exec cc $WORK/v04_array.c runtime/tya_runtime.c -I runtime -o $WORK/v04_array -lpthread -lm -lz
! stderr .

exec $WORK/v04_array
! stdout .
! stderr .

-- current_v04.tya --
items = [1, 2, 3]
doubled = items.map(item -> item * 2)
sum = total, item -> total + item

assert("  ".trim() == "")
assert([].len() == 0)
assert_equal([2, 4, 6], doubled)
assert_equal(6, items.reduce(0, sum))
assert_equal(true, items.any(item -> item == 2))
assert_equal(true, items.all(item -> item > 0))
assert_equal(2, items.find(item -> item == 2))
assert_equal(true, equal([1, {name: "tya"}], [1, {name: "tya"}]))
print(["ok"][0])

-- fail_assert.tya --
assert(false)

-- fail_equal.tya --
assert_equal([1, {name: "tya"}], [1, {name: "Tya"}])

-- v04_string.tya --
assert(" ".trim() == "")
assert("tya".trim() != "")
assert_equal(false, "tya".trim() == "")
assert_equal(true, "tya".trim() != "")

-- v04_array.tya --
assert([].len() == 0)
assert_equal(false, ["tya"].len() == 0)
assert_equal("tya", ["tya"][0])
assert_equal([1, {name: "tya"}], [1, {name: "tya"}])
