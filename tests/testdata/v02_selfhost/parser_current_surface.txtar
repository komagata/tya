# v02 parser accepts current-spec lexer/parser surface families. This fixture
# builds the self-host stage once, then runs parser-only AST checks for each
# syntax family so the full suite stays within the default Go test timeout.
cd $REPO
env TYA_LEGACY_MODULES=1

exec cp $SELFHOST_V02_STAGE1_C $WORK/stage1.c
exec cp $SELFHOST_V02_STAGE1_BIN $WORK/stage1

exec $WORK/stage1 --ast $WORK/imports.tya
stdout '1: import greeting\n2: import net/http\n3: import net/http as http\n4: assign name = string\n'
! stderr .

! exec $WORK/stage1 --ast $WORK/reserved.tya
stdout '1: spawn cannot be used as a name'
stdout '2: await cannot be used as a name'
stdout '3: with cannot be used as a name'
stdout '4: private cannot be used as a name'
! stderr .

exec $WORK/stage1 --ast $WORK/interfaces.tya
stdout '1: interface Named methods 2 fields 0\n7: interface Timestamped methods 1 fields 1\n13: class Account implements 2\n'
! stderr .

exec $WORK/stage1 --ast $WORK/control.tya
stdout '1: assign run = func 0 block 2\n'
! stderr .

exec $WORK/stage1 --ast $WORK/match_select.tya
stdout '1: match 2\n6: select 4\n'
! stderr .

exec $WORK/stage1 --ast $WORK/embed.tya
stdout '1: embed index_html\n2: embed assets\n3: assign name = string\n'
! stderr .

exec $WORK/stage1 --ast $WORK/strings.tya
stdout '1: assign plain = string\n2: assign bytes = string\n3: assign raw = string\n4: assign multi = string\n7: assign tagged = string\n'
! stderr .

exec $WORK/stage1 --ast $WORK/lambda.tya
stdout '1: assign add = func 2 expr binary \+\n2: assign square = func 1 expr binary \*\n'
! stderr .

exec $WORK/stage1 --ast $WORK/latest_closure_iterable.tya
stdout '1: assign make_counter = func 1 block 3\n7: assign items = array 3\n8: for\n'
! stderr .

exec $WORK/stage1 --ast $WORK/predicate_bitwise.tya
stdout '1: assign empty? = func 1 expr binary ==\n2: expr_stmt call ident print 1\n3: assign mask = binary \\|\n4: assign shifted = binary >>\n'
! stderr .

exec $WORK/stage1 --ast lib/comparable.tya
stdout '2: interface Comparable methods 6 fields 0\n'
! stderr .

exec $WORK/stage1 --ast lib/equatable.tya
stdout '2: interface Equatable methods 1 fields 0\n'
! stderr .

exec $WORK/stage1 --ast lib/stringable.tya
stdout '2: interface Stringable methods 1 fields 0\n'
! stderr .

exec $WORK/stage1 --ast lib/sequence.tya
stdout '2: interface Sequence methods 11 fields 0\n'
! stderr .

exec $WORK/stage1 --ast $WORK/heredoc.tya
stdout '1: assign plain = string\n4: assign raw = string\n7: assign bytes = string\n10: assign tagged = string\n'
! stderr .

exec $WORK/stage1 --ast $WORK/member_modifiers.tya
stdout '1: class Account implements 1\n10: interface Named methods 1 fields 0\n'
! stderr .

exec $WORK/stage1 --check $WORK/valid_semantics.tya
! stderr .

! exec $WORK/stage1 --check $WORK/invalid_semantics.tya
stdout '1: class Broken must implement interface method name'
stdout '7: duplicate class member value'
stdout '15: self is only valid inside a class method'
stdout '17: missing embed file: missing.txt'
! stderr .

exec sh -c '"$WORK/stage1" "$WORK/current_runtime.tya" > "$WORK/current_runtime.c"'
! stderr .

exec cc $WORK/current_runtime.c runtime/tya_runtime.c -I runtime -o $WORK/current_runtime -lpthread -lm -lz
! stderr .

exec $WORK/current_runtime
stdout 'Hello, Tya\nasset-body\nA,B\n'
! stderr .

! exec $WORK/stage1 $WORK/unsupported_runtime.tya
stdout '1: unsupported codegen: scope'
stdout '2: unsupported codegen: spawn'
stdout '3: unsupported codegen: await'
! stderr .

-- imports.tya --
import greeting
import net/http/*
import net/http/*
name = "imports parsed"

-- reserved.tya --
spawn = 1
await = 2
with = 3
private = 4

-- interfaces.tya --
interface Named
  name: ->

  label: ->
    "label:" + self.name()

interface Timestamped extends Named
  created_at: nil

  initialize: ->
    self.created_at = Time.now()

class Account implements Named, Timestamped
  name_value: nil

  initialize: name ->
    self.name_value = name

-- control.tya --
run = ->
  scope
    task = spawn work()
    print(await task)
  try
    raise "boom"
  catch err
    print(err)

-- match_select.tya --
match status
  case "ok"
    print("ok")
  case _
    print("other")
select
  value = receive inbox
    print(value)
  send outbox, "next"
    print("sent")
  timeout 1
    print("timeout")
  default
    print("idle")

-- embed.tya --
embed "templates/index.html" as index_html
embed "static/**" as assets with { hash: true, gzip: true }
name = "embed parsed"

-- strings.tya --
plain = "Hello, {name}"
bytes = b"abc"
raw = r"""{name}"""
multi = """
hello
"""
tagged = sql"""select 1"""

-- lambda.tya --
add = (a, b) -> a + b
square = (x) -> x * x

-- latest_closure_iterable.tya --
make_counter = start ->
  count = start
  step = delta ->
    count + delta
  step

items = [1, 2, 3]
for item in items.map(x -> x + 1).filter(x -> x > 1)
  print(item)

-- predicate_bitwise.tya --
empty? = values -> values.len() == 0
print(empty?([]))
mask = 1 | 2 ^ 3 & 4
shifted = mask << 1 >> 1

-- heredoc.tya --
plain = <<<TEXT
hello
TEXT
raw = r<<<RAW
\d+
RAW
bytes = b<<<BYTES
abc
BYTES
tagged = sql<<<SQL
select 1
SQL

-- member_modifiers.tya --
class Account implements Named
  private token: ""

  static build: name ->
    Account(name)

  override label: ->
    "account"

interface Named
  abstract label: ->

-- valid_semantics.tya --
import net/http/*

embed "templates/index.html" as index_html

interface Named
  name: ->

class Account implements Named
  name_value: nil

  initialize: name ->
    self.name_value = name

  name: ->
    self.name_value

  static build: name ->
    Self(name)

run = ->
  status = "ok"
  scope
    task = spawn work()
    print(await task)
  try
    raise "boom"
  catch err
    print(err)
  match status
    case "ok"
      print("ok")
    case _
      print("other")
  select
    value = receive inbox
      print(value)
    default
      print("idle")

work = ->
  "done"

-- invalid_semantics.tya --
class Broken implements Named
  value: 1

interface Named
  name: ->

class Duplicate
  value: ->
    1

  value: ->
    2

outside = ->
  self

embed "missing.txt" as missing

-- current_runtime.tya --
embed "asset.txt" as asset_text

interface RuntimeNamed
  name: ->

class RuntimeAccount implements RuntimeNamed
  init: name ->
    @name = name

  name: ->
    @name

  greeting: ->
    "Hello, {@name}"

account = RuntimeAccount("Tya")
print(account.greeting())
print(asset_text.trim())
print(["A", "B"].join(","))

-- unsupported_runtime.tya --
scope
  task = spawn work()
  print(await task)

work = ->
  "done"

-- asset.txt --
asset-body

-- templates/index.html --
<h1>ok</h1>
