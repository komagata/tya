# v0.45 M8.2c: v02 parser accepts `abstract` and `final` as class
# modifiers in front of `class`. v02 codegen treats them as no-ops
# (the strict semantic checks live in the Go reference checker), so a
# class declared `final class X extends Y` still compiles, links, and
# runs through the v02 self-host pipeline.
cd $REPO
env TYA_LEGACY_MODULES=1

exec cp $SELFHOST_V02_STAGE1_C $WORK/stage1.c
exec cp $SELFHOST_V02_STAGE1_BIN $WORK/stage1

exec sh -c '"$WORK/stage1" "$WORK/abstract_final.tya" > "$WORK/abstract_final.c"'
! stderr .

exec cc $WORK/abstract_final.c runtime/tya_runtime.c -I runtime -o $WORK/abstract_final -lpthread -lm -lz
! stderr .

exec $WORK/abstract_final
stdout 'shape\ncircle\n'
! stderr .

-- abstract_final.tya --
abstract class Shape
  init: name ->
    @name = name

  describe: ->
    @name

final class Circle extends Shape
  init: ->
    super("circle")

s = Shape("shape")
print(s.describe())
c = Circle()
print(c.describe())
