# v0.30 coverage foundation: tya test --cover writes a profile,
# tya cover renders text and JSON.
cd $REPO

# version
exec go run ./cmd/tya version
stdout '0.34.0\n'

# tya cover without a profile errors cleanly.
! exec go run ./cmd/tya cover --profile $WORK/missing.cov
stderr 'no such file|cannot find'

# Run a tiny test suite under --cover.
exec go run ./cmd/tya test --cover --profile $WORK/profile.cov $WORK/probe_test.tya
stdout 'PASS  test_one'
stdout 'PASS  test_two'

# Profile file exists with the documented header.
exec cat $WORK/profile.cov
stdout '^# tya-cover 1'
stdout '^F 0 '
stdout '^S 0 '
stdout '^H 0 '

# tya cover renders the table.
exec go run ./cmd/tya cover --profile $WORK/profile.cov
stdout 'File '
stdout 'Stmts'
stdout 'Total'
stdout '%'

# tya cover --format=json renders JSON with the documented top-level keys.
exec go run ./cmd/tya cover --profile $WORK/profile.cov --format=json
stdout '"tool": "tya"'
stdout '"version": "0.34.0"'
stdout '"format": 1'
stdout '"totals":'

-- probe_test.tya --
import unittest

module probe_test
  test_one = ->
    unittest.assert(1 == 1)
  test_two = ->
    unittest.assert_equal(2, 1 + 1)
