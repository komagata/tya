# v0.30 coverage foundation: tya test --cover writes a profile,
# tya cover renders text and JSON.
cd $REPO

# version
exec go run ./cmd/tya version
stdout '0.71.0\n'

# tya cover without a profile errors cleanly.
! exec go run ./cmd/tya cover --profile $WORK/missing.cov
stderr 'no such file|cannot find'

# Run a tiny test suite under --cover.
exec go run ./cmd/tya test --cover --profile $WORK/profile.cov $WORK/probe_test.tya
stdout 'PASS  ProbeTest.test_one'
stdout 'PASS  ProbeTest.test_two'

# Profile file exists with the documented header.
exec cat $WORK/profile.cov
stdout '^# tya-cover 1'
stdout '^F 0 '
stdout '^S 0 '
stdout '^H 0 '

# tya cover renders the table.
exec go run ./cmd/tya cover --profile $WORK/profile.cov
stdout 'File '
stdout 'Stmts'
stdout 'Total'
stdout '%'

# tya cover --format=json renders JSON with the documented top-level keys.
exec go run ./cmd/tya cover --profile $WORK/profile.cov --format=json
stdout '"tool": "tya"'
stdout '"version": "0.71.0"'
stdout '"format": 1'
stdout '"totals":'

# HTML, filters, and minimum threshold work on existing profiles.
cd $REPO
exec sh -c 'printf "# tya-cover 1\nF 0 %s/src/app.tya\nF 1 %s/src/skip/ignored.tya\nS 0 0 1 1\nS 1 0 2 1\nS 2 1 1 1\nH 0 1\n" "$WORK" "$WORK" > "$WORK/manual_abs.cov"'
exec go run ./cmd/tya cover html --profile $WORK/manual_abs.cov -o $WORK/report.html --include 'src/**' --exclude 'src/skip/**' --min 50
exists $WORK/report.html
exec cat $WORK/report.html
stdout 'Tya Coverage'
stdout 'src/app.tya'
stdout 'covered'
stdout 'missed'
! stdout 'src/skip/ignored.tya'

! exec go run ./cmd/tya cover --profile $WORK/manual_abs.cov --min 90
stderr 'below minimum'

-- probe_test.tya --
import unittest/*

class ProbeTest extends TestCase
  test_one: ->
    self.assert(1 == 1, "one")
  test_two: ->
    self.assert_equal(2, 1 + 1, "two")

-- src/app.tya --
x = 1
print(x)

-- src/skip/ignored.tya --
ignored = true
