cd $REPO

exec go run ./cmd/tya run $WORK/default_stderr.tya
! stdout .
stderr ' info hello app=tya\n'
stderr ' warn careful\n'
stderr ' error bad\n'
! stderr 'debug'

-- default_stderr.tya --
import logger

log = logger.Logger(nil).default()
log.debug("debug", {})
log.info("hello", { app: "tya" })
log.warn("careful", {})
log.error("bad", {})
