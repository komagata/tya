# Build the CLI once so closure behavior is tested through the active C path.
exec env -u GOROOT go -C $REPO build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
env TYA_LIB_DIR=$REPO/lib

# Grandchild closures can capture values from every enclosing function.
exec $WORK/tya run nested_capture.tya
stdout '6\n'
! stderr .

# Returned closures can capture parameters and locals, each call receives an
# independent environment, and later creator reassignment does not alter the
# captured snapshot.
exec $WORK/tya run returned_capture.tya
stdout '5\n'
stdout '8\n'
stdout '1\n'
! stderr .

# Captured values remain usable through array higher-order methods.
exec $WORK/tya run array_higher_order.tya
stdout '11,12,13\n'
stdout '2,3\n'
stdout '36\n'
! stderr .

# Captured closures can be passed to spawn and awaited.
exec $WORK/tya run spawn_capture.tya
stdout '42\n'
! stderr .

# Captured heap values stay reachable across explicit GC.
exec $WORK/tya run gc_capture.tya
stdout '42\n'
! stderr .

# Direct reassignment to an outer binding remains rejected.
! exec $WORK/tya check direct_outer_reassign.tya
stderr 'Cannot reassign `x` from inside a function body'

# Closures may not mutate through captured outer bindings.
! exec $WORK/tya check captured_array_mutation.tya
stderr 'Cannot mutate `items` through a captured binding'

! exec $WORK/tya check captured_dict_mutation.tya
stderr 'Cannot mutate `state` through a captured binding'

! exec $WORK/tya check captured_member_mutation.tya
stderr 'Cannot mutate `box` through a captured binding'

# Passing mutable state explicitly keeps mutation possible.
exec $WORK/tya run explicit_parameter_mutation.tya
stdout '2\n'
! stderr .

# Primitive values, user-defined Iterable values, lazy Sequence wrappers, and
# dictionary entry iteration all works through the same active C path.
exec $WORK/tya run iterable_protocol.tya
stdout '1\n2\n3\n10/0\n20/1\nt\ny\na\nname=Tya\nname\nTya\ntrue\nnil\ntrue\ncaught\nnil\n7\nbuilt\nfilter 1\nfilter 2\nmap 2\nfilter 3\nmap 3\n4,6\nfilter 1\nfilter 2\nmap 2\nfilter 3\nmap 3\n4,6\n5\nname=Tya\n'
! stderr .

exec $WORK/tya run primitive_sequence_methods.tya
stdout 'a,b,c\ntrue\ntrue\nb\n65,66,67\n198\n65\n66\n67\nseen a\nseen b\ntrue\nall a\nall b\nfalse\nfind a\nfind b\nb\nx\ny\nnil\n'
! stderr .

-- nested_capture.tya --
make = x ->
  mid = y ->
    z -> x + y + z
  mid

f = make(1)(2)
print(f(3))

-- returned_capture.tya --
make_param = x ->
  y -> x + y

make_local = base ->
  local = base + 1
  y -> local + y

make_snapshot = ->
  x = 1
  f = -> x
  x = 2
  f

add2 = make_param(2)
add5 = make_param(5)
print(add2(3))
print(add5(3))
print(make_snapshot()())

-- array_higher_order.tya --
make_mapper = offset ->
  item -> item + offset

make_filter = min ->
  item -> item > min

make_sum = offset ->
  total, item -> total + item + offset

items = [1, 2, 3]
print(items.map(make_mapper(10)).join(","))
print(items.filter(make_filter(1)).join(","))
print(items.reduce(0, make_sum(10)))

-- spawn_capture.tya --
make_worker = base ->
  -> base + 1

worker = make_worker(41)
task = spawn worker()
print(await task)

-- gc_capture.tya --
import runtime

make = ->
  items = [41]
  -> items[0] + 1

f = make()
runtime.Runtime().gc()
print(f())

-- direct_outer_reassign.tya --
make = ->
  x = 1
  ->
    x = 2

make()

-- captured_array_mutation.tya --
make = ->
  items = [1]
  ->
    items[0] = 2

make()

-- captured_dict_mutation.tya --
make = ->
  state = { count: 0 }
  ->
    state["count"] = state["count"] + 1

make()

-- captured_member_mutation.tya --
class Box
  initialize: value ->
    self.value = value

make = ->
  box = Box.new(1)
  ->
    box.value = 2

make()

-- explicit_parameter_mutation.tya --
set_first = items ->
  items[0] = 2

items = [1]
set_first(items)
print(items[0])

-- primitive_iteration.tya --
for item in [1, 2, 3]
  print(item)

for item, index in [10, 20]
  print("{item}/{index}")

for char in "tya"
  print(char)

for entry in { name: "Tya" }
  key = entry["key"]
  value = entry["value"]
  print("{key}={value}")

for key in { name: "Tya" }.keys()
  print(key)

for value in { name: "Tya" }.values()
  print(value)

-- primitive_sequence_methods.tya --
print("abc".sequence().to_a().join(","))
print("abc".sequence().any?(c -> c == "b"))
print("abc".sequence().all?(c -> c != "z"))
print("abc".sequence().find(c -> c == "b"))
print(b"ABC".sequence().to_a().join(","))
byte_sum = total, byte -> total + byte
sum = b"ABC".sequence().reduce(0, byte_sum)
print(sum)

for byte in b"ABC"
  print(byte)

any_check = c ->
  print("seen {c}")
  if c == "b"
    return true
  false

any_result = "abc".sequence().any?(any_check)
print(any_result)

all_check = c ->
  print("all {c}")
  if c != "b"
    return true
  false

all_result = "abc".sequence().all?(all_check)
print(all_result)

find_check = c ->
  print("find {c}")
  if c == "b"
    return true
  false

found = "abc".sequence().find(find_check)
print(found)

print_item = c ->
  print(c)

each_result = "xy".sequence().each(print_item)
print(each_result)

-- explicit_iterators.tya --
array_iter = [nil].iter()
print(array_iter.has_next?())
print(array_iter.next())
print(not array_iter.has_next?())
try
  array_iter.next()
  print("missing")
catch err
  print("caught")

-- user_iterable.tya --
interface Iterable
  iter: ->

class PairIterator
  initialize: ->
    self.index = 0

  has_next?: ->
    self.index < 2

  next: ->
    if not self.has_next?()
      raise error("done")
    self.index = self.index + 1
    if self.index == 1
      return nil
    7

class Pair implements Iterable
  iter: ->
    PairIterator()

for item in Pair()
  if item == nil
    print("nil")
  else
    print(item)

-- lazy_sequence.tya --
items = [1, 2, 3, 4]
filter_fn = item ->
  print("filter {item}")
  return item > 1

map_fn = item ->
  print("map {item}")
  return item * 2

seq = items.sequence().filter(filter_fn).map(map_fn).take(2)

print("built")
print(seq.to_a().join(","))
print(seq.to_a().join(","))

sum_fn = total, item -> total + item
sum = [1, 2, 3].sequence().drop(1).reduce(0, sum_fn)
print(sum)

-- dict_entries.tya --
for entry in { name: "Tya" }
  key = entry["key"]
  value = entry["value"]
  print("{key}={value}")

-- iterable_protocol.tya --
for item in [1, 2, 3]
  print(item)

for item, index in [10, 20]
  print("{item}/{index}")

for char in "tya"
  print(char)

for entry in { name: "Tya" }
  key = entry["key"]
  value = entry["value"]
  print("{key}={value}")

for key in { name: "Tya" }.keys()
  print(key)

for value in { name: "Tya" }.values()
  print(value)

array_iter = [nil].iter()
print(array_iter.has_next?())
print(array_iter.next())
print(not array_iter.has_next?())
try
  array_iter.next()
  print("missing")
catch err
  print("caught")

interface Iterable
  iter: ->

class PairIterator
  initialize: ->
    self.index = 0

  has_next?: ->
    self.index < 2

  next: ->
    if not self.has_next?()
      raise error("done")
    self.index = self.index + 1
    if self.index == 1
      return nil
    7

class Pair implements Iterable
  iter: ->
    PairIterator()

for item in Pair()
  if item == nil
    print("nil")
  else
    print(item)

items = [1, 2, 3, 4]
filter_fn = item ->
  print("filter {item}")
  return item > 1

map_fn = item ->
  print("map {item}")
  return item * 2

seq = items.sequence().filter(filter_fn).map(map_fn).take(2)

print("built")
print(seq.to_a().join(","))
print(seq.to_a().join(","))

sum_fn = total, item -> total + item
sum = [1, 2, 3].sequence().drop(1).reduce(0, sum_fn)
print(sum)

for entry in { name: "Tya" }
  key = entry["key"]
  value = entry["value"]
  print("{key}={value}")
