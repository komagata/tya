# v0.6 class-level state and behavior.
cd $REPO

exec go run ./cmd/tya run $WORK/classes.tya
stdout '0\nHello, komagata\nkomagata\n1\n1\n9\non:komagata\n0\n'
! stderr .

exec go run ./cmd/tya run $WORK/main.tya
stdout 'module\n1\n1\n7\n'
! stderr .

exec go run ./cmd/tya run $WORK/shadowing.tya
stdout '201\n202\n'
! stderr .

! exec go run ./cmd/tya run $WORK/class_var_outside.tya
stderr 'TYA-E0412'

! exec go run ./cmd/tya run $WORK/duplicate_class_member.tya
stderr 'duplicate class member count'

! exec go run ./cmd/tya run $WORK/duplicate_instance_member.tya
stderr 'duplicate instance member name'

! exec go run ./cmd/tya run $WORK/missing_class_member.tya
stderr 'missing class variable or method: missing'
! stdout .

exec go run ./cmd/tya version
stdout '0.72.11\n'
! stderr .

-- classes.tya --
class User
  name: ""
  active: true
  static count: 0
  static prefix: "on"

  initialize: user_name ->
    self.name = user_name
    Self.count = Self.count + 1

  greeting: ->
    "Hello, {self.name}"

  count: ->
    Self.count

  label: ->
    "{Self.prefix}:{self.name}"

  static build: user_name ->
    User(user_name)

  static count_users: ->
    Self.count

  static reset: ->
    Self.count = 0

print(User.count)
user = User.build("komagata")
print(user.greeting())
print(user.name)
print(user.count())
print(User.count_users())
User.count = 9
print(User.count)
print(user.label())
User.reset()
print(User.count)

-- user.tya --
class User
  name: ""
  static count: 0

  initialize: user_name ->
    self.name = user_name
    Self.count = Self.count + 1

  name: ->
    self.name

  static count_users: ->
    Self.count

-- main.tya --
import user

u = user.User("module")
print(u.name())
print(user.User.count)
print(user.User.count_users())
user.User.count = 7
print(user.User.count)

-- shadowing.tya --
class Response
  status: 0

  initialize: ->
    self.status = 200
    self.bump()

  bump: ->
    self.status = self.status + 1

  status: ->
    self.status

response = Response()
print(response.status())
response.bump()
print(response.status())

-- class_var_outside.tya --
Self.count = 0

-- duplicate_class_member.tya --
class User
  static count: 0
  static count: ->
    1

-- duplicate_instance_member.tya --
class User
  name: ""
  name: "again"

-- missing_class_member.tya --
class User
  static count: 0

print(User.missing)
