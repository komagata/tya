# v0.6 class-level state and behavior.
cd $REPO

exec go run ./cmd/tya run $WORK/classes.tya
stdout '0\nHello, komagata\nkomagata\n1\n1\n9\non:komagata\n0\n'
! stderr .

exec go run ./cmd/tya run $WORK/main.tya
stdout 'module\n1\n1\n7\n'
! stderr .

! exec go run ./cmd/tya run $WORK/at_in_class_method.tya
stderr '@name is only valid inside an instance method'

! exec go run ./cmd/tya run $WORK/class_var_outside.tya
stderr '@@count is only valid inside a class'

! exec go run ./cmd/tya run $WORK/duplicate_class_member.tya
stderr 'duplicate class member count'

! exec go run ./cmd/tya run $WORK/duplicate_instance_member.tya
stderr 'duplicate instance member name'

! exec go run ./cmd/tya run $WORK/missing_class_member.tya
stderr 'missing class variable or method: missing'
! stdout .

exec go run ./cmd/tya version
stdout '0.6.0\n'
! stderr .

-- classes.tya --
class User
  name = ""
  active = true
  @@count = 0
  @@prefix = "on"

  init = name ->
    @name = name
    @@count = @@count + 1

  greeting = ->
    "Hello, {@name}"

  count = ->
    @@count

  label = ->
    "{@@prefix}:{@name}"

  @@build = name ->
    User(name)

  @@count_users = ->
    @@count

  @@reset = ->
    @@count = 0

print User.count
user = User.build("komagata")
print user.greeting()
print user.name
print user.count()
print User.count_users()
User.count = 9
print User.count
print user.label()
User.reset()
print User.count

-- user.tya --
module user
  class User
    @@count = 0

    init = name ->
      @name = name
      @@count = @@count + 1

    name = ->
      @name

    @@count_users = ->
      @@count

-- main.tya --
import user

u = user.User("module")
print u.name()
print user.User.count
print user.User.count_users()
user.User.count = 7
print user.User.count

-- at_in_class_method.tya --
class User
  @@bad = ->
    @name

-- class_var_outside.tya --
@@count = 0

-- duplicate_class_member.tya --
class User
  @@count = 0
  @@count = ->
    1

-- duplicate_instance_member.tya --
class User
  name = ""
  name = ->
    @name

-- missing_class_member.tya --
class User
  @@count = 0

print User.missing
