# Serializable interface shape.
cd $REPO

exec go run ./cmd/tya run $WORK/serializable.tya
stdout 'Ada\n'

! exec go run ./cmd/tya run $WORK/construct_serializable.tya
stderr 'cannot construct interface Serializable'

! exec go run ./cmd/tya run $WORK/missing_to_data.tya
stderr 'class BrokenSerializable must implement interface method to_data'

-- serializable.tya --
interface Serializable
  to_data: ->

class Player implements Serializable
  initialize: name ->
    self.name = name

  to_data: ->
    { name: self.name }

print(Player("Ada").to_data()["name"])

-- construct_serializable.tya --
import serialization as serialization

value = serialization.Serializable()

-- missing_to_data.tya --
interface Serializable
  to_data: ->

class BrokenSerializable implements Serializable
  name: "Ada"
