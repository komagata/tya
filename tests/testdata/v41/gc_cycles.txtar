# v0.41: mark-and-sweep reclaims cyclic data once it is unreachable
# from the root set.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout 'made cycles, peak live:'
stdout 'cleared root, after gc:'
stdout 'cycle reclaimed: true'

-- sample.tya --
import runtime

# Build many cyclic dicts: each holds a reference to itself.
root = []
i = 0
while i < 30
  c = {}
  c["self"] = c
  push(root, c)
  i = i + 1

peak = runtime.Runtime.gc_stats()
print("made cycles, peak live: " + to_string(peak["live_count"]))

# Drop the only reference. The cycles are now unreachable yet still
# reference each other.
root = []
runtime.Runtime.gc()

after = runtime.Runtime.gc_stats()
print("cleared root, after gc: " + to_string(after["live_count"]))
print("cycle reclaimed: " + to_string(after["live_count"] < peak["live_count"]))
