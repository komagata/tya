# v0.41 STEPs 2-4: explicit runtime.Runtime().gc() reclaims unreachable allocations.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout 'before live:'
stdout 'peak live:'
stdout 'after gc, live:'
stdout 'collect_count: 1'
stdout 'shrunk: true'

-- sample.tya --
import runtime

# Allocate a tree of arrays. Hold the root in a global so it survives GC.
root = []
i = 0
while i < 50
  root.push([i, i + 1, i + 2])
  i = i + 1

before = runtime.Runtime().gc_stats()
print("before live: " + before["live_count"].to_string())

# Capture the peak live count, then drop the references by overwriting
# root with a fresh empty array. The previous tree is now unreachable.
peak = runtime.Runtime().gc_stats()
print("peak live: " + peak["live_count"].to_string())
root = []

# Trigger a collection. The unreachable inner arrays must be reclaimed.
runtime.Runtime().gc()

after = runtime.Runtime().gc_stats()
print("after gc, live: " + after["live_count"].to_string())
print("collect_count: " + after["collect_count"].to_string())
shrunk = after["live_count"] < peak["live_count"]
print("shrunk: " + shrunk.to_string())
