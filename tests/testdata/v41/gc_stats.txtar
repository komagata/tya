# v0.41 STEP 1: GC-aware allocator + runtime.Runtime().gc_stats() introspection.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout 'has all keys: true'
stdout 'live grew: true'

-- sample.tya --
import runtime

before = runtime.Runtime().gc_stats()

# Allocate enough heap structs that live_count must increase.
items = []
i = 0
while i < 50
  items.push([i, i + 1])
  i = i + 1

after = runtime.Runtime().gc_stats()

# Expected keys are present.
keys_ok = before.has("alloc_count") and before.has("alloc_bytes")
keys_ok = keys_ok and before.has("freed_count") and before.has("freed_bytes")
keys_ok = keys_ok and before.has("live_count") and before.has("live_bytes")
print("has all keys: " + keys_ok.to_s())

# Allocations track new heap structs.
grew = after["alloc_count"] > before["alloc_count"]
grew = grew and after["live_count"] > before["live_count"]
print("live grew: " + grew.to_s())
