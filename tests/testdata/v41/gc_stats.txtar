# v0.41 STEP 1: GC-aware allocator + runtime.gc_stats() introspection.
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout 'has all keys: true'
stdout 'live grew: true'

-- sample.tya --
import runtime

before = runtime.gc_stats()

# Allocate enough heap structs that live_count must increase.
items = []
i = 0
while i < 50
  push(items, [i, i + 1])
  i = i + 1

after = runtime.gc_stats()

# Expected keys are present.
keys_ok = has(before, "alloc_count") and has(before, "alloc_bytes")
keys_ok = keys_ok and has(before, "freed_count") and has(before, "freed_bytes")
keys_ok = keys_ok and has(before, "live_count") and has(before, "live_bytes")
print("has all keys: " + to_string(keys_ok))

# Allocations track new heap structs.
grew = after["alloc_count"] > before["alloc_count"]
grew = grew and after["live_count"] > before["live_count"]
print("live grew: " + to_string(grew))
