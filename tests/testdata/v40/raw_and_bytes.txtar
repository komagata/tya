# v0.40 raw and bytes string extensions: r"..." / r"""...""" /
# b"""..."""
cd $REPO

exec go run ./cmd/tya run $WORK/sample.tya
stdout '\\d\+ files in \{dir\}'
stdout 'Use \{name\} with care:'
stdout '  \\n is two characters here.'
stdout 'bytes len: 12'
stdout 'raw heredoc: \\d\+ files in \{dir\}'
stdout 'bytes heredoc len: 5'

exec go run ./cmd/tya version
stdout '0.72.1\n'

-- sample.tya --
re = r"\d+ files in {dir}"
print(re)

template = r"""
  Use {name} with care:
    \n is two characters here.
  """
print(template)

multi = b"""
  hello
  world
  """
print("bytes len: " + (multi.len()).to_s())

rawh = r<<<REGEX
  \d+ files in {dir}
  REGEX
print("raw heredoc: " + rawh)

payload = b<<<BYTES
  hi\x0a!
  BYTES
print("bytes heredoc len: " + (payload.len()).to_s())
