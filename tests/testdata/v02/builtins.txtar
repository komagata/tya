# v0.2 collection builtins, deep equality, and stdin.
cd $REPO
exec go run ./cmd/tya run $WORK/builtins.tya
stdout '2,4,6,8\n2\n3\ntrue\ntrue\n10\ntrue\ntrue\ntrue\n'
! stderr .

exec sh -c 'printf "hello\n" | go run ./cmd/tya run "$WORK/read.tya"'
stdout 'hello\n'
! stderr .

exec sh -c 'printf "" | go run ./cmd/tya run "$WORK/read.tya"'
stdout 'empty\n'
! stderr .

-- builtins.tya --
items = [1, 2, 3, 4]
mapped = items.map(item -> item * 2)
print(mapped.map(item -> item.to_string()).join(","))
filtered = items.filter(item -> item > 2)
sum = total, item -> total + item
print(filtered.len())
print(items.find(item -> item == 3))
print(items.any(item -> item == 4))
print(items.all(item -> item > 0))
print(items.reduce(0, sum))
print([1] == [1])
print([1, {name: "tya"}].equal?([1, {name: "tya"}]))
print({nested: [1, 2]}.equal?({nested: [1, 2]}))

-- read.tya --
import io/*

input_line = io.Io().stdin().read_line()
if input_line == nil
  print("empty")
else
  print(input_line)
