# v0.2 public CLI commands.
cd $REPO
exec go run ./cmd/tya check $WORK/good.tya
! stdout .
! stderr .

exec go run ./cmd/tya emit-c $WORK/good.tya
stdout 'tya_print'
! stderr .

exec go run ./cmd/tya format $WORK/messy.tya
stdout 'name = "Tya"\nprint\(name\)\n'
! stderr .

cp $WORK/messy.tya $WORK/write.tya
exec go run ./cmd/tya format -w $WORK/write.tya
! stdout .
! stderr .
cmp $WORK/write.tya $WORK/formatted.tya

! exec go run ./cmd/tya check $WORK/bad.tya
stderr 'bad.tya:1:7: undefined variable missing'
stderr 'print\(missing\)'
stderr '^'

exec go run ./cmd/tya version
stdout '0.61.0\n'
! stderr .

-- good.tya --
name = "Tya"
print(name)

-- bad.tya --
print(missing)

-- messy.tya --
name = "Tya"
print(name)

-- formatted.tya --
name = "Tya"
print(name)
