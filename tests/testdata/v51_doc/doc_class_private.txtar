# Classes and documented top-level bindings are listed. Leading `_` is
# ordinary spelling for top-level names, not a documentation privacy marker.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
cd $WORK

mkdir src
cp mix.tya src/mix.tya

exec $WORK/tya doc
stdout '## class Greeter'
stdout '## function pub'
stdout '## function _priv'

-- mix.tya --
# Public surface
pub = x -> x + 1

# Hidden helper
_priv = y -> y - 1

# Greeter says hello.
class Greeter
  static hi = name -> "hi " + name
