# Metadata tags are rendered in text, HTML, and JSON modes. Warning
# diagnostics for metadata do not block output.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
cd $WORK

mkdir src
cp csv.tya src/csv.tya
cp bad.tya src/bad.tya

exec $WORK/tya doc src/csv.tya
stdout '## instance variable Csv.rows'
stdout 'type: Array<Dict>'
stdout 'param options_arg: Dict\? - optional CSV options.'
stdout 'option options.separator: String - field separator.'
stdout 'return: Csv - receiver.'
! stderr .

exec $WORK/tya doc --html out src/csv.tya
exists out/items/class_Csv.html
! exists out/items/variable_Csv-rows.html
! exists out/items/method_Csv-initialize.html
grep '<h1>class <code>Csv</code></h1>' out/items/class_Csv.html
grep '<h2>Class Constants</h2>' out/items/class_Csv.html
grep '<h2>Instance Variables</h2>' out/items/class_Csv.html
grep '<h3><code>rows</code></h3>' out/items/class_Csv.html
grep '<dt>Type</dt><dd><code>Array&lt;Dict&gt;</code></dd>' out/items/class_Csv.html
grep '<h3><code>initialize</code></h3>' out/items/class_Csv.html
grep '<dt>Param <code>options_arg</code></dt><dd><code>Dict\?</code> optional CSV options.</dd>' out/items/class_Csv.html

exec $WORK/tya doc --json src/csv.tya
stdout '"kind": "instance variable"'
stdout '"kind": "class constant"'
stdout '"type": "Array\\u003cDict\\u003e"'
stdout '"name": "options_arg"'
stdout '"key": "separator"'
stdout '"return": \{'

exec $WORK/tya doc src/bad.tya
stderr 'TYADOC0005'
stderr 'TYADOC0007'
stderr 'TYADOC0008'

-- csv.tya --
# Csv docs.
class Csv
  # Separator docs.
  # @type String
  SEPARATOR: ","

  # Rows docs.
  # @type Array<Dict>
  rows: []

  # Options docs.
  # @type Dict
  # @option options.separator String field separator.
  options: { separator: "," }

  # Initialize docs.
  # @param options_arg Dict? optional CSV options.
  # @option options.separator String field separator.
  # @return Csv receiver.
  initialize: options_arg = nil ->
    self.rows = []

  # Hidden docs.
  # @type Array
  private hidden: []

-- bad.tya --
class Bad
  # Bad docs.
  # @unknown value
  # @param missing String no such parameter.
  # @param value String first.
  # @param value String duplicate.
  run: value ->
    value
