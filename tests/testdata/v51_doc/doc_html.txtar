# v0.51 `tya doc --html <out>` writes a multi-page static site:
#   index.html, items/<kind>_<name>.html, style.css.
# This fixture also covers every supported Markdown inline marker:
# bold, italic, link, inline code, plus heading and code fence.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
cd $WORK

mkdir src
cp greet.tya src/greet.tya

exec $WORK/tya doc --html out
exists out/index.html
exists out/items/function_greet.html
exists out/style.css

grep '<title>API</title>' out/index.html
grep 'items/function_greet.html' out/index.html

grep '<strong>greet</strong>' out/items/function_greet.html
grep '<em>name</em>' out/items/function_greet.html
grep '<a href="https://example.com">docs</a>' out/items/function_greet.html
grep '<code>name</code>' out/items/function_greet.html
grep 'language-tya' out/items/function_greet.html
grep '&lt;script&gt;' out/items/function_greet.html

-- greet.tya --
# Returns a greeting for the given **greet**.
#
# The *name* parameter is the receiver. See [docs](https://example.com).
# Inline `name` reference. <script>danger</script>
#
# ```tya
# greet("World")
# ```
greet = name -> "Hello, " + name
