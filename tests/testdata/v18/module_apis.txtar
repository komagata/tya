# v0.18 module-style string, array, and dict APIs.
cd $REPO

exec go run ./cmd/tya run $WORK/module_apis.tya
stdout 'hello\n3\n3\ntrue\ntrue\ntrue\nHi, Tya\na:b:c\na\nb\nTYA\ntya\n3\na\nc\n\[a, b\]\n\[c, b, a\]\na:b:c\n\[a, b, c, d\]\nd\nc\n2\ntrue\n1\nfallback\nadmin\nfalse\neditor\ntokyo\n'

exec go run ./cmd/tya build $WORK/module_apis.tya -o $WORK/module_apis
exec $WORK/module_apis
stdout 'hello\n3\n3\ntrue\ntrue\ntrue\nHi, Tya\na:b:c\na\nb\nTYA\ntya\n3\na\nc\n\[a, b\]\n\[c, b, a\]\na:b:c\n\[a, b, c, d\]\nd\nc\n2\ntrue\n1\nfallback\nadmin\nfalse\neditor\ntokyo\n'

! exec go run ./cmd/tya run $WORK/bad_slice.tya
stderr 'array.slice does not support negative indexes'

-- module_apis.tya --
import string
import array
import dict

println("hello")

items = ["a", "b", "c"]
user =
  name: "komagata"
  role: "admin"
count =
  count: 1
override =
  role: "editor"
  city: "tokyo"

print string.len("tya")
print string.byte_len("tya")
print string.contains("hello", "ell")
print string.starts_with("hello", "he")
print string.ends_with("hello", "lo")
print string.replace("Hi, NAME", "NAME", "Tya")
print string.join(items, ":")
lines = string.lines("a\nb\n")
print lines[0]
print lines[1]
print string.upcase("tya")
print string.downcase("TYA")

print array.len(items)
print array.first(items)
print array.last(items)
print array.slice(items, 0, 2)
print array.reverse(items)
print array.join(items, ":")
print array.push(items, "d")
print array.pop(items)
print array.last(items)

print dict.len(user)
print dict.has(user, "name")
print dict.get(count, "count")
print dict.get(user, "missing", "fallback")
dict.set(user, "role", "admin")
print dict.delete(user, "role")
print dict.has(user, "role")
merged = dict.merge(user, override)
print dict.get(merged, "role")
print dict.get(merged, "city")

-- bad_slice.tya --
import array

print array.slice(["a"], -1, 1)
