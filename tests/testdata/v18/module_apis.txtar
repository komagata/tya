# v0.18 module-style string, array, and dict APIs.
cd $REPO

exec go run ./cmd/tya run $WORK/module_apis.tya
stdout 'hello\n3\n3\ntrue\ntrue\ntrue\nHi, Tya\na:b:c\na\nb\nTYA\ntya\n3\na\nc\n\[a, b\]\n\[c, b, a\]\na:b:c\nnil\nd\nc\n2\ntrue\n1\nfallback\nnil\nfalse\neditor\ntokyo\n'

exec go run ./cmd/tya build $WORK/module_apis.tya -o $WORK/module_apis
exec $WORK/module_apis
stdout 'hello\n3\n3\ntrue\ntrue\ntrue\nHi, Tya\na:b:c\na\nb\nTYA\ntya\n3\na\nc\n\[a, b\]\n\[c, b, a\]\na:b:c\nnil\nd\nc\n2\ntrue\n1\nfallback\nnil\nfalse\neditor\ntokyo\n'

! exec go run ./cmd/tya run $WORK/bad_slice.tya
stderr 'array.slice does not support negative indexes'

-- module_apis.tya --
println("hello")

items = ["a", "b", "c"]
user =
  name: "komagata"
  role: "admin"
count =
  count: 1
override =
  role: "editor"
  city: "tokyo"

print("tya".len())
print("tya".byte_len())
print("hello".contains("ell"))
print("hello".starts_with("he"))
print("hello".ends_with("lo"))
print("Hi, NAME".replace("NAME", "Tya"))
print(items.join(":"))
lines = "a\nb\n".lines()
print(lines[0])
print(lines[1])
print("tya".upper())
print("TYA".lower())

print(items.len())
print(items.first())
print(items.last())
print(items.slice(0, 2))
print(items.reverse())
print(items.join(":"))
print(items.push("d"))
print(items.pop())
print(items.last())

print(user.len())
print(user.has("name"))
print(count.get("count"))
print(user.get("missing", "fallback"))
user.set("role", "admin")
print(user.delete("role"))
print(user.has("role"))
merged = user.merge(override)
print(merged.get("role"))
print(merged.get("city"))

-- bad_slice.tya --
print(["a"].slice(-1, 1))
