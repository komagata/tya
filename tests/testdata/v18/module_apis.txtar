# v0.18 module-style string, array, and dict APIs.
cd $REPO

exec go run ./cmd/tya run $WORK/module_apis.tya
stdout 'hello\n3\n3\ntrue\ntrue\ntrue\nHi, Tya\na:b:c\na\nb\nTYA\ntya\n3\na\nc\n\[a, b\]\n\[c, b, a\]\na:b:c\n\[a, b, c, d\]\nd\nc\n2\ntrue\n1\nfallback\nadmin\nfalse\neditor\ntokyo\n'

exec go run ./cmd/tya build $WORK/module_apis.tya -o $WORK/module_apis
exec $WORK/module_apis
stdout 'hello\n3\n3\ntrue\ntrue\ntrue\nHi, Tya\na:b:c\na\nb\nTYA\ntya\n3\na\nc\n\[a, b\]\n\[c, b, a\]\na:b:c\n\[a, b, c, d\]\nd\nc\n2\ntrue\n1\nfallback\nadmin\nfalse\neditor\ntokyo\n'

! exec go run ./cmd/tya run $WORK/bad_slice.tya
stderr 'array.Array.slice does not support negative indexes'

-- module_apis.tya --
import string
import array
import dict

println("hello")

items = ["a", "b", "c"]
user =
  name: "komagata"
  role: "admin"
count =
  count: 1
override =
  role: "editor"
  city: "tokyo"

print string.String.len("tya")
print string.String.byte_len("tya")
print string.String.contains("hello", "ell")
print string.String.starts_with("hello", "he")
print string.String.ends_with("hello", "lo")
print string.String.replace("Hi, NAME", "NAME", "Tya")
print string.String.join(items, ":")
lines = string.String.lines("a\nb\n")
print lines[0]
print lines[1]
print string.String.upcase("tya")
print string.String.downcase("TYA")

print array.Array.len(items)
print array.Array.first(items)
print array.Array.last(items)
print array.Array.slice(items, 0, 2)
print array.Array.reverse(items)
print array.Array.join(items, ":")
print array.Array.push(items, "d")
print array.Array.pop(items)
print array.Array.last(items)

print dict.Dict.len(user)
print dict.Dict.has(user, "name")
print dict.Dict.get(count, "count")
print dict.Dict.get(user, "missing", "fallback")
dict.Dict.set(user, "role", "admin")
print dict.Dict.delete(user, "role")
print dict.Dict.has(user, "role")
merged = dict.Dict.merge(user, override)
print dict.Dict.get(merged, "role")
print dict.Dict.get(merged, "city")

-- bad_slice.tya --
import array

print array.Array.slice(["a"], -1, 1)
