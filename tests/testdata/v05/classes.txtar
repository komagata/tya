# v0.5 minimal classes and objects.
cd $REPO

exec go run ./cmd/tya run $WORK/classes.tya
stdout 'Hello, komagata\nTya\nHello, Ty\n1\n2\nmarker\n'
! stderr .

exec go run ./cmd/tya run $WORK/main.tya
stdout 'Hello, module\n'
! stderr .

exec go run ./cmd/tya run $WORK/constructor_defaults.tya
stdout 'guest:member\nkomagata:member\nkomagata:admin\n'
! stderr .

! exec go run ./cmd/tya run $WORK/bad_class_name.tya
stderr 'invalid class name user'

! exec go run ./cmd/tya run $WORK/at_outside_method.tya
stderr 'self is only valid inside a class method or instance method'

! exec go run ./cmd/tya run $WORK/class_variable.tya
stderr 'TYA-E0412'
! stdout .

! exec go run ./cmd/tya run $WORK/duplicate_method.tya
stderr 'duplicate instance member name'

! exec go run ./cmd/tya run $WORK/constructor_arity.tya
stderr 'class User constructor expects 1 arguments'

! exec go run ./cmd/tya run $WORK/constructor_defaults_too_few.tya
stderr 'class User constructor expects 1 to 2 arguments'

! exec go run ./cmd/tya run $WORK/constructor_defaults_too_many.tya
stderr 'class User constructor expects 1 to 2 arguments'

! exec go run ./cmd/tya run $WORK/no_init_args.tya
stderr 'class Marker has no init and takes no arguments'

! exec go run ./cmd/tya run $WORK/dict_dot.tya
stderr 'cannot use . access on dictionary; use index access'
! stdout .

! exec go run ./cmd/tya run $WORK/missing_field.tya
stderr 'missing object field or method: missing'
! stdout .

exec go run ./cmd/tya version
stdout '0.72.0\n'
! stderr .

-- classes.tya --
class User
  name: ""

  initialize: user_name ->
    self.name = user_name

  rename: user_name ->
    self.name = user_name

  greeting: ->
    "Hello, {self.name}"

class Counter
  value: 0

  initialize: ->
    self.value = 0

  increment: ->
    self.value = self.value + 1
    self.value

class Marker
  label: ->
    "marker"

user = User("komagata")
print(user.greeting())
user.rename("Tya")
print(user.name)
user.name = "Ty"
print(user.greeting())

counter = Counter()
print(counter.increment())
print(counter.increment())

marker = Marker()
print(marker.label())

-- user.tya --
class User
  name: ""

  initialize: user_name ->
    self.name = user_name

  greeting: ->
    "Hello, {self.name}"

-- main.tya --
import user

item = user.User("module")
print(item.greeting())

-- constructor_defaults.tya --
class Profile
  name: ""
  role: ""

  initialize: profile_name = "guest", profile_role = "member" ->
    self.name = profile_name
    self.role = profile_role

  label: ->
    "{self.name}:{self.role}"

class User
  name: ""
  role: ""

  initialize: user_name, user_role = "member" ->
    self.name = user_name
    self.role = user_role

  label: ->
    "{self.name}:{self.role}"

print(Profile().label())
print(User("komagata").label())
print(User("komagata", "admin").label())

-- constructor_defaults_too_few.tya --
class User
  name: ""
  role: ""

  initialize: user_name, user_role = "member" ->
    self.name = user_name
    self.role = user_role

user = User()

-- constructor_defaults_too_many.tya --
class User
  name: ""
  role: ""

  initialize: user_name, user_role = "member" ->
    self.name = user_name
    self.role = user_role

user = User("komagata", "admin", "extra")

-- bad_class_name.tya --
class user
  name: nil

  initialize: ->
    self.name = "bad"

-- at_outside_method.tya --
self.name = "bad"

-- class_variable.tya --
Self.name = "bad"

-- duplicate_method.tya --
class User
  name: ->
    "a"

  name: ->
    "b"

-- constructor_arity.tya --
class User
  name: ""

  initialize: user_name ->
    self.name = user_name

user = User()

-- no_init_args.tya --
class Marker
  label: -> "marker"

marker = Marker("bad")

-- dict_dot.tya --
profile = {name: "komagata"}
print(profile.name)

-- missing_field.tya --
class User
  name: ""

  initialize: user_name ->
    self.name = user_name

user = User("komagata")
print(user.missing)
