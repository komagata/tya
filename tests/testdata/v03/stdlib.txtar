# v0.3 attached standard library imports.
cd $REPO
exec go run ./cmd/tya run $WORK/std/main.tya
stdout 'true\nfalse\ntrue\ntya\n'
! stderr .

env TYA_PATH=$WORK/lib
exec go run ./cmd/tya run $WORK/precedence/main.tya
stdout 'local string\npath array\n'
! stderr .

exec go run ./cmd/tya version
stdout '0.66.0\n'
! stderr .

-- std/main.tya --
print("  ".blank?())
print("  ".present?())
print([].empty?())
print(["tya"].first())

-- precedence/main.tya --
import local_string
import path_array

print(local_string.blank("ignored"))
print(path_array.empty([]))

-- precedence/local_string.tya --
blank = _text -> "local string"

-- lib/path_array.tya --
empty = _items -> "path array"
