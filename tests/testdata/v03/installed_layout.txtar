# Installed binary finds share/tya runtime and lib outside the source checkout.
cd $REPO
mkdir $WORK/install
mkdir $WORK/install/bin
mkdir $WORK/install/share
mkdir $WORK/install/share/tya
mkdir $WORK/install/share/tya/runtime
exec sh -c 'cp runtime/tya_runtime*.c "$WORK/install/share/tya/runtime/"'
cp runtime/tya_runtime.h $WORK/install/share/tya/runtime/tya_runtime.h
exec go build -o $WORK/install/bin/tya ./cmd/tya
mkdir $WORK/outside
cd $WORK/outside
exec $WORK/install/bin/tya run $WORK/app/main.tya
stdout 'true\ntya\n'
! stderr .

-- app/main.tya --
print("".blank?())
print(["tya"].first())
