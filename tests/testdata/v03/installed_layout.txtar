# Installed binary finds share/tya runtime and stdlib outside the source checkout.
cd $REPO
mkdir $WORK/install
mkdir $WORK/install/bin
mkdir $WORK/install/share
mkdir $WORK/install/share/tya
mkdir $WORK/install/share/tya/runtime
mkdir $WORK/install/share/tya/stdlib
cp runtime/tya_runtime.c $WORK/install/share/tya/runtime/tya_runtime.c
cp runtime/tya_runtime.h $WORK/install/share/tya/runtime/tya_runtime.h
cp stdlib/string.tya $WORK/install/share/tya/stdlib/string.tya
cp stdlib/array.tya $WORK/install/share/tya/stdlib/array.tya
exec go build -o $WORK/install/bin/tya ./cmd/tya
mkdir $WORK/outside
cd $WORK/outside
exec $WORK/install/bin/tya run $WORK/app/main.tya
stdout 'true\ntya\n'
! stderr .

-- app/main.tya --
import string
import array

print string.String.blank("")
print array.Array.first(["tya"])
