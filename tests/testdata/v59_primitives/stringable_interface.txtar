# Stringable interface and primitive to_string behavior.
cd $REPO

exec go run ./cmd/tya check lib/stringable.tya

exec go run ./cmd/tya run $WORK/user_stringable.tya
stdout 'user:Ada\n'

! exec go run ./cmd/tya check $WORK/missing_to_string.tya
stderr 'class User must implement interface method to_string'

exec go run ./cmd/tya run $WORK/primitives.tya
stdout '42'
stdout 'hi'
stdout '\[1, 2\]'
stdout '\{name: Tya\}'
stdout 'true'
stdout 'nil'
stdout 'Number'
stdout 'String'
stdout 'Array'
stdout 'Dict'
stdout 'Boolean'
stdout 'Nil'

-- user_stringable.tya --
interface Stringable
  to_string: ->

class User implements Stringable
  name: nil

  initialize: name_arg ->
    self.name = name_arg

  to_string: ->
    "user:" + self.name

print(User("Ada").to_string())

-- missing_to_string.tya --
interface Stringable
  to_string: ->

class User implements Stringable
  name: "Ada"

-- primitives.tya --
print(42.to_string())
print("hi".to_string())
print([1, 2].to_string())
print({ name: "Tya" }.to_string())
print(true.to_string())
print(nil.to_string())
print(42.class.name)
print("hi".class.name)
print([1, 2].class.name)
print({ name: "Tya" }.class.name)
print(true.class.name)
print(nil.class.name)
