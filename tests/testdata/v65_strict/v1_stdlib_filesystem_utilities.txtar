# v1 filesystem utility stdlib contract.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
env TYA_STDLIB_DIR=$REPO/stdlib
cd $WORK

exec $WORK/tya check filesystem_utilities.tya
exec $WORK/tya run filesystem_utilities.tya
stdout '255'
stdout 'true'
stdout 'false'
stdout 'true'
stdout 'false'
stdout 'class'
stdout 'true'

exec $WORK/tya build filesystem_utilities.tya -o filesystem_utilities
exec ./filesystem_utilities
stdout '255'
stdout 'true'
stdout 'false'
stdout 'true'
stdout 'false'
stdout 'class'
stdout 'true'

! exec $WORK/tya run invalid_remove_all.tya
stderr 'filesystem.remove_all: dangerous path'

! exec $WORK/tya run invalid_copy.tya
stderr 'filesystem.copy: destination exists'

-- filesystem_utilities.tya --
import file/* as file
import dir/* as dir
import bytes/* as bytes

root = dir.Dir(nil).temp_dir("tya-fs")
dir.Dir("{root}/nested").mkdir_all()
file.File("{root}/a.txt").write_bytes(bytes.Bytes([0, 255]).from_array())
file.File("{root}/a.txt").copy("{root}/b.txt", {})
print(bytes.Bytes().to_array(file.File("{root}/b.txt").read_bytes())[1])
file.File("{root}/b.txt").chmod(420)
print(file.File("{root}/b.txt").stat()["mode"] == 420)

seen = []
record = entry -> seen.push(entry["name"])
dir.Dir(root).walk(record, {})
print(seen.contains("nested"))
print(seen.join(","))

tmp = file.File().temp("tya-fs", ".tmp")
print(file.File(tmp).exists?())
file.File(tmp).remove()
dir.Dir(root).remove_all()
print(file.File(root).exists?())

class_file = file.File.temp("tya-fs-class", ".tmp")
file.File.write(class_file, "class")
print(file.File.read(class_file))
print(file.File.exists?(class_file))
file.File.remove(class_file)

-- invalid_remove_all.tya --
import dir/* as dir

dir.Dir(".").remove_all()

-- invalid_copy.tya --
import file/* as file

file.File("src.txt").write("a")
file.File("dst.txt").write("b")
file.File("src.txt").copy("dst.txt", { overwrite: false })
