# v0.65 strict dynamic semantics audit smoke coverage.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
cd $WORK

exec $WORK/tya check valid.tya
exec $WORK/tya run valid.tya
stdout 'truthy'
stdout 'Ty'
stdout '<bytes:2>'
stdout 'count: 3'
stdout 'nil'
stdout 'true'
stdout 'true'
stdout 'komagata'
stdout 'true'
stdout '2'
stdout '2'
stdout 'matched'
stdout 'text/plain'
stdout 'x'
stdout 'empty'
stdout 'nil'
stdout '1'
stdout 'nil'
stdout 'あ'
stdout 'nil'
stdout 'true'
stdout '2'
stdout '2.5'
stdout '-2'
stdout '-1'
stdout '1'
stdout 'Tya!'
stdout 'fallback'
stdout 'nil'
stdout '1'
stdout '1'

exec $WORK/tya build valid.tya -o valid
exec ./valid
stdout 'truthy'
stdout 'Ty'
stdout '<bytes:2>'
stdout 'count: 3'
stdout 'nil'
stdout 'true'
stdout 'true'
stdout 'komagata'
stdout 'true'
stdout '2'
stdout '2'
stdout 'matched'
stdout 'text/plain'
stdout 'x'
stdout 'empty'
stdout 'nil'
stdout '1'
stdout 'nil'
stdout 'あ'
stdout 'nil'
stdout 'true'
stdout '2'
stdout '2.5'
stdout '-2'
stdout '-1'
stdout '1'
stdout 'Tya!'
stdout 'fallback'
stdout 'nil'
stdout '1'
stdout '1'

! exec $WORK/tya check return_outside.tya
stderr 'TYA-E0120'

! exec $WORK/tya check bad_pattern.tya
stderr 'TYA-E0160'

! exec $WORK/tya check kind_reassign.tya
stderr 'cannot reassign value from number to string'

! exec $WORK/tya check constant_mutation.tya
stderr 'cannot mutate constant ITEMS'

! exec $WORK/tya check dict_dot.tya
stderr 'cannot use . access on dictionary; use index access'

! exec $WORK/tya check duplicate_normalized_dict_key.tya
stderr 'duplicate dictionary key name'

! exec $WORK/tya check kind_reassign_through_nil.tya
stderr 'cannot reassign value from number to string'

! exec $WORK/tya check block_local.tya
stderr 'undefined variable'

! exec $WORK/tya check for_binding_local.tya
stderr 'undefined variable'

! exec $WORK/tya check catch_binding_local.tya
stderr 'undefined variable'

! exec $WORK/tya check match_binding_local.tya
stderr 'binding patterns are not part of Tya v1.0.0'

! exec $WORK/tya run raise_nil.tya
stderr 'raise expects error value'

! exec $WORK/tya run raise_string.tya
stderr 'raise expects error value'

! exec $WORK/tya check string_plus_number.tya
stderr '\+ expects numbers, strings, or bytes of the same kind'

! exec $WORK/tya check number_plus_string.tya
stderr '\+ expects numbers, strings, or bytes of the same kind'

! exec $WORK/tya check float_modulo.tya
stderr '% expects integers'

! exec $WORK/tya check negative_index.tya
stderr 'negative indexes are invalid'

exec $WORK/tya check string_ordering.tya

! exec $WORK/tya check required_after_default.tya
stderr 'required parameter b after default parameter'

! exec $WORK/tya check default_later_reference.tya
stderr 'undefined variable b'

exec $WORK/tya check trailing_comma.tya

! exec $WORK/tya check duplicate_import.tya
stderr 'duplicate import helper'

! exec $WORK/tya build string_plus_number.tya -o bad_string_plus
stderr '\+ expects numbers, strings, or bytes of the same kind'

exec $WORK/tya build dynamic_string_plus_number.tya -o dynamic_bad_string_plus
! exec ./dynamic_bad_string_plus
stderr '\+ expects numbers, strings, or bytes of the same kind'

exec $WORK/tya build dynamic_dict_dot.tya -o dynamic_dict_dot
! exec ./dynamic_dict_dot
stderr 'cannot use . access on dictionary; use index access'

exec $WORK/tya run bad_call.tya
stdout 'nil'

exec $WORK/tya run bad_index.tya
stdout 'nil'

-- valid.tya --
if 0
  print("truthy")

print("T" + "y")
print(b"T" + b"y")
count = 3
print("count: {count}")
print({ name: "Tya" }["missing"])
print(nil or "fallback")
print({ nested: [1, 2] } == { nested: [1, 2] })
user = { name: "komagata" }
print(user["name"])
print(user.has?("name"))
count = 1
if true
  count = 2
  local = 9
print(count)
handler = -> 1
handler = -> 2
print(handler())

value = "ok"
match value
  case "ok"
    print("matched")
  case _
    print("fallback")

bounds = items ->
  return items[0], items[items.len() - 1]

min, max = bounds([1, 2])

headers = { "Content-Type": "text/plain", "$schema": "x", "": "empty" }
print(headers["Content-Type"])
print(headers["$schema"])
print(headers[""])
items = []
print(items.push(1))
print(items.pop())
dict = {}
print(dict.set("name", "Tya"))
print("あい"[0])
print("あい"[99])
print(1 == 1.0)
print(5 / 2)
print(5.0 / 2)
print(-5 / 2)
print(-5 % 2)
print(5 % 2)
greet = name, suffix = "!" -> name + suffix
print(greet("Tya"))
maybe = value = "fallback" -> value
print(maybe())
print(maybe(nil))
make = items = [] ->
  items.push(1)
  items.len()
print(make())
print(make())

-- return_outside.tya --
return 1

-- bad_pattern.tya --
user = { name: "tya" }
match user
  case { name: value }
    print(value)

-- kind_reassign.tya --
value = 1
value = "one"

-- constant_mutation.tya --
ITEMS = [1]
ITEMS[0] = 2

-- dict_dot.tya --
user = { name: "komagata" }
print(user.name)

-- duplicate_normalized_dict_key.tya --
user = { name: "Tya", "name": "duplicate" }

-- kind_reassign_through_nil.tya --
value = 1
value = nil
value = "one"

-- block_local.tya --
if true
  local = 1
print(local)

-- for_binding_local.tya --
items = [1]
for item, index in items
  print(item)
print(item)

-- catch_binding_local.tya --
try
  raise error("bad")
catch err
  print(err["message"])
print(err)

-- match_binding_local.tya --
value = [1]
match value
  case [item]
    print(item)
print(item)

-- raise_nil.tya --
raise nil

-- raise_string.tya --
raise "failed"

-- string_plus_number.tya --
count = 3
print("count: " + count)

-- number_plus_string.tya --
count = 3
print(count + " items")

-- float_modulo.tya --
print(5.5 % 2)

-- negative_index.tya --
items = [1]
print(items[-1])

-- string_ordering.tya --
print("a" < "b")

-- required_after_default.tya --
f = a = 1, b -> b

-- default_later_reference.tya --
f = a = b, b = 1 -> a

-- trailing_comma.tya --
add = (a, b,) -> a + b
items = [1, 2,]
user = { name: 'Tya', age: 20, }
print(add(items[0], add(1, 2,)))

-- duplicate_import.tya --
import helper as first
import helper as second

-- helper.tya --
value = 1

-- dynamic_string_plus_number.tya --
value = -> 3
print("count: " + value())

-- dynamic_dict_dot.tya --
make_user = -> { name: "komagata" }
user = make_user()
print(user.name)

-- bad_call.tya --
fn = nil
print(fn())

-- bad_index.tya --
print(nil[0])
