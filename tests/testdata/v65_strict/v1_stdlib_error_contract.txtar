# Representative stdlib failures raise structured error values.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
env TYA_LIB_DIR=$REPO/lib
cd $WORK

exec $WORK/tya run stdlib_errors.tya
stdout 'file'
stdout 'json'
stdout 'process'
stdout 'serialization'

-- stdlib_errors.tya --
import file
import json
import process
import serializer as serialization

try
  file.File("__missing__.txt").stat()
catch err
  if err["message"] != ""
    print("file")

try
  json.Json("{{").parse()
catch err
  if err["message"] != ""
    print("json")

try
  process.Process([]).run()
catch err
  if err["message"] != ""
    print("process")

try
  serialization.Serializer(nil).serialize(-> nil)
catch err
  if err["message"] != ""
    print("serialization")
