# v1 Regex stdlib contract.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
env TYA_LIB_DIR=$REPO/lib
cd $WORK

exec $WORK/tya check regex_valid.tya
exec $WORK/tya run regex_valid.tya
stdout 'abc123'
stdout '3'
stdout '9'
stdout 'abc'
stdout '2'
stdout 'a|b|c'
stdout '1 b=22'
stdout 'いう'
stdout '1'
stdout '3'

exec $WORK/tya build regex_valid.tya -o regex_valid
exec ./regex_valid
stdout 'abc123'
stdout 'a|b|c'
stdout '1 b=22'

! exec $WORK/tya run regex_invalid.tya
stderr 'regex.compile: invalid pattern'

-- regex_valid.tya --
import regex/* as regex

rx = regex.Regex("([a-z]+)([0-9]+)").compile()
found = rx.find("xx abc123 yy")
print(found["text"])
print(found["start"])
print(found["end"])
print(found["groups"][0])

pairs = regex.Regex("([a-z]+)=([0-9]+)").compile()
print(pairs.find_all("a=1 b=22").len())
print(regex.Regex(", *").compile().split("a, b, c").join("|"))
print(pairs.replace("a=1 b=22", r"${2}", 1))

utf8 = regex.Regex("い.").search("あいうえ")
print(utf8["text"])
print(utf8["start"])
print(utf8["end"])

-- regex_invalid.tya --
import regex/* as regex

regex.Regex("[").compile()
