# v1 public contract finalization docs and stdlib imports.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
env TYA_LIB_DIR=$REPO/lib
cd $WORK

exec $WORK/tya check public_contract.tya
exec $WORK/tya run public_contract.tya
stdout '1'
stdout '0'
stdout 'true'
stdout 'true'

-- public_contract.tya --
import regex
import time
import hmac
import file
import dir
import os
import process

print(regex.Regex("[0-9]+").search("v1")["text"])
print(time.Time().unix(0).format("unix"))
print(hmac.Hmac("sha256", "key").verify("The quick brown fox jumps over the lazy dog", "f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8"))
print(os.Os().env("TYA_NO_SUCH_V1_ENV") == nil)
