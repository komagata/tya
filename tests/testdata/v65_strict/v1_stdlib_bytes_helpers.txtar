# v1 bytes helpers expose reusable byte sequence operations.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
env TYA_LIB_DIR=$REPO/lib
cd $WORK

exec $WORK/tya run bytes_helpers.tya
stdout '3'
stdout '3'
stdout '3'
stdout '84'
stdout '121'
stdout '227'
stdout '1'
stdout '1'
stdout '1'
stdout '0'
stdout 'nil'
stdout '3'
stdout 'bytes.at: index out of bounds'
stdout 'bytes.at: index must be an integer'
stdout 'bytes.index_of: byte must be 0..255'
stdout 'bytes.index_of: byte must be exactly one byte'

-- bytes_helpers.tya --
import bytes

print(bytes.Bytes.from_string("Tya").len())
print(bytes.Bytes(b"Tya").len())
print(bytes.Bytes.from_string("あ").len())
print(bytes.Bytes.from_string("Tya").at(0))
print(bytes.Bytes(b"Tya").at(1))
print(bytes.Bytes.from_string("あ").at(0))
print(bytes.Bytes.index_of(bytes.Bytes.from_string("abc"), 98))
print(bytes.Bytes.index_of(bytes.Bytes.from_string("abc"), bytes.Bytes.from_string("b")))
print(bytes.Bytes.index_of(bytes.Bytes(b"abc"), bytes.Bytes(b"b")))
print(bytes.Bytes.index_of(bytes.Bytes.from_string("あ"), 227))
print(bytes.Bytes.index_of(bytes.Bytes.from_string("abc"), bytes.Bytes.from_string("x")))
print(bytes.Bytes.index_of(bytes.Bytes.from_string("abca"), bytes.Bytes.from_string("a"), 1))

try
  bytes.Bytes.from_string("abc").at(3)
catch e
  print(e["message"])
try
  bytes.Bytes.from_string("abc").at(1.5)
catch e
  print(e["message"])
try
  bytes.Bytes.index_of(bytes.Bytes.from_string("abc"), 256)
catch e
  print(e["message"])
try
  bytes.Bytes.index_of(bytes.Bytes.from_string("abc"), bytes.Bytes.from_string("ab"))
catch e
  print(e["message"])
