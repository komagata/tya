# v1 bytes helpers expose reusable byte sequence operations.
cd $REPO
exec go build -o $WORK/tya ./cmd/tya
env TYA_RUNTIME_DIR=$REPO/runtime
env TYA_LIB_DIR=$REPO/lib
cd $WORK

exec $WORK/tya run bytes_helpers.tya
stdout '3'
stdout '3'
stdout '3'
stdout '84'
stdout '121'
stdout '227'
stdout '1'
stdout '1'
stdout '1'
stdout '0'
stdout 'nil'
stdout '3'
stdout 'bytes.at: index out of bounds'
stdout 'bytes.at: index must be an integer'
stdout 'bytes.index_of: byte must be 0..255'
stdout 'bytes.index_of: byte must be exactly one byte'

-- bytes_helpers.tya --
import bytes

print(bytes.Bytes.len("Tya"))
print(bytes.Bytes.len(b"Tya"))
print(bytes.Bytes.len("あ"))
print(bytes.Bytes.at("Tya", 0))
print(bytes.Bytes.at(b"Tya", 1))
print(bytes.Bytes.at("あ", 0))
print(bytes.Bytes.index_of("abc", 98))
print(bytes.Bytes.index_of("abc", "b"))
print(bytes.Bytes.index_of(b"abc", b"b"))
print(bytes.Bytes.index_of("あ", 227))
print(bytes.Bytes.index_of("abc", "x"))
print(bytes.Bytes.index_of("abca", "a", 1))

try
  bytes.Bytes.at("abc", 3)
catch e
  print(e["message"])
try
  bytes.Bytes.at("abc", 1.5)
catch e
  print(e["message"])
try
  bytes.Bytes.index_of("abc", 256)
catch e
  print(e["message"])
try
  bytes.Bytes.index_of("abc", "ab")
catch e
  print(e["message"])
