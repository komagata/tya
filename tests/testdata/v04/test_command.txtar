# tya test discovers *_test.tya as importable test case modules and runs them
# through unittest.run as a synthesized suite (v0.22 behavior).
cd $REPO
exec go build -o $WORK/tya ./cmd/tya

# Directory invocation: discover and run all *_test.tya cases.
exec go run ./cmd/tya test $WORK/pass
stdout '5 tests, 5 passed, 0 failed'
! stderr .

# Single-file invocation works for one test case file.
exec go run ./cmd/tya test $WORK/pass/nested/one_test.tya
stdout '2 tests, 2 passed, 0 failed'
! stderr .

# Failing assertion is captured and reported, suite continues, exit non-zero.
! exec go run ./cmd/tya test $WORK/fail/fail_assert_test.tya
stdout 'FAIL  test_fails'
stdout '1 tests, 0 passed, 1 failed'

# assert_equal failure shows expected/actual.
! exec go run ./cmd/tya test $WORK/fail/fail_equal_test.tya
stdout 'FAIL  test_unequal'
stdout '1 tests, 0 passed, 1 failed'

# Repository-level discovery finds all migrated stdlib tests and they pass.
exec go run ./cmd/tya test tests
stdout 'tests, '
stdout 'passed, 0 failed'
! stderr .

exec go run ./cmd/tya version
stdout '0.33.0\n'
! stderr .

-- pass/nested/one_test.tya --
import unittest

module one_test
  test_truthy = ->
    unittest.assert(true, "true")
  test_deep_equal = ->
    unittest.assert_equal([1, {name: "tya"}], [1, {name: "tya"}], "deep")

-- pass/two_test.tya --
import unittest

module two_test
  test_arithmetic = ->
    unittest.assert_equal(2, 1 + 1, "plus")
  test_concat = ->
    unittest.assert_equal("tya", "ty" + "a", "concat")
  test_negation = ->
    unittest.assert_falsy(false, "false")

-- pass/not_a_test_file.tya --
print "ignored"

-- fail/fail_assert_test.tya --
import unittest

module fail_assert_test
  test_fails = ->
    unittest.assert(false, "intentional")

-- fail/fail_equal_test.tya --
import unittest

module fail_equal_test
  test_unequal = ->
    unittest.assert_equal([1, {name: "tya"}], [1, {name: "Tya"}], "case mismatch")
