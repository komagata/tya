import unittest
import math

module stdlib_math_test
  test_abs_negative = ->
    unittest.assert_equal(3, math.abs(-3), "abs negative")
  test_abs_positive = ->
    unittest.assert_equal(5, math.abs(5), "abs positive")
  test_abs_zero = ->
    unittest.assert_equal(0, math.abs(0), "abs zero")
  test_min = ->
    unittest.assert_equal(2, math.min(2, 5), "min")
  test_max = ->
    unittest.assert_equal(5, math.max(2, 5), "max")
  test_clamp_above_max = ->
    unittest.assert_equal(10, math.clamp(12, 0, 10), "clamp above max")
  test_clamp_below_min = ->
    unittest.assert_equal(0, math.clamp(-1, 0, 10), "clamp below min")
  test_clamp_within = ->
    unittest.assert_equal(5, math.clamp(5, 0, 10), "clamp within")
