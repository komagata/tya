class Random
  static seed = value ->
    random_seed(value)

  static int = min, max ->
    random_int(min, max)

  static float = ->
    random_float()

  static choice = items ->
    n = len(items)
    if n == 0
      raise "random.choice: empty array"
    return items[random_int(0, n - 1)]

  static shuffle = items ->
    n = len(items)
    i = n - 1
    while i > 0
      j = random_int(0, i)
      tmp = items[i]
      items[i] = items[j]
      items[j] = tmp
      i = i - 1
    return nil
