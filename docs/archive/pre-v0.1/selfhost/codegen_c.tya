  push lines, ""
  push lines, "static int ast_print_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 1 >= tokens_len) return 0;"
  push lines, "  if (!token_is(tokens[start], \"IDENT\", \"print\")) return 0;"
  push lines, "  if (start + 2 < tokens_len) {"
  push lines, "    char line[32];"
  push lines, "    char next_line[32];"
  push lines, "    token_part(tokens[start], 0, line, sizeof(line));"
  push lines, "    token_part(tokens[start + 2], 0, next_line, sizeof(next_line));"
  push lines, "    if (strcmp(line, next_line) == 0 && ast_arithmetic_expr_from_tokens(tokens, tokens_len, start + 1, out, out_size)) return 1;"
  push lines, "    if (strcmp(line, next_line) == 0 && ast_binary_compare_from_tokens(tokens, tokens_len, start + 1, out, out_size)) return 1;"
  push lines, "    if (strcmp(line, next_line) == 0 && ast_expr_from_tokens(tokens, tokens_len, start + 1, out, out_size)) return 1;"
  push lines, "  }"
  push lines, "  return ast_atom_from_token(tokens[start + 1], out, out_size);"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_return_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 1 >= tokens_len) return 0;"
