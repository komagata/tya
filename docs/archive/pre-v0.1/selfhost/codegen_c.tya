  push lines, "static void node_field(const char *node, int wanted, char *out, size_t out_size) {"
  push lines, "  int field = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; node[i] != 0; i++) {"
  push lines, "    if (node[i] == ':') {"
  push lines, "      field++;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (field == wanted && n + 1 < out_size) {"
  push lines, "      out[n++] = node[i];"
  push lines, "    }"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void node_tail_field(const char *node, int wanted, char *out, size_t out_size) {"
  push lines, "  int field = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; node[i] != 0; i++) {"
  push lines, "    if (node[i] == ':') {"
  push lines, "      field++;"
  push lines, "      if (field == wanted) {"
  push lines, "        i++;"
  push lines, "        while (node[i] != 0 && n + 1 < out_size) out[n++] = node[i++];"
  push lines, "        break;"
  push lines, "      }"
  push lines, "    }"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
