  push lines, "      strcpy(generated_bool_func_names[generated_bool_func_len], pending_bool_func);"
  push lines, "      strcpy(generated_bool_func_args[generated_bool_func_len], pending_bool_arg);"
  push lines, "      strcpy(generated_bool_func_exprs[generated_bool_func_len], a);"
