  push lines, "  char generated_array_func_arrays[128][256];"
  push lines, "  int generated_array_func_called[128];"
  push lines, "  int generated_array_func_len = 0;"
  push lines, "  char pending_array_func[256];"
  push lines, "  char pending_array_arg[256];"
  push lines, "  char pending_array_name[256];"
  push lines, "  char pending_bool_func[256];"
  push lines, "  char pending_bool_arg[256];"
  push lines, "  int pending_bool_body_seen = 0;"
