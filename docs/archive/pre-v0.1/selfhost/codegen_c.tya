  push lines, "          if (stmt_if_condition[0] != 0 && stmt_if_body_indent[0] != 0 && atoi(stmt_indent) >= atoi(stmt_if_body_indent)) printf(has_loop ? \"    if (%s) %s = concat_text(%s, %s);\\n\" : \"  if (%s) %s = concat_text(%s, %s);\\n\", stmt_if_condition, x, x, value);"
  push lines, "          else printf(has_loop ? \"    %s = concat_text(%s, %s);\\n\" : \"  %s = concat_text(%s, %s);\\n\", x, x, value);"
  push lines, "        }"
