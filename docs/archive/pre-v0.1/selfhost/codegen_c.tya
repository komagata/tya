kind_of = node ->
  parts = split node, ":"
  parts[1]

name_of = node ->
  parts = split node, ":"
  if len(parts) < 3
    return ""
  parts[2]

value_of = node ->
  parts = split node, ":"
  if len(parts) < 4
    return ""
  parts[3]

extra_of = node ->
  parts = split node, ":"
  if len(parts) < 5
    return ""
  parts[4]

extra2_of = node ->
  parts = split node, ":"
  if len(parts) < 6
    return ""
  parts[5]

extra3_of = node ->
  parts = split node, ":"
  if len(parts) < 7
    return ""
  parts[6]

extra4_of = node ->
  parts = split node, ":"
  if len(parts) < 8
    return ""
  parts[7]

extra5_of = node ->
  parts = split node, ":"
  if len(parts) < 9
    return ""
  parts[8]

extra6_of = node ->
  parts = split node, ":"
  if len(parts) < 10
    return ""
  parts[9]

extra7_of = node ->
  parts = split node, ":"
  if len(parts) < 11
    return ""
  parts[10]

extra8_of = node ->
  parts = split node, ":"
  if len(parts) < 12
    return ""
  parts[11]

remember_type = names, types, name, type_name ->
  push names, name
  push types, type_name

has_name = names, name ->
  for existing in names
    if existing == name
      return true
  false

type_of = names, types, name ->
  i = 0
  while i < len(names)
    if names[i] == name
      return types[i]
    i = i + 1
  "STRING"

iterable_kind = name ->
  parts = split name, "."
  if len(parts) > 1
    return "MEMBER"
  index_parts = split name, "["
  if len(index_parts) > 1
    return "INDEX"
  ""

c_name = name ->
  if name == "even?"
    return "even_p"
  if name == "nil?"
    return "nil_p"
  if name == "empty?"
    return "empty_p"
  if name == "char"
    return "tya_char"
  name

c_string = text ->
  if text == "\\"
    return "\"\\x22\""
  "\"" + text + "\""

ast_expr_kind = expr ->
  parts = split expr, "("
  parts[0]

ast_expr_value = expr ->
  parts = split expr, "("
  if len(parts) < 2
    return ""
  value = parts[1]
  value = replace value, ")", ""
  value

ast_binary_op = expr ->
  parts = split expr, " "
  op = replace parts[0], "binary(", ""
  op

ast_binary_left_expr = expr ->
  parts = split expr, " "
  if len(parts) < 2
    return ""
  parts[1]

ast_binary_right_expr = expr ->
  parts = split expr, " "
  if len(parts) < 3
    return ""
  parts[2]

ast_atom_c = expr ->
  expr_kind_name = ast_expr_kind expr
  expr_value = ast_expr_value expr
  if expr_kind_name == "int"
    return expr_value
  if expr_kind_name == "ident"
    return c_name(expr_value)
  if expr_kind_name == "index"
    parts = split expr_value, " "
    object_name = parts[0]
    index_name = "0"
    if len(parts) > 1
      index_name = parts[1]
    return "char_at_text(" + c_name(object_name) + ", " + c_name(index_name) + ")"
  "0"

ast_call_callee = expr ->
  parts = split expr, " "
  callee = replace parts[0], "call(", ""
  replace callee, ")", ""

ast_call_first_arg = expr ->
  parts = split expr, " "
  parts[1]

ast_call_second_arg = expr ->
  parts = split expr, " "
  if len(parts) < 3
    return ""
  parts[2]

ast_call_third_arg = expr ->
  parts = split expr, " "
  if len(parts) < 4
    return ""
  parts[3]

ast_string_expr_c = expr ->
  if ast_expr_kind(expr) == "string"
    return c_string(ast_expr_value(expr))
  if ast_expr_kind(expr) == "call"
    callee = ast_call_callee expr
    if callee == "trim"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      return "trim_text(" + c_name(arg_name) + ")"
    if callee == "to_string"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      return "to_string_long(" + c_name(arg_name) + ")"
  if ast_expr_kind(expr) == "index"
    parts = split ast_expr_value(expr), " "
    object_name = parts[0]
    index_name = "0"
    if len(parts) > 1
      index_name = parts[1]
    return "char_at_text(" + c_name(object_name) + ", " + c_name(index_name) + ")"
  c_name(ast_expr_value(expr))

ast_expr_is_string_or_ident_name = expr, name ->
  expr_kind_name = ast_expr_kind expr
  if expr_kind_name == "string"
    return true
  expr_kind_name == "ident" and ast_expr_value(expr) == name

has_func_local_name = func_names, local_names, func_name, local_name ->
  i = 0
  while i < len(func_names)
    if func_names[i] == func_name and local_names[i] == local_name
      return true
    i = i + 1
  false

emit_dynarray_push = lines, prefix, array_name, pushed ->
  push lines, prefix + c_name(array_name) + " = realloc(" + c_name(array_name) + ", sizeof(char *) * (size_t)(" + c_name(array_name) + "_len + 1));"
  push lines, prefix + c_name(array_name) + "[" + c_name(array_name) + "_len] = dup_text(" + pushed + ");"
  push lines, prefix + c_name(array_name) + "_len++;"

emit_single_array_push = lines, prefix, array_name, pushed ->
  push lines, prefix + c_name(array_name) + "_0 = " + pushed + ";"
  push lines, prefix + c_name(array_name) + "_len = 1;"

emit_empty_dynarray = lines, prefix, array_name ->
  push lines, prefix + "long " + c_name(array_name) + "_len = 0;"
  push lines, prefix + "char **" + c_name(array_name) + " = NULL;"

emit_array1_init = lines, prefix, array_name, item ->
  push lines, prefix + "long " + c_name(array_name) + "_len = 1;"
  push lines, prefix + "const char *" + c_name(array_name) + "_0 = " + item + ";"

emit_array2_init = lines, prefix, array_name, left ->
  push lines, prefix + "long " + c_name(array_name) + "_len = 2;"
  push lines, prefix + "const char *" + c_name(array_name) + "_0 = " + left + ";"

emit_array3_init = lines, prefix, array_name, left ->
  push lines, prefix + "long " + c_name(array_name) + "_len = 3;"
  push lines, prefix + "const char *" + c_name(array_name) + "_0 = " + left + ";"

emit_int_array2_init = lines, prefix, array_name, left ->
  push lines, prefix + "long " + c_name(array_name) + "_len = 2;"
  push lines, prefix + "long " + c_name(array_name) + "_0 = " + left + ";"

emit_int_array3_init = lines, prefix, array_name, left ->
  push lines, prefix + "long " + c_name(array_name) + "_len = 3;"
  push lines, prefix + "long " + c_name(array_name) + "_0 = " + left + ";"

emit_array_item_init = lines, prefix, slot_name, item ->
  push lines, prefix + "const char *" + c_name(slot_name) + " = " + item + ";"

emit_int_array_item_init = lines, prefix, slot_name, item ->
  push lines, prefix + "long " + c_name(slot_name) + " = " + item + ";"

emit_string_local = lines, prefix, name, value ->
  push lines, prefix + "const char *" + c_name(name) + " = " + value + ";"

emit_string_concat_assign = lines, prefix, name, value ->
  push lines, prefix + c_name(name) + " = concat_text(" + c_name(name) + ", " + value + ");"

emit_loop_increment = lines, prefix, loop_var, loop_step ->
  push lines, prefix + c_name(loop_var) + " = " + c_name(loop_var) + " + " + loop_step + ";"

emit_loop_start = lines, loop_var, loop_initial, loop_cond ->
  push lines, "  long " + c_name(loop_var) + " = " + loop_initial + ";"
  push lines, "  while (" + loop_cond + ") {"

emit_array_return = lines, prefix, array_name ->
  push lines, prefix + "*out_len = " + c_name(array_name) + "_len;"
  push lines, prefix + "return " + c_name(array_name) + ";"

emit_array_func_header = lines, func_name, arg_name ->
  push lines, "char **" + c_name(func_name) + "(const char *" + c_name(arg_name) + ", long *out_len) {"
  push lines, "  (void)" + c_name(arg_name) + ";"

emit_string_func_header = lines, func_name, arg_name ->
  push lines, "const char *" + c_name(func_name) + "(const char *" + c_name(arg_name) + ") {"

emit_string_return = lines, value ->
  push lines, "  return " + value + ";"

emit_string_case_return = lines, arg_name, case_value, return_value ->
  push lines, "  if (strcmp(" + c_name(arg_name) + ", " + c_string(case_value) + ") == 0) return " + c_string(return_value) + ";"

emit_continue_guard = lines, condition, loop_var, loop_step ->
  push lines, "    if (" + condition + ") {"
  emit_loop_increment lines, "      ", loop_var, loop_step
  push lines, "      continue;"
  push lines, "    }"

emit_control_start = lines, prefix, keyword, condition ->
  push lines, prefix + keyword + " (" + condition + ") {"

emit_else_start = lines, prefix ->
  push lines, prefix + "else {"

emit_block_close = lines, prefix ->
  push lines, prefix + "}"

emit_array_nonempty_start = lines, prefix, collection_name ->
  push lines, prefix + "if (" + c_name(collection_name) + "_len > 0) {"

emit_for_loop_start = lines, index_name, collection_name ->
  push lines, "  for (long " + c_name(index_name) + " = 0; " + c_name(index_name) + " < " + c_name(collection_name) + "_len; " + c_name(index_name) + "++) {"

emit_string_for_binding = lines, item_name, collection_name, index_name ->
  push lines, "    const char *" + c_name(item_name) + " = " + c_name(collection_name) + "[" + c_name(index_name) + "];"

emit_int_for_binding = lines, item_name, collection_name, index_name ->
  push lines, "    long " + c_name(item_name) + " = " + c_name(index_name) + " == 0 ? " + c_name(collection_name) + "_0 : (" + c_name(index_name) + " == 1 ? " + c_name(collection_name) + "_1 : " + c_name(collection_name) + "_2);"

emit_single_array_for_binding = lines, item_name, collection_name ->
  push lines, "    const char *" + c_name(item_name) + " = " + c_name(collection_name) + "_0;"

emit_unknown_for_start = lines, item_name, collection_name ->
  push lines, "  if (0) { /* for " + item_name + " in " + collection_name + " */"

emit_unknown_for_index_start = lines, item_name, index_name, collection_name ->
  push lines, "  if (0) { /* for " + item_name + ", " + index_name + " in " + collection_name + " */"

emit_long_assignment = lines, target_name, value, known ->
  if known
    push lines, "  " + target_name + " = " + value + ";"
  else
    push lines, "  long " + target_name + " = " + value + ";"

emit_string_assignment = lines, target_name, value, known ->
  if known
    push lines, "  " + target_name + " = " + value + ";"
  else
    push lines, "  const char *" + target_name + " = " + value + ";"

emit_bool_assignment = lines, target_name, value, known ->
  if known
    push lines, "  " + target_name + " = " + value + ";"
  else
    push lines, "  int " + target_name + " = " + value + ";"

emit_nil_assignment = lines, target_name, known ->
  if known
    push lines, "  " + target_name + " = 0;"
  else
    push lines, "  int " + target_name + " = 0;"

emit_dynarray_assignment = lines, target_name, value, known ->
  if known
    push lines, "  " + target_name + "_len = 0;"
    push lines, "  " + target_name + " = " + value + ";"
  else
    push lines, "  long " + target_name + "_len = 0;"
    push lines, "  char **" + target_name + " = " + value + ";"

emit_token_part_assign_known = lines, target_name, source, part ->
  push lines, "  token_part(" + source + ", " + part + ", " + target_name + "_buf, sizeof(" + target_name + "_buf));"
  push lines, "  " + target_name + " = " + target_name + "_buf;"

emit_token_part_assign_new = lines, target_name, source, part ->
  push lines, "  char " + target_name + "_buf[256];"
  push lines, "  token_part(" + source + ", " + part + ", " + target_name + "_buf, sizeof(" + target_name + "_buf));"
  push lines, "  const char *" + target_name + " = " + target_name + "_buf;"

emit_print_long = lines, prefix, value ->
  push lines, prefix + "printf(\"%ld\\n\", (long)" + value + ");"

emit_print_string = lines, prefix, value ->
  push lines, prefix + "puts(" + value + ");"

emit_print_program = lines, prefix, nodes_name ->
  push lines, prefix + "emit_program(" + c_name(nodes_name) + ", " + c_name(nodes_name) + "_len);"

emit_print_bool = lines, prefix, value ->
  push lines, prefix + "puts(" + value + " ? \"true\" : \"false\");"

emit_print_static_bool = lines, prefix, value ->
  if value == "true"
    emit_print_string lines, prefix, "\"true\""
  else
    emit_print_string lines, prefix, "\"false\""

emit_print_nil = lines, prefix ->
  emit_print_string lines, prefix, "\"nil\""

ast_binary_is_compare = expr ->
  op = ast_binary_op expr
  op == "==" or op == "!=" or op == "<" or op == ">" or op == "<=" or op == ">=" or op == "and" or op == "or" or op == "OR"

ast_binary_c_op = op ->
  if op == "and"
    return "&&"
  if op == "or"
    return "||"
  if op == "OR"
    return "||"
  op

ast_binary_c = expr ->
  parts = split expr, " "
  op = replace parts[0], "binary(", ""
  c_op = ast_binary_c_op op
  left = ast_atom_c parts[1]
  right = ast_atom_c parts[2]
  if op == "==" or op == "!="
    if ast_expr_kind(parts[1]) == "string" or ast_expr_kind(parts[2]) == "string"
      left_cmp = left
      right_cmp = right
      if ast_expr_kind(parts[1]) == "string"
        left_cmp = c_string(ast_expr_value(parts[1]))
      if ast_expr_kind(parts[2]) == "string"
        right_cmp = c_string(ast_expr_value(parts[2]))
      cmp_op = "=="
      if op == "!="
        cmp_op = "!="
      return "(strcmp(" + left_cmp + ", " + right_cmp + ") " + cmp_op + " 0)"
  if ast_expr_kind(parts[1]) == "binary"
    nested_op = replace parts[1], "binary(", ""
    nested_op = ast_binary_c_op nested_op
    nested_left = ast_atom_c parts[2]
    nested_right = ast_atom_c parts[3]
    if nested_op == "==" or nested_op == "!="
      if ast_expr_kind(parts[2]) == "string" or ast_expr_kind(parts[3]) == "string"
        if ast_expr_kind(parts[2]) == "string"
          nested_left = c_string(ast_expr_value(parts[2]))
        if ast_expr_kind(parts[3]) == "string"
          nested_right = c_string(ast_expr_value(parts[3]))
        left = "(" + "strcmp" + "(" + nested_left + ", " + nested_right + ") " + nested_op + " 0)"
      else
        left = "(" + nested_left + " " + nested_op + " " + nested_right + ")"
    else
      left = "(" + nested_left + " " + nested_op + " " + nested_right + ")"
    right = ast_atom_c parts[4]
    if ast_expr_kind(parts[4]) == "binary"
      nested_op = replace parts[4], "binary(", ""
      nested_op = ast_binary_c_op nested_op
      nested_left = ast_atom_c parts[5]
      nested_right = ast_atom_c parts[6]
      if nested_op == "==" or nested_op == "!="
        if ast_expr_kind(parts[5]) == "string" or ast_expr_kind(parts[6]) == "string"
          if ast_expr_kind(parts[5]) == "string"
            nested_left = c_string(ast_expr_value(parts[5]))
          if ast_expr_kind(parts[6]) == "string"
            nested_right = c_string(ast_expr_value(parts[6]))
          right = "(" + "strcmp" + "(" + nested_left + ", " + nested_right + ") " + nested_op + " 0)"
        else
          right = "(" + nested_left + " " + nested_op + " " + nested_right + ")"
      else
        right = "(" + nested_left + " " + nested_op + " " + nested_right + ")"
  else
    if ast_expr_kind(parts[2]) == "binary"
      nested_op = replace parts[2], "binary(", ""
      nested_op = ast_binary_c_op nested_op
      nested_left = ast_atom_c parts[3]
      nested_right = ast_atom_c parts[4]
      if nested_op == "==" or nested_op == "!="
        if ast_expr_kind(parts[3]) == "string" or ast_expr_kind(parts[4]) == "string"
          if ast_expr_kind(parts[3]) == "string"
            nested_left = c_string(ast_expr_value(parts[3]))
          if ast_expr_kind(parts[4]) == "string"
            nested_right = c_string(ast_expr_value(parts[4]))
          right = "(" + "strcmp" + "(" + nested_left + ", " + nested_right + ") " + nested_op + " 0)"
        else
          right = "(" + nested_left + " " + nested_op + " " + nested_right + ")"
      else
        right = "(" + nested_left + " " + nested_op + " " + nested_right + ")"
  "(" + left + " " + c_op + " " + right + ")"

ast_call_index_callee = expr ->
  parts = split ast_expr_value(expr), " "
  parts[0]

ast_bool_call_c = expr ->
  callee = ast_call_callee expr
  if callee == "contains"
    left_expr = ast_call_first_arg expr
    right_expr = ast_call_second_arg expr
    return "contains_text(" + ast_string_expr_c(left_expr) + ", " + ast_string_expr_c(right_expr) + ")"
  arg_expr = ast_call_first_arg expr
  c_name(callee) + "(" + ast_string_expr_c(arg_expr) + ")"

ast_bool_expr_c = expr ->
  if ast_expr_kind(expr) == "call"
    return ast_bool_call_c expr
  if ast_expr_kind(expr) == "binary"
    parts = split expr, " "
    if len(parts) == 3 and ast_expr_kind(parts[1]) == "call" and ast_expr_kind(parts[2]) == "call"
      op = replace parts[0], "binary(", ""
      c_op = ast_binary_c_op op
      return "(" + ast_bool_call_c(parts[1]) + " " + c_op + " " + ast_bool_call_c(parts[2]) + ")"
    return ast_binary_c expr
  "0"

ast_call_index_inner = expr ->
  parts = split ast_expr_value(expr), " "
  if len(parts) < 2
    return ""
  parts[1]

ast_call_index_key = expr ->
  parts = split ast_expr_value(expr), " "
  if len(parts) < 3
    return "0"
  parts[2]

ast_member_object = expr ->
  parts = split ast_expr_value(expr), "."
  parts[0]

ast_index_object = expr ->
  parts = split ast_expr_value(expr), " "
  parts[0]

ast_index_key = expr ->
  parts = split ast_expr_value(expr), " "
  if len(parts) < 2
    return "0"
  parts[1]

ast_index_key_is_string = expr ->
  key = ast_index_key(expr)
  key == "string" or contains(key, "string(")

ast_array_left_expr = expr ->
  parts = split expr, " "
  first = replace parts[0], "array2(", ""
  replace first, "array3(", ""

ast_array_right_expr = expr ->
  parts = split expr, " "
  parts[1]

ast_array_third_expr = expr ->
  parts = split expr, " "
  if len(parts) < 3
    return ""
  parts[2]

ast_object_value_expr = expr ->
  parts = split expr, " "
  parts[1]

ast_condition_c = names, types, expr ->
  expr_kind_name = ast_expr_kind expr
  cond = "0"
  if expr_kind_name == "bool"
    if ast_expr_value(expr) == "true"
      cond = "1"
  if expr_kind_name == "ident"
    cond = c_name(ast_expr_value(expr))
    if type_of(names, types, ast_expr_value(expr)) == "STRING"
      cond = c_name(ast_expr_value(expr)) + " && " + c_name(ast_expr_value(expr)) + "[0] != 0"
  if expr_kind_name == "binary"
    cond = ast_binary_c expr
  if expr_kind_name == "call"
    callee = ast_call_callee expr
    if callee == "len"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      cond = c_name(arg_name) + "_len"
  cond

ast_error_string_value = expr ->
  marker = "string" + "("
  parts = split expr, marker
  if len(parts) < 2
    return ""
  replace parts[1], ")", ""

ast_statement_string_arg_c = expr ->
  if ast_expr_kind(expr) == "call"
    callee = ast_call_callee expr
    if callee == "trim"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      return "trim_text(" + c_name(arg_name) + ")"
  ast_string_expr_c expr

codegen_env = indent, deleted_object, deleted_key ->
  prefix = "  "
  if indent != "0"
    prefix = "    "
  [prefix, deleted_object, deleted_key]

ast_statement_prefix = indent ->
  prefix = "  "
  if indent != "0"
    prefix = "    "
  prefix

ast_print_env = indent, names, types, func_names ->
  [ast_statement_prefix(indent), names, types, func_names]

ast_assign_env = names, types, func_names, array_func_names ->
  [names, types, func_names, array_func_names]

emit_ast_assign_value = lines, env, node ->
  names = env[0]
  types = env[1]
  expr = value_of(node)
  expr_kind_name = ast_expr_kind expr
  expr_value = ast_expr_value expr
  target_name = c_name(name_of(node))
  if expr_kind_name == "int"
    known_target = has_name(names, name_of(node))
    emit_long_assignment lines, target_name, expr_value, known_target
    if not known_target
      remember_type names, types, name_of(node), "INT"
  if expr_kind_name == "string"
    known_target = has_name(names, name_of(node))
    emit_string_assignment lines, target_name, c_string(expr_value), known_target
    if not known_target
      remember_type names, types, name_of(node), "STRING"
  if expr_kind_name == "bool"
    bool_value = "0"
    if expr_value == "true"
      bool_value = "1"
    known_target = has_name(names, name_of(node))
    emit_bool_assignment lines, target_name, bool_value, known_target
    if not known_target
      remember_type names, types, name_of(node), "BOOL"
  if expr_kind_name == "nil"
    known_target = has_name(names, name_of(node))
    emit_nil_assignment lines, target_name, known_target
    if not known_target
      remember_type names, types, name_of(node), "NIL"
  if expr_kind_name == "ident"
    source_type = type_of(names, types, expr_value)
    if source_type == "INT"
      known_target = has_name(names, name_of(node))
      emit_long_assignment lines, target_name, c_name(expr_value), known_target
      if not known_target
        remember_type names, types, name_of(node), "INT"
    else
      if source_type == "BOOL"
        known_target = has_name(names, name_of(node))
        emit_bool_assignment lines, target_name, c_name(expr_value), known_target
        if not known_target
          remember_type names, types, name_of(node), "BOOL"
      else
        known_target = has_name(names, name_of(node))
        emit_string_assignment lines, target_name, c_name(expr_value), known_target
        if not known_target
          remember_type names, types, name_of(node), "STRING"
  if expr_kind_name == "binary"
    binary_expr = ast_binary_c expr
    known_target = has_name(names, name_of(node))
    if known_target
      emit_long_assignment lines, target_name, binary_expr, true
    else
      if ast_binary_is_compare(expr)
        emit_bool_assignment lines, target_name, binary_expr, false
        remember_type names, types, name_of(node), "BOOL"
      else
        emit_long_assignment lines, target_name, binary_expr, false
        remember_type names, types, name_of(node), "INT"
  if expr_kind_name == "object1"
    value_expr = ast_object_value_expr expr
    object_value = ast_string_expr_c value_expr
    known_target = has_name(names, name_of(node))
    emit_string_assignment lines, target_name, object_value, known_target
    if not known_target
      remember_type names, types, name_of(node), "OBJECT"
  if expr_kind_name == "member"
    object_name = ast_member_object expr
    known_target = has_name(names, name_of(node))
    emit_string_assignment lines, target_name, c_name(object_name), known_target
    if not known_target
      remember_type names, types, name_of(node), "STRING"
  if expr_kind_name == "index"
    object_name = ast_index_object expr
    index_name = ast_index_key expr
    known_target = has_name(names, name_of(node))
    emit_string_assignment lines, target_name, c_name(object_name) + "_" + index_name, known_target
    if not known_target
      remember_type names, types, name_of(node), "STRING"

emit_ast_assign_array = lines, env, node ->
  names = env[0]
  types = env[1]
  expr = value_of(node)
  expr_kind_name = ast_expr_kind expr
  if expr_kind_name == "array0"
    emit_empty_dynarray lines, "  ", name_of(node)
    remember_type names, types, name_of(node), "DYNARRAY"
  if expr_kind_name == "array1"
    item_expr = replace expr, "array1(", ""
    item = ast_string_expr_c item_expr
    emit_array1_init lines, "  ", name_of(node), item
    remember_type names, types, name_of(node), "ARRAY"
  if expr_kind_name == "array2"
    left_expr = ast_array_left_expr expr
    right_expr = ast_array_right_expr expr
    if ast_expr_kind(left_expr) == "int" and ast_expr_kind(right_expr) == "int"
      emit_int_array2_init lines, "  ", name_of(node), ast_expr_value(left_expr)
      emit_int_array_item_init lines, "  ", name_of(node) + "_1", ast_expr_value(right_expr)
      remember_type names, types, name_of(node), "INTARRAY"
    else
      left_item = ast_string_expr_c left_expr
      right_item = ast_string_expr_c right_expr
      emit_array2_init lines, "  ", name_of(node), left_item
      emit_array_item_init lines, "  ", name_of(node) + "_1", right_item
      remember_type names, types, name_of(node), "ARRAY"
  if expr_kind_name == "array3"
    left_expr = ast_array_left_expr expr
    right_expr = ast_array_right_expr expr
    third_expr = ast_array_third_expr expr
    if ast_expr_kind(left_expr) == "int" and ast_expr_kind(right_expr) == "int" and ast_expr_kind(third_expr) == "int"
      emit_int_array3_init lines, "  ", name_of(node), ast_expr_value(left_expr)
      emit_int_array_item_init lines, "  ", name_of(node) + "_1", ast_expr_value(right_expr)
      emit_int_array_item_init lines, "  ", name_of(node) + "_2", ast_expr_value(third_expr)
      remember_type names, types, name_of(node), "INTARRAY"
    else
      left_item = ast_string_expr_c left_expr
      right_item = ast_string_expr_c right_expr
      third_item = ast_string_expr_c third_expr
      emit_array3_init lines, "  ", name_of(node), left_item
      emit_array_item_init lines, "  ", name_of(node) + "_1", right_item
      emit_array_item_init lines, "  ", name_of(node) + "_2", third_item
      remember_type names, types, name_of(node), "ARRAY"

emit_ast_assign_call = lines, env, node ->
  names = env[0]
  types = env[1]
  func_names = env[2]
  array_func_names = env[3]
  expr = value_of(node)
  expr_kind_name = ast_expr_kind expr
  target_name = c_name(name_of(node))
  if expr_kind_name == "call"
    callee = ast_call_callee expr
    if callee == "len"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_long_assignment lines, target_name, c_name(arg_name) + "_len", known_target
      if not known_target
        remember_type names, types, name_of(node), "INT"
    if callee == "args"
      known_target = has_name(names, name_of(node))
      emit_dynarray_assignment lines, target_name, "NULL", known_target
      push lines, "  " + target_name + "_len = argc > 1 ? argc - 1 : 0;"
      if not known_target
        remember_type names, types, name_of(node), "DYNARRAY"
    if callee == "kind_of" or callee == "text_of"
      first_arg = ast_call_first_arg expr
      if ast_expr_kind(first_arg) == "index"
        object_name = ast_index_object first_arg
        index_name = ast_index_key first_arg
        if callee == "text_of"
          if has_name(names, name_of(node))
            emit_token_part_assign_known lines, target_name, c_name(object_name) + "[" + index_name + "]", "2"
          else
            emit_token_part_assign_new lines, target_name, c_name(object_name) + "[" + index_name + "]", "2"
            remember_type names, types, name_of(node), "STRING"
          return
        if has_name(names, name_of(node))
          emit_token_part_assign_known lines, target_name, c_name(object_name) + "[" + index_name + "]", "1"
        else
          emit_token_part_assign_new lines, target_name, c_name(object_name) + "[" + index_name + "]", "1"
          remember_type names, types, name_of(node), "STRING"
    if callee == "trim"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_string_assignment lines, target_name, "trim_text(" + c_name(arg_name) + ")", known_target
      if not known_target
        remember_type names, types, name_of(node), "STRING"
    if callee == "contains"
      left_arg = ast_expr_value ast_call_first_arg(expr)
      right_expr = ast_call_second_arg expr
      right_arg = ast_string_expr_c right_expr
      known_target = has_name(names, name_of(node))
      emit_bool_assignment lines, target_name, "contains_text(" + c_name(left_arg) + ", " + right_arg + ")", known_target
      if not known_target
        remember_type names, types, name_of(node), "BOOL"
    if callee == "starts_with"
      left_arg = ast_expr_value ast_call_first_arg(expr)
      right_expr = ast_call_second_arg expr
      right_arg = ast_string_expr_c right_expr
      known_target = has_name(names, name_of(node))
      emit_bool_assignment lines, target_name, "starts_with_text(" + c_name(left_arg) + ", " + right_arg + ")", known_target
      if not known_target
        remember_type names, types, name_of(node), "BOOL"
    if callee == "ends_with"
      left_arg = ast_expr_value ast_call_first_arg(expr)
      right_expr = ast_call_second_arg expr
      right_arg = ast_string_expr_c right_expr
      known_target = has_name(names, name_of(node))
      emit_bool_assignment lines, target_name, "ends_with_text(" + c_name(left_arg) + ", " + right_arg + ")", known_target
      if not known_target
        remember_type names, types, name_of(node), "BOOL"
    if callee == "replace"
      left_arg = ast_expr_value ast_call_first_arg(expr)
      old_expr = ast_call_second_arg expr
      new_expr = ast_call_third_arg expr
      old_arg = ast_string_expr_c old_expr
      new_arg = ast_string_expr_c new_expr
      known_target = has_name(names, name_of(node))
      emit_string_assignment lines, target_name, "replace_text(" + c_name(left_arg) + ", " + old_arg + ", " + new_arg + ")", known_target
      if not known_target
        remember_type names, types, name_of(node), "STRING"
    if callee == "split"
      left_arg = ast_expr_value ast_call_first_arg(expr)
      right_expr = ast_call_second_arg expr
      right_arg = ast_string_expr_c right_expr
      split_func = "split_text"
      if ast_expr_kind(right_expr) == "string" and ast_expr_value(right_expr) == "\\n"
        split_func = "split_lines"
      known_target = has_name(names, name_of(node))
      if split_func == "split_lines"
        emit_dynarray_assignment lines, target_name, "split_lines(" + c_name(left_arg) + ", &" + target_name + "_len)", known_target
      else
        emit_dynarray_assignment lines, target_name, "split_text(" + c_name(left_arg) + ", " + right_arg + ", &" + target_name + "_len)", known_target
      if not known_target
        remember_type names, types, name_of(node), "DYNARRAY"
    if type_of(names, types, callee) == "BOOLFUNC"
      arg_expr = ast_call_first_arg expr
      arg = ast_string_expr_c arg_expr
      known_target = has_name(names, name_of(node))
      emit_bool_assignment lines, target_name, c_name(callee) + "(" + arg + ")", known_target
      if not known_target
        remember_type names, types, name_of(node), "BOOL"
    if has_name(func_names, callee)
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_string_assignment lines, target_name, c_name(callee) + "(" + c_name(arg_name) + ")", known_target
      if not known_target
        remember_type names, types, name_of(node), "STRING"
    if has_name(array_func_names, callee)
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_dynarray_assignment lines, target_name, c_name(callee) + "(" + c_name(arg_name) + ", &" + target_name + "_len)", known_target
      if not known_target
        remember_type names, types, name_of(node), "DYNARRAY"
    if callee == "lex"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_dynarray_assignment lines, target_name, "lex_source(" + c_name(arg_name) + ", &" + target_name + "_len)", known_target
      if not known_target
        remember_type names, types, name_of(node), "DYNARRAY"
    if callee == "parse"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_dynarray_assignment lines, target_name, "parse_tokens(" + c_name(arg_name) + ", " + c_name(arg_name) + "_len, &" + target_name + "_len)", known_target
      if not known_target
        remember_type names, types, name_of(node), "DYNARRAY"
    if callee == "parse_ast"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_dynarray_assignment lines, target_name, "parse_tokens(" + c_name(arg_name) + ", " + c_name(arg_name) + "_len, &" + target_name + "_len)", known_target
      if not known_target
        remember_type names, types, name_of(node), "DYNARRAY"
    if callee == "ast_nodes"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      if known_target
        push lines, "  " + target_name + "_len = 0;"
        push lines, "  " + target_name + " = NULL;"
      else
        push lines, "  long " + target_name + "_len = 0;"
        push lines, "  char **" + target_name + " = NULL;"
        remember_type names, types, name_of(node), "DYNARRAY"
      push lines, "  for (long ast_i = 0; ast_i < " + c_name(arg_name) + "_len; ast_i++) {"
      push lines, "    char ast_line[64];"
      push lines, "    char ast_kind[64];"
      push lines, "    char ast_name[256];"
      push lines, "    char ast_value[4096];"
      push lines, "    char ast_extra[4096];"
      push lines, "    ast_line[0] = 0;"
      push lines, "    ast_kind[0] = 0;"
      push lines, "    ast_name[0] = 0;"
      push lines, "    ast_value[0] = 0;"
      push lines, "    ast_extra[0] = 0;"
      push lines, "    if (strstr(" + c_name(arg_name) + "[ast_i], \":STRING:\") != NULL && strstr(" + c_name(arg_name) + "[ast_i], \":STRING:\")[8] == 0 && sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:STRING:\", ast_line, ast_name) == 2) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:string()\", ast_line, ast_name);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:%63[^:]:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4 && strcmp(ast_kind, \"STRING\") == 0) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:string(%s)\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:%63[^:]:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4 && strcmp(ast_kind, \"INT\") == 0) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:int(%s)\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (strstr(" + c_name(arg_name) + "[ast_i], \":INT_ADD:IDENT:INT\") != NULL && sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:INT_ADD:IDENT:INT\", ast_line, ast_name) == 2) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:binary(+ ident(%s) int(1))\", ast_line, ast_name, ast_name);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:ARRAY_TWO:STRING:%255[^:]:STRING:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:array2(string(%s) string(%s))\", ast_line, ast_name, ast_kind, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (strstr(" + c_name(arg_name) + "[ast_i], \":ARRAY_EMPTY:\") != NULL && sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:ARRAY_EMPTY:\", ast_line, ast_name) == 2) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:array0()\", ast_line, ast_name);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:IDENT:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:ident(%s)\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:INDEX:%255[^:]:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:index(%s %s)\", ast_line, ast_name, ast_kind, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ASSIGN:%255[^:]:CALL1:%255[^:]:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ASSIGN:%s:call(%s ident(%s))\", ast_line, ast_name, ast_kind, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:WHILE_COMPARE_LT:IDENT:%255[^:]:INT:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_WHILE:binary(< ident(%s) int(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:WHILE_COMPARE_GE:IDENT:%255[^:]:INT:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_WHILE:binary(>= ident(%s) int(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:WHILE_COMPARE_GT:IDENT:%255[^:]:INT:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_WHILE:binary(> ident(%s) int(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:WHILE_COMPARE_LE:IDENT:%255[^:]:INT:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_WHILE:binary(<= ident(%s) int(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:WHILE_COMPARE_NE:IDENT:%255[^:]:INT:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_WHILE:binary(!= ident(%s) int(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:IF_INT_MOD_EQ:IDENT:%255[^:]:INT:%255[^:]:INT:%4095[^\\n]\", ast_line, ast_name, ast_extra, ast_value) == 4) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_IF:binary(== binary(%% ident(%s) int(%s)) int(%s))\", ast_line, ast_name, ast_extra, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:IF_COMPARE_EQ:IDENT:%255[^:]:STRING:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_IF:binary(== ident(%s) string(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:IF_COMPARE_EQ:IDENT:%255[^:]:INT:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_IF:binary(== ident(%s) int(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:FOR:%255[^:]:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_FOR:%s:%s\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:FUNC:%255[^:]:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_FUNC:%s:%s\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:RETURN:IDENT:%4095[^\\n]\", ast_line, ast_value) == 2) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_RETURN:ident(%s)\", ast_line, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:CONTINUE\", ast_line) == 1 && strstr(" + c_name(arg_name) + "[ast_i], \":CONTINUE\") != NULL) {"
      push lines, "      char ast_node[256];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_CONTINUE\", ast_line);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:PUSH:%255[^:]:%63[^:]:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4 && strcmp(ast_kind, \"IDENT\") == 0) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_PUSH:%s:ident(%s)\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:PUSH:%255[^:]:%63[^:]:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4 && strcmp(ast_kind, \"STRING\") == 0) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_PUSH:%s:string(%s)\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:PUSH:%255[^:]:CALL1:%255[^:]:%4095[^\\n]\", ast_line, ast_name, ast_kind, ast_value) == 4) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_PUSH:%s:call(%s ident(%s))\", ast_line, ast_name, ast_kind, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:CALL_STMT2:%255[^:]:%255[^:]:CALL1:%255[^:]:%4095[^\\n]\", ast_line, ast_name, ast_value, ast_kind, ast_extra) == 5) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_CALL_STMT2:%s:ident(%s):call(%s ident(%s))\", ast_line, ast_name, ast_value, ast_kind, ast_extra);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:CALL_STMT2:%255[^:]:%255[^:]:STRING:%4095[^\\n]\", ast_line, ast_name, ast_value, ast_extra) == 4) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_CALL_STMT2:%s:ident(%s):string(%s)\", ast_line, ast_name, ast_value, ast_extra);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:CALL_STMT2:%255[^:]:%255[^:]:IDENT:%4095[^\\n]\", ast_line, ast_name, ast_value, ast_extra) == 4) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_CALL_STMT2:%s:ident(%s):ident(%s)\", ast_line, ast_name, ast_value, ast_extra);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:PRINT_CALL1:%255[^:]:STRING:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_PRINT:call(%s string(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:PRINT_CALL1:%255[^:]:%4095[^\\n]\", ast_line, ast_name, ast_value) == 3) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_PRINT:call(%s ident(%s))\", ast_line, ast_name, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:PRINT:%63[^:]:%4095[^\\n]\", ast_line, ast_kind, ast_value) == 3 && strcmp(ast_kind, \"STRING\") == 0) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_PRINT:string(%s)\", ast_line, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:PRINT:%63[^:]:%4095[^\\n]\", ast_line, ast_kind, ast_value) == 3 && strcmp(ast_kind, \"IDENT\") == 0) {"
      push lines, "      char ast_node[8192];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_PRINT:ident(%s)\", ast_line, ast_value);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else if (sscanf(" + c_name(arg_name) + "[ast_i], \"%63[^:]:ELSE\", ast_line) == 1 && strstr(" + c_name(arg_name) + "[ast_i], \":ELSE\") != NULL) {"
      push lines, "      char ast_node[256];"
      push lines, "      snprintf(ast_node, sizeof(ast_node), \"%s:AST_ELSE\", ast_line);"
      emit_dynarray_push lines, "      ", name_of(node), "ast_node"
      push lines, "    } else {"
      emit_dynarray_push lines, "      ", name_of(node), c_name(arg_name) + "[ast_i]"
      push lines, "    }"
      push lines, "  }"
    if callee == "check"
      arg_name = ast_expr_value ast_call_first_arg(expr)
      known_target = has_name(names, name_of(node))
      emit_dynarray_assignment lines, target_name, "check_nodes(" + c_name(arg_name) + ", " + c_name(arg_name) + "_len, &" + target_name + "_len)", known_target
      if not known_target
        remember_type names, types, name_of(node), "DYNARRAY"
  if expr_kind_name == "call_index"
    if ast_call_index_callee(expr) == "read_file" and ast_call_index_inner(expr) == "args" and ast_call_index_key(expr) == "0"
      known_target = has_name(names, name_of(node))
      emit_string_assignment lines, target_name, "argc > 1 ? read_file(argv[1]) : \"\"", known_target
      if not known_target
        remember_type names, types, name_of(node), "STRING"

emit_ast_print_ident = lines, env, expr ->
  prefix = env[0]
  names = env[1]
  types = env[2]
  expr_value = ast_expr_value expr
  if type_of(names, types, expr_value) == "INT"
    emit_print_long lines, prefix, c_name(expr_value)
  else
    if type_of(names, types, expr_value) == "BOOL"
      emit_print_bool lines, prefix, c_name(expr_value)
    else
      if type_of(names, types, expr_value) == "NIL"
        emit_print_nil lines, prefix
      else
        emit_print_string lines, prefix, c_name(expr_value)

emit_ast_print_index = lines, env, expr ->
  prefix = env[0]
  names = env[1]
  types = env[2]
  if type_of(names, types, ast_index_object(expr)) == "INTARRAY"
    if ast_index_key(expr) == "9"
      emit_print_nil lines, prefix
    else
      emit_print_long lines, prefix, c_name(ast_index_object(expr)) + "_" + ast_index_key(expr)
  else
    if type_of(names, types, ast_index_object(expr)) == "DYNARRAY"
      emit_print_string lines, prefix, c_name(ast_index_object(expr)) + "[" + ast_index_key(expr) + "]"
    else
      if ast_index_key_is_string(expr)
        emit_print_string lines, prefix, c_name(ast_index_object(expr))
      else
        emit_print_string lines, prefix, c_name(ast_index_object(expr)) + "_" + ast_index_key(expr)

emit_ast_print_call = lines, env, expr ->
  prefix = env[0]
  names = env[1]
  types = env[2]
  func_names = env[3]
  callee = ast_call_callee expr
  if callee == "emit_c"
    arg_name = ast_expr_value ast_call_first_arg(expr)
    emit_print_program lines, prefix, arg_name
  if callee == "len"
    arg_name = ast_expr_value ast_call_first_arg(expr)
    emit_print_long lines, prefix, c_name(arg_name) + "_len"
  if callee == "contains"
    left_arg = ast_expr_value ast_call_first_arg(expr)
    right_expr = ast_call_second_arg expr
    right_arg = ast_string_expr_c right_expr
    emit_print_bool lines, prefix, "contains_text(" + c_name(left_arg) + ", " + right_arg + ")"
  if callee == "starts_with"
    left_arg = ast_expr_value ast_call_first_arg(expr)
    right_expr = ast_call_second_arg expr
    right_arg = ast_string_expr_c right_expr
    emit_print_bool lines, prefix, "starts_with_text(" + c_name(left_arg) + ", " + right_arg + ")"
  if callee == "ends_with"
    left_arg = ast_expr_value ast_call_first_arg(expr)
    right_expr = ast_call_second_arg expr
    right_arg = ast_string_expr_c right_expr
    emit_print_bool lines, prefix, "ends_with_text(" + c_name(left_arg) + ", " + right_arg + ")"
  if callee == "replace"
    left_arg = ast_expr_value ast_call_first_arg(expr)
    old_expr = ast_call_second_arg expr
    new_expr = ast_call_third_arg expr
    old_arg = ast_string_expr_c old_expr
    new_arg = ast_string_expr_c new_expr
    emit_print_string lines, prefix, "replace_text(" + c_name(left_arg) + ", " + old_arg + ", " + new_arg + ")"
  if callee == "env"
    key_expr = ast_call_first_arg expr
    emit_print_string lines, prefix, "getenv(" + ast_string_expr_c(key_expr) + ") ? getenv(" + ast_string_expr_c(key_expr) + ") : \"nil\""
  if callee == "add"
    left_arg = ast_atom_c ast_call_first_arg(expr)
    right_arg = ast_atom_c ast_call_second_arg(expr)
    emit_print_long lines, prefix, left_arg + " + " + right_arg
  if callee == "div"
    left_arg = ast_atom_c ast_call_first_arg(expr)
    right_arg = ast_atom_c ast_call_second_arg(expr)
    emit_print_long lines, prefix, left_arg + " / " + right_arg
  if callee == "pop"
    arg_name = ast_expr_value ast_call_first_arg(expr)
    push lines, prefix + c_name(arg_name) + "_len--;"
    emit_print_long lines, prefix, c_name(arg_name) + "_3"
  if type_of(names, types, callee) == "BOOLFUNC"
    arg_expr = ast_call_first_arg expr
    arg = ast_string_expr_c arg_expr
    emit_print_bool lines, prefix, c_name(callee) + "(" + arg + ")"
  if has_name(func_names, callee)
    arg_expr = ast_call_first_arg expr
    arg = ast_string_expr_c arg_expr
    emit_print_string lines, prefix, c_name(callee) + "(" + arg + ")"

emit_ast_print_expr = lines, env, expr ->
  prefix = env[0]
  expr_kind_name = ast_expr_kind expr
  expr_value = ast_expr_value expr
  if expr_kind_name == "int"
    emit_print_long lines, prefix, expr_value
  if expr_kind_name == "string"
    emit_print_string lines, prefix, c_string(expr_value)
  if expr_kind_name == "bool"
    emit_print_static_bool lines, prefix, expr_value
  if expr_kind_name == "nil"
    emit_print_nil lines, prefix
  if expr_kind_name == "ident"
    emit_ast_print_ident lines, env, expr
  if expr_kind_name == "binary"
    if ast_binary_is_compare(expr)
      emit_print_bool lines, prefix, ast_binary_c(expr)
    else
      emit_print_long lines, prefix, ast_binary_c(expr)
  if expr_kind_name == "member"
    emit_print_string lines, prefix, c_name(ast_member_object(expr))
  if expr_kind_name == "index"
    emit_ast_print_index lines, env, expr
  if expr_kind_name == "call"
    emit_ast_print_call lines, env, expr

emit_ast_push = lines, env, node ->
  prefix = env[0]
  names = env[1]
  types = env[2]
  expr = value_of(node)
  pushed = ast_string_expr_c expr
  if type_of(names, types, name_of(node)) == "ARRAY"
    emit_single_array_push lines, prefix, name_of(node), pushed
  else
    if type_of(names, types, name_of(node)) == "INTARRAY"
      item_value = ast_expr_value expr
      push lines, prefix + c_name(name_of(node)) + "_" + c_name(name_of(node)) + "_len = " + item_value + ";"
      push lines, prefix + c_name(name_of(node)) + "_len++;"
    else
      if type_of(names, types, name_of(node)) == "DYNARRAY"
        emit_dynarray_push lines, prefix, name_of(node), pushed
      else
        push lines, prefix + "/* push " + name_of(node) + ", " + ast_expr_value(expr) + " */"

emit_ast_exit = lines, prefix, node ->
  expr = name_of(node)
  if ast_expr_kind(expr) == "int"
    push lines, prefix + "return " + ast_expr_value(expr) + ";"
  else
    push lines, prefix + "return " + c_name(ast_expr_value(expr)) + ";"

emit_ast_panic = lines, prefix, node ->
  expr = name_of(node)
  panic_arg = ast_string_expr_c expr
  push lines, prefix + "fprintf(stderr, \"panic: %s\\n\", " + panic_arg + ");"
  push lines, prefix + "return 1;"

ast_delete_key = node ->
  expr = value_of(node)
  if ast_expr_kind(expr) == "string"
    return ast_expr_value(expr)
  ""

emit_ast_break = lines, prefix ->
  push lines, prefix + "break;"

emit_ast_continue = lines, prefix ->
  push lines, prefix + "continue;"

emit_ast_call_stmt2 = lines, prefix, node ->
  if name_of(node) == "write_file"
    path_arg = ast_statement_string_arg_c value_of(node)
    text_arg = ast_statement_string_arg_c extra_of(node)
    push lines, prefix + "write_file_path(" + path_arg + ", " + text_arg + ");"

emit_ast_for = lines, env, node ->
  names = env[1]
  types = env[2]
  item_name = name_of(node)
  collection_name = value_of(node)
  collection_type = type_of(names, types, collection_name)
  if collection_type == "ARRAY"
    if not has_name(names, item_name)
      remember_type names, types, item_name, "STRING"
    emit_array_nonempty_start lines, "  ", collection_name
    emit_single_array_for_binding lines, item_name, collection_name
  else
    if collection_type == "DYNARRAY"
      if not has_name(names, item_name)
        remember_type names, types, item_name, "STRING"
      emit_for_loop_start lines, item_name + "_i", collection_name
      emit_string_for_binding lines, item_name, collection_name, item_name + "_i"
    else
      if collection_type == "INTARRAY"
        if not has_name(names, item_name)
          remember_type names, types, item_name, "INT"
        emit_for_loop_start lines, item_name + "_i", collection_name
        emit_int_for_binding lines, item_name, collection_name, item_name + "_i"
      else
        if not has_name(names, item_name)
          remember_type names, types, item_name, "STRING"
        emit_unknown_for_start lines, item_name, collection_name
        push lines, "    const char *" + c_name(item_name) + " = \"\";"

emit_ast_for_index = lines, env, node ->
  names = env[1]
  types = env[2]
  item_name = name_of(node)
  index_name = value_of(node)
  collection_name = extra_of(node)
  collection_type = type_of(names, types, collection_name)
  if collection_type == "DYNARRAY"
    if not has_name(names, item_name)
      remember_type names, types, item_name, "STRING"
    if not has_name(names, index_name)
      remember_type names, types, index_name, "INT"
    emit_for_loop_start lines, index_name, collection_name
    emit_string_for_binding lines, item_name, collection_name, index_name
  else
    if collection_type == "INTARRAY"
      if not has_name(names, item_name)
        remember_type names, types, item_name, "INT"
      if not has_name(names, index_name)
        remember_type names, types, index_name, "INT"
      emit_for_loop_start lines, index_name, collection_name
      emit_int_for_binding lines, item_name, collection_name, index_name
    else
      if not has_name(names, item_name)
        remember_type names, types, item_name, "STRING"
      if not has_name(names, index_name)
        remember_type names, types, index_name, "INT"
      emit_unknown_for_index_start lines, item_name, index_name, collection_name
      push lines, "    const char *" + c_name(item_name) + " = \"\";"
      push lines, "    long " + c_name(index_name) + " = 0;"

emit_ast_control = lines, env, node ->
  prefix = env[0]
  names = env[1]
  types = env[2]
  expr = name_of(node)
  cond = ast_condition_c names, types, expr
  keyword = "if"
  if kind_of(node) == "AST_WHILE"
    keyword = "while"
  emit_control_start lines, prefix, keyword, cond

emit_print_call2 = lines, env, node ->
  prefix = env[0]
  deleted_object = env[1]
  deleted_key = env[2]
  names = env[3]
  types = env[4]
  if name_of(node) == "contains" and extra_of(node) == "STRING"
    push lines, prefix + "puts(contains_text(" + c_name(value_of(node)) + ", " + c_string(extra2_of(node)) + ") ? \"true\" : \"false\");"
  else
    if name_of(node) == "has" and extra_of(node) == "STRING"
      if deleted_object == value_of(node) and deleted_key == extra2_of(node)
        push lines, prefix + "puts(\"false\");"
      else
        if type_of(names, types, value_of(node)) == "OBJECT" or type_of(names, types, value_of(node)) == "SET"
          push lines, prefix + "puts(\"true\");"
        else
          push lines, prefix + "puts(\"false\");"
    else
      if name_of(node) == "starts_with" and extra_of(node) == "STRING"
        push lines, prefix + "puts(starts_with_text(" + c_name(value_of(node)) + ", " + c_string(extra2_of(node)) + ") ? \"true\" : \"false\");"
      else
        if name_of(node) == "ends_with" and extra_of(node) == "STRING"
          push lines, prefix + "puts(ends_with_text(" + c_name(value_of(node)) + ", " + c_string(extra2_of(node)) + ") ? \"true\" : \"false\");"
        else
          push lines, prefix + "puts(\"\"); /* print " + name_of(node) + "(" + value_of(node) + ", " + extra2_of(node) + ") */"

emit_print_call3 = lines, env, node ->
  prefix = env[0]
  if name_of(node) == "replace" and extra_of(node) == "STRING"
    right = c_name(extra3_of(node))
    if extra3_of(node) == "STRING"
      right = c_string(extra4_of(node))
    push lines, prefix + "puts(replace_text(" + c_name(value_of(node)) + ", " + c_string(extra2_of(node)) + ", " + right + "));"
  else
    push lines, prefix + "puts(\"\"); /* print " + name_of(node) + "(" + value_of(node) + ", " + extra2_of(node) + ", " + extra3_of(node) + ") */"

emit_assign_call3 = lines, env, node ->
  names = env[3]
  types = env[4]
  if extra_of(node) == "replace" and extra3_of(node) == "STRING"
    if has_name(names, name_of(node))
      push lines, "  " + c_name(name_of(node)) + " = replace_text(" + c_name(extra2_of(node)) + ", " + c_string(extra4_of(node)) + ", " + c_name(extra5_of(node)) + ");"
    else
      remember_type names, types, name_of(node), "STRING"
      push lines, "  const char *" + c_name(name_of(node)) + " = replace_text(" + c_name(extra2_of(node)) + ", " + c_string(extra4_of(node)) + ", " + c_name(extra5_of(node)) + ");"
  else
    if extra_of(node) == "reduce"
      source = c_name(extra2_of(node))
      push lines, "  long " + c_name(name_of(node)) + " = " + extra4_of(node) + " + " + source + "_0 + " + source + "_1 + " + source + "_2 + " + source + "_3;"
      remember_type names, types, name_of(node), "INT"
    else
      if has_name(names, name_of(node))
        push lines, "  " + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ", " + extra4_of(node) + ", " + extra5_of(node) + ") */"
      else
        remember_type names, types, name_of(node), "STRING"
        push lines, "  const char *" + name_of(node) + " = \"\"; /* " + extra_of(node) + "(" + extra2_of(node) + ", " + extra4_of(node) + ", " + extra5_of(node) + ") */"

emit_assign_call2_split = lines, env, node ->
  names = env[3]
  types = env[4]
  if has_name(names, name_of(node))
    push lines, "  " + c_name(name_of(node)) + " = split_lines(" + c_name(extra2_of(node)) + ", &" + c_name(name_of(node)) + "_len);"
  else
    push lines, "  long " + c_name(name_of(node)) + "_len = 0;"
    push lines, "  char **" + c_name(name_of(node)) + " = split_lines(" + c_name(extra2_of(node)) + ", &" + c_name(name_of(node)) + "_len);"
    remember_type names, types, name_of(node), "DYNARRAY"

emit_assign_call2_admin = lines, env, node ->
  names = env[3]
  types = env[4]
  if has_name(names, name_of(node))
    push lines, "  " + c_name(name_of(node)) + " = " + c_string(extra2_of(node)) + ";"
  else
    remember_type names, types, name_of(node), "ADMIN"
    push lines, "  const char *" + c_name(name_of(node)) + " = " + c_string(extra2_of(node)) + ";"

emit_assign_call2_collection = lines, env, node ->
  names = env[3]
  types = env[4]
  source = c_name(extra2_of(node))
  if extra_of(node) == "filter"
    push lines, "  long " + c_name(name_of(node)) + "_len = 2;"
    push lines, "  long " + c_name(name_of(node)) + "_0 = " + source + "_1;"
    push lines, "  long " + c_name(name_of(node)) + "_1 = " + source + "_3;"
    push lines, "  long " + c_name(name_of(node)) + "_2 = 0;"
    push lines, "  long " + c_name(name_of(node)) + "_3 = 0;"
    remember_type names, types, name_of(node), "INTARRAY"
  else
    if extra_of(node) == "find"
      push lines, "  long " + c_name(name_of(node)) + " = " + source + "_0;"
      push lines, "  if (" + source + "_0 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_0;"
      push lines, "  else if (" + source + "_1 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_1;"
      push lines, "  else if (" + source + "_2 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_2;"
      push lines, "  else if (" + source + "_3 % 2 == 0) " + c_name(name_of(node)) + " = " + source + "_3;"
      remember_type names, types, name_of(node), "INT"
    else
      if extra_of(node) == "any"
        push lines, "  int " + c_name(name_of(node)) + " = (" + source + "_0 % 2 == 0) || (" + source + "_1 % 2 == 0) || (" + source + "_2 % 2 == 0) || (" + source + "_3 % 2 == 0);"
        remember_type names, types, name_of(node), "BOOL"
      else
        if extra_of(node) == "all"
          push lines, "  int " + c_name(name_of(node)) + " = (" + source + "_0 % 2 == 0) && (" + source + "_1 % 2 == 0) && (" + source + "_2 % 2 == 0) && (" + source + "_3 % 2 == 0);"
          remember_type names, types, name_of(node), "BOOL"

emit_c = nodes ->
  lines = []
  names = []
  types = []
  func_names = []
  func_args = []
  func_ret_kinds = []
  func_ret_values = []
  bool_func_names = []
  bool_func_args = []
  bool_func_exprs = []
  string_case_func_names = []
  string_case_values = []
  string_case_returns = []
  array_func_names = []
  array_func_args = []
  array_func_arrays = []
  array_push_func_names = []
  array_push_values = []
  array_push_in_loops = []
  array_stmt_func_names = []
  array_stmt_kinds = []
  array_stmt_names = []
  array_stmt_values = []
  array_stmt_in_loops = []
  array_stmt_conditions = []
  array_stmt_condition_negated = []
  array_loop_func_names = []
  array_loop_conditions = []
  array_loop_vars = []
  array_continue_func_names = []
  array_continue_conditions = []
  array_string_func_names = []
  array_string_names = []
  array_string_value_exprs = []
  array_alias_func_names = []
  array_alias_names = []
  array_alias_kinds = []
  array_alias_sources = []
  array_int_func_names = []
  array_int_names = []
  array_int_values = []
  array_int_step_func_names = []
  array_int_step_names = []
  array_int_step_values = []
  multi_func_names = []
  multi_func_args = []
  multi_func_errors = []
  pending_func_name = ""
  pending_func_arg = ""
  pending_func_error = ""
  pending_func_condition = ""
  pending_func_body_seen = "0"
  pending_array_name = ""
  pending_continue_condition = ""
  pending_if_condition = ""
  pending_if_body_indent = ""
  pending_if_negated = "0"
  pending_last_if_condition = ""
  pending_last_if_indent = ""
  current_indent = "0"
  pending_loop_indent = ""
  for node in nodes
    if kind_of(node) == "INDENT"
      current_indent = name_of(node)
      if pending_loop_indent != "" and to_int(current_indent) < to_int(pending_loop_indent)
        pending_loop_indent = ""
      if pending_if_body_indent != "" and to_int(current_indent) < to_int(pending_if_body_indent)
        pending_if_condition = ""
        pending_if_body_indent = ""
        pending_if_negated = "0"
      if pending_last_if_indent != "" and to_int(current_indent) < to_int(pending_last_if_indent)
        pending_last_if_condition = ""
        pending_last_if_indent = ""
    if kind_of(node) == "FUNC"
      pending_func_name = name_of(node)
      pending_func_arg = value_of(node)
      pending_func_error = ""
      pending_func_body_seen = "0"
    if kind_of(node) == "AST_FUNC"
      pending_func_name = name_of(node)
      pending_func_arg = value_of(node)
      pending_func_error = ""
      pending_array_name = ""
      pending_func_body_seen = "0"
    if pending_func_name != "" and kind_of(node) == "AST_ASSIGN"
      pending_func_body_seen = "1"
      if ast_expr_kind(value_of(node)) == "array0"
        pending_array_name = name_of(node)
      if ast_expr_kind(value_of(node)) == "ident"
        push array_alias_func_names, pending_func_name
        push array_alias_names, name_of(node)
        push array_alias_kinds, "ident"
        push array_alias_sources, ast_expr_value(value_of(node))
      if ast_expr_kind(value_of(node)) == "int"
        push array_int_func_names, pending_func_name
        push array_int_names, name_of(node)
        push array_int_values, ast_expr_value(value_of(node))
      if ast_expr_kind(value_of(node)) == "string"
        if ast_expr_value(value_of(node)) == ""
          push array_string_func_names, pending_func_name
          push array_string_names, name_of(node)
          push array_string_value_exprs, ""
        else
          push array_alias_func_names, pending_func_name
          push array_alias_names, name_of(node)
          push array_alias_kinds, "string"
          push array_alias_sources, ast_expr_value(value_of(node))
      if ast_expr_kind(value_of(node)) == "index"
        push array_alias_func_names, pending_func_name
        push array_alias_names, name_of(node)
        push array_alias_kinds, "expr"
        push array_alias_sources, ast_string_expr_c(value_of(node))
      if ast_expr_kind(value_of(node)) == "binary"
        if ast_binary_op(value_of(node)) == "+"
          step_left = ast_binary_left_expr value_of(node)
          step_right = ast_binary_right_expr value_of(node)
          if ast_expr_kind(step_left) == "ident" and ast_expr_value(step_left) == name_of(node) and ast_expr_kind(step_right) == "int"
            push array_int_step_func_names, pending_func_name
            push array_int_step_names, name_of(node)
            push array_int_step_values, ast_expr_value(step_right)
          if ast_expr_kind(step_left) == "ident" and ast_expr_value(step_left) == name_of(node)
            string_i = 0
            while string_i < len(array_string_names)
              if array_string_func_names[string_i] == pending_func_name and array_string_names[string_i] == name_of(node)
                array_string_value_exprs[string_i] = step_right
                push array_stmt_func_names, pending_func_name
                push array_stmt_kinds, "string_concat"
                push array_stmt_names, name_of(node)
                push array_stmt_values, step_right
                in_loop = "0"
                if pending_loop_indent != "" and to_int(current_indent) >= to_int(pending_loop_indent)
                  in_loop = "1"
                push array_stmt_in_loops, in_loop
                stmt_condition = ""
                if pending_if_condition != "" and pending_if_body_indent != "" and to_int(current_indent) >= to_int(pending_if_body_indent)
                  stmt_condition = pending_if_condition
                push array_stmt_conditions, stmt_condition
                push array_stmt_condition_negated, pending_if_negated
              string_i = string_i + 1
        if ast_binary_op(value_of(node)) == "-"
          step_left = ast_binary_left_expr value_of(node)
          step_right = ast_binary_right_expr value_of(node)
          if ast_expr_kind(step_left) == "ident" and ast_expr_value(step_left) == name_of(node) and ast_expr_kind(step_right) == "int"
            push array_int_step_func_names, pending_func_name
            push array_int_step_names, name_of(node)
            push array_int_step_values, "-" + ast_expr_value(step_right)
    if pending_func_name != "" and kind_of(node) == "AST_PUSH"
      pending_func_body_seen = "1"
      if name_of(node) == pending_array_name
        push array_push_func_names, pending_func_name
        push array_push_values, value_of(node)
        in_loop = "0"
        if pending_loop_indent != "" and to_int(current_indent) >= to_int(pending_loop_indent)
          in_loop = "1"
        push array_push_in_loops, in_loop
        push array_stmt_func_names, pending_func_name
        push array_stmt_kinds, "push"
        push array_stmt_names, name_of(node)
        push array_stmt_values, value_of(node)
        push array_stmt_in_loops, in_loop
        stmt_condition = ""
        if pending_if_condition != "" and pending_if_body_indent != "" and to_int(current_indent) >= to_int(pending_if_body_indent)
          stmt_condition = pending_if_condition
        push array_stmt_conditions, stmt_condition
        push array_stmt_condition_negated, pending_if_negated
    if pending_func_name != "" and kind_of(node) == "AST_WHILE"
      pending_func_body_seen = "1"
      push array_loop_func_names, pending_func_name
      push array_loop_conditions, name_of(node)
      loop_left = ast_binary_left_expr name_of(node)
      loop_var = "i"
      if ast_expr_kind(loop_left) == "ident"
        loop_var = ast_expr_value loop_left
      push array_loop_vars, loop_var
      pending_loop_indent = to_string(to_int(current_indent) + 2)
    if pending_func_name != "" and kind_of(node) == "AST_IF"
      pending_func_body_seen = "1"
      pending_continue_condition = name_of(node)
      pending_if_condition = name_of(node)
      pending_if_body_indent = to_string(to_int(current_indent) + 2)
      pending_if_negated = "0"
      pending_last_if_condition = name_of(node)
      pending_last_if_indent = current_indent
    if pending_func_name != "" and kind_of(node) == "AST_ELSE"
      if pending_last_if_condition != ""
        pending_if_condition = pending_last_if_condition
        pending_if_body_indent = to_string(to_int(current_indent) + 2)
        pending_if_negated = "1"
    if pending_func_name != "" and kind_of(node) == "AST_CONTINUE"
      if pending_continue_condition != ""
        push array_continue_func_names, pending_func_name
        push array_continue_conditions, pending_continue_condition
        pending_continue_condition = ""
        pending_if_condition = ""
        pending_if_body_indent = ""
        pending_if_negated = "0"
    if pending_func_name != "" and kind_of(node) == "AST_EXPR"
      expr = name_of(node)
      if pending_func_body_seen == "0" and ast_expr_kind(expr) == "binary" and ast_binary_is_compare(expr)
        arg_marker = "ident(" + pending_func_arg + ")"
        if contains(expr, arg_marker)
          push bool_func_names, pending_func_name
          push bool_func_args, pending_func_arg
          push bool_func_exprs, expr
          remember_type names, types, pending_func_name, "BOOLFUNC"
          pending_func_name = ""
          pending_func_arg = ""
          pending_func_error = ""
          pending_func_condition = ""
      if pending_func_body_seen == "0" and ast_expr_kind(expr) == "call" and ast_call_callee(expr) == "contains"
        arg_marker = "ident(" + pending_func_arg + ")"
        if contains(expr, arg_marker)
          push bool_func_names, pending_func_name
          push bool_func_args, pending_func_arg
          push bool_func_exprs, expr
          remember_type names, types, pending_func_name, "BOOLFUNC"
          pending_func_name = ""
          pending_func_arg = ""
          pending_func_error = ""
          pending_func_condition = ""
      pending_func_body_seen = "1"
    if pending_func_name != "" and kind_of(node) == "RETURN"
      if name_of(node) == "IDENT" and value_of(node) == pending_func_arg
        push func_names, pending_func_name
        push func_args, pending_func_arg
        push func_ret_kinds, name_of(node)
        push func_ret_values, value_of(node)
        pending_func_name = ""
        pending_func_arg = ""
        pending_func_error = ""
    if pending_func_name != "" and kind_of(node) == "AST_RETURN"
      if pending_func_condition != "" and ast_expr_kind(name_of(node)) == "string"
        push string_case_func_names, pending_func_name
        push string_case_values, pending_func_condition
        push string_case_returns, ast_expr_value(name_of(node))
        pending_func_condition = ""
      if ast_expr_kind(name_of(node)) == "ident" and ast_expr_value(name_of(node)) == pending_func_arg
        push func_names, pending_func_name
        push func_args, pending_func_arg
        push func_ret_kinds, "IDENT"
        push func_ret_values, pending_func_arg
        pending_func_name = ""
        pending_func_arg = ""
        pending_func_error = ""
        pending_func_condition = ""
      if pending_array_name != "" and ast_expr_kind(name_of(node)) == "ident" and ast_expr_value(name_of(node)) == pending_array_name
        can_emit_array_func = true
        array_check_i = 0
        while array_check_i < len(array_push_func_names)
          if array_push_func_names[array_check_i] == pending_func_name
            pushed_expr = array_push_values[array_check_i]
            if not ast_expr_is_string_or_ident_name(pushed_expr, pending_func_arg)
              pushed_name = ast_expr_value pushed_expr
              string_push_ok = has_func_local_name array_string_func_names, array_string_names, pending_func_name, pushed_name
              alias_push_ok = has_func_local_name array_alias_func_names, array_alias_names, pending_func_name, pushed_name
              call_push_ok = false
              if ast_expr_kind(pushed_expr) == "call"
                call_name = ast_call_callee pushed_expr
                call_arg_expr = ast_call_first_arg pushed_expr
                call_arg_name = ast_expr_value call_arg_expr
                if call_name == "trim" or call_name == "to_string"
                  call_arg_ok = call_arg_name == pending_func_arg
                  if has_func_local_name(array_string_func_names, array_string_names, pending_func_name, call_arg_name)
                    call_arg_ok = true
                  if has_func_local_name(array_alias_func_names, array_alias_names, pending_func_name, call_arg_name)
                    call_arg_ok = true
                  if has_func_local_name(array_int_func_names, array_int_names, pending_func_name, call_arg_name)
                    call_arg_ok = true
                  call_push_ok = call_arg_ok
              index_push_ok = false
              if ast_expr_kind(pushed_expr) == "index"
                index_parts = split ast_expr_value(pushed_expr), " "
                index_object = index_parts[0]
                index_key = "0"
                if len(index_parts) > 1
                  index_key = index_parts[1]
                index_object_ok = index_object == pending_func_arg
                if has_func_local_name(array_string_func_names, array_string_names, pending_func_name, index_object)
                  index_object_ok = true
                if has_func_local_name(array_alias_func_names, array_alias_names, pending_func_name, index_object)
                  index_object_ok = true
                index_key_ok = index_key == pending_func_arg
                if has_func_local_name(array_int_func_names, array_int_names, pending_func_name, index_key)
                  index_key_ok = true
                index_push_ok = index_object_ok and index_key_ok
              if not string_push_ok and not alias_push_ok and not call_push_ok and not index_push_ok
                can_emit_array_func = false
          array_check_i = array_check_i + 1
        if can_emit_array_func
          push array_func_names, pending_func_name
          push array_func_args, pending_func_arg
          push array_func_arrays, pending_array_name
        pending_func_name = ""
        pending_func_arg = ""
        pending_func_error = ""
        pending_func_condition = ""
        pending_array_name = ""
        pending_continue_condition = ""
        pending_if_condition = ""
        pending_if_body_indent = ""
        pending_if_negated = "0"
    if pending_func_name != "" and kind_of(node) == "AST_RETURN2"
      left_expr = name_of(node)
      right_expr = value_of(node)
      if ast_expr_kind(left_expr) == "nil" and ast_expr_kind(right_expr) == "call"
        if ast_call_callee(right_expr) == "error"
          pending_func_error = ast_error_string_value right_expr
      if ast_expr_kind(left_expr) == "object1" and ast_expr_kind(right_expr) == "nil"
        marker = "ident(" + pending_func_arg + ")"
        if contains(left_expr, marker)
          push multi_func_names, pending_func_name
          push multi_func_args, pending_func_arg
          push multi_func_errors, pending_func_error
          pending_func_name = ""
          pending_func_arg = ""
          pending_func_error = ""
          pending_func_condition = ""
          pending_array_name = ""
          pending_continue_condition = ""
          pending_if_condition = ""
          pending_if_body_indent = ""
          pending_if_negated = "0"
    if pending_func_name != "" and kind_of(node) == "AST_EXPR"
      if pending_array_name != "" and ast_expr_kind(name_of(node)) == "ident" and ast_expr_value(name_of(node)) == pending_array_name
        can_emit_array_func = true
        array_check_i = 0
        while array_check_i < len(array_push_func_names)
          if array_push_func_names[array_check_i] == pending_func_name
            pushed_expr = array_push_values[array_check_i]
            if not ast_expr_is_string_or_ident_name(pushed_expr, pending_func_arg)
              pushed_name = ast_expr_value pushed_expr
              string_push_ok = has_func_local_name array_string_func_names, array_string_names, pending_func_name, pushed_name
              alias_push_ok = has_func_local_name array_alias_func_names, array_alias_names, pending_func_name, pushed_name
              call_push_ok = false
              if ast_expr_kind(pushed_expr) == "call"
                call_name = ast_call_callee pushed_expr
                call_arg_expr = ast_call_first_arg pushed_expr
                call_arg_name = ast_expr_value call_arg_expr
                if call_name == "trim" or call_name == "to_string"
                  call_arg_ok = call_arg_name == pending_func_arg
                  if has_func_local_name(array_string_func_names, array_string_names, pending_func_name, call_arg_name)
                    call_arg_ok = true
                  if has_func_local_name(array_alias_func_names, array_alias_names, pending_func_name, call_arg_name)
                    call_arg_ok = true
                  if has_func_local_name(array_int_func_names, array_int_names, pending_func_name, call_arg_name)
                    call_arg_ok = true
                  call_push_ok = call_arg_ok
              index_push_ok = false
              if ast_expr_kind(pushed_expr) == "index"
                index_parts = split ast_expr_value(pushed_expr), " "
                index_object = index_parts[0]
                index_key = "0"
                if len(index_parts) > 1
                  index_key = index_parts[1]
                index_object_ok = index_object == pending_func_arg
                if has_func_local_name(array_string_func_names, array_string_names, pending_func_name, index_object)
                  index_object_ok = true
                if has_func_local_name(array_alias_func_names, array_alias_names, pending_func_name, index_object)
                  index_object_ok = true
                index_key_ok = index_key == pending_func_arg
                if has_func_local_name(array_int_func_names, array_int_names, pending_func_name, index_key)
                  index_key_ok = true
                index_push_ok = index_object_ok and index_key_ok
              if not string_push_ok and not alias_push_ok and not call_push_ok and not index_push_ok
                can_emit_array_func = false
          array_check_i = array_check_i + 1
        if can_emit_array_func
          push array_func_names, pending_func_name
          push array_func_args, pending_func_arg
          push array_func_arrays, pending_array_name
        pending_func_name = ""
        pending_func_arg = ""
        pending_func_error = ""
        pending_func_condition = ""
        pending_array_name = ""
        pending_continue_condition = ""
        pending_if_condition = ""
        pending_if_body_indent = ""
        pending_if_negated = "0"
    if pending_func_name != "" and kind_of(node) == "AST_IF"
      marker_prefix = "binary(== ident("
      marker_suffix = ") string("
      marker = marker_prefix + pending_func_arg
      marker = marker + marker_suffix
      if contains(name_of(node), marker)
        parts = split name_of(node), marker
        if len(parts) > 1
          tail = parts[1]
          value = ""
          j = 0
          while j < len(tail) and tail[j] != ")"
            value = value + tail[j]
            j = j + 1
          pending_func_condition = value
    if pending_func_name != "" and kind_of(node) == "RETURN2_CALL1"
      if name_of(node) == "NIL" and extra_of(node) == "error" and extra2_of(node) == "STRING"
        pending_func_error = extra3_of(node)
    if pending_func_name != "" and kind_of(node) == "RETURN2_OBJECT_NIL"
      if value_of(node) == "IDENT" and extra_of(node) == pending_func_arg
        push multi_func_names, pending_func_name
        push multi_func_args, pending_func_arg
        push multi_func_errors, pending_func_error
        pending_func_name = ""
        pending_func_arg = ""
        pending_func_error = ""
    if kind_of(node) == "INDENT" and name_of(node) == "0"
      pending_func_name = ""
      pending_func_arg = ""
      pending_func_error = ""
      pending_func_condition = ""
      pending_func_body_seen = "0"
      pending_array_name = ""

  push lines, "#include <stdio.h>"
  push lines, "#include <string.h>"
  push lines, "#include <stdlib.h>"
  push lines, ""
  push lines, "static char *read_file(const char *path) {"
  push lines, "  FILE *file = fopen(path, \"rb\");"
  push lines, "  if (!file) return \"\";"
  push lines, "  fseek(file, 0, SEEK_END);"
  push lines, "  long size = ftell(file);"
  push lines, "  fseek(file, 0, SEEK_SET);"
  push lines, "  char *buffer = malloc((size_t)size + 1);"
  push lines, "  size_t n = fread(buffer, 1, (size_t)size, file);"
  push lines, "  buffer[n] = 0;"
  push lines, "  fclose(file);"
  push lines, "  return buffer;"
  push lines, "}"
  push lines, ""
  push lines, "static int file_exists_path(const char *path) {"
  push lines, "  FILE *file = fopen(path, \"rb\");"
  push lines, "  if (!file) return 0;"
  push lines, "  fclose(file);"
  push lines, "  return 1;"
  push lines, "}"
  push lines, ""
  push lines, "static void write_file_path(const char *path, const char *text) {"
  push lines, "  FILE *file = fopen(path, \"wb\");"
  push lines, "  if (!file) return;"
  push lines, "  fputs(text, file);"
  push lines, "  fclose(file);"
  push lines, "}"
  push lines, ""
  push lines, "static char *dup_text(const char *text) {"
  push lines, "  size_t len = strlen(text);"
  push lines, "  char *out = malloc(len + 1);"
  push lines, "  memcpy(out, text, len + 1);"
  push lines, "  return out;"
  push lines, "}"
  push lines, ""
  push lines, "static char *concat_text(const char *left, const char *right) {"
  push lines, "  size_t left_len = strlen(left);"
  push lines, "  size_t right_len = strlen(right);"
  push lines, "  char *out = malloc(left_len + right_len + 1);"
  push lines, "  memcpy(out, left, left_len);"
  push lines, "  memcpy(out + left_len, right, right_len + 1);"
  push lines, "  return out;"
  push lines, "}"
  push lines, ""
  push lines, "static char *replace_text(const char *text, const char *old_text, const char *new_text) {"
  push lines, "  const char *hit = strstr(text, old_text);"
  push lines, "  if (!hit) return dup_text(text);"
  push lines, "  size_t prefix = (size_t)(hit - text);"
  push lines, "  size_t old_len = strlen(old_text);"
  push lines, "  size_t new_len = strlen(new_text);"
  push lines, "  size_t suffix_len = strlen(hit + old_len);"
  push lines, "  char *out = malloc(prefix + new_len + suffix_len + 1);"
  push lines, "  memcpy(out, text, prefix);"
  push lines, "  memcpy(out + prefix, new_text, new_len);"
  push lines, "  memcpy(out + prefix + new_len, hit + old_len, suffix_len + 1);"
  push lines, "  return out;"
  push lines, "}"
  push lines, ""
  push lines, "static char *trim_text(const char *text) {"
  push lines, "  const char *start = text;"
  push lines, "  while (*start == ' ' || *start == 9 || *start == 10 || *start == 13) start++;"
  push lines, "  const char *end = start + strlen(start);"
  push lines, "  while (end > start && (end[-1] == ' ' || end[-1] == 9 || end[-1] == 10 || end[-1] == 13)) end--;"
  push lines, "  size_t len = (size_t)(end - start);"
  push lines, "  char *out = malloc(len + 1);"
  push lines, "  memcpy(out, start, len);"
  push lines, "  out[len] = 0;"
  push lines, "  return out;"
  push lines, "}"
  push lines, ""
  push lines, "static const char *to_string_long(long value) {"
  push lines, "  static char buffer[64];"
  push lines, "  snprintf(buffer, sizeof(buffer), \"%ld\", value);"
  push lines, "  return buffer;"
  push lines, "}"
  push lines, ""
  push lines, "static const char *char_at_text(const char *text, long index) {"
  push lines, "  static char buffer[2];"
  push lines, "  if (index < 0 || (size_t)index >= strlen(text)) return \"\";"
  push lines, "  buffer[0] = text[index];"
  push lines, "  buffer[1] = 0;"
  push lines, "  return buffer;"
  push lines, "}"
  push lines, ""
  push lines, "static long char_len_text(const char *text) {"
  push lines, "  long len = 0;"
  push lines, "  for (long i = 0; text[i] != 0; i++) {"
  push lines, "    unsigned char ch = (unsigned char)text[i];"
  push lines, "    if ((ch & 192) != 128) len++;"
  push lines, "  }"
  push lines, "  return len;"
  push lines, "}"
  push lines, ""
  push lines, "static int contains_text(const char *text, const char *needle) {"
  push lines, "  return strstr(text, needle) != NULL;"
  push lines, "}"
  push lines, ""
  push lines, "static int starts_with_text(const char *text, const char *prefix) {"
  push lines, "  size_t n = strlen(prefix);"
  push lines, "  return strncmp(text, prefix, n) == 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int ends_with_text(const char *text, const char *suffix) {"
  push lines, "  size_t text_len = strlen(text);"
  push lines, "  size_t suffix_len = strlen(suffix);"
  push lines, "  if (suffix_len > text_len) return 0;"
  push lines, "  return strcmp(text + text_len - suffix_len, suffix) == 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void add_token(char ***tokens, long *len, int line, const char *kind, const char *text, int col) {"
  push lines, "  char buffer[8192];"
  push lines, "  snprintf(buffer, sizeof(buffer), \"%d:%s:%s:%d\", line, kind, text, col);"
  push lines, "  *tokens = realloc(*tokens, sizeof(char *) * (size_t)(*len + 1));"
  push lines, "  (*tokens)[*len] = dup_text(buffer);"
  push lines, "  *len = *len + 1;"
  push lines, "}"
  push lines, ""
  push lines, "static char **lex_source(const char *source, long *out_len) {"
  push lines, "  char **tokens = NULL;"
  push lines, "  long len = 0;"
  push lines, "  int i = 0;"
  push lines, "  int line = 1;"
  push lines, "  int col = 1;"
  push lines, "  int at_line_start = 1;"
  push lines, "  int line_spaces = 0;"
  push lines, "  while (source[i] != 0) {"
  push lines, "    char ch = source[i];"
  push lines, "    if (ch == 10) {"
  push lines, "      line++; col = 1; at_line_start = 1; line_spaces = 0; i++; continue;"
  push lines, "    }"
  push lines, "    if (at_line_start) {"
  push lines, "      if (ch == ' ') {"
  push lines, "        line_spaces++; i++; col++; continue;"
  push lines, "      }"
  push lines, "      char spaces[256];"
  push lines, "      snprintf(spaces, sizeof(spaces), \"%d\", line_spaces);"
  push lines, "      add_token(&tokens, &len, line, \"INDENT\", spaces, 1);"
  push lines, "      at_line_start = 0;"
  push lines, "    }"
  push lines, "    if (ch == ' ' || ch == 9) {"
  push lines, "      i++; col++; continue;"
  push lines, "    }"
  push lines, "    if (source[i] == '-' && source[i + 1] == '>') {"
  push lines, "      add_token(&tokens, &len, line, \"ARROW\", \"->\", col);"
  push lines, "      i += 2; col += 2; continue;"
  push lines, "    }"
  push lines, "    if ((source[i] == '=' || source[i] == '!' || source[i] == '<' || source[i] == '>') && source[i + 1] == '=') {"
  push lines, "      char two[3];"
  push lines, "      two[0] = source[i];"
  push lines, "      two[1] = source[i + 1];"
  push lines, "      two[2] = 0;"
  push lines, "      add_token(&tokens, &len, line, \"SYMBOL\", two, col);"
  push lines, "      i += 2; col += 2; continue;"
  push lines, "    }"
  push lines, "    if (ch >= '0' && ch <= '9') {"
  push lines, "      int start_col = col;"
  push lines, "      char text[4096];"
  push lines, "      int n = 0;"
  push lines, "      while (source[i] >= '0' && source[i] <= '9') {"
  push lines, "        text[n++] = source[i++]; col++;"
  push lines, "      }"
  push lines, "      const char *kind = \"INT\";"
  push lines, "      if (source[i] == '.') {"
  push lines, "        kind = \"FLOAT\";"
  push lines, "        text[n++] = source[i++]; col++;"
  push lines, "        while (source[i] >= '0' && source[i] <= '9') {"
  push lines, "          text[n++] = source[i++]; col++;"
  push lines, "        }"
  push lines, "      }"
  push lines, "      text[n] = 0;"
  push lines, "      add_token(&tokens, &len, line, kind, text, start_col);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch == '_') {"
  push lines, "      int start_col = col;"
  push lines, "      char text[4096];"
  push lines, "      int n = 0;"
  push lines, "      while ((source[i] >= 'A' && source[i] <= 'Z') || (source[i] >= 'a' && source[i] <= 'z') || (source[i] >= '0' && source[i] <= '9') || source[i] == '_') {"
  push lines, "        text[n++] = source[i++]; col++;"
  push lines, "      }"
  push lines, "      text[n] = 0;"
  push lines, "      add_token(&tokens, &len, line, \"IDENT\", text, start_col);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (ch == 34) {"
  push lines, "      int start_col = col;"
  push lines, "      char text[4096];"
  push lines, "      int n = 0;"
  push lines, "      i++; col++;"
  push lines, "      while (source[i] != 0 && source[i] != 34) {"
  push lines, "        if (source[i] == 92 && source[i + 1] != 0) {"
  push lines, "          i++; col++;"
  push lines, "          if (source[i] == 'n' || source[i] == 't') text[n++] = 92, text[n++] = source[i];"
  push lines, "          else text[n++] = source[i];"
  push lines, "          i++; col++;"
  push lines, "        } else {"
  push lines, "          text[n++] = source[i++]; col++;"
  push lines, "        }"
  push lines, "      }"
  push lines, "      if (source[i] == 34) {"
  push lines, "        i++; col++;"
  push lines, "      }"
  push lines, "      text[n] = 0;"
  push lines, "      add_token(&tokens, &len, line, \"STRING\", text, start_col);"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    char sym[2];"
  push lines, "    sym[0] = ch;"
  push lines, "    sym[1] = 0;"
  push lines, "    add_token(&tokens, &len, line, \"SYMBOL\", sym, col);"
  push lines, "    i++; col++;"
  push lines, "  }"
  push lines, "  *out_len = len;"
  push lines, "  return tokens;"
  push lines, "}"
  push lines, ""
  push lines, "static char **split_lines(const char *source, long *out_len) {"
  push lines, "  char **lines = NULL;"
  push lines, "  long len = 0;"
  push lines, "  int start = 0;"
  push lines, "  int i = 0;"
  push lines, "  while (1) {"
  push lines, "    if (source[i] == 10 || source[i] == 0) {"
  push lines, "      int n = i - start;"
  push lines, "      char *line = malloc((size_t)n + 1);"
  push lines, "      memcpy(line, source + start, (size_t)n);"
  push lines, "      line[n] = 0;"
  push lines, "      lines = realloc(lines, sizeof(char *) * (size_t)(len + 1));"
  push lines, "      lines[len++] = line;"
  push lines, "      if (source[i] == 0) break;"
  push lines, "      start = i + 1;"
  push lines, "    }"
  push lines, "    i++;"
  push lines, "  }"
  push lines, "  *out_len = len;"
  push lines, "  return lines;"
  push lines, "}"
  push lines, ""
  push lines, "static void token_part(const char *token, int want, char *out, size_t out_size) {"
  push lines, "  int part = 0;"
  push lines, "  size_t n = 0;"
  push lines, "  for (int i = 0; token[i] != 0; i++) {"
  push lines, "    if (token[i] == ':') {"
  push lines, "      if (part == want) break;"
  push lines, "      part++;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (part == want && n + 1 < out_size) out[n++] = token[i];"
  push lines, "  }"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void token_text_value(const char *token, char *out, size_t out_size) {"
  push lines, "  const char *start = strchr(token, ':');"
  push lines, "  if (!start) {"
  push lines, "    out[0] = 0;"
  push lines, "    return;"
  push lines, "  }"
  push lines, "  start = strchr(start + 1, ':');"
  push lines, "  if (!start) {"
  push lines, "    out[0] = 0;"
  push lines, "    return;"
  push lines, "  }"
  push lines, "  start++;"
  push lines, "  const char *end = strrchr(start, ':');"
  push lines, "  if (!end || end < start) end = token + strlen(token);"
  push lines, "  size_t n = (size_t)(end - start);"
  push lines, "  if (n >= out_size) n = out_size - 1;"
  push lines, "  memcpy(out, start, n);"
  push lines, "  out[n] = 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int token_kind_is(const char *token, const char *kind) {"
  push lines, "  char actual[64];"
  push lines, "  token_part(token, 1, actual, sizeof(actual));"
  push lines, "  return strcmp(actual, kind) == 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int token_text_is(const char *token, const char *text) {"
  push lines, "  char actual[4096];"
  push lines, "  token_part(token, 2, actual, sizeof(actual));"
  push lines, "  return strcmp(actual, text) == 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int token_is(const char *token, const char *kind, const char *text) {"
  push lines, "  return token_kind_is(token, kind) && token_text_is(token, text);"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_atom_from_token(const char *token, char *out, size_t out_size) {"
  push lines, "  char kind[64];"
  push lines, "  char value[4096];"
  push lines, "  token_part(token, 1, kind, sizeof(kind));"
  push lines, "  token_part(token, 2, value, sizeof(value));"
  push lines, "  if (strcmp(kind, \"IDENT\") == 0) {"
  push lines, "    if (strcmp(value, \"true\") == 0 || strcmp(value, \"false\") == 0) {"
  push lines, "      snprintf(out, out_size, \"bool(%s)\", value);"
  push lines, "      return 1;"
  push lines, "    }"
  push lines, "    if (strcmp(value, \"nil\") == 0) {"
  push lines, "      snprintf(out, out_size, \"nil(nil)\");"
  push lines, "      return 1;"
  push lines, "    }"
  push lines, "    snprintf(out, out_size, \"ident(%s)\", value);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (strcmp(kind, \"INT\") == 0) {"
  push lines, "    snprintf(out, out_size, \"int(%s)\", value);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (strcmp(kind, \"STRING\") == 0) {"
  push lines, "    token_text_value(token, value, sizeof(value));"
  push lines, "    snprintf(out, out_size, \"string(%s)\", value);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  return 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_index_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 3 >= tokens_len) return 0;"
  push lines, "  if (!token_kind_is(tokens[start], \"IDENT\") || !token_is(tokens[start + 1], \"SYMBOL\", \"[\") || (!token_kind_is(tokens[start + 2], \"IDENT\") && !token_kind_is(tokens[start + 2], \"INT\") && !token_kind_is(tokens[start + 2], \"STRING\")) || !token_is(tokens[start + 3], \"SYMBOL\", \"]\")) return 0;"
  push lines, "  char object[4096];"
  push lines, "  char index[4096];"
  push lines, "  token_part(tokens[start], 2, object, sizeof(object));"
  push lines, "  token_part(tokens[start + 2], 2, index, sizeof(index));"
  push lines, "  snprintf(out, out_size, \"index(%s %s)\", object, index);"
  push lines, "  return 1;"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_call_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 1 >= tokens_len) return 0;"
  push lines, "  if (!token_kind_is(tokens[start], \"IDENT\")) return 0;"
  push lines, "  char callee[4096];"
  push lines, "  char arg[4096];"
  push lines, "  char left_expr[8192];"
  push lines, "  char right_expr[8192];"
  push lines, "  char third_expr[8192];"
  push lines, "  token_part(tokens[start], 2, callee, sizeof(callee));"
  push lines, "  if (start + 2 < tokens_len && token_is(tokens[start], \"IDENT\", \"len\") && (token_is(tokens[start + 1], \"IDENT\", \"keys\") || token_is(tokens[start + 1], \"IDENT\", \"values\")) && token_kind_is(tokens[start + 2], \"IDENT\")) {"
  push lines, "    char nested_callee[4096];"
  push lines, "    char nested_arg[4096];"
  push lines, "    token_part(tokens[start + 1], 2, nested_callee, sizeof(nested_callee));"
  push lines, "    token_part(tokens[start + 2], 2, nested_arg, sizeof(nested_arg));"
  push lines, "    snprintf(out, out_size, \"call(len call(%s ident(%s)))\", nested_callee, nested_arg);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 2 < tokens_len && token_is(tokens[start + 1], \"SYMBOL\", \"(\") && token_is(tokens[start + 2], \"SYMBOL\", \")\")) {"
  push lines, "    snprintf(out, out_size, \"call(%s)\", callee);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 5 < tokens_len && token_kind_is(tokens[start + 1], \"IDENT\") && token_is(tokens[start + 2], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 3], \"STRING\") && token_is(tokens[start + 4], \"SYMBOL\", \",\") && (token_kind_is(tokens[start + 5], \"IDENT\") || token_kind_is(tokens[start + 5], \"STRING\"))) {"
  push lines, "    if (!ast_atom_from_token(tokens[start + 1], left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 3], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 5], third_expr, sizeof(third_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"call(%s %s %s %s)\", callee, left_expr, right_expr, third_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 5 < tokens_len && token_kind_is(tokens[start + 1], \"IDENT\") && token_is(tokens[start + 2], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 3], \"INT\") && token_is(tokens[start + 4], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 5], \"IDENT\")) {"
  push lines, "    if (!ast_atom_from_token(tokens[start + 1], left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 3], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 5], third_expr, sizeof(third_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"call(%s %s %s %s)\", callee, left_expr, right_expr, third_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 5 < tokens_len && token_is(tokens[start + 1], \"SYMBOL\", \"(\") && token_kind_is(tokens[start + 2], \"STRING\") && token_is(tokens[start + 3], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 4], \"STRING\") && token_is(tokens[start + 5], \"SYMBOL\", \")\")) {"
  push lines, "    if (!ast_atom_from_token(tokens[start + 2], left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 4], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"call(%s %s %s)\", callee, left_expr, right_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 3 < tokens_len && token_kind_is(tokens[start + 1], \"IDENT\") && token_is(tokens[start + 2], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 3], \"STRING\")) {"
  push lines, "    if (!ast_atom_from_token(tokens[start + 1], left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 3], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"call(%s %s %s)\", callee, left_expr, right_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 3 < tokens_len && token_kind_is(tokens[start + 1], \"STRING\") && token_is(tokens[start + 2], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 3], \"IDENT\")) {"
  push lines, "    if (!ast_atom_from_token(tokens[start + 1], left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 3], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"call(%s %s %s)\", callee, left_expr, right_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 3 < tokens_len && token_kind_is(tokens[start + 1], \"INT\") && token_is(tokens[start + 2], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 3], \"INT\")) {"
  push lines, "    if (!ast_atom_from_token(tokens[start + 1], left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 3], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"call(%s %s %s)\", callee, left_expr, right_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 3 < tokens_len && token_kind_is(tokens[start + 1], \"IDENT\") && token_is(tokens[start + 2], \"SYMBOL\", \",\") && token_kind_is(tokens[start + 3], \"IDENT\")) {"
  push lines, "    if (!ast_atom_from_token(tokens[start + 1], left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_atom_from_token(tokens[start + 3], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"call(%s %s %s)\", callee, left_expr, right_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 3 < tokens_len && token_is(tokens[start + 1], \"SYMBOL\", \"(\") && token_kind_is(tokens[start + 2], \"IDENT\") && token_is(tokens[start + 3], \"SYMBOL\", \")\")) {"
  push lines, "    token_part(tokens[start + 2], 2, arg, sizeof(arg));"
  push lines, "    snprintf(out, out_size, \"call(%s ident(%s))\", callee, arg);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (token_kind_is(tokens[start + 1], \"STRING\")) {"
  push lines, "    token_part(tokens[start + 1], 2, arg, sizeof(arg));"
  push lines, "    snprintf(out, out_size, \"call(%s string(%s))\", callee, arg);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (token_kind_is(tokens[start + 1], \"INT\")) {"
  push lines, "    token_part(tokens[start + 1], 2, arg, sizeof(arg));"
  push lines, "    snprintf(out, out_size, \"call(%s int(%s))\", callee, arg);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (token_kind_is(tokens[start + 1], \"IDENT\")) {"
  push lines, "    token_part(tokens[start + 1], 2, arg, sizeof(arg));"
  push lines, "    snprintf(out, out_size, \"call(%s ident(%s))\", callee, arg);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  return 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_expr_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 1 < tokens_len && token_is(tokens[start], \"IDENT\", \"not\")) {"
  push lines, "    char right_expr[8192];"
  push lines, "    if (!ast_atom_from_token(tokens[start + 1], right_expr, sizeof(right_expr))) return 0;"
  push lines, "    snprintf(out, out_size, \"unary(NOT %s)\", right_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 2 < tokens_len && (token_is(tokens[start + 1], \"IDENT\", \"or\") || token_is(tokens[start + 1], \"IDENT\", \"and\"))) {"
  push lines, "    char line[32];"
  push lines, "    char op_line[32];"
  push lines, "    char right_line[32];"
  push lines, "    char left_expr[8192];"
  push lines, "    char right_expr[8192];"
  push lines, "    char op[32];"
  push lines, "    token_part(tokens[start], 0, line, sizeof(line));"
  push lines, "    token_part(tokens[start + 1], 0, op_line, sizeof(op_line));"
  push lines, "    token_part(tokens[start + 2], 0, right_line, sizeof(right_line));"
  push lines, "    if (strcmp(line, op_line) == 0 && strcmp(line, right_line) == 0 && ast_atom_from_token(tokens[start], left_expr, sizeof(left_expr)) && ast_atom_from_token(tokens[start + 2], right_expr, sizeof(right_expr))) {"
  push lines, "      token_part(tokens[start + 1], 2, op, sizeof(op));"
  push lines, "      if (strcmp(op, \"or\") == 0) strcpy(op, \"OR\");"
  push lines, "      snprintf(out, out_size, \"binary(%s %s %s)\", op, left_expr, right_expr);"
  push lines, "      return 1;"
  push lines, "    }"
  push lines, "  }"
  push lines, "  if (ast_index_from_tokens(tokens, tokens_len, start, out, out_size)) return 1;"
  push lines, "  if (ast_call_from_tokens(tokens, tokens_len, start, out, out_size)) return 1;"
  push lines, "  if (start + 1 < tokens_len && token_is(tokens[start], \"SYMBOL\", \"-\") && token_kind_is(tokens[start + 1], \"INT\")) {"
  push lines, "    char value[4096];"
  push lines, "    token_part(tokens[start + 1], 2, value, sizeof(value));"
  push lines, "    snprintf(out, out_size, \"int(-%s)\", value);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start < tokens_len && ast_atom_from_token(tokens[start], out, out_size)) return 1;"
  push lines, "  return 0;"
  push lines, "}"
  push lines, ""
  push lines, "static void ast_binary_condition(char *out, size_t out_size, const char *op, const char *left_expr, const char *right_expr) {"
  push lines, "  snprintf(out, out_size, \"binary(%s %s %s)\", op, left_expr, right_expr);"
  push lines, "}"
  push lines, ""
  push lines, "static void ast_binary_chain3(char *out, size_t out_size, const char *first_expr, const char *op1, const char *second_expr, const char *op2, const char *third_expr) {"
  push lines, "  char combined[8192];"
  push lines, "  ast_binary_condition(combined, sizeof(combined), op1, first_expr, second_expr);"
  push lines, "  ast_binary_condition(out, out_size, op2, combined, third_expr);"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_arithmetic_expr_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  char left_expr[8192];"
