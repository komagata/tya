  push lines, "    char stmt_last_if_indent[32];"
  push lines, "    strcpy(stmt_indent, \"0\");"
  push lines, "    stmt_if_condition[0] = 0;"
  push lines, "    stmt_if_body_indent[0] = 0;"
  push lines, "    stmt_last_if_condition[0] = 0;"
  push lines, "    stmt_last_if_indent[0] = 0;"
  push lines, "    for (long node_i = 0; node_i < nodes_len; node_i++) {"
  push lines, "      char k[64];"
  push lines, "      char x[512];"
  push lines, "      char y[512];"
  push lines, "      node_field(nodes[node_i], 1, k, sizeof(k));"
  push lines, "      node_field(nodes[node_i], 2, x, sizeof(x));"
  push lines, "      node_field(nodes[node_i], 3, y, sizeof(y));"
  push lines, "      if (strcmp(k, \"INDENT\") == 0) {"
  push lines, "        strcpy(stmt_indent, x);"
  push lines, "        if (has_loop && seen_loop_node && atoi(stmt_indent) < atoi(loop_indent)) loop_body_active = 0;"
  push lines, "        if (stmt_if_body_indent[0] != 0 && atoi(stmt_indent) < atoi(stmt_if_body_indent)) {"
  push lines, "          stmt_if_condition[0] = 0;"
  push lines, "          stmt_if_body_indent[0] = 0;"
  push lines, "        }"
