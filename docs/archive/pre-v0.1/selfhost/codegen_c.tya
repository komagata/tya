  push lines, "      needs_lex = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"parse\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_parse = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"check\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_check = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1_CALL0_INDEX\") == 0 && strcmp(c, \"read_file\") == 0 && strcmp(d, \"args\") == 0) {"
  push lines, "      needs_read_file = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strncmp(b, \"call_index(read_file args 0\", 27) == 0) {"
  push lines, "      needs_read_file = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strncmp(b, \"call(split \", 11) == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_split = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strncmp(b, \"call(lex \", 9) == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_lex = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strncmp(b, \"call(parse \", 11) == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_parse = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strncmp(b, \"call(check \", 11) == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_check = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"read_file\") == 0) needs_read_file = 1;"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"file_exists\") == 0) needs_read_file = 1;"
  push lines, "    if (strcmp(kind, \"CALL_STMT2\") == 0 && strcmp(a, \"write_file\") == 0) needs_read_file = 1;"
  push lines, "    if (strcmp(kind, \"FUNC\") == 0 && strcmp(a, \"parse_user\") == 0) {"
  push lines, "      needs_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(a, \"parse_user\") == 0 && strcmp(b, \"BOOL\") == 0) {"
  push lines, "      needs_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
