  push lines, "      needs_ends = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL3\") == 0 && strcmp(a, \"replace\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_replace = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL2\") == 0 && strcmp(c, \"split\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_split = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"join\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_join = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"trim\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_trim = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PUSH\") == 0 && strncmp(b, \"call(trim \", 10) == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_trim = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PUSH\") == 0 && strncmp(b, \"call(to_string \", 15) == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_to_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strstr(b, \"call(trim \") != NULL) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_trim = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PRINT\") == 0 && strstr(a, \"call(trim \") != NULL) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_trim = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strstr(b, \"call(to_string \") != NULL) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_to_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PRINT\") == 0 && strstr(a, \"call(to_string \") != NULL) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_to_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strstr(b, \"call(replace \") != NULL) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_replace = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PRINT\") == 0 && strstr(a, \"call(replace \") != NULL) {"
