  push lines, "  if (strncmp(expr, \"binary(+ ident(\", 15) == 0 && strstr(expr, \") call(trim ident(\") != NULL) return 1;"
  push lines, "  if (strncmp(expr, \"binary(+ ident(\", 15) == 0 && strstr(expr, \") call(to_string ident(\") != NULL) return 1;"
  push lines, "  if (strncmp(expr, \"binary(+ ident(\", 15) == 0 && strstr(expr, \") index(\") != NULL) return 1;"
  push lines, "  if (strncmp(expr, \"binary(+ string(\", 16) == 0 && strstr(expr, \") ident(\") != NULL) return 1;"
  push lines, "  if (strncmp(expr, \"binary(+ string(\", 16) == 0 && strstr(expr, \") index(\") != NULL) return 1;"
  push lines, "  return 0;"
