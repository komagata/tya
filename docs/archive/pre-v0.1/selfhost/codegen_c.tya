  push lines, "      needs_trim = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strcmp(b, \"CALL1\") == 0 && strcmp(c, \"lex\") == 0) {"
