  push lines, "}"
  push lines, ""
  push lines, "static int ast_simple_if_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 6 < tokens_len && token_is(tokens[start], \"IDENT\", \"if\") && token_kind_is(tokens[start + 1], \"IDENT\") && token_is(tokens[start + 2], \"SYMBOL\", \"[\") && token_kind_is(tokens[start + 3], \"IDENT\") && token_is(tokens[start + 4], \"SYMBOL\", \"]\") && (token_is(tokens[start + 5], \"SYMBOL\", \"==\") || token_is(tokens[start + 5], \"SYMBOL\", \"!=\")) && token_kind_is(tokens[start + 6], \"STRING\")) {"
  push lines, "    const char *op = token_is(tokens[start + 5], \"SYMBOL\", \"!=\") ? \"!=\" : \"==\";"
  push lines, "    char left_expr[8192];"
  push lines, "    char right_expr[8192];"
  push lines, "    if (!ast_expr_from_tokens(tokens, tokens_len, start + 1, left_expr, sizeof(left_expr))) return 0;"
  push lines, "    if (!ast_expr_from_tokens(tokens, tokens_len, start + 6, right_expr, sizeof(right_expr))) return 0;"
  push lines, "    ast_binary_condition(out, out_size, op, left_expr, right_expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  if (start + 3 >= tokens_len) return 0;"
  push lines, "  if (!token_is(tokens[start], \"IDENT\", \"if\")) return 0;"
  push lines, "  if (!token_kind_is(tokens[start + 1], \"IDENT\")) return 0;"
  push lines, "  const char *op = NULL;"
  push lines, "  if (token_is(tokens[start + 2], \"SYMBOL\", \"==\") && (token_kind_is(tokens[start + 3], \"STRING\") || token_kind_is(tokens[start + 3], \"INT\"))) op = \"==\";"
  push lines, "  else if (token_is(tokens[start + 2], \"SYMBOL\", \"!=\") && (token_kind_is(tokens[start + 3], \"STRING\") || token_kind_is(tokens[start + 3], \"INT\"))) op = \"!=\";"
  push lines, "  else if (token_is(tokens[start + 2], \"SYMBOL\", \">=\") && token_kind_is(tokens[start + 3], \"INT\")) op = \">=\";"
  push lines, "  else if (token_is(tokens[start + 2], \"SYMBOL\", \">\") && token_kind_is(tokens[start + 3], \"INT\")) op = \">\";"
  push lines, "  else if (token_is(tokens[start + 2], \"SYMBOL\", \"<=\") && token_kind_is(tokens[start + 3], \"INT\")) op = \"<=\";"
  push lines, "  else return 0;"
  push lines, "  char left_expr[8192];"
  push lines, "  char right_expr[8192];"
  push lines, "  if (!ast_expr_from_tokens(tokens, tokens_len, start + 1, left_expr, sizeof(left_expr))) return 0;"
  push lines, "  if (!ast_expr_from_tokens(tokens, tokens_len, start + 3, right_expr, sizeof(right_expr))) return 0;"
  push lines, "  ast_binary_condition(out, out_size, op, left_expr, right_expr);"
  push lines, "  return 1;"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_simple_while_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 3 >= tokens_len) return 0;"
  push lines, "  if (!token_is(tokens[start], \"IDENT\", \"while\")) return 0;"
  push lines, "  if (!token_kind_is(tokens[start + 1], \"IDENT\")) return 0;"
  push lines, "  if (!token_kind_is(tokens[start + 3], \"INT\")) return 0;"
  push lines, "  const char *op = NULL;"
  push lines, "  if (token_is(tokens[start + 2], \"SYMBOL\", \"<\")) op = \"<\";"
  push lines, "  else if (token_is(tokens[start + 2], \"SYMBOL\", \">=\")) op = \">=\";"
  push lines, "  else if (token_is(tokens[start + 2], \"SYMBOL\", \">\")) op = \">\";"
  push lines, "  else if (token_is(tokens[start + 2], \"SYMBOL\", \"<=\")) op = \"<=\";"
  push lines, "  else return 0;"
  push lines, "  char left_expr[8192];"
  push lines, "  char right_expr[8192];"
  push lines, "  if (!ast_expr_from_tokens(tokens, tokens_len, start + 1, left_expr, sizeof(left_expr))) return 0;"
  push lines, "  if (!ast_expr_from_tokens(tokens, tokens_len, start + 3, right_expr, sizeof(right_expr))) return 0;"
  push lines, "  ast_binary_condition(out, out_size, op, left_expr, right_expr);"
  push lines, "  return 1;"
  push lines, "}"
  push lines, ""
  push lines, "static char **parse_tokens(char **tokens, long tokens_len, long *out_len) {"
  push lines, "  char **nodes = NULL;"
  push lines, "  long len = 0;"
  push lines, "  int need_block_indent = 0;"
  push lines, "  int in_block = 0;"
  push lines, "  int current_indent = 0;"
  push lines, "  int skip_function_body = 0;"
  push lines, "  int ast_mode = 0;"
  push lines, "  for (long i = 0; i + 1 < tokens_len; i++) {"
  push lines, "    if (token_is(tokens[i], \"IDENT\", \"ASTMODE\")) {"
  push lines, "      ast_mode = 1;"
  push lines, "      continue;"
  push lines, "    }"
  push lines, "    if (strstr(tokens[i], \":INDENT:\")) {"
  push lines, "      char line[32];"
  push lines, "      int p = 0;"
  push lines, "      while (tokens[i][p] != 0 && tokens[i][p] != ':') {"
  push lines, "        line[p] = tokens[i][p]; p++;"
  push lines, "      }"
  push lines, "      line[p] = 0;"
  push lines, "      char *start = strstr(tokens[i], \":INDENT:\") + 8;"
  push lines, "      char *end = strrchr(start, ':');"
  push lines, "      int n = end ? (int)(end - start) : (int)strlen(start);"
  push lines, "      char spaces[256];"
  push lines, "      memcpy(spaces, start, (size_t)n);"
  push lines, "      spaces[n] = 0;"
  push lines, "      current_indent = atoi(spaces);"
  push lines, "      if (current_indent == 0) skip_function_body = 0;"
  push lines, "      if (ast_mode || need_block_indent || (in_block && strcmp(spaces, \"0\") == 0)) {"
  push lines, "        char node[8192];"
  push lines, "        snprintf(node, sizeof(node), \"%s:INDENT:%s\", line, spaces);"
