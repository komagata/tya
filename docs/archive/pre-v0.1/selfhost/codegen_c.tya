  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PRINT\") == 0 && strstr(a, \"call(env \") != NULL) {"
  push lines, "      needs_env = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PRINT\") == 0 && (strstr(a, \"call(file_exists \") != NULL || strstr(a, \"call(read_file \") != NULL)) {"
  push lines, "      needs_read_file = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && ast_generated_needs_concat(b)) {"
