  push lines, "      pending_bool_func[0] = 0;"
  push lines, "      pending_bool_arg[0] = 0;"
  push lines, "    }"
  push lines, "    if (pending_bool_func[0] != 0 && strcmp(kind, \"AST_EXPR\") == 0) pending_bool_body_seen = 1;"
  push lines, "    if (pending_array_func[0] != 0 && strcmp(kind, \"AST_ASSIGN\") == 0 && strcmp(b, \"array0()\") == 0) {"
  push lines, "      strcpy(pending_array_name, a);"
  push lines, "    }"
  push lines, "    if (pending_array_func[0] != 0 && strcmp(kind, \"AST_RETURN\") == 0 && pending_array_name[0] != 0) {"
  push lines, "      char ret_name[256];"
  push lines, "      ret_name[0] = 0;"
  push lines, "      if (sscanf(a, \"ident(%255[^)])\", ret_name) == 1 && strcmp(ret_name, pending_array_name) == 0) {"
  push lines, "        strcpy(generated_array_func_names[generated_array_func_len], pending_array_func);"
  push lines, "        strcpy(generated_array_func_args[generated_array_func_len], pending_array_arg);"
  push lines, "        strcpy(generated_array_func_arrays[generated_array_func_len], pending_array_name);"
  push lines, "        generated_array_func_called[generated_array_func_len] = 0;"
  push lines, "        generated_array_func_len++;"
  push lines, "      }"
  push lines, "      pending_array_func[0] = 0;"
  push lines, "      pending_array_arg[0] = 0;"
  push lines, "      pending_array_name[0] = 0;"
  push lines, "      pending_bool_func[0] = 0;"
  push lines, "      pending_bool_arg[0] = 0;"
  push lines, "      pending_bool_body_seen = 0;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"INDENT\") == 0 && strcmp(a, \"0\") == 0) {"
  push lines, "      pending_array_func[0] = 0;"
  push lines, "      pending_array_arg[0] = 0;"
  push lines, "      pending_array_name[0] = 0;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0) {"
  push lines, "      for (int func_i = 0; func_i < generated_func_len; func_i++) {"
  push lines, "        if (strcmp(generated_func_names[func_i], a) == 0) generated_func_called[func_i] = 1;"
  push lines, "      }"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_PRINT\") == 0 && strncmp(a, \"call(\", 5) == 0) {"
  push lines, "      char call_name[256];"
  push lines, "      char call_arg[256];"
  push lines, "      call_name[0] = 0;"
  push lines, "      call_arg[0] = 0;"
  push lines, "      if (sscanf(a, \"call(%255s ident(%255[^)]))\", call_name, call_arg) == 2 || sscanf(a, \"call(%255s string(%255[^)]))\", call_name, call_arg) == 2) {"
  push lines, "        for (int func_i = 0; func_i < generated_bool_func_len; func_i++) {"
  push lines, "          if (strcmp(generated_bool_func_names[func_i], call_name) == 0) generated_bool_func_called[func_i] = 1;"
  push lines, "        }"
  push lines, "        for (int func_i = 0; func_i < generated_func_len; func_i++) {"
  push lines, "          if (strcmp(generated_func_names[func_i], call_name) == 0) generated_func_called[func_i] = 1;"
  push lines, "        }"
  push lines, "      }"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_ASSIGN\") == 0 && strncmp(b, \"call(\", 5) == 0) {"
  push lines, "      char call_name[256];"
  push lines, "      char call_arg[256];"
  push lines, "      call_name[0] = 0;"
  push lines, "      call_arg[0] = 0;"
  push lines, "      if (sscanf(b, \"call(%255s ident(%255[^)]))\", call_name, call_arg) == 2) {"
  push lines, "        for (int func_i = 0; func_i < generated_bool_func_len; func_i++) {"
  push lines, "          if (strcmp(generated_bool_func_names[func_i], call_name) == 0) generated_bool_func_called[func_i] = 1;"
  push lines, "        }"
  push lines, "        for (int func_i = 0; func_i < generated_array_func_len; func_i++) {"
  push lines, "          if (strcmp(generated_array_func_names[func_i], call_name) == 0) generated_array_func_called[func_i] = 1;"
  push lines, "        }"
  push lines, "      }"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"len\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"byte_len\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"IF_COMPARE_EQ\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"AST_IF\") == 0) needs_string = 1;"
  push lines, "    if (strcmp(kind, \"AST_EXPR\") == 0 && strncmp(a, \"call(contains \", 14) == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_contains = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL1\") == 0 && strcmp(a, \"char_len\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_char_len = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"contains\") == 0) {"
