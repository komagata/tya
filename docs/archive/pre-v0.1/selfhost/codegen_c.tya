  push lines, "      strcpy(pending_bool_arg, b);"
  push lines, "      pending_bool_body_seen = 0;"
  push lines, "    }"
  push lines, "    if (pending_bool_func[0] != 0 && strcmp(kind, \"INDENT\") != 0 && strcmp(kind, \"AST_FUNC\") != 0 && strcmp(kind, \"AST_EXPR\") != 0) pending_bool_body_seen = 1;"
  push lines, "    if (pending_bool_func[0] != 0 && !pending_bool_body_seen && strcmp(kind, \"AST_EXPR\") == 0 && (strncmp(a, \"binary(\", 7) == 0 || strncmp(a, \"call(contains \", 14) == 0)) {"
  push lines, "      char arg_marker[300];"
