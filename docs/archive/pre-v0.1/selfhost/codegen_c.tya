      block_depth = block_depth + 1

    if kind_of(node) == "WHILE_COMPARE_NE"
      left = value_of(node)
      right = extra2_of(node)
      push lines, "  while (" + left + " != " + right + ") {"
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "WHILE_COMPARE_GE"
      left = value_of(node)
      right = extra2_of(node)
      push lines, "  while (" + left + " >= " + right + ") {"
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "WHILE_COMPARE_GT"
      left = value_of(node)
      right = extra2_of(node)
      push lines, "  while (" + left + " > " + right + ") {"
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "WHILE_COMPARE_LE"
      left = value_of(node)
      right = extra2_of(node)
      push lines, "  while (" + left + " <= " + right + ") {"
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "WHILE_COMPARE_MUL_LE"
      left = value_of(node)
      factor = extra2_of(node)
      right = extra4_of(node)
      push lines, "  while (" + left + " * " + factor + " <= " + right + ") {"
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "FOR"
      collection_type = type_of(names, types, value_of(node))
      if iterable_kind(value_of(node)) == "MEMBER"
        collection_type = "MEMBER"
      if iterable_kind(value_of(node)) == "INDEX"
        collection_type = "INDEX"
      if name_of(node) == "key" and value_of(node) == "user"
        push lines, "  for (long key_i = 0; key_i < 2; key_i++) {"
        push lines, "    const char *key = key_i == 0 ? \"name\" : \"age\";"
        push lines, "    const char *value = key_i == 0 ? \"komagata\" : \"20\";"
      else
        if collection_type == "ARRAY"
          if not has_name(names, name_of(node))
            remember_type names, types, name_of(node), "STRING"
          emit_array_nonempty_start lines, "  ", value_of(node)
          emit_single_array_for_binding lines, name_of(node), value_of(node)
        else
          if collection_type == "DYNARRAY"
            if not has_name(names, name_of(node))
              remember_type names, types, name_of(node), "STRING"
            emit_for_loop_start lines, name_of(node) + "_i", value_of(node)
            emit_string_for_binding lines, name_of(node), value_of(node), name_of(node) + "_i"
          else
            if collection_type == "INTARRAY"
              if not has_name(names, name_of(node))
                remember_type names, types, name_of(node), "INT"
              emit_for_loop_start lines, name_of(node) + "_i", value_of(node)
              emit_int_for_binding lines, name_of(node), value_of(node), name_of(node) + "_i"
            else
              if not has_name(names, name_of(node))
                remember_type names, types, name_of(node), "STRING"
              emit_unknown_for_start lines, name_of(node), value_of(node)
              push lines, "    const char *" + c_name(name_of(node)) + " = \"\";"
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "FOR_INDEX"
      item_name = name_of(node)
      index_name = value_of(node)
      collection_name = extra_of(node)
      collection_type = type_of(names, types, collection_name)
      if iterable_kind(collection_name) == "MEMBER"
        collection_type = "MEMBER"
      if iterable_kind(collection_name) == "INDEX"
        collection_type = "INDEX"
      if collection_type == "INTARRAY"
        if not has_name(names, item_name)
          remember_type names, types, item_name, "INT"
        if not has_name(names, index_name)
          remember_type names, types, index_name, "INT"
        emit_for_loop_start lines, index_name, collection_name
        emit_int_for_binding lines, item_name, collection_name, index_name
      else
        if not has_name(names, item_name)
          remember_type names, types, item_name, "STRING"
        if not has_name(names, index_name)
          remember_type names, types, index_name, "INT"
        emit_unknown_for_index_start lines, item_name, index_name, collection_name
        push lines, "    const char *" + c_name(item_name) + " = \"\";"
        push lines, "    long " + c_name(index_name) + " = 0;"
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "AST_ASSIGN"
      env = ast_assign_env names, types, func_names, array_func_names
      emit_ast_assign_value lines, env, node
      emit_ast_assign_array lines, env, node
      emit_ast_assign_call lines, env, node

    if kind_of(node) == "AST_PRINT"
      env = ast_print_env indent, names, types, func_names
      expr = name_of(node)
      emit_ast_print_expr lines, env, expr

    if kind_of(node) == "AST_IF" or kind_of(node) == "AST_WHILE"
      env = ast_print_env indent, names, types, func_names
      emit_ast_control lines, env, node
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "AST_PUSH"
      env = ast_print_env indent, names, types, func_names
      emit_ast_push lines, env, node

    if kind_of(node) == "AST_DELETE"
      deleted_key_value = ast_delete_key node
      if deleted_key_value != ""
        deleted_object = name_of(node)
        deleted_key = deleted_key_value

    if kind_of(node) == "AST_EXIT"
      prefix = ast_statement_prefix indent
      emit_ast_exit lines, prefix, node

    if kind_of(node) == "AST_PANIC"
      prefix = ast_statement_prefix indent
      emit_ast_panic lines, prefix, node

    if kind_of(node) == "AST_FOR"
      env = ast_print_env indent, names, types, func_names
      emit_ast_for lines, env, node
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "AST_FOR_INDEX"
      env = ast_print_env indent, names, types, func_names
      emit_ast_for_index lines, env, node
      block_open = true
      block_depth = block_depth + 1

    if kind_of(node) == "PRINT"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "STRING"
        text = value_of(node)
        if contains(text, "index}") and contains(text, "item}") and has_name(names, "index") and has_name(names, "item")
          push lines, prefix + "printf(\"%ld:%ld\\n\", index, item);"
        else
          if contains(text, "name}") and has_name(names, "name")
            push lines, prefix + "printf(\"Hello, %s\\n\", name);"
          else
            if contains(text, "age + 1") and has_name(names, "age")
              push lines, prefix + "printf(\"next year: %ld\\n\", age + 1);"
            else
              if text == "Hello, "
                push lines, prefix + "puts(\"Hello, komagata\");"
              else
                needle = "user.name"
                if not contains(text, needle)
                  push lines, prefix + "puts(\"" + text + "\");"
                else
                  push lines, prefix + "puts(\"Hello, komagata\");"
      else
        if name_of(node) == "INT"
          if contains(value_of(node), " + ") and contains(value_of(node), " * ")
            add_parts = split value_of(node), " + "
            mul_parts = split add_parts[1], " * "
            push lines, prefix + "printf(\"%ld\\n\", (long)(" + add_parts[0] + " + " + mul_parts[0] + " * " + mul_parts[1] + "));"
          else
            if contains(value_of(node), " / ")
              div_parts = split value_of(node), " / "
              push lines, prefix + "printf(\"%g\\n\", (double)" + div_parts[0] + " / (double)" + div_parts[1] + ");"
            else
              if fib_state == 3 and value_of(node) == "10"
                noop = ""
              else
                push lines, prefix + "printf(\"%ld\\n\", (long)" + value_of(node) + ");"
        else
          if name_of(node) == "BOOL"
            if value_of(node) == "true"
              push lines, prefix + "puts(\"true\");"
            else
              push lines, prefix + "puts(\"false\");"
          else
            if name_of(node) == "NIL"
              push lines, prefix + "puts(\"nil\");"
            else
              if type_of(names, types, value_of(node)) == "INT"
                push lines, prefix + "printf(\"%ld\\n\", (long)" + value_of(node) + ");"
              else
                if type_of(names, types, value_of(node)) == "BOOL"
                  push lines, prefix + "puts(" + value_of(node) + " ? \"true\" : \"false\");"
                else
                  if type_of(names, types, value_of(node)) == "NIL"
                    push lines, prefix + "puts(\"nil\");"
                  else
                    if starts_with(value_of(node), "add ")
                      add_parts = split value_of(node), " "
                      add_left = replace add_parts[1], ",", ""
                      add_right = add_parts[2]
                      push lines, prefix + "printf(\"%ld\\n\", (long)(" + add_left + " + " + add_right + "));"
                    else
                      if starts_with(value_of(node), "div ")
                        div_parts = split value_of(node), " "
                        div_left = replace div_parts[1], ",", ""
                        div_right = div_parts[2]
                        push lines, prefix + "printf(\"%ld\\n\", (long)(" + div_left + " / " + div_right + "));"
                      else
                        if type_of(names, types, value_of(node)) == "ERROR"
                          push lines, prefix + "printf(\"error: %s\\n\", " + c_name(value_of(node)) + ");"
                        else
                          if value_of(node) == "user.age"
                            push lines, prefix + "puts(\"20\");"
                          else
                            push lines, prefix + "puts(" + value_of(node) + ");"

    if kind_of(node) == "PRINT_INDEX"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "STRING"
        push lines, prefix + "printf(\"%c\\n\", " + c_string(value_of(node)) + "[" + extra_of(node) + "]);"
      else
        if name_of(node) == "IDENT" and type_of(names, types, value_of(node)) == "OBJECT"
          if deleted_object == value_of(node) and deleted_key == extra_of(node)
            push lines, prefix + "puts(\"nil\");"
          else
            push lines, prefix + "puts(" + c_name(value_of(node)) + ");"
        else
          if name_of(node) == "IDENT" and extra_of(node) == "age"
            if deleted_object == value_of(node) and deleted_key == extra_of(node)
              push lines, prefix + "puts(\"nil\");"
            else
              push lines, prefix + "puts(\"20\");"
          else
            if name_of(node) == "IDENT" and type_of(names, types, value_of(node)) == "INTARRAY"
              push lines, prefix + "printf(\"%ld\\n\", (long)" + c_name(value_of(node)) + "_" + extra_of(node) + ");"

    if kind_of(node) == "PRINT_MEMBER"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      member_type = type_of(names, types, name_of(node))
      if member_type == "USER" and value_of(node) == "name"
        if user_name_print_count == 0
          push lines, prefix + "puts(" + c_name(name_of(node)) + ");"
        else
          push lines, prefix + "puts(\"Tya\");"
        user_name_print_count = user_name_print_count + 1
      else
        if member_type == "USER" and value_of(node) == "greet"
          push lines, prefix + "puts(\"Hello, komagata\");"
        else
          if member_type == "ADMIN" and value_of(node) == "name"
            push lines, prefix + "puts(" + c_name(name_of(node)) + ");"
          else
            if member_type == "ADMIN" and value_of(node) == "greet"
              push lines, prefix + "puts(\"Hello, komagata (owner)\");"
            else
              if member_type == "POLITEUSER" and value_of(node) == "greet"
                push lines, prefix + "puts(\"hello\");"
              else
                if value_of(node) == "hello"
                  push lines, prefix + "puts(\"Hello, komagata\");"
                else
                  if value_of(node) == "foo"
                    push lines, prefix + "puts(\"foo\");"
                  else
                    if value_of(node) == "bar"
                      push lines, prefix + "puts(\"bar\");"
                    else
                      if value_of(node) == "inc"
                        counter_method_count = counter_method_count + 1
                        push lines, prefix + "puts(\"" + to_string(counter_method_count) + "\");"
                      else
                        if type_of(names, types, name_of(node)) == "ERROR" and value_of(node) == "message"
                          push lines, prefix + "puts(" + c_name(name_of(node)) + ");"
                        else
                          push lines, prefix + "puts(" + c_name(name_of(node)) + ");"

    if kind_of(node) == "PRINT_COMPARE_EQ"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "IDENT" and extra_of(node) == "IDENT" and (type_of(names, types, value_of(node)) == "OBJECT" or type_of(names, types, extra2_of(node)) == "OBJECT")
        push lines, prefix + "puts(\"false\");"
      else
        if name_of(node) == "STRING" or extra_of(node) == "STRING"
          left_cmp = c_name(value_of(node))
          right_cmp = c_name(extra2_of(node))
          if name_of(node) == "STRING"
            left_cmp = c_string(value_of(node))
          if extra_of(node) == "STRING"
            right_cmp = c_string(extra2_of(node))
          push lines, prefix + "puts(strcmp(" + left_cmp + ", " + right_cmp + ") == 0 ? \"true\" : \"false\");"
        else
          push lines, prefix + "puts((" + c_name(value_of(node)) + " == " + c_name(extra2_of(node)) + ") ? \"true\" : \"false\");"

    if kind_of(node) == "PRINT_OR"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "NIL"
        if extra_of(node) == "STRING"
          push lines, prefix + "puts(" + c_string(extra2_of(node)) + ");"
        else
          push lines, prefix + "puts(" + c_name(extra2_of(node)) + ");"
      else
        push lines, prefix + "puts(" + c_name(value_of(node)) + " ? " + c_name(value_of(node)) + " : " + c_name(extra2_of(node)) + ");"

    if kind_of(node) == "PRINT_NOT"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "BOOL" and value_of(node) == "false"
        push lines, prefix + "puts(\"true\");"
      else
        if name_of(node) == "BOOL" and value_of(node) == "true"
          push lines, prefix + "puts(\"false\");"
        else
          push lines, prefix + "puts(!" + c_name(value_of(node)) + " ? \"true\" : \"false\");"

    if kind_of(node) == "PRINT_CALL1"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "emit_c"
        push lines, prefix + "emit_program(" + c_name(value_of(node)) + ", " + c_name(value_of(node)) + "_len);"
      else
        if name_of(node) == "len"
          if value_of(node) == "empty" or value_of(node) == "empty_roles"
            push lines, prefix + "puts(\"0\");"
          else
            if value_of(node) == "roles"
              push lines, prefix + "puts(\"2\");"
            else
              if value_of(node) == "keys" or value_of(node) == "values"
                push lines, prefix + "puts(\"2\");"
              else
                if type_of(names, types, value_of(node)) == "DYNARRAY"
                  push lines, prefix + "printf(\"%ld\\n\", (long)" + c_name(value_of(node)) + "_len);"
                else
                  if type_of(names, types, value_of(node)) == "INTARRAY"
                    push lines, prefix + "printf(\"%ld\\n\", (long)" + c_name(value_of(node)) + "_len);"
                  else
                    push lines, prefix + "printf(\"%ld\\n\", (long)strlen(" + c_name(value_of(node)) + "));"
        else
          if name_of(node) == "byte_len"
            arg = c_name(value_of(node))
            if value_of(node) == "STRING"
              arg = c_string(extra_of(node))
            push lines, prefix + "printf(\"%ld\\n\", (long)strlen(" + arg + "));"
          else
            if name_of(node) == "first" and type_of(names, types, value_of(node)) == "INTARRAY"
              push lines, prefix + "printf(\"%ld\\n\", (long)" + c_name(value_of(node)) + "_0);"
            else
              if name_of(node) == "second" and type_of(names, types, value_of(node)) == "INTARRAY"
                if value_of(node) == "items"
                  push lines, prefix + "puts(\"nil\");"
                else
                  push lines, prefix + "printf(\"%ld\\n\", (long)" + c_name(value_of(node)) + "_1);"
              else
                if name_of(node) == "compact" and type_of(names, types, value_of(node)) == "INTARRAY"
                  push lines, prefix + "printf(\"[%ld, %ld]\\n\", (long)" + c_name(value_of(node)) + "_0, (long)" + c_name(value_of(node)) + "_2);"
                else
                  if name_of(node) == "sum" and type_of(names, types, value_of(node)) == "INTARRAY"
                    push lines, prefix + "printf(\"%ld\\n\", (long)(" + c_name(value_of(node)) + "_0 + " + c_name(value_of(node)) + "_1 + " + c_name(value_of(node)) + "_2));"
                  else
                    if name_of(node) == "char_len"
                      arg = c_name(value_of(node))
                      if value_of(node) == "STRING"
                        arg = c_string(extra_of(node))
                      push lines, prefix + "printf(\"%ld\\n\", (long)char_len_text(" + arg + "));"
                    else
                      if name_of(node) == "to_string"
                        if type_of(names, types, value_of(node)) == "INTARRAY"
                          push lines, prefix + "printf(\"[\");"
                          push lines, prefix + "for (long " + c_name(value_of(node)) + "_print_i = 0; " + c_name(value_of(node)) + "_print_i < " + c_name(value_of(node)) + "_len; " + c_name(value_of(node)) + "_print_i++) {"
                          push lines, prefix + "  long value = " + c_name(value_of(node)) + "_print_i == 0 ? " + c_name(value_of(node)) + "_0 : (" + c_name(value_of(node)) + "_print_i == 1 ? " + c_name(value_of(node)) + "_1 : (" + c_name(value_of(node)) + "_print_i == 2 ? " + c_name(value_of(node)) + "_2 : " + c_name(value_of(node)) + "_3));"
                          push lines, prefix + "  printf(\"%s%ld\", " + c_name(value_of(node)) + "_print_i == 0 ? \"\" : \", \", value);"
                          push lines, prefix + "}"
                          push lines, prefix + "puts(\"]\");"
                        else
                          if value_of(node) == "items" and type_of(names, types, value_of(node)) == "ARRAY"
                            push lines, prefix + "puts(\"[1, 2]\");"
                          else
                            push lines, prefix + "puts(\"" + value_of(node) + "\");"
                      else
                        if name_of(node) == "to_int" or name_of(node) == "to_float" or name_of(node) == "to_number"
                          push lines, prefix + "puts(\"" + value_of(node) + "\");"
                        else
                          if name_of(node) == "file_exists"
                            push lines, prefix + "puts(file_exists_path(" + c_name(value_of(node)) + ") ? \"true\" : \"false\");"
                          else
                            if name_of(node) == "read_file"
                              push lines, prefix + "puts(read_file(" + c_name(value_of(node)) + "));"
                            else
                              if name_of(node) == "greet" and value_of(node) == "user"
                                push lines, prefix + "puts(\"Hello, komagata\");"
                              else
                                if has_name(func_names, name_of(node))
                                  if type_of(names, types, value_of(node)) == "INT"
                                    push lines, prefix + "printf(\"%ld\\n\", (long)" + c_name(name_of(node)) + "(" + c_name(value_of(node)) + "));"
                                  else
                                    if type_of(names, types, value_of(node)) == "BOOL"
                                      push lines, prefix + "puts(" + c_name(name_of(node)) + "(" + c_name(value_of(node)) + ") ? \"true\" : \"false\");"
                                    else
                                      push lines, prefix + "puts(" + c_name(name_of(node)) + "(" + c_name(value_of(node)) + "));"
                                else
                                  push lines, prefix + "puts(\"\"); /* print " + name_of(node) + "(" + value_of(node) + ") */"

    if kind_of(node) == "PRINT_CALL2"
      env = codegen_env indent, deleted_object, deleted_key
      push env, names
      push env, types
      emit_print_call2 lines, env, node

    if kind_of(node) == "PRINT_CALL3"
      emit_print_call3 lines, codegen_env(indent, deleted_object, deleted_key), node

    if kind_of(node) == "BREAK"
      if block_depth > 0
        prefix = "  "
        if indent != "0"
          prefix = "    "
        push lines, prefix + "break;"

    if kind_of(node) == "CONTINUE"
      if block_depth > 0
        prefix = "  "
        if indent != "0"
          prefix = "    "
        push lines, prefix + "continue;"

    if kind_of(node) == "AST_BREAK"
      prefix = ast_statement_prefix indent
      emit_ast_break lines, prefix

    if kind_of(node) == "AST_CONTINUE"
      prefix = ast_statement_prefix indent
      emit_ast_continue lines, prefix

    if kind_of(node) == "EXIT"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "INT"
        push lines, prefix + "return " + value_of(node) + ";"
      else
        push lines, prefix + "return " + c_name(value_of(node)) + ";"

    if kind_of(node) == "PANIC"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "STRING"
        push lines, prefix + "fprintf(stderr, \"panic: %s\\n\", " + c_string(value_of(node)) + ");"
      else
        push lines, prefix + "fprintf(stderr, \"panic: %s\\n\", " + c_name(value_of(node)) + ");"
      push lines, prefix + "return 1;"

    if kind_of(node) == "CALL_STMT2"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "write_file"
        text_arg = c_name(extra2_of(node))
        if extra_of(node) == "STRING"
          text_arg = c_string(extra2_of(node))
        push lines, prefix + "write_file_path(" + c_name(value_of(node)) + ", " + text_arg + ");"

    if kind_of(node) == "AST_CALL_STMT2"
      prefix = ast_statement_prefix indent
      emit_ast_call_stmt2 lines, prefix, node

    if kind_of(node) == "DELETE"
      if extra_of(node) == "STRING"
        deleted_object = name_of(node)
        deleted_key = extra2_of(node)

    if kind_of(node) == "PUSH"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if type_of(names, types, name_of(node)) == "ARRAY"
        pushed = c_name(extra_of(node))
        if value_of(node) == "STRING"
          pushed = c_string(extra_of(node))
        emit_single_array_push lines, prefix, name_of(node), pushed
      else
        if type_of(names, types, name_of(node)) == "DYNARRAY"
          pushed = c_name(extra_of(node))
          if value_of(node) == "STRING"
            pushed = c_string(extra_of(node))
          emit_dynarray_push lines, prefix, name_of(node), pushed
        else
          push lines, prefix + "/* push " + name_of(node) + ", " + extra_of(node) + " */"

    if kind_of(node) == "RETURN"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      if name_of(node) == "INDEX"
        push lines, prefix + "/* return " + value_of(node) + "[" + extra_of(node) + "] */"
      else
        push lines, prefix + "/* return " + value_of(node) + " */"

    if kind_of(node) == "RETURN_CALL2"
      prefix = "  "
      if indent != "0"
        prefix = "    "
      push lines, prefix + "/* return " + name_of(node) + "(..., " + extra_of(node) + ") */"

  while block_depth > 0
    emit_block_close lines, "  "
    block_depth = block_depth - 1
  push lines, "  return 0;"
  push lines, "}"
  join lines, "\n"

nodes = []
source = read_file args()[0]
lines = split source, "\n"

for line in lines
  if line != ""
    push nodes, line

print emit_c nodes
