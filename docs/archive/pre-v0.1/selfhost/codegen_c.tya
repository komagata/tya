  push lines, "          stmt_last_if_indent[0] = 0;"
  push lines, "        }"
  push lines, "      }"
  push lines, "      if (strcmp(k, \"AST_FUNC\") == 0) in_func = strcmp(x, generated_array_func_names[func_i]) == 0;"
  push lines, "      if (!in_func) continue;"
  push lines, "      if (strcmp(k, \"INDENT\") == 0 && strcmp(x, \"0\") == 0) in_func = 0;"
  push lines, "      if (strcmp(k, \"AST_WHILE\") == 0 && has_loop) {"
  push lines, "        seen_loop_node = 1;"
  push lines, "        loop_body_active = 1;"
  push lines, "        continue;"
  push lines, "      }"
  push lines, "      if (has_loop && !loop_body_active) continue;"
  push lines, "      if (has_loop && atoi(stmt_indent) < atoi(loop_indent)) continue;"
  push lines, "      if (strcmp(k, \"AST_IF\") == 0) {"
  push lines, "        char stmt_if_op[16];"
  push lines, "        char stmt_if_object[256];"
  push lines, "        char stmt_if_index[256];"
  push lines, "        char stmt_if_string[256];"
  push lines, "        stmt_if_op[0] = 0;"
  push lines, "        if (sscanf(x, \"binary(%15s index(%255s %255[^)]) string(%255[^)]))\", stmt_if_op, stmt_if_object, stmt_if_index, stmt_if_string) == 4 && (strcmp(stmt_if_op, \"==\") == 0 || strcmp(stmt_if_op, \"!=\") == 0)) {"
  push lines, "          const char *object_c = strcmp(stmt_if_object, \"char\") == 0 ? \"tya_char\" : stmt_if_object;"
