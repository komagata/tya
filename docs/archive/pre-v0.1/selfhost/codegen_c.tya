  push lines, ""
  push lines, "static int ast_push_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
  push lines, "  if (start + 3 >= tokens_len) return 0;"
  push lines, "  if (!token_is(tokens[start], \"IDENT\", \"push\")) return 0;"
  push lines, "  if (!token_kind_is(tokens[start + 1], \"IDENT\")) return 0;"
  push lines, "  if (!token_is(tokens[start + 2], \"SYMBOL\", \",\")) return 0;"
