  push lines, ""
  push lines, "static int ast_effect_from_tokens(char **tokens, long tokens_len, long start, char *kind_out, size_t kind_size, char *out, size_t out_size) {"
  push lines, "  if (start + 1 >= tokens_len) return 0;"
  push lines, "  if (token_is(tokens[start], \"IDENT\", \"exit\") && ast_atom_from_token(tokens[start + 1], out, out_size)) {"
  push lines, "    snprintf(kind_out, kind_size, \"AST_EXIT\");"
