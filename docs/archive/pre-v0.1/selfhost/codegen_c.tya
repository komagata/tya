  push lines, "          snprintf(stmt_if_condition, sizeof(stmt_if_condition), \"strcmp(char_at_text(%s, %s), \\\"%s\\\") %s 0\", object_c, index_c, stmt_if_string, strcmp(stmt_if_op, \"==\") == 0 ? \"==\" : \"!=\");"
