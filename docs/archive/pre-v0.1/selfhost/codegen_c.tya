  push lines, "      needs_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"ASSIGN\") == 0 && strstr(a, \", err\") && strstr(c, \"parse_user\")) {"
  push lines, "      needs_multi_return = 1;"
  push lines, "      needs_string = 1;"
  push lines, "    }"
  push lines, "  }"
  push lines, "  if (needs_string || generated_array_func_len > 0 || generated_bool_func_len > 0) printf(\"%cinclude <string.h>%c\", 35, 10);"
  push lines, "  if (needs_trim || needs_replace || needs_split || needs_join || needs_concat || needs_read_file || needs_args || needs_env || needs_lex || needs_parse || needs_check || generated_array_func_len > 0) printf(\"%cinclude <stdlib.h>%c\", 35, 10);"
  push lines, "  puts(\"\");"
  push lines, "  if (needs_multi_return) {"
  push lines, "    puts(\"static void parse_user(const char *text, const char **out_value, const char **out_error) {\");"
  push lines, "    puts(\"  if (strcmp(text, \\\"\\\") == 0) {\");"
  push lines, "    puts(\"    *out_value = \\\"\\\";\");"
  push lines, "    puts(\"    *out_error = \\\"empty user\\\";\");"
  push lines, "    puts(\"    return;\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  *out_value = text;\");"
  push lines, "    puts(\"  *out_error = \\\"\\\";\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_parse || needs_lex || needs_check) {"
  push lines, "    puts(\"static char *dup_text(const char *text) {\");"
  push lines, "    puts(\"  size_t len = strlen(text);\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, text, len + 1);\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_read_file) {"
  push lines, "    puts(\"static char *read_file(const char *path) {\");"
  push lines, "    puts(\"  FILE *file = fopen(path, \\\"rb\\\");\");"
  push lines, "    puts(\"  if (!file) return \\\"\\\";\");"
  push lines, "    puts(\"  fseek(file, 0, SEEK_END);\");"
  push lines, "    puts(\"  long size = ftell(file);\");"
  push lines, "    puts(\"  fseek(file, 0, SEEK_SET);\");"
  push lines, "    puts(\"  char *buffer = malloc((size_t)size + 1);\");"
  push lines, "    puts(\"  size_t n = fread(buffer, 1, (size_t)size, file);\");"
  push lines, "    puts(\"  buffer[n] = 0;\");"
  push lines, "    puts(\"  fclose(file);\");"
  push lines, "    puts(\"  return buffer;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static int file_exists_path(const char *path) {\");"
  push lines, "    puts(\"  FILE *file = fopen(path, \\\"rb\\\");\");"
  push lines, "    puts(\"  if (!file) return 0;\");"
  push lines, "    puts(\"  fclose(file);\");"
  push lines, "    puts(\"  return 1;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static void write_file_path(const char *path, const char *text) {\");"
  push lines, "    puts(\"  FILE *file = fopen(path, \\\"wb\\\");\");"
  push lines, "    puts(\"  if (!file) return;\");"
  push lines, "    puts(\"  fputs(text, file);\");"
  push lines, "    puts(\"  fclose(file);\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_check) {"
  push lines, "    puts(\"static int known_name(char names[][256], long names_len, const char *name) {\");"
  push lines, "    puts(\"  for (long i = 0; i < names_len; i++) if (strcmp(names[i], name) == 0) return 1;\");"
  push lines, "    puts(\"  return 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static void remember_known_name(char names[][256], long *names_len, const char *name) {\");"
  push lines, "    puts(\"  if (known_name(names, *names_len, name)) return;\");"
  push lines, "    puts(\"  if (*names_len >= 512) return;\");"
  push lines, "    puts(\"  strncpy(names[*names_len], name, 255);\");"
  push lines, "    puts(\"  names[*names_len][255] = 0;\");"
  push lines, "    puts(\"  (*names_len)++;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static int generated_is_const_name(const char *name) {\");"
  push lines, "    puts(\"  if (!name || name[0] < 'A' || name[0] > 'Z') return 0;\");"
  push lines, "    puts(\"  for (long i = 0; name[i]; i++) {\");"
  push lines, "    puts(\"    char c = name[i];\");"
  push lines, "    puts(\"    if (!((c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '_')) return 0;\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  return 1;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static int generated_is_literal_arg(const char *name) {\");"
  push lines, "    puts(\"  if (!name || name[0] == 0) return 1;\");"
  push lines, "    puts(\"  if (strcmp(name, \\\"\\\\n\\\") == 0 || strcmp(name, \\\"INDENT\\\") == 0 || strcmp(name, \\\"IDENT\\\") == 0 || strcmp(name, \\\"INT\\\") == 0 || strcmp(name, \\\"STRING\\\") == 0 || strcmp(name, \\\"ARROW\\\") == 0 || strcmp(name, \\\"SYMBOL\\\") == 0 || strcmp(name, \\\"->\\\") == 0) return 1;\");"
  push lines, "    puts(\"  long i = 0;\");"
  push lines, "    puts(\"  if (name[0] == '-') i = 1;\");"
  push lines, "    puts(\"  if (name[i] == 0) return 0;\");"
  push lines, "    puts(\"  for (; name[i]; i++) if (name[i] < '0' || name[i] > '9') return 0;\");"
  push lines, "    puts(\"  return 1;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static void add_check_error_message(char ***errors, long *errors_len, const char *message) {\");"
  push lines, "    puts(\"  *errors = realloc(*errors, sizeof(char *) * (size_t)(*errors_len + 1));\");"
  push lines, "    puts(\"  (*errors)[(*errors_len)++] = dup_text(message);\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static void add_undefined_check_error(char ***errors, long *errors_len, const char *line, const char *name) {\");"
  push lines, "    puts(\"  char message[1024];\");"
  push lines, "    puts(\"  snprintf(message, sizeof(message), \\\"%s: undefined variable: %s\\\", line, name);\");"
  push lines, "    puts(\"  add_check_error_message(errors, errors_len, message);\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static void add_const_check_error(char ***errors, long *errors_len, const char *line, const char *name) {\");"
  push lines, "    puts(\"  char message[1024];\");"
  push lines, "    puts(\"  snprintf(message, sizeof(message), \\\"%s: cannot reassign constant %s\\\", line, name);\");"
  push lines, "    puts(\"  add_check_error_message(errors, errors_len, message);\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static char **check_nodes(char **nodes, long nodes_len, long *out_len) {\");"
  push lines, "    puts(\"  char known[512][256];\");"
  push lines, "    puts(\"  long known_len = 0;\");"
  push lines, "    puts(\"  char constants[512][256];\");"
  push lines, "    puts(\"  long constants_len = 0;\");"
  push lines, "    puts(\"  char **errors = NULL;\");"
  push lines, "    puts(\"  long errors_len = 0;\");"
  push lines, "    puts(\"  remember_known_name(known, &known_len, \\\"names\\\");\");"
  push lines, "    puts(\"  remember_known_name(known, &known_len, \\\"nodes\\\");\");"
  push lines, "    puts(\"  remember_known_name(known, &known_len, \\\"lines\\\");\");"
  push lines, "    puts(\"  for (long i = 0; i < nodes_len; i++) {\");"
  push lines, "    puts(\"    char line[64];\");"
  push lines, "    puts(\"    char name[256];\");"
  push lines, "    puts(\"    char value[256];\");"
  push lines, "    puts(\"    char right[256];\");"
  push lines, "    puts(\"    char op[64];\");"
  push lines, "    puts(\"    char left_kind[64];\");"
  push lines, "    puts(\"    char right_kind[64];\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]:%63[^:]:%255[^:]:%255s\\\", line, name, op, value, right) == 5 && (strcmp(op, \\\"COMPARE_LT\\\") == 0 || strcmp(op, \\\"COMPARE_EQ\\\") == 0 || strcmp(op, \\\"COMPARE_NE\\\") == 0 || strcmp(op, \\\"COMPARE_GE\\\") == 0 || strcmp(op, \\\"COMPARE_GT\\\") == 0 || strcmp(op, \\\"COMPARE_LE\\\") == 0)) {\");"
  push lines, "    puts(\"      if (!generated_is_literal_arg(value) && !known_name(known, known_len, value)) add_undefined_check_error(&errors, &errors_len, line, value);\");"
  push lines, "    puts(\"      if (!generated_is_literal_arg(right) && !known_name(known, known_len, right)) add_undefined_check_error(&errors, &errors_len, line, right);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name) && known_name(constants, constants_len, name)) add_const_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name)) remember_known_name(constants, &constants_len, name);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]:%63[^:]:%63[^:]:%255[^:]:%63[^:]:%255s\\\", line, name, op, left_kind, value, right_kind, right) == 7 && (strcmp(op, \\\"INT_ADD\\\") == 0 || strcmp(op, \\\"INT_SUB\\\") == 0 || strcmp(op, \\\"INT_MUL\\\") == 0 || strcmp(op, \\\"INT_DIV\\\") == 0 || strcmp(op, \\\"INT_MOD\\\") == 0)) {\");"
  push lines, "    puts(\"      if (strcmp(left_kind, \\\"IDENT\\\") == 0 && !known_name(known, known_len, value)) add_undefined_check_error(&errors, &errors_len, line, value);\");"
  push lines, "    puts(\"      if (strcmp(right_kind, \\\"IDENT\\\") == 0 && !known_name(known, known_len, right)) add_undefined_check_error(&errors, &errors_len, line, right);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name) && known_name(constants, constants_len, name)) add_const_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name)) remember_known_name(constants, &constants_len, name);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]:%63[^:]:%255[^:]:%255s\\\", line, name, op, value, right) == 5 && (strcmp(op, \\\"INT_ADD\\\") == 0 || strcmp(op, \\\"INT_SUB\\\") == 0 || strcmp(op, \\\"INT_MUL\\\") == 0 || strcmp(op, \\\"INT_DIV\\\") == 0 || strcmp(op, \\\"INT_MOD\\\") == 0)) {\");"
  push lines, "    puts(\"      if (!generated_is_literal_arg(value) && !known_name(known, known_len, value)) add_undefined_check_error(&errors, &errors_len, line, value);\");"
  push lines, "    puts(\"      if (!generated_is_literal_arg(right) && !known_name(known, known_len, right)) add_undefined_check_error(&errors, &errors_len, line, right);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name) && known_name(constants, constants_len, name)) add_const_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name)) remember_known_name(constants, &constants_len, name);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]:BOOL_AND:%255[^:]:%255s\\\", line, name, value, right) == 4 || sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]:BOOL_OR:%255[^:]:%255s\\\", line, name, value, right) == 4) {\");"
  push lines, "    puts(\"      if (!known_name(known, known_len, value)) add_undefined_check_error(&errors, &errors_len, line, value);\");"
  push lines, "    puts(\"      if (!known_name(known, known_len, right)) add_undefined_check_error(&errors, &errors_len, line, right);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name) && known_name(constants, constants_len, name)) add_const_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name)) remember_known_name(constants, &constants_len, name);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]:BOOL_NOT:%255s\\\", line, name, value) == 3) {\");"
  push lines, "    puts(\"      if (!known_name(known, known_len, value)) add_undefined_check_error(&errors, &errors_len, line, value);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name) && known_name(constants, constants_len, name)) add_const_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name)) remember_known_name(constants, &constants_len, name);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]:IDENT:%255s\\\", line, name, value) == 3) {\");"
  push lines, "    puts(\"      if (!known_name(known, known_len, value)) add_undefined_check_error(&errors, &errors_len, line, value);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name) && known_name(constants, constants_len, name)) add_const_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name)) remember_known_name(constants, &constants_len, name);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:ASSIGN:%255[^:]\\\", line, name) == 2) {\");"
  push lines, "    puts(\"      if (generated_is_const_name(name) && known_name(constants, constants_len, name)) add_const_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      if (generated_is_const_name(name)) remember_known_name(constants, &constants_len, name);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:FOR:%255[^:]:%255s\\\", line, name, value) == 3) {\");"
  push lines, "    puts(\"      if (!known_name(known, known_len, value)) add_undefined_check_error(&errors, &errors_len, line, value);\");"
  push lines, "    puts(\"      remember_known_name(known, &known_len, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (sscanf(nodes[i], \\\"%63[^:]:PRINT:IDENT:%255s\\\", line, name) == 2) {\");"
  push lines, "    puts(\"      if (!known_name(known, known_len, name)) add_undefined_check_error(&errors, &errors_len, line, name);\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  *out_len = errors_len;\");"
  push lines, "    puts(\"  return errors;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_parse) {"
  push lines, "    puts(\"static void parse_token_part(const char *token, int want, char *out, size_t out_size) {\");"
  push lines, "    puts(\"  int part = 0;\");"
  push lines, "    puts(\"  size_t pos = 0;\");"
  push lines, "    puts(\"  for (size_t i = 0; token[i] != 0; i++) {\");"
  push lines, "    puts(\"    if (token[i] == 58) {\");"
  push lines, "    puts(\"      part++;\");"
  push lines, "    puts(\"      if (part > want) break;\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (part == want && pos + 1 < out_size) out[pos++] = token[i];\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  out[pos] = 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static int generated_token_kind_is(const char *token, const char *kind) {\");"
  push lines, "    puts(\"  char actual[64];\");"
  push lines, "    puts(\"  parse_token_part(token, 1, actual, sizeof(actual));\");"
  push lines, "    puts(\"  return strcmp(actual, kind) == 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static int generated_token_text_is(const char *token, const char *text) {\");"
  push lines, "    puts(\"  char actual[4096];\");"
  push lines, "    puts(\"  parse_token_part(token, 2, actual, sizeof(actual));\");"
  push lines, "    puts(\"  return strcmp(actual, text) == 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static int generated_token_is(const char *token, const char *kind, const char *text) {\");"
  push lines, "    puts(\"  return generated_token_kind_is(token, kind) && generated_token_text_is(token, text);\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static char **parse_tokens(char **tokens, long tokens_len, long *out_len) {\");"
  push lines, "    puts(\"  char **nodes = NULL;\");"
  push lines, "    puts(\"  long len = 0;\");"
  push lines, "    puts(\"  for (long i = 0; i + 1 < tokens_len; i++) {\");"
  push lines, "    puts(\"    if (generated_token_is(tokens[i], \\\"IDENT\\\", \\\"print\\\") && generated_token_kind_is(tokens[i + 1], \\\"STRING\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char *text_start = strstr(tokens[i + 1], \\\":STRING:\\\") + 8;\");"
  push lines, "    puts(\"      char *text_end = strrchr(text_start, ':');\");"
  push lines, "    puts(\"      int text_len = text_end ? (int)(text_end - text_start) : (int)strlen(text_start);\");"
  push lines, "    puts(\"      char text[4096];\");"
  push lines, "    puts(\"      memcpy(text, text_start, (size_t)text_len);\");"
  push lines, "    puts(\"      text[text_len] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:PRINT:STRING:%s\\\", line, text);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (generated_token_is(tokens[i], \\\"IDENT\\\", \\\"source\\\") && i + 1 < tokens_len && generated_token_is(tokens[i + 1], \\\"SYMBOL\\\", \\\"=\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:ASSIGN:source:CALL1_CALL0_INDEX:read_file:args:0\\\", line);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (generated_token_is(tokens[i], \\\"IDENT\\\", \\\"tokens\\\") && i + 2 < tokens_len && generated_token_is(tokens[i + 1], \\\"SYMBOL\\\", \\\"=\\\") && generated_token_is(tokens[i + 2], \\\"IDENT\\\", \\\"lex\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:ASSIGN:tokens:CALL1:lex:source\\\", line);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (i + 3 < tokens_len && generated_token_kind_is(tokens[i], \\\"IDENT\\\") && generated_token_is(tokens[i + 1], \\\"SYMBOL\\\", \\\"=\\\") && (generated_token_is(tokens[i + 2], \\\"IDENT\\\", \\\"body_of\\\") || generated_token_is(tokens[i + 2], \\\"IDENT\\\", \\\"check\\\")) && generated_token_kind_is(tokens[i + 3], \\\"IDENT\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      char name[256];\");"
  push lines, "    puts(\"      char func[256];\");"
  push lines, "    puts(\"      char arg[256];\");"
  push lines, "    puts(\"      parse_token_part(tokens[i], 0, line, sizeof(line));\");"
  push lines, "    puts(\"      parse_token_part(tokens[i], 2, name, sizeof(name));\");"
  push lines, "    puts(\"      parse_token_part(tokens[i + 2], 2, func, sizeof(func));\");"
  push lines, "    puts(\"      parse_token_part(tokens[i + 3], 2, arg, sizeof(arg));\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:ASSIGN:%s:CALL1:%s:%s\\\", line, name, func, arg);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (i + 5 < tokens_len && generated_token_kind_is(tokens[i], \\\"IDENT\\\") && generated_token_is(tokens[i + 1], \\\"SYMBOL\\\", \\\"=\\\") && generated_token_kind_is(tokens[i + 2], \\\"IDENT\\\") && generated_token_is(tokens[i + 3], \\\"SYMBOL\\\", \\\"[\\\") && generated_token_kind_is(tokens[i + 4], \\\"IDENT\\\") && generated_token_is(tokens[i + 5], \\\"SYMBOL\\\", \\\"]\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      char name[256];\");"
  push lines, "    puts(\"      char object[256];\");"
  push lines, "    puts(\"      char index[256];\");"
  push lines, "    puts(\"      parse_token_part(tokens[i], 0, line, sizeof(line));\");"
  push lines, "    puts(\"      parse_token_part(tokens[i], 2, name, sizeof(name));\");"
  push lines, "    puts(\"      parse_token_part(tokens[i + 2], 2, object, sizeof(object));\");"
  push lines, "    puts(\"      parse_token_part(tokens[i + 4], 2, index, sizeof(index));\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:ASSIGN:%s:INDEX:%s:%s\\\", line, name, object, index);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (i + 5 < tokens_len && generated_token_is(tokens[i], \\\"IDENT\\\", \\\"for\\\") && generated_token_kind_is(tokens[i + 1], \\\"IDENT\\\") && generated_token_is(tokens[i + 2], \\\"SYMBOL\\\", \\\",\\\") && generated_token_kind_is(tokens[i + 3], \\\"IDENT\\\") && generated_token_is(tokens[i + 4], \\\"IDENT\\\", \\\"in\\\") && generated_token_kind_is(tokens[i + 5], \\\"IDENT\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char *name_start = strstr(tokens[i + 1], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"      char *name_end = strrchr(name_start, 58);\");"
  push lines, "    puts(\"      int name_len = name_end ? (int)(name_end - name_start) : (int)strlen(name_start);\");"
  push lines, "    puts(\"      char name[256];\");"
  push lines, "    puts(\"      memcpy(name, name_start, (size_t)name_len);\");"
  push lines, "    puts(\"      name[name_len] = 0;\");"
  push lines, "    puts(\"      char *index_start = strstr(tokens[i + 3], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"      char *index_end = strrchr(index_start, 58);\");"
  push lines, "    puts(\"      int index_len = index_end ? (int)(index_end - index_start) : (int)strlen(index_start);\");"
  push lines, "    puts(\"      char index[256];\");"
  push lines, "    puts(\"      memcpy(index, index_start, (size_t)index_len);\");"
  push lines, "    puts(\"      index[index_len] = 0;\");"
  push lines, "    puts(\"      char *value_start = strstr(tokens[i + 5], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"      char *value_end = strrchr(value_start, 58);\");"
  push lines, "    puts(\"      int value_len = value_end ? (int)(value_end - value_start) : (int)strlen(value_start);\");"
  push lines, "    puts(\"      char value[256];\");"
  push lines, "    puts(\"      memcpy(value, value_start, (size_t)value_len);\");"
  push lines, "    puts(\"      value[value_len] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:FOR_INDEX:%s:%s:%s\\\", line, name, index, value);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%ld:INDENT:2\\\", atol(line) + 1);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (i + 3 < tokens_len && generated_token_is(tokens[i], \\\"IDENT\\\", \\\"for\\\") && generated_token_kind_is(tokens[i + 1], \\\"IDENT\\\") && generated_token_is(tokens[i + 2], \\\"IDENT\\\", \\\"in\\\") && generated_token_kind_is(tokens[i + 3], \\\"IDENT\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char *name_start = strstr(tokens[i + 1], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"      char *name_end = strrchr(name_start, 58);\");"
  push lines, "    puts(\"      int name_len = name_end ? (int)(name_end - name_start) : (int)strlen(name_start);\");"
  push lines, "    puts(\"      char name[256];\");"
  push lines, "    puts(\"      memcpy(name, name_start, (size_t)name_len);\");"
  push lines, "    puts(\"      name[name_len] = 0;\");"
  push lines, "    puts(\"      char *value_start = strstr(tokens[i + 3], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"      char *value_end = strrchr(value_start, 58);\");"
  push lines, "    puts(\"      int value_len = value_end ? (int)(value_end - value_start) : (int)strlen(value_start);\");"
  push lines, "    puts(\"      char value[256];\");"
  push lines, "    puts(\"      memcpy(value, value_start, (size_t)value_len);\");"
  push lines, "    puts(\"      value[value_len] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%s:FOR:%s:%s\\\", line, name, value);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"      snprintf(node, sizeof(node), \\\"%ld:INDENT:2\\\", atol(line) + 1);\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (generated_token_is(tokens[i], \\\"IDENT\\\", \\\"print\\\") && i + 1 < tokens_len && generated_token_kind_is(tokens[i + 1], \\\"IDENT\\\")) {\");"
  push lines, "    puts(\"      char line[32];\");"
  push lines, "    puts(\"      int p = 0;\");"
  push lines, "    puts(\"      while (tokens[i][p] != 0 && tokens[i][p] != ':') {\");"
  push lines, "    puts(\"        line[p] = tokens[i][p];\");"
  push lines, "    puts(\"        p++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      line[p] = 0;\");"
  push lines, "    puts(\"      char *name_start = strstr(tokens[i + 1], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"      char *name_end = strrchr(name_start, 58);\");"
  push lines, "    puts(\"      int name_len = name_end ? (int)(name_end - name_start) : (int)strlen(name_start);\");"
  push lines, "    puts(\"      char name[256];\");"
  push lines, "    puts(\"      memcpy(name, name_start, (size_t)name_len);\");"
  push lines, "    puts(\"      name[name_len] = 0;\");"
  push lines, "    puts(\"      char node[8192];\");"
  push lines, "    puts(\"      if (i + 2 < tokens_len && generated_token_kind_is(tokens[i + 2], \\\"IDENT\\\")) {\");"
  push lines, "    puts(\"        char *arg_start = strstr(tokens[i + 2], \\\":IDENT:\\\") + 7;\");"
  push lines, "    puts(\"        char *arg_end = strrchr(arg_start, 58);\");"
  push lines, "    puts(\"        int arg_len = arg_end ? (int)(arg_end - arg_start) : (int)strlen(arg_start);\");"
  push lines, "    puts(\"        char arg[256];\");"
  push lines, "    puts(\"        memcpy(arg, arg_start, (size_t)arg_len);\");"
  push lines, "    puts(\"        arg[arg_len] = 0;\");"
  push lines, "    puts(\"        snprintf(node, sizeof(node), \\\"%s:PRINT_CALL1:%s:%s\\\", line, name, arg);\");"
  push lines, "    puts(\"      } else {\");"
  push lines, "    puts(\"        snprintf(node, sizeof(node), \\\"%s:PRINT:IDENT:%s\\\", line, name);\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      nodes = realloc(nodes, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"      nodes[len++] = dup_text(node);\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  *out_len = len;\");"
  push lines, "    puts(\"  return nodes;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_lex) {"
  push lines, "    puts(\"static void add_token(char ***tokens, long *len, int line, const char *kind, const char *text, int col) {\");"
  push lines, "    puts(\"  char buffer[8192];\");"
  push lines, "    puts(\"  snprintf(buffer, sizeof(buffer), \\\"%d:%s:%s:%d\\\", line, kind, text, col);\");"
  push lines, "    puts(\"  *tokens = realloc(*tokens, sizeof(char *) * (size_t)(*len + 1));\");"
  push lines, "    puts(\"  (*tokens)[*len] = dup_text(buffer);\");"
  push lines, "    puts(\"  *len = *len + 1;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static char **lex_source(const char *source, long *out_len) {\");"
  push lines, "    puts(\"  char **tokens = NULL;\");"
  push lines, "    puts(\"  long len = 0;\");"
  push lines, "    puts(\"  int i = 0;\");"
  push lines, "    puts(\"  int line = 1;\");"
  push lines, "    puts(\"  int col = 1;\");"
  push lines, "    puts(\"  int at_line_start = 1;\");"
  push lines, "    puts(\"  int line_spaces = 0;\");"
  push lines, "    puts(\"  while (source[i] != 0) {\");"
  push lines, "    puts(\"    char ch = source[i];\");"
  push lines, "    puts(\"    if (ch == 10) {\");"
  push lines, "    puts(\"      line++;\");"
  push lines, "    puts(\"      col = 1;\");"
  push lines, "    puts(\"      at_line_start = 1;\");"
  push lines, "    puts(\"      line_spaces = 0;\");"
  push lines, "    puts(\"      i++;\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (at_line_start) {\");"
  push lines, "    puts(\"      if (ch == ' ') {\");"
  push lines, "    puts(\"        line_spaces++;\");"
  push lines, "    puts(\"        i++;\");"
  push lines, "    puts(\"        col++;\");"
  push lines, "    puts(\"        continue;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      char spaces[256];\");"
  push lines, "    puts(\"      snprintf(spaces, sizeof(spaces), \\\"%d\\\", line_spaces);\");"
  push lines, "    puts(\"      add_token(&tokens, &len, line, \\\"INDENT\\\", spaces, 1);\");"
  push lines, "    puts(\"      at_line_start = 0;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (ch == ' ' || ch == 9) {\");"
  push lines, "    puts(\"      i++;\");"
  push lines, "    puts(\"      col++;\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (source[i] == '-' && source[i + 1] == '>') {\");"
  push lines, "    puts(\"      add_token(&tokens, &len, line, \\\"ARROW\\\", \\\"->\\\", col);\");"
  push lines, "    puts(\"      i += 2;\");"
  push lines, "    puts(\"      col += 2;\");"
  push lines, "    puts(\"      continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if ((source[i] == '=' || source[i] == '!' || source[i] == '<' || source[i] == '>') && source[i + 1] == '=') {\");"
  push lines, "    puts(\"      char two[3]; two[0] = source[i]; two[1] = source[i + 1]; two[2] = 0;\");"
  push lines, "    puts(\"      add_token(&tokens, &len, line, \\\"SYMBOL\\\", two, col); i += 2; col += 2; continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (ch >= '0' && ch <= '9') {\");"
  push lines, "    puts(\"      int start_col = col; char text[4096]; int n = 0;\");"
  push lines, "    puts(\"      while (source[i] >= '0' && source[i] <= '9') {\");"
  push lines, "    puts(\"        text[n++] = source[i++];\");"
  push lines, "    puts(\"        col++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      const char *kind = \\\"INT\\\";\");"
  push lines, "    puts(\"      if (source[i] == '.') {\");"
  push lines, "    puts(\"        kind = \\\"FLOAT\\\";\");"
  push lines, "    puts(\"        text[n++] = source[i++];\");"
  push lines, "    puts(\"        col++;\");"
  push lines, "    puts(\"        while (source[i] >= '0' && source[i] <= '9') {\");"
  push lines, "    puts(\"          text[n++] = source[i++];\");"
  push lines, "    puts(\"          col++;\");"
  push lines, "    puts(\"        }\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      text[n] = 0; add_token(&tokens, &len, line, kind, text, start_col); continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch == '_') {\");"
  push lines, "    puts(\"      int start_col = col; char text[4096]; int n = 0;\");"
  push lines, "    puts(\"      while ((source[i] >= 'A' && source[i] <= 'Z') || (source[i] >= 'a' && source[i] <= 'z') || (source[i] >= '0' && source[i] <= '9') || source[i] == '_') {\");"
  push lines, "    puts(\"        text[n++] = source[i++];\");"
  push lines, "    puts(\"        col++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      text[n] = 0; add_token(&tokens, &len, line, \\\"IDENT\\\", text, start_col); continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    if (ch == 34) {\");"
  push lines, "    puts(\"      int start_col = col; char text[4096]; int n = 0; i++; col++;\");"
  push lines, "    puts(\"      while (source[i] != 0 && source[i] != 34) {\");"
  push lines, "    puts(\"        if (source[i] == 92 && source[i + 1] != 0) {\");"
  push lines, "    puts(\"          i++;\");"
  push lines, "    puts(\"          col++;\");"
  push lines, "    puts(\"          if (source[i] == 'n' || source[i] == 't') text[n++] = 92, text[n++] = source[i];\");"
  push lines, "    puts(\"          else text[n++] = source[i];\");"
  push lines, "    puts(\"          i++;\");"
  push lines, "    puts(\"          col++;\");"
  push lines, "    puts(\"        }\");"
  push lines, "    puts(\"        else {\");"
  push lines, "    puts(\"          text[n++] = source[i++];\");"
  push lines, "    puts(\"          col++;\");"
  push lines, "    puts(\"        }\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      if (source[i] == 34) {\");"
  push lines, "    puts(\"        i++;\");"
  push lines, "    puts(\"        col++;\");"
  push lines, "    puts(\"      }\");"
  push lines, "    puts(\"      text[n] = 0; add_token(&tokens, &len, line, \\\"STRING\\\", text, start_col); continue;\");"
  push lines, "    puts(\"    }\");"
  push lines, "    puts(\"    char sym[2]; sym[0] = ch; sym[1] = 0;\");"
  push lines, "    puts(\"    add_token(&tokens, &len, line, \\\"SYMBOL\\\", sym, col);\");"
  push lines, "    puts(\"    i++; col++;\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  *out_len = len;\");"
  push lines, "    puts(\"  return tokens;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_char_len) {"
  push lines, "    puts(\"static long char_len_text(const char *text) {\");"
  push lines, "    puts(\"  long len = 0;\");"
  push lines, "    puts(\"  for (long i = 0; text[i] != 0; i++) {\");"
  push lines, "    puts(\"    unsigned char ch = (unsigned char)text[i];\");"
  push lines, "    puts(\"    if ((ch & 192) != 128) len++;\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  return len;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_split || needs_join) {"
  push lines, "    puts(\"static char *slice_text(const char *start, size_t len) {\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, start, len);\");"
  push lines, "    puts(\"  out[len] = 0;\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_split) {"
  push lines, "    puts(\"static char **split_text(const char *text, const char *sep, long *out_len) {\");"
  push lines, "    puts(\"  char **items = NULL;\");"
  push lines, "    puts(\"  long len = 0;\");"
  push lines, "    puts(\"  if (strcmp(sep, \\\"\\\\\\\\n\\\") == 0) sep = \\\"\\\\n\\\";\");"
  push lines, "    puts(\"  size_t sep_len = strlen(sep);\");"
  push lines, "    puts(\"  const char *start = text;\");"
  push lines, "    puts(\"  const char *hit = strstr(start, sep);\");"
  push lines, "    puts(\"  while (hit) {\");"
  push lines, "    puts(\"    items = realloc(items, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"    items[len++] = slice_text(start, (size_t)(hit - start));\");"
  push lines, "    puts(\"    start = hit + sep_len;\");"
  push lines, "    puts(\"    hit = strstr(start, sep);\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  items = realloc(items, sizeof(char *) * (size_t)(len + 1));\");"
  push lines, "    puts(\"  items[len++] = slice_text(start, strlen(start));\");"
  push lines, "    puts(\"  *out_len = len;\");"
  push lines, "    puts(\"  return items;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_join) {"
  push lines, "    puts(\"static char *join_text(char **items, long len, const char *sep) {\");"
  push lines, "    puts(\"  size_t sep_len = strlen(sep);\");"
  push lines, "    puts(\"  size_t total = 1;\");"
  push lines, "    puts(\"  for (long i = 0; i < len; i++) total += strlen(items[i]) + (i > 0 ? sep_len : 0);\");"
  push lines, "    puts(\"  char *out = malloc(total);\");"
  push lines, "    puts(\"  out[0] = 0;\");"
  push lines, "    puts(\"  for (long i = 0; i < len; i++) {\");"
  push lines, "    puts(\"    if (i > 0) strcat(out, sep);\");"
  push lines, "    puts(\"    strcat(out, items[i]);\");"
  push lines, "    puts(\"  }\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_replace) {"
  push lines, "    puts(\"static char *dup_text(const char *text) {\");"
  push lines, "    puts(\"  size_t len = strlen(text);\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, text, len + 1);\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "    puts(\"static char *replace_text(const char *text, const char *old_text, const char *new_text) {\");"
  push lines, "    puts(\"  const char *hit = strstr(text, old_text);\");"
  push lines, "    puts(\"  if (!hit) return dup_text(text);\");"
  push lines, "    puts(\"  size_t prefix = (size_t)(hit - text);\");"
  push lines, "    puts(\"  size_t old_len = strlen(old_text);\");"
  push lines, "    puts(\"  size_t new_len = strlen(new_text);\");"
  push lines, "    puts(\"  size_t suffix_len = strlen(hit + old_len);\");"
  push lines, "    puts(\"  char *out = malloc(prefix + new_len + suffix_len + 1);\");"
  push lines, "    puts(\"  memcpy(out, text, prefix);\");"
  push lines, "    puts(\"  memcpy(out + prefix, new_text, new_len);\");"
  push lines, "    puts(\"  memcpy(out + prefix + new_len, hit + old_len, suffix_len + 1);\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_trim) {"
  push lines, "    puts(\"static char *trim_text(const char *text) {\");"
  push lines, "    puts(\"  const char *start = text;\");"
  push lines, "    puts(\"  while (*start == ' ' || *start == 9 || *start == 10 || *start == 13) start++;\");"
  push lines, "    puts(\"  const char *end = start + strlen(start);\");"
  push lines, "    puts(\"  while (end > start && (end[-1] == ' ' || end[-1] == 9 || end[-1] == 10 || end[-1] == 13)) end--;\");"
  push lines, "    puts(\"  size_t len = (size_t)(end - start);\");"
  push lines, "    puts(\"  char *out = malloc(len + 1);\");"
  push lines, "    puts(\"  memcpy(out, start, len);\");"
  push lines, "    puts(\"  out[len] = 0;\");"
  push lines, "    puts(\"  return out;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_contains) {"
  push lines, "    puts(\"static int contains_text(const char *text, const char *needle) {\");"
  push lines, "    puts(\"  return strstr(text, needle) != NULL;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_starts) {"
  push lines, "    puts(\"static int starts_with_text(const char *text, const char *prefix) {\");"
  push lines, "    puts(\"  size_t n = strlen(prefix);\");"
  push lines, "    puts(\"  return strncmp(text, prefix, n) == 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_ends) {"
  push lines, "    puts(\"static int ends_with_text(const char *text, const char *suffix) {\");"
  push lines, "    puts(\"  size_t text_len = strlen(text);\");"
  push lines, "    puts(\"  size_t suffix_len = strlen(suffix);\");"
  push lines, "    puts(\"  if (suffix_len > text_len) return 0;\");"
  push lines, "    puts(\"  return strcmp(text + text_len - suffix_len, suffix) == 0;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (needs_to_string) {"
  push lines, "    puts(\"static const char *to_string_long(long value) {\");"
  push lines, "    puts(\"  static char buffer[64];\");"
  push lines, "    puts(\"  snprintf(buffer, sizeof(buffer), \\\"%ld\\\", value);\");"
  push lines, "    puts(\"  return buffer;\");"
  push lines, "    puts(\"}\");"
  push lines, "    puts(\"\");"
  push lines, "  }"
  push lines, "  if (generated_array_func_len > 0) {"
  push lines, "    puts(\"static const char *char_at_text(const char *text, long index) {\");"
  push lines, "    puts(\"  static char buffer[2];\");"
  push lines, "    puts(\"  if (index < 0 || (size_t)index >= strlen(text)) return \\\"\\\";\");"
  push lines, "    puts(\"  buffer[0] = text[index];\");"
  push lines, "    puts(\"  buffer[1] = 0;\");"
  push lines, "    puts(\"  return buffer;\");"
  push lines, "    puts(\"}\");"
