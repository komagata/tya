  push lines, "      snprintf(out, out_size, \"%s:%s\", target, expr);"
  push lines, "      return 1;"
  push lines, "    }"
  push lines, "  }"
  push lines, "  if (ast_index_from_tokens(tokens, tokens_len, start + 3, expr, sizeof(expr)) || ast_atom_from_token(tokens[start + 3], expr, sizeof(expr))) {"
  push lines, "    snprintf(out, out_size, \"%s:%s\", target, expr);"
  push lines, "    return 1;"
  push lines, "  }"
  push lines, "  return 0;"
  push lines, "}"
  push lines, ""
  push lines, "static int ast_call_stmt2_from_tokens(char **tokens, long tokens_len, long start, char *out, size_t out_size) {"
