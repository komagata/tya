  push lines, "      needs_contains = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"starts_with\") == 0) {"
  push lines, "      needs_string = 1;"
  push lines, "      needs_starts = 1;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"PRINT_CALL2\") == 0 && strcmp(a, \"ends_with\") == 0) {"
