  push lines, "    node_field(nodes[i], 5, d, sizeof(d));"
  push lines, "    if (strcmp(kind, \"FUNC\") == 0) {"
  push lines, "      strcpy(generated_func_names[generated_func_len], a);"
  push lines, "      strcpy(generated_func_args[generated_func_len], b);"
  push lines, "      generated_func_called[generated_func_len] = 0;"
  push lines, "      generated_func_len++;"
  push lines, "    }"
  push lines, "    if (strcmp(kind, \"AST_FUNC\") == 0) {"
