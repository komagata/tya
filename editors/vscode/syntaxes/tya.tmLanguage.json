{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "tya",
  "scopeName": "source.tya",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#literals" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.tya",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tya",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.tya", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.tya", "match": "\\b0x[0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.tya", "match": "\\b0b[01_]+\\b" },
        { "name": "constant.numeric.tya", "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tya",
          "match": "\\b(if|elseif|else|while|for|in|break|continue|return|raise|try|catch|match|when)\\b"
        },
        {
          "name": "storage.type.tya",
          "match": "\\b(class|module|interface|implements|extends|abstract|final|private|static|initialize|import|as)\\b"
        },
        {
          "name": "variable.language.tya",
          "match": "\\b(self|super)\\b"
        },
        {
          "name": "keyword.other.tya",
          "match": "\\b(spawn|await|scope)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        { "name": "constant.language.tya", "match": "\\b(true|false|nil)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.tya",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.tya", "match": "->|==|!=|<=|>=|<|>|\\+|-|\\*|/|%|=|\\.|,|:" }
      ]
    }
  }
}
