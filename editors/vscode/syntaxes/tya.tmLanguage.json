{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "tya",
  "scopeName": "source.tya",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#literals" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.tya",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.raw.block.tya",
          "begin": "r\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.bytes.block.tya",
          "begin": "b\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.block.tya",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.double.tya",
          "begin": "(?<![A-Za-z_])\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.tya", "match": "\\\\." },
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.double.raw.tya",
          "begin": "r\"",
          "end": "\""
        },
        {
          "name": "string.quoted.double.bytes.tya",
          "begin": "b\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.tya", "match": "\\\\." },
            { "include": "#interpolation" }
          ]
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.tya",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#literals" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.tya", "match": "\\b0x[0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.tya", "match": "\\b0b[01_]+\\b" },
        { "name": "constant.numeric.tya", "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tya",
          "match": "\\b(if|elseif|else|while|for|in|break|continue|return|raise|try|catch|match|case|when|select|receive|send|timeout|default)\\b"
        },
        {
          "name": "storage.type.tya",
          "match": "\\b(class|module|interface|struct|record|implements|extends|abstract|final|override|private|static|initialize|import|as|embed)\\b"
        },
        {
          "name": "variable.language.tya",
          "match": "\\b(self|Self|super)\\b"
        },
        {
          "name": "keyword.other.tya",
          "match": "\\b(spawn|await|scope)\\b"
        },
        {
          "name": "keyword.operator.logical.tya",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        { "name": "constant.language.tya", "match": "\\b(true|false|nil)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.type.tya",
          "match": "\\b(?:class|interface|struct|record)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.tya" }
          }
        },
        {
          "name": "entity.name.namespace.tya",
          "match": "\\bmodule\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.tya" }
          }
        },
        {
          "name": "entity.name.function.tya",
          "match": "\\b([A-Za-z_][A-Za-z0-9_?]*)\\s*(?:=|:)\\s*->",
          "captures": {
            "1": { "name": "entity.name.function.tya" }
          }
        },
        {
          "name": "entity.name.function.tya",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.tya", "match": "->|==|!=|<=|>=|<<|>>|<|>|\\+|-|\\*|/|%|=|\\.|,|:|&|\\||\\^|~" }
      ]
    }
  }
}
